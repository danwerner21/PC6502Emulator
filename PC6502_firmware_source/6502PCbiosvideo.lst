00FC67  2  0D 0A 20 41          .BYTE   13,10," ARE YOU SURE YOU WANT TO REPLACE BOOT IMAGE?",13,10
00FC6B  2  52 45 20 59  
00FC6F  2  4F 55 20 53  
00FC98  2  20 50 52 45          .BYTE   " PRESS 'Y' TO CONTINUE",13,10
00FC9C  2  53 53 20 27  
00FCA0  2  59 27 20 54  
00FCB0  2  00                   .BYTE   00
00FCB1  2               MESSAGE8:
00FCB1  2  20 42 4F 4F          .BYTE   " BOOT IMAGE WRITE ABORTED.",13,10
00FCB5  2  54 20 49 4D  
00FCB9  2  41 47 45 20  
00FCCD  2  00                   .BYTE   00
00FCCE  2               MESSAGE9:
00FCCE  2  20 42 4F 4F          .BYTE   " BOOT IMAGE WRITTEN.",13,10
00FCD2  2  54 20 49 4D  
