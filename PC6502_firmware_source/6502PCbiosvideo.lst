00F90E  2  9D 8A 1D 23          .BYTE   $9D,$8A,$1D,$23 ; RTI PHA BVC CLI
00F912  2  9D 8B 1D A1          .BYTE   $9D,$8B,$1D,$A1 ; RTS PLA BVS SEI
00F916  2  00 29 19 AE          .BYTE   $00,$29,$19,$AE ; ??? DEY BCC TYA
00F91A  2  69 A8 19 23          .BYTE   $69,$A8,$19,$23 ; LDY TAY BCS CLV
00F91E  2  24 53 1B 23          .BYTE   $24,$53,$1B,$23 ; CPY INY BNE CLD
00F922  2  24 53 19 A1          .BYTE   $24,$53,$19,$A1 ; CPX INX BEQ SED
00F926  2               ; XXXYY100 opcodes
00F926  2  00 1A 5B 5B          .BYTE   $00,$1A,$5B,$5B ; ??? BIT JMP JMP
00F92A  2  A5 69 24 24          .BYTE   $A5,$69,$24,$24 ; STY LDY CPY CPX
00F92E  2               ; 1XXX1010 opcodes
00F92E  2  AE AE A8 AD          .BYTE   $AE,$AE,$A8,$AD ; TXA TXS TAX TSX
00F932  2  29 00 7C 00          .BYTE   $29,$00,$7C,$00 ; DEX ??? NOP ???
00F936  2               ; XXXYYY10 opcodes
00F936  2  15 9C 6D 9C          .BYTE   $15,$9C,$6D,$9C ; ASL ROL LSR ROR
00F93A  2  A5 69 29 53          .BYTE   $A5,$69,$29,$53 ; STX LDX DEC INC
00F93E  2               ; XXXYYY01 opcodes
00F93E  2  84 13 34 11          .BYTE   $84,$13,$34,$11 ; ORA AND EOR ADC
00F942  2  A5 69 23 A0          .BYTE   $A5,$69,$23,$A0 ; STA LDA CMP SBC
00F946  2               
00F946  2               ; right 7 bits, left justified
00F946  2               ; XXXXX000 opcodes
00F946  2               MNEMR:
