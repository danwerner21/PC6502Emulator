00FD68  1               ;______________________________________________________________
00FD68  1               OUTSTR:
00FD68  1  A0 00                LDY     #$00            ; LOAD $00 INTO Y
00FD6A  1               OUTSTRLP:
00FD6A  1  B1 41                LDA     (STRPTR),Y      ; LOAD NEXT CHAR FROM STRING INTO ACC
00FD6C  1  C9 00                CMP     #$00            ; IS NULL?
00FD6E  1  F0 0C                BEQ     ENDOUTSTR       ; YES, END PRINT OUT
00FD70  1  20 53 FD             JSR     IOF_OUTCH       ; PRINT CHAR IN ACC
00FD73  1  E6 41                INC     STRPTR
00FD75  1  D0 F3                BNE     OUTSTRLP
00FD77  1  E6 42                INC     STRPTR+1
00FD79  1  4C 6A FD             JMP     OUTSTRLP        ; DO NEXT CHAR
00FD7C  1               ENDOUTSTR:
00FD7C  1  60                   RTS                     ; RETURN
