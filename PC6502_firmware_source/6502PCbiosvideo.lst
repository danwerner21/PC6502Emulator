00F9C6  1                       .INCLUDE "bios_serial.asm"
00F9C6  2               ;__SERIAL DRIVERS________________________________________________________________________________________________________________
00F9C6  2               ;
00F9C6  2               ; 	serial drivers
00F9C6  2               ;
00F9C6  2               ;	Entry points:
00F9C6  2               ;		SERIALINIT  - called during OS init
00F9C6  2               ;		RDSER1	    - read a byte from serial port ('A' POINTS TO BYTE)
00F9C6  2               ;		WRSER1	    - write a byte from serial port  ('A' POINTS TO BYTE)
00F9C6  2               ;		RDSER1W	    - read a byte from serial port ('A' POINTS TO BYTE, WAIT FOR INPUT)
00F9C6  2               ;		SERIALSTATUS- GET UART STATUS
00F9C6  2               ;________________________________________________________________________________________________________________________________
00F9C6  2               ;
00F9C6  2               
00F9C6  2               
00F9C6  2               ;*
00F9C6  2               ;* HARDWARE I/O ADDRESSES
00F9C6  2               ;*
00F9C6  2               
00F9C6  2               UART1DATA       = PC6502_IOSPACE+$84; SERIAL PORT 1 (I/O Card)
00F9C6  2               UART1STATUS     = PC6502_IOSPACE+$85; SERIAL PORT 1 (I/O Card)
00F9C6  2               UART1COMMAND    = PC6502_IOSPACE+$86; SERIAL PORT 1 (I/O Card)
00F9C6  2               UART1CONTROL    = PC6502_IOSPACE+$87; SERIAL PORT 1 (I/O Card)
00F9C6  2               
00F9C6  2               
00F9C6  2               ;Command Register
00F9C6  2               ;No bit is affected by a software reset, however, all bits are set to zero on a hardware reset.
00F9C6  2               ;Bit 7 6 5  configuration
00F9C6  2               ;    x x 0  no parity bit
00F9C6  2               ;    0 0 1  send and receive with odd parity
00F9C6  2               ;    0 1 1  send and receive with even parity
00F9C6  2               ;    1 0 1  send: parity=1; receive: parity not evaluated
00F9C6  2               ;    1 1 1  send: parity=0; receive: parity not evaluated
00F9C6  2               ;
00F9C6  2               ;Bit 4  0: no echo
00F9C6  2               ;       1: echo (received characters are being sent again,
00F9C6  2               ;                bits 2 and 3 must be 0 for that)
00F9C6  2               ;
00F9C6  2               ;Bit 3 2  sender interr.   RTS level   sender
00F9C6  2               ;    0 0  no               high        off
00F9C6  2               ;    0 1  yes              low         on
00F9C6  2               ;    1 0  no               low         on
00F9C6  2               ;    1 1  no               low         send BRK
00F9C6  2               ;
00F9C6  2               ;Bit 1  0: interrupt gets triggered by bit 3 in status register
00F9C6  2               ;       1: no interrupt
00F9C6  2               ;
00F9C6  2               ;Bit 0  0: disable transceiver and interrupts, /DTR high
00F9C6  2               ;       1: enable transceiver and interrupts, /DTR low
00F9C6  2               ;
00F9C6  2               ;Control Register
00F9C6  2               ;Bits 0 to 3 are set to zero on a software reset, and all bits are set to zero on a hardware reset.
00F9C6  2               ;Bit 7  0: 1 stop bit
00F9C6  2               ;       1: a) with 8 data bits and 1 parity bit: 1 stop bit
00F9C6  2               ;          b) with 5 data bits and no parity bit: 1.5 stop bits
00F9C6  2               ;          c) otherwise 2 stop bits
00F9C6  2               ;
00F9C6  2               ;Bit 6 5  data bits
00F9C6  2               ;    0 0  8
00F9C6  2               ;    0 1  7
00F9C6  2               ;    1 0  6
00F9C6  2               ;    1 1  5
00F9C6  2               ;
00F9C6  2               ;Bit 4  0: external receive clock
00F9C6  2               ;       1: builtin clock as receive clock
00F9C6  2               ;
00F9C6  2               ;Bit 3 2 1 0  baud rate
00F9C6  2               ;    0 0 0 0  1/16 times external clock
00F9C6  2               ;    0 0 0 1  50 bps
00F9C6  2               ;    0 0 1 0  75 bps
00F9C6  2               ;    0 0 1 1  109.92 bps
00F9C6  2               ;    0 1 0 0  134.58 bps
00F9C6  2               ;    0 1 0 1  150 bps
00F9C6  2               ;    0 1 1 0  300 bps
00F9C6  2               ;    0 1 1 1  600 bps
00F9C6  2               ;    1 0 0 0  1200 bps
00F9C6  2               ;    1 0 0 1  1800 bps
00F9C6  2               ;    1 0 1 0  2400 bps
00F9C6  2               ;    1 0 1 1  3600 bps
00F9C6  2               ;    1 1 0 0  4800 bps
00F9C6  2               ;    1 1 0 1  7200 bps
00F9C6  2               ;    1 1 1 0  9600 bps
00F9C6  2               ;    1 1 1 1  19200 bps
00F9C6  2               
00F9C6  2               
00F9C6  2               
00F9C6  2               ;__SERIALINIT____________________________________________________________________________________________________________________
00F9C6  2               ;
00F9C6  2               ;	INITIALIZE SERIAL PORTS
00F9C6  2               ;________________________________________________________________________________________________________________________________
00F9C6  2               ;
00F9C6  2               SERIALINIT:
00F9C6  2  A9 00                LDA     #$00            ; RESET UART
00F9C8  2  8D 85 EF             STA     UART1STATUS     ;
00F9CB  2  A9 0B                LDA     #$0B            ;
00F9CD  2  8D 86 EF             STA     UART1COMMAND    ;
00F9D0  2  A9 1E                LDA     #$1E            ; 9600, 8 BITS, NO PARITY, 1 STOP BIT
00F9D2  2  8D 87 EF             STA     UART1CONTROL    ;
00F9D5  2  60                   RTS
00F9D6  2               
00F9D6  2               
00F9D6  2               
00F9D6  2               ;__WRSER1________________________________________________________________________________________________________________________
00F9D6  2               ;
00F9D6  2               ;	WRITE CHARACTER(A) TO UART
00F9D6  2               ;________________________________________________________________________________________________________________________________
00F9D6  2               ;
00F9D6  2               WRSER1:
00F9D6  2  48                   PHA
00F9D7  2               WRSER1a:
00F9D7  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS
00F9DA  2  29 10                AND     #%00010000      ; IS TX READY
00F9DC  2  F0 F9                BEQ     WRSER1a         ; NO, WAIT FOR IT
00F9DE  2  68                   PLA
00F9DF  2  8D 84 EF             STA     UART1DATA       ; WRITE DATA
00F9E2  2  60                   RTS
00F9E3  2               
00F9E3  2               ;__RDSER1________________________________________________________________________________________________________________________
00F9E3  2               ;
00F9E3  2               ;	READ CHARACTER FROM UART TO (A)
00F9E3  2               ;________________________________________________________________________________________________________________________________
00F9E3  2               ;
00F9E3  2               RDSER1:
00F9E3  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS REGISTER
00F9E6  2  29 08                AND     #%00001000      ; IS RX READY
00F9E8  2  F0 04                BEQ     RDSER1N         ; NO, INDICATE NO CHAR
00F9EA  2  AD 84 EF             LDA     UART1DATA       ; GET DATA CHAR
00F9ED  2  60                   RTS
00F9EE  2               RDSER1N:
00F9EE  2  A9 00                LDA     #$00            ;
00F9F0  2  60                   RTS                     ;
00F9F1  2               
00F9F1  2               ;__RDSER1W_______________________________________________________________________________________________________________________
00F9F1  2               ;
00F9F1  2               ;	READ CHARACTER FROM UART TO (A) - WAIT FOR CHAR
00F9F1  2               ;________________________________________________________________________________________________________________________________
00F9F1  2               ;
00F9F1  2               RDSER1W:
00F9F1  2  20 E3 F9             JSR     RDSER1
00F9F4  2  C9 00                CMP     #$00
00F9F6  2  F0 F9                BEQ     RDSER1W
00F9F8  2  29 7F                AND     #$7F
00F9FA  2  60                   RTS
00F9FB  2               
00F9FB  2               ;__SERIALSTATUS__________________________________________________________________________________________________________________
00F9FB  2               ;
00F9FB  2               ;	READ UARD STATUS
00F9FB  2               ;________________________________________________________________________________________________________________________________
00F9FB  2               ;
00F9FB  2               SERIALSTATUS:
00F9FB  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS REGISTER
00F9FE  2  29 08                AND     #%00001000      ; IS RX READY
00FA00  2  D0 03                BNE     RDSTAT1         ; INDICATE CHAR
00FA02  2  A9 00                LDA     #$00            ; NO CHAR
00FA04  2  60                   RTS
00FA05  2               RDSTAT1:
00FA05  2  A9 FF                LDA     #$FF            ; DATA CHAR
00FA07  2  60                   RTS
00FA08  2               
00FA08  1                       .INCLUDE "bios_ide.asm"
00FA08  2               ;__IDE DRIVERS___________________________________________________________________________________________________________________
00FA08  2               ;
00FA08  2               ; 	DOS/65 IDE disk drivers 6502PC - XT IDE ISA CARD
00FA08  2               ;
00FA08  2               ;	Entry points:
00FA08  2               ;		XTIDE_INIT   	- CALLED DURING OS INIT
00FA08  2               ;		IDE_READ_SECTOR  - read a sector from drive
00FA08  2               ;		IDE_WRITE_SECTOR - write a sector to drive
00FA08  2               ;________________________________________________________________________________________________________________________________
00FA08  2               ;
00FA08  2               PC6502_IO       = $E000
00FA08  2               
00FA08  2               XTIDE_DATA_LO   = PC6502_IO+$300
00FA08  2               XTIDE_DATA_HI   = PC6502_IO+$301
00FA08  2               XTIDE_ERR       = PC6502_IO+$302
00FA08  2               XTIDE_FECODE    = PC6502_IO+$302
00FA08  2               XTIDE_SEC_CNT   = PC6502_IO+$304
00FA08  2               XTIDE_LBALOW    = PC6502_IO+$306
00FA08  2               XTIDE_LBAMID    = PC6502_IO+$308
00FA08  2               XTIDE_LBAHI     = PC6502_IO+$30A
00FA08  2               XTIDE_DEVICE    = PC6502_IO+$30C
00FA08  2               XTIDE_COMMAND   = PC6502_IO+$30E
00FA08  2               XTIDE_STATUS    = PC6502_IO+$30E
00FA08  2               
00FA08  2               
00FA08  2               
00FA08  2               
00FA08  2               ;IDE COMMAND CONSTANTS.  THESE SHOULD NEVER CHANGE.
00FA08  2               XTIDE_CMD_RECAL = $10
00FA08  2               XTIDE_CMD_READ  = $20
00FA08  2               XTIDE_CMD_WRITE = $30
00FA08  2               XTIDE_CMD_INIT  = $91
00FA08  2               XTIDE_CMD_ID    = $EC
00FA08  2               XTIDE_CMD_FEAT  = $EF
00FA08  2               XTIDE_CMD_SPINDOWN = $E0
00FA08  2               XTIDE_CMD_SPINUP = $E1
00FA08  2               
00FA08  2               
00FA08  2               
00FA08  2                       .IFDEF  PC6502BIOS
00FA08  2               XTIDE_INIT:
00FA08  2               ; RESET PORTS
00FA08  2  A2 00                LDX     #$00
00FA0A  2  A9 FF                LDA     #$FF
00FA0C  2               :
00FA0C  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA0F  2  E8                   INX
00FA10  2  E0 31                CPX     #$31
00FA12  2  D0 F8                BNE     :-
00FA14  2               
00FA14  2  A2 00                LDX     #$00
00FA16  2  A9 00                LDA     #$00
00FA18  2               :
00FA18  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA1B  2  E8                   INX
00FA1C  2  E0 31                CPX     #$31
00FA1E  2  D0 F8                BNE     :-
00FA20  2  20 3A FA             JSR     XTIDE_PROBE
00FA23  2  A9 E0                LDA     #$E0            ; E0=MST  F0=SLV
00FA25  2  8D 0C E3             STA     XTIDE_DEVICE
00FA28  2               
00FA28  2  20 BB FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA2B  2  C9 00                CMP     #$00
00FA2D  2  D0 0A                BNE     :+
00FA2F  2               
00FA2F  2  A9 01                LDA     #$01            ; ENABLE 8-BIT MODE (XT-CF-LITE)
00FA31  2  8D 02 E3             STA     XTIDE_FECODE
00FA34  2  A9 EF                LDA     #XTIDE_CMD_FEAT
00FA36  2  8D 0E E3             STA     XTIDE_COMMAND
00FA39  2               :
00FA39  2  60                   RTS
00FA3A  2                       .ENDIF
00FA3A  2               
00FA3A  2               
00FA3A  2                       .IFNDEF PC6502BIOS
00FA3A  2               XTIDETIMEOUT:
00FA3A  2                       .BYTE   $00,$00
00FA3A  2               
00FA3A  2               
00FA3A  2               
00FA3A  2               ;__XTIDE_INIT________________________________________________________________________________________
00FA3A  2               ;
00FA3A  2               ;  INIT AND DISPLAY IDE INFO
00FA3A  2               ;____________________________________________________________________________________________________
00FA3A  2               ;
00FA3A  2               XTIDE_INIT:
00FA3A  2                       JSR     LFCR            ; AND CRLF
00FA3A  2                       LDA     #<MESSAGE1      ;
00FA3A  2                       STA     STRPTR          ;
00FA3A  2                       LDA     #>MESSAGE1      ;
00FA3A  2                       STA     STRPTR+1        ;
00FA3A  2                       JSR     WRSTR
00FA3A  2                       JSR     LFCR            ; AND CRLF
00FA3A  2               ;
00FA3A  2                       LDA     #<MESSAGE2      ;
00FA3A  2                       STA     STRPTR          ;
00FA3A  2                       LDA     #>MESSAGE2      ;
00FA3A  2                       STA     STRPTR+1        ;
00FA3A  2                       JSR     WRSTR           ; DO PROMPT
00FA3A  2               
00FA3A  2                       LDA     #>XTIDE_DATA_LO ; GET BASE PORT
00FA3A  2                       JSR     PRINT_BYTE      ; PRINT BASE PORT
00FA3A  2                       LDA     #<XTIDE_DATA_LO ; GET BASE PORT
00FA3A  2                       JSR     PRINT_BYTE      ; PRINT BASE PORT
00FA3A  2               ;
00FA3A  2                       JSR     XTIDE_PROBE     ; DETECT AN ATA DEVICE, ABORT IF NOT FOUND
00FA3A  2                       CMP     #$00
00FA3A  2                       BNE     IDE_ABORT
00FA3A  2                       JMP     IDE_PRINT_INFO
00FA3A  2               IDE_ABORT:
00FA3A  2                       LDA     #<MESSAGE3      ;
00FA3A  2                       STA     STRPTR          ;
00FA3A  2                       LDA     #>MESSAGE3      ;
00FA3A  2                       STA     STRPTR+1        ;
00FA3A  2                       JSR     WRSTR           ; DO PROMPT
00FA3A  2                       JMP     IDE_INITA
00FA3A  2               IDE_PRINT_INFO:
00FA3A  2                       JSR     LFCR            ; AND CRLF
00FA3A  2                       LDA     #<MESSAGE4      ;
00FA3A  2                       STA     STRPTR          ;
00FA3A  2                       LDA     #>MESSAGE4      ;
00FA3A  2                       STA     STRPTR+1        ;
00FA3A  2                       JSR     WRSTR           ; DO PROMPT
00FA3A  2                       LDA     #$00
00FA3A  2                       JSR     IDE_READ_INFO   ; GET DRIVE INFO, ABORT IF ERROR
00FA3A  2                       LDA     #<MESSAGE5      ;
00FA3A  2                       STA     STRPTR          ;
00FA3A  2                       LDA     #>MESSAGE5      ;
00FA3A  2                       STA     STRPTR+1        ;
00FA3A  2                       JSR     WRSTR           ; DO PROMPT
00FA3A  2                       LDA     #$01
00FA3A  2                       JSR     IDE_READ_INFO   ; GET DRIVE INFO, ABORT IF ERROR
00FA3A  2               IDE_INITA:
00FA3A  2                       RTS                     ; DONE
00FA3A  2                       .ENDIF
00FA3A  2               ;
00FA3A  2               ;__XTIDE_PROBE_______________________________________________________________________________________
00FA3A  2               ;
00FA3A  2               ;  XTPROBE FOR IDE HARDWARE
00FA3A  2               ;____________________________________________________________________________________________________
00FA3A  2               ;
00FA3A  2               XTIDE_PROBE:
00FA3A  2               ;
00FA3A  2               ; RESET PORTS
00FA3A  2  A2 00                LDX     #$00
00FA3C  2  A9 FF                LDA     #$FF
00FA3E  2               :
00FA3E  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA41  2  E8                   INX
00FA42  2  E0 31                CPX     #$31
00FA44  2  D0 F8                BNE     :-
00FA46  2               
00FA46  2  A2 00                LDX     #$00
00FA48  2  A9 00                LDA     #$00
00FA4A  2               :
00FA4A  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA4D  2  E8                   INX
00FA4E  2  E0 31                CPX     #$31
00FA50  2  D0 F8                BNE     :-
00FA52  2               ; CHECK SIGNATURE
00FA52  2  A0 00                LDY     #$00
00FA54  2  A2 00                LDX     #$00
00FA56  2               ;       SOMETIMES THE CF-XTIDE WILL ONLY READ 80, THIS CAN BE RESET BY WRITING ZEROS UNTIL VALUES ARE PROPERLY READ
00FA56  2               :
00FA56  2  AD 00 E3             LDA     XTIDE_DATA_LO
00FA59  2  C9 80                CMP     #$80
00FA5B  2  D0 2F                BNE     :+
00FA5D  2  A9 00                LDA     #$00
00FA5F  2  8D 00 E3             STA     XTIDE_DATA_LO
00FA62  2  EA                   NOP
00FA63  2  8D 01 E3             STA     XTIDE_DATA_HI
00FA66  2  EA                   NOP
00FA67  2  8D 06 E3             STA     XTIDE_LBALOW
00FA6A  2  EA                   NOP
00FA6B  2  8D 08 E3             STA     XTIDE_LBAMID
00FA6E  2  EA                   NOP
00FA6F  2  8D 0A E3             STA     XTIDE_LBAHI
00FA72  2  EA                   NOP
00FA73  2  8D 0C E3             STA     XTIDE_DEVICE
00FA76  2  EA                   NOP
00FA77  2  8D 0E E3             STA     XTIDE_COMMAND
00FA7A  2  EA                   NOP
00FA7B  2  8D 0E E3             STA     XTIDE_STATUS
00FA7E  2  EA                   NOP
00FA7F  2  E8                   INX
00FA80  2  E0 00                CPX     #$00
00FA82  2  D0 D2                BNE     :-
00FA84  2  C8                   INY
00FA85  2  C0 03                CPY     #$03
00FA87  2  D0 CD                BNE     :-
00FA89  2  4C 96 FA             JMP     XTIDE_PROBE_FAIL; TIMED OUT
00FA8C  2               :
00FA8C  2  20 BB FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA8F  2  C9 00                CMP     #$00
00FA91  2  D0 03                BNE     XTIDE_PROBE_FAIL
00FA93  2  4C 99 FA             JMP     XTIDE_PROBE_SUCCESS
00FA96  2               XTIDE_PROBE_FAIL:
00FA96  2  A9 FF                LDA     #$FF
00FA98  2  60                   RTS
00FA99  2               XTIDE_PROBE_SUCCESS:
00FA99  2  A9 00                LDA     #$00
00FA9B  2  60                   RTS                     ; DONE, NOTE THAT A=0 AND Z IS SET
00FA9C  2               
00FA9C  2                       .IFNDEF PC6502BIOS
00FA9C  2               ;*__IDE_READ_INFO___________________________________________________________________________________
00FA9C  2               ;*
00FA9C  2               ;*  READ IDE INFORMATION
00FA9C  2               ;*	CARRY SET ON ERROR
00FA9C  2               ;* 	A=MST/SLV
00FA9C  2               ;*____________________________________________________________________________________________________
00FA9C  2               IDE_READ_INFO:
00FA9C  2               ; SET DRIVE BIT
00FA9C  2                       AND     #$01            ; ONLY WANT THE 1 BIT (MST/SLV)
00FA9C  2                       ASL     A               ; SHIFT 4
00FA9C  2                       ASL     A               ;
00FA9C  2                       ASL     A               ;
00FA9C  2                       ASL     A               ;
00FA9C  2                       ORA     #$E0            ; E0=MST  F0=SLV
00FA9C  2                       STA     XTIDE_DEVICE
00FA9C  2               
00FA9C  2                       JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA9C  2                       CMP     #$00
00FA9C  2                       BNE     IDE_READ_INFO_ABORT
00FA9C  2               
00FA9C  2                       LDA     #$01            ; ENABLE 8-BIT MODE (XT-CF-LITE)
00FA9C  2                       STA     XTIDE_FECODE
00FA9C  2                       LDA     #XTIDE_CMD_FEAT
00FA9C  2                       STA     XTIDE_COMMAND
00FA9C  2               
00FA9C  2                       NOP                     ; TINY DELAY, JUST IN CASE
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2                       NOP
00FA9C  2               
00FA9C  2               
00FA9C  2                       LDA     #XTIDE_CMD_ID   ; ID COMMAND
00FA9C  2                       STA     XTIDE_COMMAND
00FA9C  2               
00FA9C  2                       JSR     IDE_WAIT_DRQ    ;WAIT UNTIL IT'S GOT THE DATA
00FA9C  2                       CMP     #$00
00FA9C  2                       BNE     IDE_READ_INFO_ABORT
00FA9C  2               
00FA9C  2                       JSR     IDE_READ_BUFFER ; GRAB THE 256 WORDS FROM THE BUFFER
00FA9C  2               
00FA9C  2                       LDA     #<MESSAGE6      ;
00FA9C  2                       STA     STRPTR          ;
00FA9C  2                       LDA     #>MESSAGE6      ;
00FA9C  2                       STA     STRPTR+1        ;
00FA9C  2                       JSR     WRSTR
00FA9C  2                       LDA     hstbuf+123
00FA9C  2                       JSR     PRINT_BYTE
00FA9C  2                       LDA     hstbuf+122
00FA9C  2                       JSR     PRINT_BYTE
00FA9C  2                       LDA     hstbuf+121
00FA9C  2                       JSR     PRINT_BYTE
00FA9C  2                       LDA     hstbuf+120
00FA9C  2                       JSR     PRINT_BYTE
00FA9C  2                       JMP     IDE_READ_INFO_OK
00FA9C  2               IDE_READ_INFO_ABORT:
00FA9C  2                       LDA     #<MESSAGE3      ;
00FA9C  2                       STA     STRPTR          ;
00FA9C  2                       LDA     #>MESSAGE3      ;
00FA9C  2                       STA     STRPTR+1        ;
00FA9C  2                       JSR     WRSTR           ;DO PROMPT
00FA9C  2                       JSR     LFCR            ;AND CRLF
00FA9C  2                       LDA     #$FF
00FA9C  2                       RTS                     ;
00FA9C  2               IDE_READ_INFO_OK:
00FA9C  2                       JSR     LFCR            ; AND CRLF
00FA9C  2                       LDA     #$00
00FA9C  2                       RTS
00FA9C  2                       .ENDIF
00FA9C  2               
00FA9C  2               
00FA9C  2               ;*__IDE_READ_SECTOR___________________________________________________________________________________
00FA9C  2               ;*
00FA9C  2               ;*  READ IDE SECTOR (IN LBA) INTO BUFFER
00FA9C  2               ;*
00FA9C  2               ;*____________________________________________________________________________________________________
00FA9C  2               IDE_READ_SECTOR:
00FA9C  2                       .IFNDEF PC6502BIOS
00FA9C  2                       JSR     IDE_CONVERT_SECTOR_LBA
00FA9C  2                       LDA     debsehd         ; STORE CURRENT PARMS
00FA9C  2                       CMP     Cdebsehd        ;
00FA9C  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA9C  2                       LDA     debcylm         ;
00FA9C  2                       CMP     Cdebcylm        ;
00FA9C  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA9C  2                       LDA     debcyll         ;
00FA9C  2                       CMP     Cdebcyll        ;
00FA9C  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA9C  2                       LDA     sekdsk          ;
00FA9C  2                       CMP     currentDrive
00FA9C  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA9C  2                       LDA     #$00            ; ZERO = 1 ON RETURN = OPERATION OK
00FA9C  2                       RTS
00FA9C  2                       .ENDIF
00FA9C  2               IDE_READ_SECTOR_DIRTY:
00FA9C  2  20 BB FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA9F  2  C9 00                CMP     #$00
00FAA1  2  D0 15                BNE     IDE_READ_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FAA3  2               IDE_READ_SECTOR_1:
00FAA3  2  20 7B FB             JSR     IDE_SETUP_LBA   ;TELL IT WHICH SECTOR WE WANT
00FAA6  2  A9 20                LDA     #XTIDE_CMD_READ
00FAA8  2  8D 0E E3             STA     XTIDE_COMMAND
00FAAB  2               
00FAAB  2  20 E4 FA             JSR     IDE_WAIT_DRQ    ; WAIT UNTIL IT'S GOT THE DATA
00FAAE  2  C9 00                CMP     #$00
00FAB0  2  D0 06                BNE     IDE_READ_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FAB2  2  20 07 FB             JSR     IDE_READ_BUFFER ; GRAB THE 256 WORDS FROM THE BUFFER
00FAB5  2                       .IFNDEF PC6502BIOS
00FAB5  2                       LDA     debsehd         ; STORE CURRENT PARMS
00FAB5  2                       STA     Cdebsehd        ;
00FAB5  2                       LDA     debcyll         ;
00FAB5  2                       STA     Cdebcyll        ;
00FAB5  2                       LDA     debcylm         ;
00FAB5  2                       STA     Cdebcylm        ;
00FAB5  2                       .ENDIF
00FAB5  2               
00FAB5  2  A9 00                LDA     #$00            ; ZERO = 1 ON RETURN = OPERATION OK
00FAB7  2  60                   RTS
00FAB8  2               IDE_READ_SECTOR_ERROR:
00FAB8  2  A9 FF                LDA     #$FF            ; ZERO = 1 ON RETURN = OPERATION OK
00FABA  2  60                   RTS
00FABB  2               
00FABB  2               
00FABB  2               ;*__IDE_WAIT_NOT_BUSY_______________________________________________________________________________
00FABB  2               ;*
00FABB  2               ;*  WAIT FOR IDE CHANNEL TO BECOME READY
00FABB  2               ;*
00FABB  2               ;*____________________________________________________________________________________________________
00FABB  2               IDE_WAIT_NOT_BUSY:
00FABB  2  8A                   TXA
00FABC  2  48                   PHA
00FABD  2  98                   TYA
00FABE  2  48                   PHA
00FABF  2  A9 00                LDA     #$00
00FAC1  2  85 F0                STA     XTIDETIMEOUT
00FAC3  2  85 F1                STA     XTIDETIMEOUT+1
00FAC5  2               IDE_WAIT_NOT_BUSY1:
00FAC5  2  AD 0E E3             LDA     XTIDE_STATUS    ;WAIT FOR RDY BIT TO BE SET
00FAC8  2  29 80                AND     #$80
00FACA  2  C9 00                CMP     #$00
00FACC  2  F0 0F                BEQ     IDE_WAIT_NOT_BUSY2
00FACE  2  E6 F0                INC     XTIDETIMEOUT
00FAD0  2  D0 F3                BNE     IDE_WAIT_NOT_BUSY1
00FAD2  2  E6 F1                INC     XTIDETIMEOUT+1
00FAD4  2  D0 EF                BNE     IDE_WAIT_NOT_BUSY1
00FAD6  2  68                   PLA
00FAD7  2  A8                   TAY
00FAD8  2  68                   PLA
00FAD9  2  AA                   TAX
00FADA  2  A9 FF                LDA     #$FF
00FADC  2  60                   RTS
00FADD  2               IDE_WAIT_NOT_BUSY2:
00FADD  2  68                   PLA
00FADE  2  A8                   TAY
00FADF  2  68                   PLA
00FAE0  2  AA                   TAX
00FAE1  2  A9 00                LDA     #$00
00FAE3  2  60                   RTS
00FAE4  2               
00FAE4  2               ;*__IDE_WAIT_DRQ______________________________________________________________________________________
00FAE4  2               ;*
00FAE4  2               ;*	WAIT FOR THE DRIVE TO BE READY TO TRANSFER DATA.
00FAE4  2               ;*
00FAE4  2               ;*____________________________________________________________________________________________________
00FAE4  2               IDE_WAIT_DRQ:
00FAE4  2  A9 00                LDA     #$00
00FAE6  2  85 F0                STA     XTIDETIMEOUT
00FAE8  2  85 F1                STA     XTIDETIMEOUT+1
00FAEA  2               IDE_WAIT_DRQ1:
00FAEA  2  AD 0E E3             LDA     XTIDE_STATUS    ;WAIT FOR DRQ BIT TO BE SET
00FAED  2  29 88                AND     #%10001000      ; MASK OFF BUSY(7) AND DRQ(3)
00FAEF  2  C9 08                CMP     #%00001000      ; WE WANT BUSY(7) TO BE 0 AND DRQ (3) TO BE 1
00FAF1  2  F0 11                BEQ     IDE_WAIT_DRQ2
00FAF3  2  29 01                AND     #%00000001      ; IS ERROR?
00FAF5  2  C9 01                CMP     #%00000001      ;
00FAF7  2  F0 08                BEQ     IDE_WAIT_DRQE
00FAF9  2  E6 F0                INC     XTIDETIMEOUT
00FAFB  2  D0 ED                BNE     IDE_WAIT_DRQ1
00FAFD  2  E6 F1                INC     XTIDETIMEOUT+1
00FAFF  2  D0 E9                BNE     IDE_WAIT_DRQ1
00FB01  2               IDE_WAIT_DRQE:
00FB01  2  A9 FF                LDA     #$FF
00FB03  2  60                   RTS
00FB04  2               IDE_WAIT_DRQ2:
00FB04  2  A9 00                LDA     #$00
00FB06  2  60                   RTS
00FB07  2               
00FB07  2               
00FB07  2               ;*__IDE_READ_BUFFER___________________________________________________________________________________
00FB07  2               ;*
00FB07  2               ;*  READ IDE BUFFER LITTLE ENDIAN
00FB07  2               ;*
00FB07  2               ;*____________________________________________________________________________________________________
00FB07  2               IDE_READ_BUFFER:
00FB07  2  A0 00                LDY     #$00            ; INDEX
00FB09  2               :
00FB09  2  AD 00 E3             LDA     XTIDE_DATA_LO
00FB0C  2  99 00 04             STA     hstbuf,Y        ;
00FB0F  2  C8                   INY
00FB10  2  AD 01 E3             LDA     XTIDE_DATA_HI
00FB13  2  99 00 04             STA     hstbuf,Y        ;
00FB16  2  C8                   INY
00FB17  2  C0 00                CPY     #$00            ;
00FB19  2  D0 EE                BNE     :-
00FB1B  2               :
00FB1B  2               ;
00FB1B  2  AD 00 E3             LDA     XTIDE_DATA_LO
00FB1E  2  99 00 05             STA     hstbuf+$100,Y   ;
00FB21  2  C8                   INY
00FB22  2  AD 01 E3             LDA     XTIDE_DATA_HI
00FB25  2  99 00 05             STA     hstbuf+$100,Y   ;
00FB28  2  C8                   INY
00FB29  2  C0 00                CPY     #$00            ;
00FB2B  2  D0 EE                BNE     :-              ;
00FB2D  2  60                   RTS                     ;
00FB2E  2               
00FB2E  2               ;*__IDE_WRITE_SECTOR__________________________________________________________________________________
00FB2E  2               ;*
00FB2E  2               ;*  WRITE IDE SECTOR (IN LBA) FROM BUFFER
00FB2E  2               ;*
00FB2E  2               ;*____________________________________________________________________________________________________
00FB2E  2               IDE_WRITE_SECTOR:
00FB2E  2                       .IFNDEF PC6502BIOS
00FB2E  2                       JSR     IDE_CONVERT_SECTOR_LBA
00FB2E  2                       .ENDIF
00FB2E  2  20 BB FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FB31  2  C9 00                CMP     #$00
00FB33  2  D0 1C                BNE     IDE_WRITE_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FB35  2  20 7B FB             JSR     IDE_SETUP_LBA   ;TELL IT WHICH SECTOR WE WANT
00FB38  2  A9 30                LDA     #XTIDE_CMD_WRITE
00FB3A  2  8D 0E E3             STA     XTIDE_COMMAND
00FB3D  2  20 E4 FA             JSR     IDE_WAIT_DRQ    ;WAIT UNIT IT WANTS THE DATA
00FB40  2  C9 00                CMP     #$00
00FB42  2  D0 0D                BNE     IDE_WRITE_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FB44  2  20 54 FB             JSR     IDE_WRITE_BUFFER;GIVE THE DATA TO THE DRIVE
00FB47  2  20 BB FA             JSR     IDE_WAIT_NOT_BUSY;WAIT UNTIL THE WRITE IS COMPLETE
00FB4A  2  C9 00                CMP     #$00
00FB4C  2  D0 03                BNE     IDE_WRITE_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FB4E  2                       .IFNDEF PC6502BIOS
00FB4E  2                       LDA     #$FF            ; INVALIDATE CACHE
00FB4E  2                       STA     Cdebsehd        ;
00FB4E  2                       STA     Cdebcyll        ;
00FB4E  2                       STA     Cdebcylm        ;
00FB4E  2                       .ENDIF
00FB4E  2  A9 00                LDA     #$00            ; ZERO = 1 ON RETURN = OPERATION OK
00FB50  2  60                   RTS
00FB51  2               IDE_WRITE_SECTOR_ERROR:
00FB51  2  A9 FF                LDA     #$FF
00FB53  2  60                   RTS
00FB54  2               
00FB54  2               ;*__IDE_WRITE_BUFFER___________________________________________________________________________________
00FB54  2               ;*
00FB54  2               ;*  WRITE IDE BUFFER LITTLE ENDIAN
00FB54  2               ;*
00FB54  2               ;*____________________________________________________________________________________________________
00FB54  2               IDE_WRITE_BUFFER:
00FB54  2  A0 00                LDY     #$00            ; INDEX
00FB56  2               :
00FB56  2  B9 00 04             LDA     hstbuf,Y        ;
00FB59  2  8D 00 E3             STA     XTIDE_DATA_LO
00FB5C  2  C8                   INY
00FB5D  2  B9 00 04             LDA     hstbuf,Y        ;
00FB60  2  8D 01 E3             STA     XTIDE_DATA_HI
00FB63  2  C8                   INY
00FB64  2  C0 00                CPY     #$00            ;
00FB66  2  D0 EE                BNE     :-              ;
00FB68  2               :
00FB68  2  B9 00 05             LDA     hstbuf+$100,Y   ;
00FB6B  2  8D 00 E3             STA     XTIDE_DATA_LO
00FB6E  2  C8                   INY
00FB6F  2  B9 00 05             LDA     hstbuf+$100,Y   ;
00FB72  2  8D 01 E3             STA     XTIDE_DATA_HI
00FB75  2  C8                   INY
00FB76  2  C0 00                CPY     #$00            ;
00FB78  2  D0 EE                BNE     :-              ;
00FB7A  2  60                   RTS                     ;
00FB7B  2               
00FB7B  2                       .IFNDEF PC6502BIOS
00FB7B  2               MESSAGE1:
00FB7B  2                       .BYTE   "XT-IDE:"
00FB7B  2                       .BYTE   00
00FB7B  2               MESSAGE2:
00FB7B  2                       .BYTE   " IO=0x"
00FB7B  2                       .BYTE   00
00FB7B  2               MESSAGE3:
00FB7B  2                       .BYTE   " NOT PRESENT"
00FB7B  2                       .BYTE   00
00FB7B  2               MESSAGE4:
00FB7B  2                       .BYTE   " XT-IDE0: BLOCKS="
00FB7B  2                       .BYTE   00
00FB7B  2               MESSAGE5:
00FB7B  2                       .BYTE   " XT-IDE1: BLOCKS="
00FB7B  2                       .BYTE   00
00FB7B  2               MESSAGE6:
00FB7B  2                       .BYTE   "0x"
00FB7B  2                       .BYTE   00
00FB7B  2               
00FB7B  2               ;___IDE_CONVERT_SECTOR_LBA_______________________________________________________________________________
00FB7B  2               ;
00FB7B  2               ; 	TRANSLATE LBA SECTORS
00FB7B  2               ;________________________________________________________________________________________________________
00FB7B  2               IDE_CONVERT_SECTOR_LBA:
00FB7B  2                       LDA     sektrk          ; LOAD TRACK # (LOW BYTE)
00FB7B  2                       AND     #$0F            ; ISOLATE HEAD IN LOW 4 BITS
00FB7B  2                       ASL     a               ; MOVE TO HIGH BYTE
00FB7B  2                       ASL     a
00FB7B  2                       ASL     a
00FB7B  2                       ASL     a
00FB7B  2                       TAX                     ; PARK IN X
00FB7B  2                       LDA     seksec          ; LOAD SECTOR # (LOW BYTE)
00FB7B  2                       LSR     A               ;
00FB7B  2                       LSR     A               ; DIVIDE BY 4 (FOR BLOCKING)
00FB7B  2                       AND     #$0F            ; CLEAR UPPER 4 BITS (JUST 'CAUSE)
00FB7B  2                       STA     debsehd         ; STORE IN SECTOR/HEAD
00FB7B  2                       TXA                     ; GET HEAD BACK
00FB7B  2                       ORA     debsehd
00FB7B  2                       STA     debsehd         ; STORE IN SECTOR/HEAD
00FB7B  2               
00FB7B  2                       LDA     sektrk
00FB7B  2                       STA     debcyll         ; STORE IN TRACK (lsb)
00FB7B  2                       LDA     sektrk+1
00FB7B  2                       STA     debcylm         ; STORE IN TRACK (msb)
00FB7B  2               ; REMOVE HEAD FROM TRACK VALUE (DIV/4)
00FB7B  2                       LDA     debcylm
00FB7B  2                       LSR     A
00FB7B  2                       STA     debcylm
00FB7B  2                       LDA     debcyll
00FB7B  2                       ROR     A
00FB7B  2                       STA     debcyll
00FB7B  2               
00FB7B  2                       LDA     debcylm
00FB7B  2                       LSR     A
00FB7B  2                       STA     debcylm
00FB7B  2                       LDA     debcyll
00FB7B  2                       ROR     A
00FB7B  2                       STA     debcyll
00FB7B  2               
00FB7B  2                       LDA     debcylm
00FB7B  2                       LSR     A
00FB7B  2                       STA     debcylm
00FB7B  2                       LDA     debcyll
00FB7B  2                       ROR     A
00FB7B  2                       STA     debcyll
00FB7B  2               
00FB7B  2                       LDA     debcylm
00FB7B  2                       LSR     A
00FB7B  2                       STA     debcylm
00FB7B  2                       LDA     debcyll
00FB7B  2                       ROR     A
00FB7B  2                       STA     debcyll
00FB7B  2               ;	ADD SLICE OFFSET
00FB7B  2                       LDA     sekdsk          ; GET DRIVE#
00FB7B  2                       AND     #7              ; ONLY FIRST 8 DEVICES SUPPORTED
00FB7B  2                       ASL     a               ; DOUBLE NUMBER FOR TABLE LOOKUP
00FB7B  2                       TAX                     ; MOVE TO X REGISTER
00FB7B  2                       INX                     ; WANT SECOND BYTE OF ENTRY
00FB7B  2                       LDA     dskcfg,X        ; GET SLICE#
00FB7B  2                       STA     slicetmp+1      ; SLICE OFFSET MSB
00FB7B  2                       LDA     #0              ; GET SLICE#
00FB7B  2                       STA     slicetmp        ; SLICE OFFSET LSB
00FB7B  2                       CLC                     ; VOODOO MATH TO TAKE SLICE*$4000
00FB7B  2                       ROR     slicetmp+1
00FB7B  2                       ROR     slicetmp
00FB7B  2                       ROR     slicetmp+1
00FB7B  2                       ROR     slicetmp
00FB7B  2               
00FB7B  2                       LDA     dskcfg,X        ; GET SLICE#
00FB7B  2                       CLC
00FB7B  2                       ADC     slicetmp
00FB7B  2                       STA     slicetmp
00FB7B  2                       LDA     #$00            ; LOGIC ERROR FOR SLICES THAT CARRY?
00FB7B  2                       ADC     slicetmp+1      ;
00FB7B  2                       STA     slicetmp+1      ;
00FB7B  2               
00FB7B  2               ; ADD SLICE OFFSET TO TRACK #
00FB7B  2                       LDA     slicetmp
00FB7B  2                       ADC     debcyll
00FB7B  2                       STA     debcyll         ; store sum of LSBs
00FB7B  2                       LDA     slicetmp+1
00FB7B  2                       ADC     debcylm         ; add the MSBs using carry from
00FB7B  2                       STA     debcylm         ; the previous calculation
00FB7B  2                       RTS
00FB7B  2               
00FB7B  2                       .ENDIF
00FB7B  2               
00FB7B  2               ;*__IDE_SETUP_LBA_____________________________________________________________________________________
00FB7B  2               ;*
00FB7B  2               ;*  SETUP LBA DATA
00FB7B  2               ;*  A= DRIVE DEVICE
00FB7B  2               ;*____________________________________________________________________________________________________
00FB7B  2               IDE_SETUP_LBA:
00FB7B  2  AD 3D 06             LDA     currentDrive
00FB7E  2  29 01                AND     #$01            ; only want drive cfg
00FB80  2  0A                   ASL     a               ; SHIFT 4
00FB81  2  0A                   ASL     a               ;
00FB82  2  0A                   ASL     a               ;
00FB83  2  0A                   ASL     a               ;
00FB84  2  09 E0                ORA     #$E0            ; E0=MST  F0=SLV
00FB86  2  8D 0C E3             STA     XTIDE_DEVICE
00FB89  2               
00FB89  2  AD 11 06             LDA     debcylm
00FB8C  2  8D 0A E3             STA     XTIDE_LBAHI
00FB8F  2               
00FB8F  2  AD 10 06             LDA     debcyll
00FB92  2  8D 08 E3             STA     XTIDE_LBAMID
00FB95  2               
00FB95  2  AD 12 06             LDA     debsehd
00FB98  2  8D 06 E3             STA     XTIDE_LBALOW
00FB9B  2               
00FB9B  2  A9 01                LDA     #$01
00FB9D  2  8D 04 E3             STA     XTIDE_SEC_CNT
00FBA0  2  60                   RTS
00FBA1  2               
00FBA1  2                       .IFDEF  PC6502BIOS
00FBA1  2               ; Boot System [B]
00FBA1  2               BOOT:
00FBA1  2  20 08 FA             JSR     XTIDE_INIT      ; INIT IDE
00FBA4  2                                               ; SETUP LOCATION
00FBA4  2  A9 00                LDA     #$00
00FBA6  2  8D 10 06             STA     debcyll         ;
00FBA9  2  8D 11 06             STA     debcylm         ;
00FBAC  2  8D 12 06             STA     debsehd         ;
00FBAF  2  8D 3D 06             STA     currentDrive    ;
00FBB2  2  85 EE                STA     SRC             ; SETUP SOURCE AND DEST POINTERS
00FBB4  2  85 EC                STA     DEST
00FBB6  2  A9 04                LDA     #$04
00FBB8  2  85 EF                STA     SRC+1
00FBBA  2  A9 08                LDA     #$08
00FBBC  2  85 ED                STA     DEST+1
00FBBE  2               
00FBBE  2               BOOT1:
00FBBE  2  20 9C FA             JSR     IDE_READ_SECTOR ; READ THE SECTOR
00FBC1  2  C9 00                CMP     #$00
00FBC3  2  D0 2A                BNE     BOOTX
00FBC5  2  A0 00                LDY     #$00
00FBC7  2               :
00FBC7  2  B1 EE                LDA     (SRC),Y
00FBC9  2  91 EC                STA     (DEST),Y
00FBCB  2  C8                   INY
00FBCC  2  C0 00                CPY     #$00
00FBCE  2  D0 F7                BNE     :-
00FBD0  2  E6 EF                INC     SRC+1
00FBD2  2  E6 ED                INC     DEST+1
00FBD4  2               :
00FBD4  2  B1 EE                LDA     (SRC),Y
00FBD6  2  91 EC                STA     (DEST),Y
00FBD8  2  C8                   INY
00FBD9  2  C0 00                CPY     #$00
00FBDB  2  D0 F7                BNE     :-
00FBDD  2  E6 ED                INC     DEST+1
00FBDF  2  A9 04                LDA     #$04
00FBE1  2  85 EF                STA     SRC+1
00FBE3  2  EE 12 06             INC     debsehd
00FBE6  2  A5 ED                LDA     DEST+1
00FBE8  2  C9 80                CMP     #$80
00FBEA  2  D0 D2                BNE     BOOT1
00FBEC  2  4C 00 08             JMP     $0800
00FBEF  2               BOOTX:
00FBEF  2  4C E0 F0             JMP     ERROR           ; back to main loop
00FBF2  2               
00FBF2  2               WBOOT:
00FBF2  2  A9 67                LDA     #<MESSAGE7      ;
00FBF4  2  85 41                STA     STRPTR          ;
00FBF6  2  A9 FC                LDA     #>MESSAGE7      ;
00FBF8  2  85 42                STA     STRPTR+1        ;
00FBFA  2  20 68 FD             JSR     OUTSTR
00FBFD  2  20 5F FD             JSR     IOF_CONINW
00FC00  2  C9 59                CMP     #'Y'
00FC02  2  F0 0C                BEQ     :+
00FC04  2               
00FC04  2  A9 B1                LDA     #<MESSAGE8      ;
00FC06  2  85 41                STA     STRPTR          ;
00FC08  2  A9 FC                LDA     #>MESSAGE8      ;
00FC0A  2  85 42                STA     STRPTR+1        ;
00FC0C  2  20 68 FD             JSR     OUTSTR
00FC0F  2  00                   BRK
00FC10  2               
00FC10  2               
00FC10  2               :
00FC10  2  20 08 FA             JSR     XTIDE_INIT      ; INIT IDE
00FC13  2                                               ; SETUP LOCATION
00FC13  2  A9 00                LDA     #$00
00FC15  2  8D 10 06             STA     debcyll         ;
00FC18  2  8D 11 06             STA     debcylm         ;
00FC1B  2  8D 12 06             STA     debsehd         ;
00FC1E  2  8D 3D 06             STA     currentDrive    ;
00FC21  2  85 EE                STA     SRC             ; SETUP SOURCE AND DEST POINTERS
00FC23  2  85 EC                STA     DEST
00FC25  2  A9 08                LDA     #$08
00FC27  2  85 EF                STA     SRC+1
00FC29  2  A9 04                LDA     #$04
00FC2B  2  85 ED                STA     DEST+1
00FC2D  2               
00FC2D  2               BOOTW1:
00FC2D  2  A0 00                LDY     #$00
00FC2F  2               :
00FC2F  2  B1 EE                LDA     (SRC),Y
00FC31  2  91 EC                STA     (DEST),Y
00FC33  2  C8                   INY
00FC34  2  C0 00                CPY     #$00
00FC36  2  D0 F7                BNE     :-
00FC38  2  E6 EF                INC     SRC+1
00FC3A  2  E6 ED                INC     DEST+1
00FC3C  2               :
00FC3C  2  B1 EE                LDA     (SRC),Y
00FC3E  2  91 EC                STA     (DEST),Y
00FC40  2  C8                   INY
00FC41  2  C0 00                CPY     #$00
00FC43  2  D0 F7                BNE     :-
00FC45  2               
00FC45  2  20 2E FB             JSR     IDE_WRITE_SECTOR; READ THE SECTOR
00FC48  2  C9 00                CMP     #$00
00FC4A  2  D0 A3                BNE     BOOTX
00FC4C  2               
00FC4C  2  E6 EF                INC     SRC+1
00FC4E  2  A9 04                LDA     #$04
00FC50  2  85 ED                STA     DEST+1
00FC52  2  EE 12 06             INC     debsehd
00FC55  2  A5 EF                LDA     SRC+1
00FC57  2  C9 80                CMP     #$80
00FC59  2  D0 D2                BNE     BOOTW1
00FC5B  2               
00FC5B  2  A9 CE                LDA     #<MESSAGE9      ;
00FC5D  2  85 41                STA     STRPTR          ;
00FC5F  2  A9 FC                LDA     #>MESSAGE9      ;
00FC61  2  85 42                STA     STRPTR+1        ;
00FC63  2  20 68 FD             JSR     OUTSTR
00FC66  2  00                   BRK
