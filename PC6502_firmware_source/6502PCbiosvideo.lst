00FCE5  1               
00FCE5  1                       .INCLUDE "bios_pager.ASM"
00FCE5  2               ;__BIOS PAGERS__________________________________________________________________________________________________________________
00FCE5  2               ;
00FCE5  2               ; 	Memory Page Management Functions
00FCE5  2               ;
00FCE5  2               ;________________________________________________________________________________________________________________________________
00FCE5  2               ;
00FCE5  2               
00FCE5  2               ;__INITPAGES____________________________________________________
00FCE5  2               ;
00FCE5  2               ; SETUP MMU FOR BIOS PAGED MEMORY OPERATION
00FCE5  2               ;
00FCE5  2               ; SETUP:
00FCE5  2               ; 	TASK 0, NORMAL OPERATION
00FCE5  2               ;       TASK 1, ADDITIONAL RAM PAGED INTO C000-D000 (10,11)
00FCE5  2               ;	TASKS 2-15 -- OPEN FOR OS/USER USE
00FCE5  2               ;_______________________________________________________________
00FCE5  2               ;  The 6502PC has a flexible hardware MMU. There are 64 programmable task contexts, each with 16 4K banks ($BXXX).
00FCE5  2               ;  The MMU has several Registers.
00FCE5  2               ;     $xFE0- Write only-Task Register, Sets which context is active, when the mmu is enabled (0-63)
00FCE5  2               ;     $xFE1- Write only-Setup Register, Sets which context is being setup (exposed in the edit window) (0-63)
00FCE5  2               ;     $xFE2- Write only-Enable Register 0=MMU Disabled, 1=MMU Enabled
00FCE5  2               ;     $xFE4- Read Only- Active Task Register (only lower 6 bits)
00FCE5  2               ;     $xFE6- Read Only- hit ISA TC Bit
00FCE5  2               ;     $xFE7- Read Only- Current IO Page (only lower 4 bits)
00FCE5  2               ;
00FCE5  2               ;     $xfDx- read or write task edit window
00FCE5  2               ;
00FCE5  2               ;_______________________________________________________________
00FCE5  2               INITPAGES:
00FCE5  2  A9 00                LDA     #$00            ; ENSURE MMU IS DISABLED (SHOULD BE ALREADY, BUT . . . )
00FCE7  2  8D E2 EF             STA     PC6502_MMU_ENA
00FCEA  2  A9 01                LDA     #$01
00FCEC  2  8D E1 EF             STA     PC6502_MAP_SETUP; Fill TASK 1
00FCEF  2  20 0F FD             JSR     INITPAGE        ; FILL TASK 1 WITH A 1:1 MAP
00FCF2  2  A9 10                LDA     #$10            ; BUT, MAP Cxxx AND Dxxx TO RAM 10xxx AND 11xxx RATHER THAN RAM
00FCF4  2  8D DC EF             STA     PC6502_MAP_SPACE+$0C
00FCF7  2  A9 11                LDA     #$11
00FCF9  2  8D DD EF             STA     PC6502_MAP_SPACE+$0D
00FCFC  2  A9 00                LDA     #$00
00FCFE  2  8D E1 EF             STA     PC6502_MAP_SETUP; Then do task 0
00FD01  2  20 0F FD             JSR     INITPAGE        ; FILL TASK 0 WITH A 1:1 MAP
00FD04  2               ;  Why task 1 before task 0??   On some boards every write to the register also writes to task 0
00FD04  2               ;  so it is important to write task 0 last (or not use it)
00FD04  2  A9 00                LDA     #$00
00FD06  2  8D E0 EF             STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
00FD09  2  A9 01                LDA     #$01
00FD0B  2  8D E2 EF             STA     PC6502_MMU_ENA  ; ENABLE MMU --- FEEEEEL THE POOOOWERRRR
00FD0E  2  60                   RTS
00FD0F  2               
00FD0F  2               INITPAGE:
00FD0F  2  A2 00                LDX     #$00
00FD11  2               :
00FD11  2  8A                   TXA
00FD12  2  9D D0 EF             STA     PC6502_MAP_SPACE,X; CREATE A 1:1 MAP OF BANK
00FD15  2  E8                   INX
00FD16  2  E0 10                CPX     #$10
00FD18  2  D0 F7                BNE     :-
00FD1A  2  60                   RTS
00FD1B  2               PAGE_EXIT:
00FD1B  2  48                   PHA
00FD1C  2  A9 00                LDA     #$00
00FD1E  2  8D E0 EF             STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
00FD21  2  68                   PLA
00FD22  2  60                   RTS
00FD23  2               PAGE_ENTER:
00FD23  2  48                   PHA
00FD24  2  A9 01                LDA     #$01
00FD26  2  8D E0 EF             STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
00FD29  2  68                   PLA
00FD2A  2  60                   RTS
00FD2B  2               
00FD2B  2               
00FD2B  2               
00FD2B  2               ;__SETPAGE________________________________________________________
00FD2B  2               ;
00FD2B  2               ; SETUP MMU FOR A SPECIFIC MAPPED PAGE
00FD2B  2               ;
00FD2B  2               ; A=BANK TO SWAP
00FD2B  2               ; X=MAP PAGE (SPOT IN MEMORY MAP)
00FD2B  2               ; Y=DESTINATION PAGE (SPOT IN PHYSICAL MEMORY)
00FD2B  2               ;_______________________________________________________________
00FD2B  2               SETPAGE:
00FD2B  2  85 3B                STA     TEMPWORD
00FD2D  2  A9 00                LDA     #$00            ; DISABLE MMU
00FD2F  2  8D E2 EF             STA     PC6502_MMU_ENA
00FD32  2  A5 3B                LDA     TEMPWORD
00FD34  2  8D E1 EF             STA     PC6502_MAP_SETUP; Fill TASK AREA
00FD37  2  98                   TYA
00FD38  2  9D D0 EF             STA     PC6502_MAP_SPACE,X
00FD3B  2  A9 00                LDA     #$00            ; RE-SETUP TASK AREA 0, JUST IN CASE THE ABOVE WRITE CORRUPTED IT
00FD3D  2  8D E1 EF             STA     PC6502_MAP_SETUP; Fill TASK AREA
00FD40  2  8A                   TXA
00FD41  2  9D D0 EF             STA     PC6502_MAP_SPACE,X
00FD44  2  A9 01                LDA     #$01
00FD46  2  8D E2 EF             STA     PC6502_MMU_ENA  ; ENABLE MMU --- FEEEEEL THE POOOOWERRRR
00FD49  2  60                   RTS
