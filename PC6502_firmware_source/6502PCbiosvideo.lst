00F7BA  2  20 53 FD             JSR     CHROUT          ; output character
00F7BD  2               ZERSUP:
00F7BD  2  CA                   DEX                     ; decrement number of leading zeros
00F7BE  2  D0 DD                BNE     DIGOUT          ; next digit
00F7C0  2  60                   RTS
00F7C1  2               
00F7C1  2               
00F7C1  2               ; -----------------------------------------------------------------------------
00F7C1  2               ; print and clear routines
00F7C1  2               CLINE:
00F7C1  2  20 4C F6             JSR     CRLF
00F7C4  2  4C CA F7             JMP     SNCLR           ; clear line
00F7C7  2               SNDCLR:
00F7C7  2  20 DA F7             JSR     SNDMSG
00F7CA  2               SNCLR:
00F7CA  2  A0 28                LDY     #$28            ; loop 40 times
00F7CC  2               SNCLP:
00F7CC  2  A9 20                LDA     #$20            ; output space character
00F7CE  2  20 53 FD             JSR     CHROUT
00F7D1  2  88                   DEY
00F7D2  2  D0 F8                BNE     SNCLP
00F7D4  2  A9 0D                LDA     #13             ; output CR
00F7D6  2  20 53 FD             JSR     CHROUT          ; send CR
00F7D9  2  60                   RTS
00F7DA  2               
00F7DA  2               ; -----------------------------------------------------------------------------
00F7DA  2               ; display message from table
00F7DA  2               SNDMSG:
00F7DA  2  B9 75 F8             LDA     MSGBAS,Y        ; Y contains offset in msg table
00F7DD  2  08                   PHP
00F7DE  2  29 7F                AND     #$7F            ; strip high bit before output
00F7E0  2  20 48 F6             JSR     CHOUT
00F7E3  2  C8                   INY
00F7E4  2  28                   PLP
00F7E5  2  10 F3                BPL     SNDMSG          ; loop until high bit is set
00F7E7  2  60                   RTS
00F7E8  2               
00F7E8  2               ; -----------------------------------------------------------------------------
00F7E8  2               ; check for stop key
00F7E8  2               STOP:
00F7E8  2  20 56 FD             JSR     IOF_CONIN
00F7EB  2  C9 03                CMP     #$03
00F7ED  2  F0 03                BEQ     :+
00F7EF  2  A9 FF                LDA     #$FF
00F7F1  2  60                   RTS
00F7F2  2               :
00F7F2  2  A9 00                LDA     #$00
00F7F4  2  60                   RTS
00F7F5  2               
00F7F5  2               ; -----------------------------------------------------------------------------
00F7F5  2               ; LOAD A MOTOROLA FORMATTED HEX FILE
00F7F5  2               LOADS19:
00F7F5  2  20 5F FD             JSR     IOF_CONINW      ;
00F7F8  2  C9 53                CMP     #'S'            ;
00F7FA  2  D0 F9                BNE     LOADS19         ; FIRST CHAR NOT (S)
00F7FC  2  20 5F FD             JSR     IOF_CONINW      ; READ CHAR
00F7FF  2  C9 39                CMP     #'9'            ;
00F801  2  F0 33                BEQ     LOAD21          ;
00F803  2  C9 31                CMP     #'1'            ;
00F805  2  D0 EE                BNE     LOADS19         ; SECOND CHAR NOT (1)
00F807  2  A9 00                LDA     #$00            ;
00F809  2  85 BC                STA     CKSM            ; ZERO CHECKSUM
00F80B  2  20 37 F8             JSR     S19GETBYTE      ; READ BYTE
00F80E  2  E9 01                SBC     #$01            ;
00F810  2  85 CB                STA     DIGCNT          ; BYTE COUNT
00F812  2  20 64 F8             JSR     BADDR           ; BUILD ADDRESS
00F815  2  A0 00                LDY     #$00            ;
00F817  2               LOAD11:
00F817  2  20 37 F8             JSR     S19GETBYTE      ;
00F81A  2  C6 CB                DEC     DIGCNT          ;
00F81C  2  F0 0F                BEQ     LOAD15          ; ZERO BYTE COUNT
00F81E  2  91 BD                STA     (LOADADR),Y     ; STORE DATA
00F820  2  E6 BD                INC     LOADADR         ; INCREMENT LOWBYTE
00F822  2  A5 BD                LDA     LOADADR
00F824  2  C9 00                CMP     #$00
00F826  2  D0 EF                BNE     LOAD11          ; NOT ZERO?, LOOP
00F828  2  E6 BE                INC     LOADADR+1       ; ZERO, INC HIGH BYTE
00F82A  2  4C 17 F8             JMP     LOAD11          ;
00F82D  2               
00F82D  2               LOAD15:
00F82D  2  E6 BC                INC     CKSM            ;
00F82F  2  F0 C4                BEQ     LOADS19         ;
00F831  2               LOAD19:
00F831  2  A9 3F                LDA     #'?'            ;
00F833  2  20 53 FD             JSR     IOF_OUTCH       ;
00F836  2               LOAD21:
00F836  2  60                   RTS
00F837  2               S19GETBYTE:
00F837  2  20 4F F8             JSR     INHEX           ; GET HEX CHAR
00F83A  2  0A                   ASL                     ;
00F83B  2  0A                   ASL                     ;
00F83C  2  0A                   ASL                     ;
00F83D  2  0A                   ASL                     ;
00F83E  2  85 BF                STA     LOADWRK         ;
00F840  2  20 4F F8             JSR     INHEX           ;
00F843  2  29 0F                AND     #$0F            ; MASK TO 4 BITS
00F845  2  05 BF                ORA     LOADWRK         ;
00F847  2  48                   PHA                     ;
00F848  2  18                   CLC                     ;
00F849  2  65 BC                ADC     CKSM            ;
00F84B  2  85 BC                STA     CKSM            ;
00F84D  2  68                   PLA                     ;
00F84E  2  60                   RTS                     ;
00F84F  2               ; INPUT HEX CHAR
00F84F  2               INHEX:
00F84F  2  20 5F FD             JSR     IOF_CONINW      ;
00F852  2  48                   PHA                     ;
00F853  2  20 53 FD             JSR     IOF_OUTCH       ;
00F856  2  68                   PLA                     ;
00F857  2  C9 3A                CMP     #$3A            ; LESS THAN 9?
00F859  2  B0 02                BCS     INHEX_BIG       ; NO, SKIP NEXT
00F85B  2  E9 2F                SBC     #$2F            ; CONVERT 0-9
00F85D  2               INHEX_BIG:
00F85D  2  C9 41                CMP     #$41            ; A OR MORE?
00F85F  2  90 02                BCC     INHEX_SMALL     ; NO, SKIP NEXT
00F861  2  E9 37                SBC     #$37            ; CONVERT A-F
00F863  2               INHEX_SMALL:
00F863  2  60                   RTS                     ;
00F864  2               ; BUILD ADDRESS
00F864  2               BADDR:
00F864  2  20 37 F8             JSR     S19GETBYTE      ; READ 2 FRAMES
00F867  2  85 BE                STA     LOADADR+1       ;
00F869  2  20 37 F8             JSR     S19GETBYTE      ;
00F86C  2  85 BD                STA     LOADADR         ;
00F86E  2  60                   RTS
00F86F  2               LOAD:
00F86F  2  20 F5 F7             JSR     LOADS19
00F872  2  4C 91 F0             JMP     STRT            ; back to main loop
00F875  2               
00F875  2               
00F875  2               ; -----------------------------------------------------------------------------
00F875  2               ; message table; last character has high bit set
00F875  2               MSGBAS:
00F875  2               
00F875  2               MSG2:
00F875  2  0D                   .BYTE   $0D             ; header for registers
00F876  2  20 20 20 50          .BYTE   "   PC  SR AC XR YR SP   V1.2"
00F87A  2  43 20 20 53  
00F87E  2  52 20 41 43  
00F892  2  8D                   .BYTE   $0D+$80
00F893  2               MSG3:
00F893  2  20 BF                .BYTE   $20,$3F+$80     ; syntax error: move right, display "?"
00F895  2               MSG4:
00F895  2  2E 2E 53 59          .BYTE   "..SYS"         ; SYS call to enter monitor
00F899  2  53           
00F89A  2  A0                   .BYTE   $20+$80
00F89B  2               MSG5:
00F89B  2  3A A0                .BYTE   $3A,$20+$80     ; ":" then RVS ON for memory ASCII dump
00F89D  2               MSG6:
00F89D  2  20 45 52 52          .BYTE   " ERRO"         ; I/O error: display " ERROR"
00F8A1  2  4F           
00F8A2  2  D2                   .BYTE   'R'+$80
00F8A3  2               MSG7:
00F8A3  2  41 A0                .BYTE   $41,$20+$80     ; assemble next instruction: "A " + addr
00F8A5  2               MSG8:
00F8A5  2  20 20                .BYTE   "  "            ; pad non-existent byte: skip 3 spaces
00F8A7  2  A0                   .BYTE   $20+$80
