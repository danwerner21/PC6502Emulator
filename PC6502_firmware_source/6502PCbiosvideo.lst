000000r 1                       .SEGMENT "TROM"
000000r 1                       .ORG    $F000
00F000  1               
00F000  1               
00F000  1               ;__COLD_START___________________________________________________
00F000  1               ;
00F000  1               ; PERFORM SYSTEM COLD INIT
00F000  1               ;
00F000  1               ;_______________________________________________________________
00F000  1               COLD_START:
00F000  1  78                   SEI                     ; DISABLE INTERRUPTS
00F001  1  D8                   CLD                     ;  VERIFY DECIMAL MODE IS OFF
00F002  1  A2 FF                LDX     #$FF            ;
00F004  1  9A                   TXS                     ; CLEAR STACK
00F005  1  8A                   TXA
00F006  1               ;                                 STARTUP DELAY
00F006  1  A2 00                LDX     #$00
00F008  1  A0 00                LDY     #$00
00F00A  1               :
00F00A  1  CA                   DEX
00F00B  1  E0 00                CPX     #$00
00F00D  1  D0 FB                BNE     :-
00F00F  1  88                   DEY
00F010  1  C0 00                CPY     #$00
00F012  1  D0 F6                BNE     :-
00F014  1               ;
00F014  1                       .IFNDEF ESP
00F014  1  A9 04                LDA     #$04            ; SET CONSOLE SERIAL
00F016  1  85 3A                STA     CONSOLE         ;
00F018  1                       .ELSE
00F018  1                       LDA     #$09            ; SET CONSOLE ESP
00F018  1                       STA     CONSOLE         ;
00F018  1                       .ENDIF
00F018  1               
00F018  1                       .IFDEF VIDEO
00F018  1  A9 13                LDA     #19             ; SET CONSOLE VIDEO
00F01A  1  85 3A                STA     CONSOLE         ;
00F01C  1                       .ENDIF
00F01C  1               
00F01C  1               
00F01C  1               ;;;
00F01C  1  A9 48                LDA     #<IRQROUTINE
00F01E  1  85 35                STA     IRQVECTOR
00F020  1  85 37                STA     NMIVECTOR
00F022  1  A9 F0                LDA     #>IRQROUTINE
00F024  1  85 36                STA     IRQVECTOR+1
00F026  1  85 38                STA     NMIVECTOR+1
00F028  1               ;
00F028  1               ;       INIT PAGING
00F028  1  20 E5 FC             JSR     INITPAGES       ;
00F02B  1               
00F02B  1               ;	INIT HARDWARE
00F02B  1  20 C6 F9             JSR     SERIALINIT
00F02E  1               
00F02E  1  20 23 FD             JSR     PAGE_ENTER
00F031  1  A9 85                LDA     #<STARTUP       ; OUTPUT STARTUP STRING
00F033  1  85 41                STA     STRPTR          ;
00F035  1  A9 FD                LDA     #>STARTUP       ;
00F037  1  85 42                STA     STRPTR+1        ;
00F039  1  20 68 FD             JSR     OUTSTR          ;
00F03C  1  20 1B FD             JSR     PAGE_EXIT
00F03F  1               
00F03F  1               
00F03F  1  A9 00                LDA     #$00            ;
00F041  1  8D 00 03             STA     INBUFFER        ; MAKE SURE INPUT BUFFER IS EMPTY
00F044  1               
00F044  1                       .IFDEF VIDEO
00F044  1  4C A1 FB             JMP     BOOT
00F047  1                       .ENDIF
00F047  1               
00F047  1               
00F047  1  00                   BRK                     ; PERFORM BRK (START MONITOR)
00F048  1               
00F048  1               ;__IRQROUTINE___________________________________________________
00F048  1               ;
00F048  1               ; HANDLE INTERRUPT PROCESING
00F048  1               ;
00F048  1               ;_______________________________________________________________
00F048  1               IRQROUTINE:
00F048  1  58                   CLI                     ; ENABLE INTERRUPTS AGAIN
00F049  1  40                   RTI
00F04A  1               
00F04A  1               ;__INTERRUPT____________________________________________________
00F04A  1               ;
00F04A  1               ; HANDLE IRQ INTERRUPT AND DETERMINE IF IT IS A BRK OR AN IRQ
00F04A  1               ;
00F04A  1               ;_______________________________________________________________
00F04A  1               INTERRUPT:
00F04A  1  78                   SEI                     ; DISABLE INTERRUPTS
00F04B  1  85 3B                STA     TEMPWORD
00F04D  1  68                   PLA                     ; GET STATUS REGISTER
00F04E  1  48                   PHA                     ; SAVE STATUS REGISTER
00F04F  1  29 10                AND     #$10            ; MASK BRK
00F051  1  D0 03                BNE     BRKCMD          ; BRK CMD
00F053  1  6C 35 00             JMP     (IRQVECTOR)     ; LET USER ROUTINE HAVE IT (USER DEFINED IRQ)
00F056  1               BRKCMD:
00F056  1  A5 3B                LDA     TEMPWORD
00F058  1  48                   PHA
00F059  1  8A                   TXA
00F05A  1  48                   PHA
00F05B  1  98                   TYA
00F05C  1  48                   PHA
00F05D  1  4C 63 F0             JMP     BRKROUTINE      ; MONITOR BRK ROUTINE
00F060  1               
00F060  1               NINTERRUPT:
00F060  1  6C 37 00             JMP     (NMIVECTOR)     ; LET USER ROUTINE HAVE IT (USER DEFINED NMI)
00F063  1               
00F063  1                       .INCLUDE "../supermon/supermon.asm"
00F063  2               ; ********************************
00F063  2               ; * SUPERMON+ 64 JIM BUTTERFIELD *
00F063  2               ; * V1.2   AUGUST 20 1985        *
00F063  2               ; ********************************
00F063  2               
00F063  2               ; Reformatted and annotated in late 2016/early 2017 by J.B. Langston.
00F063  2               ; Modified for Nhyodyne/Retrobrew 3/12/2023 D. Werner
00F063  2               ;
00F063  2               ; Mr. Butterfield . . you inspired many of us, thank you.
00F063  2               ;
00F063  2               ; -----------------------------------------------------------------------------
00F063  2               ; temporary pointers
00F063  2               TMP0            = $C1           ; used to return input, often holds end address
00F063  2               TMP2            = $C3           ; usually holds start address
00F063  2               
00F063  2               ; these 7 locations are used to store the registers when
00F063  2               ; entering the monitor and restore them when exiting.
00F063  2               
00F063  2               PCH             = $B0           ; program counter high byte
00F063  2               PCL             = $B1           ; program counter low byte
00F063  2               SR              = $B2           ; status register
00F063  2               ACC             = $B3           ; accumulator
00F063  2               XR              = $B4           ; X register
00F063  2               YR              = $B5           ; Y register
00F063  2               SP              = $B6           ; stack pointer
00F063  2               STORE           = $B7           ; 2-byte temp storage
00F063  2               CHRPNT          = $B9           ; current position in input buffer
00F063  2               SAVY            = $BA           ; temp storage, often to save Y register
00F063  2               U9F             = $BB           ; index into assembler work buffer
00F063  2               CKSM            = $BC           ; S19 loader checksum store
00F063  2               LOADADR         = $BD           ; S19 load address
00F063  2               LOADWRK         = $BF           ; S19 load work
00F063  2               
00F063  2               ;-----------------------------------------------------------------------------
00F063  2               ; variables
00F063  2               ACMD            = $C5           ; addressing command
00F063  2               LENGTH          = $C6           ; length of operand
00F063  2               MNEMW           = $C7           ; 3 letter mnemonic buffer
00F063  2               SAVX            = $CA           ; 1 byte temp storage, often to save X register
00F063  2               OPCODE          = $CB           ; current opcode for assembler/disassembler
00F063  2               UPFLG           = $CC           ; flag: count up (bit 7 clear) or down (bit 7 set)
00F063  2               DIGCNT          = $CB           ; digit count
00F063  2               INDIG           = $CC           ; numeric value of single digit
00F063  2               NUMBIT          = $CD           ; numeric base of input
00F063  2               STASH           = $CE           ; 2-byte temp storage
00F063  2               U0AA0           = $D0           ; 10 byte work buffer
00F063  2               U0AAE           = $D0+10        ; end of 10 byte work buffer
00F063  2               STAGE           = $DA           ; 30 byte staging buffer for filename, search, etc.
00F063  2               ESTAGE          = $DA+30        ; end of 30 byte staging buffer for filename, search, etc.
00F063  2               INBUFF          = $0400
00F063  2               CHROUT          = IOF_OUTCH
00F063  2               
00F063  2               
00F063  2               ; -----------------------------------------------------------------------------
00F063  2               ; BRK handler
00F063  2               BRKROUTINE:
00F063  2               BREAK:
00F063  2  A2 05                LDX     #$05            ; pull registers off the stack
00F065  2               BSTACK:
00F065  2  68                   PLA                     ; order: Y,X,A,SR,PCL,PCH
00F066  2  95 B0                STA     PCH,X           ; store in memory
00F068  2  CA                   DEX
00F069  2  10 FA                BPL     BSTACK
00F06B  2  D8                   CLD                     ; disable bcd mode
00F06C  2  BA                   TSX                     ; store stack pointer in memory
00F06D  2  86 B6                STX     SP
00F06F  2  58                   CLI                     ; enable interupts
00F070  2               
00F070  2               ; -----------------------------------------------------------------------------
00F070  2               ; display registers [R]
00F070  2               DSPLYR:
00F070  2  A0 00                LDY     #MSG2-MSGBAS    ; display headers
00F072  2  20 C7 F7             JSR     SNDCLR
00F075  2  A9 3B                LDA     #$3B            ; prefix registers with "; " to allow editing
00F077  2  20 53 FD             JSR     CHROUT
00F07A  2  A9 20                LDA     #$20
00F07C  2  20 53 FD             JSR     CHROUT
00F07F  2  A5 B0                LDA     PCH             ; print 2-byte program counter
00F081  2  20 61 F6             JSR     WRTWO
00F084  2  A0 01                LDY     #1              ; start 1 byte after PC high byte
00F086  2               DISJ:
00F086  2  B9 B0 00             LDA     PCH,Y           ; loop through rest of the registers
00F089  2  20 41 F6             JSR     WRBYTE          ; print 1-byte register value
00F08C  2  C8                   INY
00F08D  2  C0 07                CPY     #7              ; there are a total of 5 registers to print
00F08F  2  90 F5                BCC     DISJ
00F091  2               
00F091  2               ; -----------------------------------------------------------------------------
00F091  2               ; main loop
00F091  2               STRT:
00F091  2  20 4C F6             JSR     CRLF            ; new line
00F094  2  A2 00                LDX     #0              ; point at start of input buffer
00F096  2  86 B9                STX     CHRPNT
00F098  2               SMOVE:
00F098  2  20 5F FD             JSR     IOF_CONINW      ; CHRIN kernal call to input a character
00F09B  2               
00F09B  2  C9 08                CMP     #$08            ; IS BACKSPACE?
00F09D  2  D0 1A                BNE     :+              ; NO, SKUP BACKSPACE RTN
00F09F  2  E0 00                CPX     #$00            ; IS INDEX =0 ?
00F0A1  2  F0 F5                BEQ     SMOVE           ; YES, SKIP BACKSPACE
00F0A3  2  20 53 FD             JSR     IOF_OUTCH       ; BACK UP CURSOR
00F0A6  2  A9 20                LDA     #$20
00F0A8  2  20 53 FD             JSR     IOF_OUTCH       ; SPACE ON SCREEN
00F0AB  2  A9 08                LDA     #$08
00F0AD  2  20 53 FD             JSR     IOF_OUTCH       ; BACK UP CURSOR
00F0B0  2               
00F0B0  2  A9 00                LDA     #0
00F0B2  2  9D 00 04             STA     INBUFF,X        ; store in input buffer
00F0B5  2  CA                   DEX
00F0B6  2  4C 98 F0             JMP     SMOVE
00F0B9  2               :
00F0B9  2  20 53 FD             JSR     IOF_OUTCH       ; OUTPUT CHAR TO SCREEN
00F0BC  2               
00F0BC  2  9D 00 04             STA     INBUFF,X        ; store in input buffer
00F0BF  2  E8                   INX
00F0C0  2  E0 00                CPX     #00             ; error if buffer is full
00F0C2  2  F0 1C                BEQ     ERROR
00F0C4  2  C9 0D                CMP     #$0D            ; keep reading until CR
00F0C6  2  D0 D0                BNE     SMOVE
00F0C8  2  A9 00                LDA     #0              ; null-terminate input buffer
00F0CA  2  9D FF 03             STA     INBUFF-1,X      ; (replacing the CR)
00F0CD  2               ST1:
00F0CD  2  20 86 F6             JSR     GETCHR          ; get a character from the buffer
00F0D0  2  F0 BF                BEQ     STRT            ; start over if buffer is empty
00F0D2  2  C9 20                CMP     #$20            ; skip leading spaces
00F0D4  2  F0 F7                BEQ     ST1
00F0D6  2               S0:
00F0D6  2  A2 14                LDX     #KEYTOP-KEYW    ; loop through valid command characters
00F0D8  2               S1:
00F0D8  2  DD 8A F9             CMP     KEYW,X          ; see if input character matches
00F0DB  2  F0 0B                BEQ     S2              ; command matched, dispatch it
00F0DD  2  CA                   DEX                     ; no match, check next command
00F0DE  2  10 F8                BPL     S1              ; keep trying until we've checked them all
00F0E0  2                                               ; then fall through to error handler
00F0E0  2               
00F0E0  2               ; -----------------------------------------------------------------------------
00F0E0  2               ; handle error
00F0E0  2               ERROR:
00F0E0  2  A0 1E                LDY     #MSG3-MSGBAS    ; display "?" to indicate error and go to new line
00F0E2  2  20 DA F7             JSR     SNDMSG
00F0E5  2  4C 91 F0             JMP     STRT            ; back to main loop
00F0E8  2               
00F0E8  2               ; -----------------------------------------------------------------------------
00F0E8  2               ; dispatch command
00F0E8  2               S2:
00F0E8  2  E0 10                CPX     #$10            ; next 4 commands are base conversions
00F0EA  2  B0 0E                BCS     CNVLNK          ;   which are handled by the same subroutine
00F0EC  2  8A                   TXA                     ; remaining commands dispatch through vector table
00F0ED  2  0A                   ASL     A               ; multiply index of command by 2
00F0EE  2  AA                   TAX                     ;   since table contains 2-byte addresses
00F0EF  2  BD 9F F9             LDA     KADDR+1,X       ; push address from vector table onto stack
00F0F2  2  48                   PHA                     ;   so that the RTS from GETPAR will jump there
00F0F3  2  BD 9E F9             LDA     KADDR,X
00F0F6  2  48                   PHA
00F0F7  2  4C 80 F5             JMP     GETPAR          ; get the first parameter for the command
00F0FA  2               CNVLNK:
00F0FA  2  4C 1B F7             JMP     CONVRT          ; handle base conversion
00F0FD  2               
00F0FD  2               
00F0FD  2               ; -----------------------------------------------------------------------------
00F0FD  2               ; display memory [M]
00F0FD  2               DSPLYM:
00F0FD  2  B0 08                BCS     DSPM11          ; start from previous end addr if no address given
00F0FF  2  20 9C F6             JSR     COPY12          ; save start address in TMP2
00F102  2  20 80 F5             JSR     GETPAR          ; get end address in TMP0
00F105  2  90 06                BCC     DSMNEW          ; did user specify one?
00F107  2               DSPM11:
00F107  2  A9 0B                LDA     #$0B            ; if not, show 12 lines by default
00F109  2  85 C1                STA     TMP0
00F10B  2  D0 0E                BNE     DSPBYT          ; always true, but BNE uses 1 byte less than JMP
00F10D  2               DSMNEW:
00F10D  2  20 A5 F6             JSR     SUB12           ; end addr given, calc bytes between start and end
00F110  2  90 1E                BCC     MERROR          ; error if start is after end
00F112  2  A2 03                LDX     #3              ; divide by 8 (shift right 3 times)
00F114  2               DSPM01:
00F114  2  46 C2                LSR     TMP0+1
00F116  2  66 C1                ROR     TMP0
00F118  2  CA                   DEX
00F119  2  D0 F9                BNE     DSPM01
00F11B  2               DSPBYT:
00F11B  2  20 E8 F7             JSR     STOP            ; check for stop key
00F11E  2  F0 0D                BEQ     DSPMX           ; exit early if pressed
00F120  2  20 94 F1             JSR     DISPMEM         ; display 1 line containing 8 bytes
00F123  2  A9 08                LDA     #8              ; increase start address by 8 bytes
00F125  2  20 D5 F6             JSR     BUMPAD2
00F128  2  20 B3 F6             JSR     SUBA1           ; decrement line counter
00F12B  2  B0 EE                BCS     DSPBYT          ; show another line until it's < 0
00F12D  2               DSPMX:
00F12D  2  4C 91 F0             JMP     STRT            ; back to main loop
00F130  2               MERROR:
00F130  2  4C E0 F0             JMP     ERROR           ; handle error
00F133  2               
00F133  2               ; -----------------------------------------------------------------------------
00F133  2               ; alter registers [;]
00F133  2               ALTR:
00F133  2  20 ED F6             JSR     COPY1P          ; store first parameter in PC
00F136  2  A0 00                LDY     #0              ; init counter
00F138  2               ALTR1:
00F138  2  20 80 F5             JSR     GETPAR          ; get value for next register
00F13B  2  B0 0A                BCS     ALTRX           ; exit early if no more values given
00F13D  2  A5 C1                LDA     TMP0            ; store in memory, offset from SR
00F13F  2  99 B2 00             STA     SR,Y            ; these locations will be transferred to the
00F142  2  C8                   INY                     ;   actual registers before exiting the monitor
00F143  2  C0 05                CPY     #$05            ; have we updated all 5 yet?
00F145  2  90 F1                BCC     ALTR1           ; if not, get next
00F147  2               ALTRX:
00F147  2  4C 91 F0             JMP     STRT            ; back to main loop
00F14A  2               
00F14A  2               ; -----------------------------------------------------------------------------
00F14A  2               ; alter memory [>]
00F14A  2               ALTM:
00F14A  2  B0 13                BCS     ALTMX           ; exit if no parameter provided
00F14C  2  20 9C F6             JSR     COPY12          ; copy parameter to start address
00F14F  2  A0 00                LDY     #0
00F151  2               ALTM1:
00F151  2  20 80 F5             JSR     GETPAR          ; get value for next byte of memory
00F154  2  B0 09                BCS     ALTMX           ; if none given, exit early
00F156  2  A5 C1                LDA     TMP0            ; poke value into memory at start address + Y
00F158  2  91 C3                STA     (TMP2),Y
00F15A  2  C8                   INY                     ; next byte
00F15B  2  C0 08                CPY     #8              ; have we read 8 bytes yet?
00F15D  2  90 F2                BCC     ALTM1           ; if not, read the next one
00F15F  2               ALTMX:
00F15F  2  A9 91                LDA     #$91            ; move cursor up
00F161  2  20 53 FD             JSR     CHROUT
00F164  2  20 94 F1             JSR     DISPMEM         ; re-display line to make ascii match hex
00F167  2  4C 91 F0             JMP     STRT            ; back to main loop
00F16A  2               
00F16A  2               ; -----------------------------------------------------------------------------
00F16A  2               ; goto (run) [G]
00F16A  2               GOTO:
00F16A  2  A6 B6                LDX     SP              ; load stack pointer from memory
00F16C  2  9A                   TXS                     ; save in SP register
00F16D  2               GOTO2:
00F16D  2  20 ED F6             JSR     COPY1P          ; copy provided address to PC
00F170  2  78                   SEI                     ; disable interrupts
00F171  2  A5 B0                LDA     PCH             ; push PC high byte on stack
00F173  2  48                   PHA
00F174  2  A5 B1                LDA     PCL             ; push PC low byte on stack
00F176  2  48                   PHA
00F177  2  A5 B2                LDA     SR              ; push status byte on stack
00F179  2  48                   PHA
00F17A  2  A5 B3                LDA     ACC             ; load accumulator from memory
00F17C  2  A6 B4                LDX     XR              ; load X from memory
00F17E  2  A4 B5                LDY     YR              ; load Y from memory
00F180  2  40                   RTI                     ; return from interrupt (pops PC and SR)
00F181  2               
00F181  2               ; jump to subroutine [J]
00F181  2               JSUB:
00F181  2  A6 B6                LDX     SP              ; load stack pointer from memory
00F183  2  9A                   TXS                     ; save value in SP register
00F184  2  20 6D F1             JSR     GOTO2           ; same as goto command
00F187  2  84 B5                STY     YR              ; save Y to memory
00F189  2  86 B4                STX     XR              ; save X to memory
00F18B  2  85 B3                STA     ACC             ; save accumulator to memory
00F18D  2  08                   PHP                     ; push processor status on stack
00F18E  2  68                   PLA                     ; pull processor status into A
00F18F  2  85 B2                STA     SR              ; save processor status to memory
00F191  2  4C 70 F0             JMP     DSPLYR          ; display registers
00F194  2               
00F194  2               ; -----------------------------------------------------------------------------
00F194  2               ; display 8 bytes of memory
00F194  2               DISPMEM:
00F194  2  20 4C F6             JSR     CRLF            ; new line
00F197  2  A9 3E                LDA     #'>'            ; prefix > so memory can be edited in place
00F199  2  20 53 FD             JSR     CHROUT
00F19C  2  20 37 F6             JSR     SHOWAD          ; show address of first byte on line
00F19F  2  A0 00                LDY     #0
00F1A1  2  F0 03                BEQ     DMEMGO          ; SHOWAD already printed a space after the address
00F1A3  2               DMEMLP:
00F1A3  2  20 44 F6             JSR     SPACE           ; print space between bytes
00F1A6  2               DMEMGO:
00F1A6  2  B1 C3                LDA     (TMP2),Y        ; load byte from start address + Y
00F1A8  2  20 61 F6             JSR     WRTWO           ; output hex digits for byte
00F1AB  2  C8                   INY                     ; next byte
00F1AC  2  C0 08                CPY     #8              ; have we output 8 bytes yet?
00F1AE  2  90 F3                BCC     DMEMLP          ; if not, output next byte
00F1B0  2  A0 26                LDY     #MSG5-MSGBAS    ; if so, output : and turn on reverse video
00F1B2  2  20 DA F7             JSR     SNDMSG          ;   before displaying ascii representation
00F1B5  2  A0 00                LDY     #0              ; back to first byte in line
00F1B7  2               DCHAR:
00F1B7  2  B1 C3                LDA     (TMP2),Y        ; load byte at start address + Y
00F1B9  2  C9 20                CMP     #$20            ; is it a printable character (>= $20)?
00F1BB  2  90 04                BCC     DDOT            ; if NOT printable, output '.'
00F1BD  2  C9 80                CMP     #$80
00F1BF  2  90 02                BCC     DCHROK          ; if printable, output character
00F1C1  2               DDOT:
00F1C1  2  A9 2E                LDA     #$2E            ; if not, output '.' instaed
00F1C3  2               DCHROK:
00F1C3  2  20 53 FD             JSR     CHROUT
00F1C6  2  C8                   INY                     ; next byte
00F1C7  2  C0 08                CPY     #8              ; have we output 8 bytes yet?
00F1C9  2  90 EC                BCC     DCHAR           ; if not, output next byte
00F1CB  2  60                   RTS
00F1CC  2               
00F1CC  2               ; -----------------------------------------------------------------------------
00F1CC  2               ; compare memory [C]
00F1CC  2               COMPAR:
00F1CC  2  A9 00                LDA     #0              ; bit 7 clear signals compare
00F1CE  2  2C                   .BYTE   $2C             ; absolute BIT opcode consumes next word (LDA #$80)
00F1CF  2               
00F1CF  2               ; transfer memory [T]
00F1CF  2               TRANS:
00F1CF  2  A9 80                LDA     #$80            ; bit 7 set signals transfer
00F1D1  2  85 BA                STA     SAVY            ; save compare/transfer flag in SAVY
00F1D3  2  A9 00                LDA     #0              ; assume we're counting up (bit 7 clear)
00F1D5  2  85 CC                STA     UPFLG           ; save direction flag
00F1D7  2  20 F8 F6             JSR     GETDIF          ; get two addresses and calculate difference
00F1DA  2                                               ;   TMP2 = source start
00F1DA  2                                               ;   STASH = source end
00F1DA  2                                               ;   STORE = length
00F1DA  2  B0 05                BCS     TERROR          ; carry set indicates error
00F1DC  2  20 80 F5             JSR     GETPAR          ; get destination address in TMP0
00F1DF  2  90 03                BCC     TOKAY           ; carry set indicates error
00F1E1  2               TERROR:
00F1E1  2  4C E0 F0             JMP     ERROR           ; handle error
00F1E4  2               TOKAY:
00F1E4  2  24 BA                BIT     SAVY            ; transfer or compare?
00F1E6  2  10 23                BPL     COMPAR1         ; high bit clear indicates compare
00F1E8  2  A5 C3                LDA     TMP2            ; if it's a transfer, we must take steps
00F1EA  2  C5 C1                CMP     TMP0            ;   to avoid overwriting the source bytes before
00F1EC  2  A5 C4                LDA     TMP2+1          ;   they have been transferred
00F1EE  2  E5 C2                SBC     TMP0+1          ; compare source (TMP2) to destination (TMP0)
00F1F0  2  B0 19                BCS     COMPAR1         ; and count up if source is before than desitnation
00F1F2  2  A5 B7                LDA     STORE           ; otherwise, start at end and count down...
00F1F4  2  65 C1                ADC     TMP0            ; add length (STORE) to desintation (TMP0)
00F1F6  2  85 C1                STA     TMP0            ; to calculate end of destination
00F1F8  2  A5 B8                LDA     STORE+1
00F1FA  2  65 C2                ADC     TMP0+1
00F1FC  2  85 C2                STA     TMP0+1
00F1FE  2  A2 01                LDX     #1              ; change source pointer from beginning to end
00F200  2               TDOWN:
00F200  2  B5 CE                LDA     STASH,X         ; TMP2 = source end (STASH)
00F202  2  95 C3                STA     TMP2,X
00F204  2  CA                   DEX
00F205  2  10 F9                BPL     TDOWN
00F207  2  A9 80                LDA     #$80            ; high bit set in UPFLG means count down
00F209  2  85 CC                STA     UPFLG
00F20B  2               COMPAR1:
00F20B  2  20 4C F6             JSR     CRLF            ; new line
00F20E  2  A0 00                LDY     #0              ; no offset from pointer
00F210  2               TCLOOP:
00F210  2  20 E8 F7             JSR     STOP            ; check for stop key
00F213  2  F0 2F                BEQ     TEXIT           ; exit if pressed
00F215  2  B1 C3                LDA     (TMP2),Y        ; load byte from source
00F217  2  24 BA                BIT     SAVY            ; transfer or compare?
00F219  2  10 02                BPL     COMPAR2         ; skip store if comparing
00F21B  2  91 C1                STA     (TMP0),Y        ; otherwise, store in destination
00F21D  2               COMPAR2:
00F21D  2  D1 C1                CMP     (TMP0),Y        ; compare to destination
00F21F  2  F0 03                BEQ     TMVAD           ; don't show address if equal
00F221  2  20 37 F6             JSR     SHOWAD          ; show address
00F224  2               TMVAD:
00F224  2  24 CC                BIT     UPFLG           ; counting up or down?
00F226  2  30 0B                BMI     TDECAD          ; high bit set means we're counting down
00F228  2  E6 C1                INC     TMP0            ; increment destination low byte
00F22A  2  D0 10                BNE     TINCOK
00F22C  2  E6 C2                INC     TMP0+1          ; carry to high byte if necessary
00F22E  2  D0 0C                BNE     TINCOK
00F230  2  4C E0 F0             JMP     ERROR           ; error if high byte overflowed
00F233  2               TDECAD:
00F233  2  20 B3 F6             JSR     SUBA1           ; decrement destination (TMP0)
00F236  2  20 DF F6             JSR     SUB21           ; decrement source (TMP2)
00F239  2  4C 3F F2             JMP     TMOR
00F23C  2               TINCOK:
00F23C  2  20 D3 F6             JSR     ADDA2           ; increment source (TMP2)
00F23F  2               TMOR:
00F23F  2  20 C5 F6             JSR     SUB13           ; decrement length
00F242  2  B0 CC                BCS     TCLOOP          ; loop until length is 0
00F244  2               TEXIT:
00F244  2  4C 91 F0             JMP     STRT            ; back to main loop
00F247  2               
00F247  2               ; -----------------------------------------------------------------------------
00F247  2               ; hunt memory [H]
00F247  2               HUNT:
00F247  2  20 F8 F6             JSR     GETDIF          ; get start (TMP2) and end (TMP0) of haystack
00F24A  2  B0 57                BCS     HERROR          ; carry indicates error
00F24C  2  A0 00                LDY     #0
00F24E  2  20 86 F6             JSR     GETCHR          ; get a single character
00F251  2  C9 27                CMP     #39             ; is it a single quote?
00F253  2  D0 16                BNE     NOSTRH          ; if not, input needle as hex bytes
00F255  2  20 86 F6             JSR     GETCHR          ; if so, input needle as string
00F258  2  C9 00                CMP     #0
00F25A  2  F0 47                BEQ     HERROR          ; error if needle isn't at least one byte
00F25C  2               HPAR:
00F25C  2  99 DA 00             STA     STAGE,Y         ; save char in staging area
00F25F  2  C8                   INY
00F260  2  20 86 F6             JSR     GETCHR          ; get another char
00F263  2  F0 18                BEQ     HTGO            ; if it's null start searching
00F265  2  C0 1E                CPY     #ESTAGE-STAGE   ; have we filled up the needle staging area?
00F267  2  D0 F3                BNE     HPAR            ; if not, get another character
00F269  2  F0 12                BEQ     HTGO            ; if so, start searching
00F26B  2               NOSTRH:
00F26B  2  20 7E F5             JSR     RDPAR           ; read hex bytes if string not indicated
00F26E  2               HLP:
00F26E  2  A5 C1                LDA     TMP0            ; save last read byte in staging area
00F270  2  99 DA 00             STA     STAGE,Y
00F273  2  C8                   INY                     ; get another hex byte
00F274  2  20 80 F5             JSR     GETPAR
00F277  2  B0 04                BCS     HTGO            ; if there is none, start searching
00F279  2  C0 1E                CPY     #ESTAGE-STAGE   ; have we filled up the needle staging area?
00F27B  2  D0 F1                BNE     HLP             ; if not, get another byte
00F27D  2               HTGO:
00F27D  2  84 BA                STY     SAVY            ; save length of needle
00F27F  2  20 4C F6             JSR     CRLF            ; new line
00F282  2               HSCAN:
00F282  2  A0 00                LDY     #0
00F284  2               HLP3:
00F284  2  B1 C3                LDA     (TMP2),Y        ; get first byte in haystack
00F286  2  D9 DA 00             CMP     STAGE,Y         ; compare it to first byte of needle
00F289  2  D0 08                BNE     HNOFT           ; if it doesn't match, we haven't found anything
00F28B  2  C8                   INY                     ; if it does, check the next byte
00F28C  2  C4 BA                CPY     SAVY            ; have we reached the end of the needle?
00F28E  2  D0 F4                BNE     HLP3            ; if not, keep comparing bytes
00F290  2  20 37 F6             JSR     SHOWAD          ; match found, show address
00F293  2               HNOFT:
00F293  2  20 E8 F7             JSR     STOP            ; no match, check for stop key
00F296  2  F0 08                BEQ     HEXIT           ; exit prematurely if pressed
00F298  2  20 D3 F6             JSR     ADDA2           ; increment haystack pointer
00F29B  2  20 C5 F6             JSR     SUB13           ; decrement haystack length
00F29E  2  B0 E2                BCS     HSCAN           ; still more haystack? keep searching
00F2A0  2               HEXIT:
00F2A0  2  4C 91 F0             JMP     STRT            ; back to main loop
00F2A3  2               HERROR:
00F2A3  2  4C E0 F0             JMP     ERROR           ; handle error
00F2A6  2               
00F2A6  2               
00F2A6  2               ; -----------------------------------------------------------------------------
00F2A6  2               ; fill memory [F]
00F2A6  2               FILL:
00F2A6  2  20 F8 F6             JSR     GETDIF          ; start in TMP2, end in STASH, length in STORE
00F2A9  2  B0 20                BCS     FERROR          ; carry set indicates error
00F2AB  2  20 80 F5             JSR     GETPAR          ; get value to fill in TMP0
00F2AE  2  B0 1B                BCS     FERROR          ; carry set indicates error
00F2B0  2  20 86 F6             JSR     GETCHR          ; any more characters triggers an error
00F2B3  2  D0 16                BNE     FERROR
00F2B5  2  A0 00                LDY     #0              ; no offset
00F2B7  2               FILLP:
00F2B7  2  A5 C1                LDA     TMP0            ; load value to fill in accumulator
00F2B9  2  91 C3                STA     (TMP2),Y        ; store fill value in current address
00F2BB  2  20 E8 F7             JSR     STOP            ; check for stop key
00F2BE  2  F0 08                BEQ     FSTART          ; if pressed, back to main loop
00F2C0  2  20 D3 F6             JSR     ADDA2           ; increment address
00F2C3  2  20 C5 F6             JSR     SUB13           ; decrement length
00F2C6  2  B0 EF                BCS     FILLP           ; keep going until length reaches 0
00F2C8  2               FSTART:
00F2C8  2  4C 91 F0             JMP     STRT            ; back to main loop
00F2CB  2               FERROR:
00F2CB  2  4C E0 F0             JMP     ERROR           ; handle error
00F2CE  2               ; -----------------------------------------------------------------------------
00F2CE  2                 .ifndef  PC6502BIOS
00F2CE  2               ; Boot System [B]
00F2CE  2               BOOT:
00F2CE  2                       BCS     BOOTX           ; exit with error if no parameter given
00F2CE  2                       LDA     TMP0
00F2CE  2                       AND     #$0F
00F2CE  2                       STA     DSKUNIT
00F2CE  2                       LDA     #$00
00F2CE  2                       STA     debcyll         ;
00F2CE  2                       STA     debcylm         ;
00F2CE  2                       STA     debsehd         ;
00F2CE  2                       JSR     GETPAR          ; get value for next byte of memory
00F2CE  2                       BCS     BOOTX           ; exit with error if no parameter given
00F2CE  2                       LDA     TMP0
00F2CE  2                       STA     farfunct
00F2CE  2                       JSR     DO_FARCALL
00F2CE  2                       JMP     hstbuf
00F2CE  2               BOOTX:
00F2CE  2               WBOOT:
00F2CE  2                       JMP     ERROR           ; back to main loop
00F2CE  2                       .endif
00F2CE  2               
00F2CE  2               
00F2CE  2               ; -----------------------------------------------------------------------------
00F2CE  2               ; assemble [A.]
00F2CE  2               ; read in mnemonic
00F2CE  2               ASTART:
00F2CE  2  4C 91 F0             JMP     STRT            ; back to main loop
00F2D1  2               ASSEM:
00F2D1  2  B0 31                BCS     AERROR          ; error if no address given
00F2D3  2  20 9C F6             JSR     COPY12          ; copy address to TMP2
00F2D6  2               AGET1:
00F2D6  2  A2 00                LDX     #0
00F2D8  2  86 D1                STX     U0AA0+1         ; clear byte that mnemonic gets shifted into
00F2DA  2  86 CB                STX     DIGCNT          ; clear digit count
00F2DC  2               AGET2:
00F2DC  2  20 86 F6             JSR     GETCHR          ; get a char
00F2DF  2  D0 04                BNE     ALMOR           ; proceed if the character isn't null
00F2E1  2  E0 00                CPX     #0              ; it's null, have read a mnemonic yet?
00F2E3  2  F0 E9                BEQ     ASTART          ; if not, silently go back to main loop
00F2E5  2               ALMOR:
00F2E5  2  C9 20                CMP     #$20            ; skip leading spaces
00F2E7  2  F0 ED                BEQ     AGET1
00F2E9  2  95 C7                STA     MNEMW,X         ; put character in mnemonic buffer
00F2EB  2  E8                   INX
00F2EC  2  E0 03                CPX     #3              ; have we read 3 characters yet?
00F2EE  2  D0 EC                BNE     AGET2           ; if not, get next character
00F2F0  2               
00F2F0  2               ; compress mnemonic into two bytes
00F2F0  2               ASQEEZ:
00F2F0  2  CA                   DEX                     ; move to previous char
00F2F1  2  30 14                BMI     AOPRND          ; if we're done with mnemonic, look for operand
00F2F3  2  B5 C7                LDA     MNEMW,X         ; get current character
00F2F5  2  38                   SEC                     ; pack 3-letter mnemonic into 2 bytes (15 bits)
00F2F6  2  E9 3F                SBC     #$3F            ; subtract $3F from ascii code so A-Z = 2 to 27
00F2F8  2  A0 05                LDY     #$05            ; letters now fit in 5 bits; shift them out
00F2FA  2               ASHIFT:
00F2FA  2  4A                   LSR     A               ;   into the first two bytes of the inst buffer
00F2FB  2  66 D1                ROR     U0AA0+1         ; catch the low bit from accumulator in right byte
00F2FD  2  66 D0                ROR     U0AA0           ; catch the low bit from right byte in left byte
00F2FF  2  88                   DEY                     ; count down bits
00F300  2  D0 F8                BNE     ASHIFT          ; keep looping until we reach zero
00F302  2  F0 EC                BEQ     ASQEEZ          ; unconditional branch to handle next char
00F304  2               AERROR:
00F304  2  4C E0 F0             JMP     ERROR           ; handle error
00F307  2               
00F307  2               ; parse operand
00F307  2               AOPRND:
00F307  2  A2 02                LDX     #2              ; mnemonic is in first two bytes so start at third
00F309  2               ASCAN:
00F309  2  A5 CB                LDA     DIGCNT          ; did we find address digits last time?
00F30B  2  D0 28                BNE     AFORM1          ; if so, look for mode chars
00F30D  2  20 A5 F5             JSR     RDVAL           ; otherwise, look for an address
00F310  2  F0 21                BEQ     AFORM0          ; we didn't find an address, look for characters
00F312  2  B0 F0                BCS     AERROR          ; carry flag indicates error
00F314  2  A9 24                LDA     #'$'
00F316  2  95 D0                STA     U0AA0,X         ; prefix addresses with $
00F318  2  E8                   INX                     ; next position in buffer
00F319  2  A0 04                LDY     #4              ; non-zero page addresses are 4 hex digits
00F31B  2  A5 CD                LDA     NUMBIT          ; check numeric base in which address was given
00F31D  2  C9 08                CMP     #8              ; for addresses given in octal or binary
00F31F  2  90 04                BCC     AADDR           ;   use only the high byte to determine page
00F321  2  C4 CB                CPY     DIGCNT          ; for decimal or hex, force non-zero page addressing
00F323  2  F0 06                BEQ     AFILL0          ;   if address was given with four digits or more
00F325  2               AADDR:
00F325  2  A5 C2                LDA     TMP0+1          ; check whether high byte of address is zero
00F327  2  D0 02                BNE     AFILL0          ; non-zero high byte means we're not in zero page
00F329  2  A0 02                LDY     #2              ; if it's in zero page, addr is 2 hex digits
00F32B  2               AFILL0:
00F32B  2  A9 30                LDA     #$30            ; use 0 as placeholder for each hex digit in addr
00F32D  2               AFIL0L:
00F32D  2  95 D0                STA     U0AA0,X         ; put placeholder in assembly buffer
00F32F  2  E8                   INX                     ; move to next byte in buffer
00F330  2  88                   DEY                     ; decrement number of remaining digits
00F331  2  D0 FA                BNE     AFIL0L          ; loop until all digits have been placed
00F333  2               AFORM0:
00F333  2  C6 B9                DEC     CHRPNT          ; non-numeric input; back 1 char to see what it was
00F335  2               AFORM1:
00F335  2  20 86 F6             JSR     GETCHR          ; get next character
00F338  2  F0 0D                BEQ     AESCAN          ; if there is none, we're finished scanning
00F33A  2  C9 20                CMP     #$20            ; skip spaces
00F33C  2  F0 CB                BEQ     ASCAN
00F33E  2  95 D0                STA     U0AA0,X         ; store character in assembly buffer
00F340  2  E8                   INX                     ; move to next byte in buffer
00F341  2  E0 0A                CPX     #U0AAE-U0AA0    ; is instruction buffer full?
00F343  2  90 C4                BCC     ASCAN           ; if not, keep scanning
00F345  2  B0 BD                BCS     AERROR          ; error if buffer is full
00F347  2               
00F347  2               ; find matching opcode
00F347  2               AESCAN:
00F347  2  86 B7                STX     STORE           ; save number of bytes in assembly buffer
00F349  2  A2 00                LDX     #0              ; start at opcode $00 and check every one until
00F34B  2  86 CB                STX     OPCODE          ;   we find one that matches our criteria
00F34D  2               ATRYOP:
00F34D  2  A2 00                LDX     #0
00F34F  2  86 BB                STX     U9F             ; reset index into work buffer
00F351  2  A5 CB                LDA     OPCODE
00F353  2  20 16 F5             JSR     INSTXX          ; look up instruction format for current opcode
00F356  2  A6 C5                LDX     ACMD            ; save addressing command for later
00F358  2  86 B8                STX     STORE+1
00F35A  2  AA                   TAX                     ; use current opcode as index
00F35B  2  BD 46 F9             LDA     MNEMR,X         ; check right byte of compressed mnemonic
00F35E  2  20 4C F4             JSR     CHEKOP
00F361  2  BD 06 F9             LDA     MNEML,X         ; check left byte of compressed mnemonic
00F364  2  20 4C F4             JSR     CHEKOP
00F367  2  A2 06                LDX     #6              ; 6 possible characters to check against operand
00F369  2               TRYIT:
00F369  2  E0 03                CPX     #3              ; are we on character 3?
00F36B  2  D0 12                BNE     TRYMOD          ; if not, check operand characters
00F36D  2  A4 C6                LDY     LENGTH          ; otherwise, check number of bytes in operand
00F36F  2  F0 0E                BEQ     TRYMOD          ; if zero, check operand characters
00F371  2               TRYAD:
00F371  2  A5 C5                LDA     ACMD            ; otherwise, look for an address
00F373  2  C9 E8                CMP     #$E8            ; special case for relative addressing mode
00F375  2                                               ;   since it's specified with 4 digits in assembly
00F375  2                                               ;   but encoded with only 1 byte in object code
00F375  2  A9 30                LDA     #$30            ; '0' is the digit placeholder we're looking for
00F377  2  B0 1D                BCS     TRY4B           ; ACMD >= $E8 indicates relative addressing
00F379  2  20 49 F4             JSR     CHEK2B          ; ACMD < $E8 indicates normal addressing
00F37C  2  88                   DEY                     ; consume byte
00F37D  2  D0 F2                BNE     TRYAD           ; check for 2 more digits if not zero-page
00F37F  2               TRYMOD:
00F37F  2  06 C5                ASL     ACMD            ; shift a bit out of the addressing command
00F381  2  90 0E                BCC     UB4DF           ; if it's zero, skip checking current character
00F383  2  BD F9 F8             LDA     CHAR1-1,X
00F386  2  20 4C F4             JSR     CHEKOP          ; otherwise first character against operand
00F389  2  BD FF F8             LDA     CHAR2-1,X       ; get second character to check
00F38C  2  F0 03                BEQ     UB4DF           ; if it's zero, skip checking it
00F38E  2  20 4C F4             JSR     CHEKOP          ; otherwise check it against hte operand
00F391  2               UB4DF:
00F391  2  CA                   DEX                     ; move to next character
00F392  2  D0 D5                BNE     TRYIT           ; repeat tests
00F394  2  F0 06                BEQ     TRYBRAN
00F396  2               TRY4B:
00F396  2  20 49 F4             JSR     CHEK2B          ; check for 4 digit address placeholder
00F399  2  20 49 F4             JSR     CHEK2B          ;   by checking for 2 digits twice
00F39C  2               TRYBRAN:
00F39C  2  A5 B7                LDA     STORE           ; get number of bytes in assembly buffer
00F39E  2  C5 BB                CMP     U9F             ; more bytes left to check?
00F3A0  2  F0 03                BEQ     ABRAN           ; if not, we've found a match; build instruction
00F3A2  2  4C 56 F4             JMP     BUMPOP          ; if so, this opcode doesn't match; try the next
00F3A5  2               
00F3A5  2               ; convert branches to relative address
00F3A5  2               ABRAN:
00F3A5  2  A4 C6                LDY     LENGTH          ; get number of bytes in operand
00F3A7  2  F0 33                BEQ     A1BYTE          ; if none, just output the opcode
00F3A9  2  A5 B8                LDA     STORE+1         ; otherwise check the address format
00F3AB  2  C9 9D                CMP     #$9D            ; is it a relative branch?
00F3AD  2  D0 25                BNE     OBJPUT          ; if not, skip relative branch calculation
00F3AF  2  A5 C1                LDA     TMP0            ; calculate the difference between the current
00F3B1  2  E5 C3                SBC     TMP2            ;   address and the branch target (low byte)
00F3B3  2  AA                   TAX                     ; save it in X
00F3B4  2  A5 C2                LDA     TMP0+1          ; borrow from the high byte if necessary
00F3B6  2  E5 C4                SBC     TMP2+1
00F3B8  2  90 0B                BCC     ABBACK          ; if result is negative, we're branching back
00F3BA  2  F0 03                BEQ     :++             ; high bytes must be equal when branching forward
00F3BC  2               :
00F3BC  2  4C 46 F4             JMP     SERROR
00F3BF  2               :
00F3BF  2  E0 82                CPX     #$82            ; difference between low bytes must be < 130
00F3C1  2  B0 F9                BCS     :--             ; error if the address is too far away
00F3C3  2  90 08                BCC     ABRANX
00F3C5  2               ABBACK:
00F3C5  2  A8                   TAY                     ; when branching backward high byte of target must
00F3C6  2  C8                   INY                     ;   be 1 less than high byte of current address
00F3C7  2  D0 7D                BNE     SERROR          ; if not, it's too far away
00F3C9  2  E0 82                CPX     #$82            ; difference between low bytes must be < 130
00F3CB  2  90 79                BCC     SERROR          ; if not, it's too far away
00F3CD  2               ABRANX:
00F3CD  2  CA                   DEX                     ; adjust branch target relative to the
00F3CE  2  CA                   DEX                     ;   instruction following this one
00F3CF  2  8A                   TXA
00F3D0  2  A4 C6                LDY     LENGTH          ; load length of operand
00F3D2  2  D0 03                BNE     OBJP2           ; don't use the absolute address
00F3D4  2               
00F3D4  2               ; assemble machine code
00F3D4  2               OBJPUT:
00F3D4  2  B9 C0 00             LDA     TMP0-1,Y        ; get the operand
00F3D7  2               OBJP2:
00F3D7  2  91 C3                STA     (TMP2),Y        ; store it after the opcode
00F3D9  2  88                   DEY
00F3DA  2  D0 F8                BNE     OBJPUT          ; copy the other byte of operand if there is one
00F3DC  2               A1BYTE:
00F3DC  2  A5 CB                LDA     OPCODE          ; put opcode into instruction
00F3DE  2  91 C3                STA     (TMP2),Y
00F3E0  2  A9 0D                LDA     #$0D            ; cr
00F3E2  2  20 53 FD             JSR     CHROUT
00F3E5  2  A0 2E                LDY     #MSG7-MSGBAS    ; "A " prefix
00F3E7  2  20 C7 F7             JSR     SNDCLR          ; clear line
00F3EA  2  A9 41                LDA     #'A'
00F3EC  2  20 53 FD             JSR     CHROUT
00F3EF  2  A9 20                LDA     #' '
00F3F1  2  20 53 FD             JSR     CHROUT
00F3F4  2  20 9E F4             JSR     DISLIN          ; disassemble the instruction we just assembled
00F3F7  2  E6 C6                INC     LENGTH          ; instruction length = operand length + 1 byte
00F3F9  2  A5 C6                LDA     LENGTH          ;   for the opcode
00F3FB  2  20 D5 F6             JSR     BUMPAD2         ; increment address by length of instruction
00F3FE  2                                               ; setup for the next assemble command
00F3FE  2  20 4C F6             JSR     CRLF
00F401  2  A9 41                LDA     #'A'            ; stuff keyboard buffer with next assemble command:
00F403  2  8D 00 04             STA     INBUFF
00F406  2  20 53 FD             JSR     IOF_OUTCH
00F409  2  A9 20                LDA     #' '            ;   after the previously assembled instruction
00F40B  2  8D 01 04             STA     INBUFF+1
00F40E  2  20 53 FD             JSR     IOF_OUTCH
00F411  2  A5 C4                LDA     TMP2+1          ; convert high byte of next address to hex
00F413  2  20 6F F6             JSR     ASCTWO
00F416  2  8D 02 04             STA     INBUFF+2        ; put it in the keyboard buffer
00F419  2  20 53 FD             JSR     IOF_OUTCH
00F41C  2  8E 03 04             STX     INBUFF+3
00F41F  2  8A                   TXA
00F420  2  20 53 FD             JSR     IOF_OUTCH
00F423  2  A5 C3                LDA     TMP2            ; convert low byte of next address to hex
00F425  2  20 6F F6             JSR     ASCTWO
00F428  2  8D 04 04             STA     INBUFF+4        ; put it in the keyboard buffer
00F42B  2  20 53 FD             JSR     IOF_OUTCH
00F42E  2  8E 05 04             STX     INBUFF+5
00F431  2  8A                   TXA
00F432  2  20 53 FD             JSR     IOF_OUTCH
00F435  2  A9 20                LDA     #' '            ;   after the previously assembled instruction
00F437  2  8D 06 04             STA     INBUFF+6
00F43A  2  20 53 FD             JSR     IOF_OUTCH
00F43D  2  A2 07                LDX     #7              ; set number of chars in keyboard buffer
00F43F  2  A9 00                LDA     #$00
00F441  2  85 B9                STA     CHRPNT
00F443  2  4C 98 F0             JMP     SMOVE           ; back to main loop
00F446  2               SERROR:
00F446  2  4C E0 F0             JMP     ERROR           ; handle error
00F449  2               
00F449  2               ; check characters in operand
00F449  2               CHEK2B:
00F449  2  20 4C F4             JSR     CHEKOP          ; check two bytes against value in accumulator
00F44C  2               CHEKOP:
00F44C  2  86 CA                STX     SAVX            ; stash X
00F44E  2  A6 BB                LDX     U9F             ; get current index into work buffer
00F450  2  D5 D0                CMP     U0AA0,X         ; check whether this opcode matches the buffer
00F452  2  F0 09                BEQ     OPOK            ;   matching so far, check the next criteria
00F454  2  68                   PLA                     ; didn't match, so throw away return address
00F455  2  68                   PLA                     ;   on the stack because we're starting over
00F456  2               BUMPOP:
00F456  2  E6 CB                INC     OPCODE          ; check the next opcode
00F458  2  F0 EC                BEQ     SERROR          ; error if we tried every opcode and none fit
00F45A  2  4C 4D F3             JMP     ATRYOP          ; start over with new opcode
00F45D  2               OPOK:
00F45D  2  E6 BB                INC     U9F             ; opcode matches so far; check the next criteria
00F45F  2  A6 CA                LDX     SAVX            ; restore X
00F461  2  60                   RTS
00F462  2               
00F462  2               ; -----------------------------------------------------------------------------
00F462  2               ; disassemble [D]
00F462  2               DISASS:
00F462  2  B0 08                BCS     DIS0AD          ; if no address was given, start from last address
00F464  2  20 9C F6             JSR     COPY12          ; copy start address to TMP2
00F467  2  20 80 F5             JSR     GETPAR          ; get end address in TMP0
00F46A  2  90 06                BCC     DIS2AD          ; if one was given, skip default
00F46C  2               DIS0AD:
00F46C  2  A9 14                LDA     #$14            ; disassemble 14 bytes by default
00F46E  2  85 C1                STA     TMP0            ; store length in TMP0
00F470  2  D0 05                BNE     DISGO           ; skip length calculation
00F472  2               DIS2AD:
00F472  2  20 A5 F6             JSR     SUB12           ; calculate number of bytes between start and end
00F475  2  90 1C                BCC     DERROR          ; error if end address is before start address
00F477  2               DISGO:
00F477  2  20 C1 F7             JSR     CLINE           ; clear the current line
00F47A  2  20 E8 F7             JSR     STOP            ; check for stop key
00F47D  2  F0 11                BEQ     DISEXIT         ; exit early if pressed
00F47F  2  20 96 F4             JSR     DSOUT1          ; output disassembly prefix ". "
00F482  2  E6 C6                INC     LENGTH
00F484  2  A5 C6                LDA     LENGTH          ; add length of last instruction to start address
00F486  2  20 D5 F6             JSR     BUMPAD2
00F489  2  A5 C6                LDA     LENGTH          ; subtract length of last inst from end address
00F48B  2  20 B5 F6             JSR     SUBA2
00F48E  2  B0 E7                BCS     DISGO
00F490  2               DISEXIT:
00F490  2  4C 91 F0             JMP     STRT            ; back to mainloop
00F493  2               DERROR:
00F493  2  4C E0 F0             JMP     ERROR
00F496  2               
00F496  2               DSOUT1:
00F496  2  A9 2E                LDA     #'.'            ; output ". " prefix to allow edit and reassemble
00F498  2  20 53 FD             JSR     CHROUT
00F49B  2  20 44 F6             JSR     SPACE
00F49E  2               
00F49E  2               DISLIN:
00F49E  2  20 37 F6             JSR     SHOWAD          ; show the address of the instruction
00F4A1  2  20 44 F6             JSR     SPACE           ; insert a space
00F4A4  2  A0 00                LDY     #0              ; no offset
00F4A6  2  B1 C3                LDA     (TMP2),Y        ; load operand of current instruction
00F4A8  2  20 16 F5             JSR     INSTXX          ; get mnemonic and addressing mode for opcode
00F4AB  2  48                   PHA                     ; save index into mnemonic table
00F4AC  2  A6 C6                LDX     LENGTH          ; get length of operand
00F4AE  2  E8                   INX                     ; add 1 byte for opcode
00F4AF  2               DSBYT:
00F4AF  2  CA                   DEX                     ; decrement index
00F4B0  2  10 0C                BPL     DSHEX           ; show hex for byte being disassembled
00F4B2  2  84 BA                STY     SAVY            ; save index
00F4B4  2  A0 30                LDY     #MSG8-MSGBAS    ; skip 3 spaces
00F4B6  2  20 DA F7             JSR     SNDMSG
00F4B9  2  A4 BA                LDY     SAVY            ; restore index
00F4BB  2  4C C3 F4             JMP     NXBYT
00F4BE  2               DSHEX:
00F4BE  2  B1 C3                LDA     (TMP2),Y        ; show hex for byte
00F4C0  2  20 41 F6             JSR     WRBYTE
00F4C3  2               
00F4C3  2               NXBYT:
00F4C3  2  C8                   INY                     ; next byte
00F4C4  2  C0 03                CPY     #3              ; have we output 3 bytes yet?
00F4C6  2  90 E7                BCC     DSBYT           ; if not, loop
00F4C8  2  68                   PLA                     ; restore index into mnemonic table
00F4C9  2  A2 03                LDX     #3              ; 3 letters in mnemonic
00F4CB  2  20 5C F5             JSR     PROPXX          ; print mnemonic
00F4CE  2  A2 06                LDX     #6              ; 6 possible address mode character combos
00F4D0  2               PRADR1:
00F4D0  2  E0 03                CPX     #3              ; have we checked the third combo yet?
00F4D2  2  D0 14                BNE     PRADR3          ; if so, output the leading characters
00F4D4  2  A4 C6                LDY     LENGTH          ; get the length of the operand
00F4D6  2  F0 10                BEQ     PRADR3          ; if it's zero, there's no operand to print
00F4D8  2               PRADR2:
00F4D8  2  A5 C5                LDA     ACMD            ; otherwise, get the addressing mode
00F4DA  2  C9 E8                CMP     #$E8            ; check for relative addressing
00F4DC  2  08                   PHP                     ; save result of check
00F4DD  2  B1 C3                LDA     (TMP2),Y        ; get the operand
00F4DF  2  28                   PLP                     ; restore result of check
00F4E0  2  B0 1C                BCS     RELAD           ; handle a relative address
00F4E2  2  20 61 F6             JSR     WRTWO           ; output digits from address
00F4E5  2  88                   DEY
00F4E6  2  D0 F0                BNE     PRADR2          ; repeat for next byte of operand, if there is one
00F4E8  2               PRADR3:
00F4E8  2  06 C5                ASL     ACMD            ; check whether addr mode uses the current char
00F4EA  2  90 0E                BCC     PRADR4          ; if not, skip it
00F4EC  2  BD F9 F8             LDA     CHAR1-1,X       ; look up the first char in the table
00F4EF  2  20 53 FD             JSR     CHROUT          ; print first char
00F4F2  2  BD FF F8             LDA     CHAR2-1,X       ; look up the second char in the table
00F4F5  2  F0 03                BEQ     PRADR4          ; if there's no second character, skip it
00F4F7  2  20 53 FD             JSR     CHROUT          ; print second char
00F4FA  2               PRADR4:
00F4FA  2  CA                   DEX                     ; next potential address mode character
00F4FB  2  D0 D3                BNE     PRADR1          ; loop if we haven't checked them all yet
00F4FD  2  60                   RTS                     ; back to caller
00F4FE  2               RELAD:
00F4FE  2  20 0A F5             JSR     UB64D           ; calculate absolute address from relative
00F501  2  18                   CLC
00F502  2  69 01                ADC     #1              ; adjust address relative to next instruction
00F504  2  D0 01                BNE     RELEND          ; don't increment high byte unless we overflowed
00F506  2  E8                   INX                     ; increment high byte
00F507  2               RELEND:
00F507  2  4C 3B F6             JMP     WRADDR          ; print address
00F50A  2               
00F50A  2               UB64D:
00F50A  2  A6 C4                LDX     TMP2+1          ; get high byte of current address
00F50C  2  A8                   TAY                     ; is relative address positive or negative?
00F50D  2  10 01                BPL     RELC2           ; if positive, leave high byte alone
00F50F  2  CA                   DEX                     ; if negative, decrement high byte
00F510  2               RELC2:
00F510  2  65 C3                ADC     TMP2            ; add relative address to low byte
00F512  2  90 01                BCC     RELC3           ; if there's no carry, we're done
00F514  2  E8                   INX                     ; if there's a carry, increment the high byte
00F515  2               RELC3:
00F515  2  60                   RTS
00F516  2               
00F516  2               ; -----------------------------------------------------------------------------
00F516  2               ; get opcode mode and length
00F516  2               
00F516  2               ; Note: the labels are different, but the code of this subroutine is almost
00F516  2               ; identical to the INSDS2 subroutine of the Apple Mini-Assembler on page 78 of
00F516  2               ; the Apple II Red Book. I'm not sure exactly where this code originated
00F516  2               ; (MOS or Apple) but it's clear that this part of Supermon64 and the
00F516  2               ; Mini-Asssembler share a common heritage.  The comments showing the way the
00F516  2               ; opcodes are transformed into indexes for the mnemonic lookup table come
00F516  2               ; from the Mini-Assembler source.
00F516  2               
00F516  2               INSTXX:
00F516  2  A8                   TAY                     ; stash opcode in accumulator in Y for later
00F517  2  4A                   LSR     A               ; is opcode even or odd?
00F518  2  90 0B                BCC     IEVEN
00F51A  2  4A                   LSR     A
00F51B  2  B0 17                BCS     ERR             ; invalid opcodes XXXXXX11
00F51D  2  C9 22                CMP     #$22
00F51F  2  F0 13                BEQ     ERR             ; invalid opcode 10001001
00F521  2  29 07                AND     #$07            ; mask bits to 10000XXX
00F523  2  09 80                ORA     #$80
00F525  2               IEVEN:
00F525  2  4A                   LSR     A               ; LSB determines whether to use left/right nybble
00F526  2  AA                   TAX                     ; get format index using remaining high bytes
00F527  2  BD A8 F8             LDA     MODE,X
00F52A  2  B0 04                BCS     RTMODE          ; look at left or right nybble based on carry bit
00F52C  2  4A                   LSR     A               ; if carry = 0, use left nybble
00F52D  2  4A                   LSR     A
00F52E  2  4A                   LSR     A
00F52F  2  4A                   LSR     A
00F530  2               RTMODE:
00F530  2  29 0F                AND     #$0F            ; if carry = 1, use right nybble
00F532  2  D0 04                BNE     GETFMT
00F534  2               ERR:
00F534  2  A0 80                LDY     #$80            ; substitute 10000000 for invalid opcodes
00F536  2  A9 00                LDA     #0
00F538  2               GETFMT:
00F538  2  AA                   TAX
00F539  2  BD EC F8             LDA     MODE2,X         ; lookup operand format using selected nybble
00F53C  2  85 C5                STA     ACMD            ; save for later use
00F53E  2  29 03                AND     #$03            ; lower 2 bits indicate number of bytes in operand
00F540  2  85 C6                STA     LENGTH
00F542  2  98                   TYA                     ; restore original opcode
00F543  2  29 8F                AND     #$8F            ; mask bits to X000XXXX
00F545  2  AA                   TAX                     ; save it
00F546  2  98                   TYA                     ; restore original opcode
00F547  2  A0 03                LDY     #3
00F549  2  E0 8A                CPX     #$8A            ; check if opcode = 1XXX1010
00F54B  2  F0 0B                BEQ     GTFM4
00F54D  2               GTFM2:
00F54D  2  4A                   LSR     A               ; transform opcode into index for mnemonic table
00F54E  2  90 08                BCC     GTFM4
00F550  2  4A                   LSR     A               ; opcodes transformed as follows:
00F551  2               GTFM3:
00F551  2  4A                   LSR     A               ; 1XXX1010->00101XXX
00F552  2  09 20                ORA     #$20            ; XXXYYY01->00111XXX
00F554  2  88                   DEY                     ; XXXYYY10->00111XXX
00F555  2  D0 FA                BNE     GTFM3           ; XXXYY100->00110XXX
00F557  2  C8                   INY                     ; XXXXX000->000XXXXX
00F558  2               GTFM4:
00F558  2  88                   DEY
00F559  2  D0 F2                BNE     GTFM2
00F55B  2  60                   RTS
00F55C  2               
00F55C  2               ; -----------------------------------------------------------------------------
00F55C  2               ; extract and print packed mnemonics
00F55C  2               PROPXX:
00F55C  2  A8                   TAY                     ; use index in accumulator to look up mnemonic
00F55D  2  B9 06 F9             LDA     MNEML,Y         ;   and place a temporary copy in STORE
00F560  2  85 B7                STA     STORE
00F562  2  B9 46 F9             LDA     MNEMR,Y
00F565  2  85 B8                STA     STORE+1
00F567  2               PRMN1:
00F567  2  A9 00                LDA     #0              ; clear accumulator
00F569  2  A0 05                LDY     #$05            ; shift 5 times
00F56B  2               PRMN2:
00F56B  2  06 B8                ASL     STORE+1         ; shift right byte
00F56D  2  26 B7                ROL     STORE           ; rotate bits from right byte into left byte
00F56F  2  2A                   ROL     A               ; rotate bits from left byte into accumulator
00F570  2  88                   DEY                     ; next bit
00F571  2  D0 F8                BNE     PRMN2           ; loop until all bits shifted
00F573  2  69 3F                ADC     #$3F            ; calculate ascii code for letter by adding to '?'
00F575  2  20 53 FD             JSR     CHROUT          ; output letter
00F578  2  CA                   DEX                     ; next letter
00F579  2  D0 EC                BNE     PRMN1           ; loop until all 3 letters are output
00F57B  2  4C 44 F6             JMP     SPACE           ; output space
00F57E  2               
00F57E  2               ; -----------------------------------------------------------------------------
00F57E  2               ; read parameters
00F57E  2               RDPAR:
00F57E  2  C6 B9                DEC     CHRPNT          ; back up one char
00F580  2               GETPAR:
00F580  2  20 A5 F5             JSR     RDVAL           ; read the value
00F583  2  B0 15                BCS     GTERR           ; carry set indicates error
