0010DB  2               ;__MULTI IO DRIVERS______________________________________________________________________________________________________________
0010DB  2               ;
0010DB  2               ; 	DOS/65 ISA MULTI IO drivers for 6502PC
0010DB  2               ;
0010DB  2               ;	Entry points:
0010DB  2               ;		MULTIOINIT  - CALLED during OS init
0010DB  2               ;		KBD_GETKEY  - read a character from the ps/2 keyboard ('A' POINTS TO BYTE)
0010DB  2               ;		LPT_OUT	    - send a character to the printer
0010DB  2               ;________________________________________________________________________________________________________________________________
0010DB  2               ;
0010DB  2               ;*
0010DB  2               ;*        HARDWARE I/O ADDRESSES
0010DB  2               ;*
0010DB  2               ;
0010DB  2               MULTIO_BASE     = PC6502_IO+$3E0
0010DB  2               KBD_DAT         = MULTIO_BASE+$1E
0010DB  2               KBD_ST          = MULTIO_BASE+$1F
0010DB  2               KBD_CMD         = MULTIO_BASE+$1F
0010DB  2               
0010DB  2               LPT_0           = MULTIO_BASE+$10
0010DB  2               LPT_1           = MULTIO_BASE+$11
0010DB  2               LPT_2           = MULTIO_BASE+$12
0010DB  2               
0010DB  2               
0010DB  2               ;__________________________________________________________________________________________________
0010DB  2               ;
0010DB  2               ; STATUS BITS (FOR KBD_STATUS)
0010DB  2               ;
0010DB  2               KBD_EXT         = $01           ; BIT 0, EXTENDED SCANCODE ACTIVE
0010DB  2               KBD_BREAK       = $02           ; BIT 1, THIS IS A KEY UP (BREAK) EVENT
0010DB  2               KBD_KEYRDY      = $80           ; BIT 7, INDICATES A DECODED KEYCODE IS READY
0010DB  2               ;
0010DB  2               ; STATE BITS (FOR KBD_STATE, KBD_LSTATE, KBD_RSTATE)
0010DB  2               ;
0010DB  2               KBD_SHIFT       = $01           ; BIT 0, SHIFT ACTIVE (PRESSED)
0010DB  2               KBD_CTRL        = $02           ; BIT 1, CONTROL ACTIVE (PRESSED)
0010DB  2               KBD_ALT         = $04           ; BIT 2, ALT ACTIVE (PRESSED)
0010DB  2               KBD_WIN         = $08           ; BIT 3, WIN ACTIVE (PRESSED)
0010DB  2               KBD_SCRLCK      = $10           ; BIT 4, CAPS LOCK ACTIVE (TOGGLED ON)
0010DB  2               KBD_NUMLCK      = $20           ; BIT 5, NUM LOCK ACTIVE (TOGGLED ON)
0010DB  2               KBD_CAPSLCK     = $40           ; BIT 6, SCROLL LOCK ACTIVE (TOGGLED ON)
0010DB  2               KBD_NUMPAD      = $80           ; BIT 7, NUM PAD KEY (KEY PRESSED IS ON NUM PAD)
0010DB  2               NOT_KBD_NUMPAD  = $7F           ; BIT 7, NUM PAD KEY (KEY PRESSED IS ON NUM PAD)
0010DB  2               ;
0010DB  2               KBD_DEFRPT      = $40           ; DEFAULT REPEAT RATE (.5 SEC DELAY, 30CPS)
0010DB  2               KBD_DEFSTATE    = KBD_NUMLCK
0010DB  2               ;
0010DB  2               ; DEFAULT STATE (NUM LOCK ON)
0010DB  2               
0010DB  2               KBD_WAITTO      = $30FF         ; DEFAULT TIMEOUT
0010DB  2               LPT_WAITTO      = $30FF         ; DEFAULT TIMEOUT
0010DB  2               ;
0010DB  2               ;__________________________________________________________________________________________________
0010DB  2               ; DATA
0010DB  2               ;__________________________________________________________________________________________________
0010DB  2               ;
0010DB  2               TMPKEY:
0010DB  2  00                   .BYTE   0
0010DC  2               KBD_SCANCODE:
0010DC  2  00                   .BYTE   0               ; RAW SCANCODE
0010DD  2               KBD_KEYCODE:
0010DD  2  00                   .BYTE   0               ; RESULTANT KEYCODE AFTER DECODING
0010DE  2               KBD_STATE:
0010DE  2  20                   .BYTE   KBD_DEFSTATE    ; STATE BITS (SEE ABOVE)
0010DF  2               KBD_LSTATE:
0010DF  2  00                   .BYTE   0               ; STATE BITS FOR "LEFT" KEYS
0010E0  2               KBD_RSTATE:
0010E0  2  00                   .BYTE   0               ; STATE BITS FOR "RIGHT" KEYS
0010E1  2               KBD_STATUS:
0010E1  2  00                   .BYTE   0               ; CURRENT STATUS BITS (SEE ABOVE)
0010E2  2               KBD_REPEAT:
0010E2  2  40                   .BYTE   KBD_DEFRPT      ; CURRENT REPEAT RATE
0010E3  2               KBD_IDLE:
0010E3  2  00                   .BYTE   0               ; IDLE COUNT
0010E4  2               KBD_TEMP:
0010E4  2  00 00                .BYTE   0,0             ; WORKING STORAGE
