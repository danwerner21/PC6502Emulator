00107F  1               ;__WRSER1________________________________________________________________________________________________________________________
00107F  1               ;
00107F  1               ;	WRITE CHARACTER(A) TO UART
00107F  1               ;________________________________________________________________________________________________________________________________
00107F  1               ;
00107F  1               DFT_CONSOLE_OUT:
00107F  1               WRSER1:
00107F  1  48                   PHA
001080  1               WRSER1a:
001080  1  AD 85 EF             LDA     UART1STATUS     ; GET STATUS
001083  1  29 10                AND     #%00010000      ; IS TX READY
001085  1  F0 F9                BEQ     WRSER1a         ; NO, WAIT FOR IT
001087  1  68                   PLA
001088  1  8D 84 EF             STA     UART1DATA       ; WRITE DATA
00108B  1  60                   RTS
00108C  1               
00108C  1               ;------------------------------------------------------------------------
00108C  1               LFCR:
00108C  1  A9 0A                LDA     #10
00108E  1  20 7F 10             JSR     DFT_CONSOLE_OUT ; PRINT CHAR IN ACC
001091  1  A9 0D                LDA     #13
001093  1  20 7F 10             JSR     DFT_CONSOLE_OUT ; PRINT CHAR IN ACC
001096  1  60                   RTS
001097  1               
001097  1               ;__WRSTR_______________________________________________________
001097  1               ;
001097  1               ; OUTPUT THE STRING POINTED TO BY OUTSTR TO THE SCREEN
001097  1               ;
001097  1               ;______________________________________________________________
001097  1               WRSTR:
001097  1  A0 00                LDY     #$00            ; LOAD $00 INTO Y
001099  1               OUTSTRLP:
001099  1  B1 41                LDA     (STRPTR),Y      ; LOAD NEXT CHAR FROM STRING INTO ACC
00109B  1  C9 00                CMP     #$00            ; IS NULL?
00109D  1  F0 0C                BEQ     ENDOUTSTR       ; YES, END PRINT OUT
00109F  1  20 7F 10             JSR     DFT_CONSOLE_OUT ; PRINT CHAR IN ACC
0010A2  1  E6 41                INC     STRPTR
0010A4  1  D0 F3                BNE     OUTSTRLP
0010A6  1  E6 42                INC     STRPTR+1
0010A8  1  4C 99 10             JMP     OUTSTRLP        ; DO NEXT CHAR
0010AB  1               ENDOUTSTR:
0010AB  1  60                   RTS                     ; RETURN
0010AC  1               
0010AC  1               PRINT_BYTE:
0010AC  1  8E D1 10             STX     SAVX            ; save X
0010AF  1  20 BC 10             JSR     ASCTWO          ; get hex chars for byte in X (lower) and A (upper)
0010B2  1  20 7F 10             JSR     DFT_CONSOLE_OUT ; output upper nybble
0010B5  1  8A                   TXA                     ; transfer lower to A
0010B6  1  AE D1 10             LDX     SAVX            ; restore X
0010B9  1  4C 7F 10             JMP     DFT_CONSOLE_OUT ; output lower nybble
0010BC  1               ASCTWO:
0010BC  1  48                   PHA                     ; save byte
0010BD  1  20 C6 10             JSR     ASCII           ; do low nybble
0010C0  1  AA                   TAX                     ; save in X
0010C1  1  68                   PLA                     ; restore byte
0010C2  1  4A                   LSR     A               ; shift upper nybble down
0010C3  1  4A                   LSR     A
0010C4  1  4A                   LSR     A
0010C5  1  4A                   LSR     A
0010C6  1               ; convert low nybble in A to hex digit
0010C6  1               ASCII:
0010C6  1  29 0F                AND     #$0F            ; clear upper nibble
0010C8  1  C9 0A                CMP     #$0A            ; if less than A, skip next step
0010CA  1  90 02                BCC     ASC1
0010CC  1  69 06                ADC     #6              ; skip ascii chars between 9 and A
0010CE  1               ASC1:
0010CE  1  69 30                ADC     #$30            ; add ascii char 0 to value
0010D0  1  60                   RTS
0010D1  1               SAVX:
