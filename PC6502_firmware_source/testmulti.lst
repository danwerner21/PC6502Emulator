0016DA  2               ;
0016DA  2               ;
0016DA  2               ;__________________________________________________________________________________________________
0016DA  2               ; KEYCODE VALUES RETURNED BY THE DECODER
0016DA  2               ;__________________________________________________________________________________________________
0016DA  2               ;
0016DA  2               ; VALUES 0-127 ARE STANDARD ASCII, SPECIAL KEYS WILL HAVE THE FOLLOWING VALUES:
0016DA  2               ;
0016DA  2               ; F1		$E0
0016DA  2               ; F2		$E1
0016DA  2               ; F3		$E2
0016DA  2               ; F4		$E3
0016DA  2               ; F5		$E4
0016DA  2               ; F6		$E5
0016DA  2               ; F7		$E6
0016DA  2               ; F8		$E7
0016DA  2               ; F9		$E8
0016DA  2               ; F10		$E9
0016DA  2               ; F11		$EA
0016DA  2               ; F12		$EB
0016DA  2               ; SYSRQ		$EC
0016DA  2               ; PRTSC		$ED
0016DA  2               ; PAUSE		$EE
0016DA  2               ; APP		$EF
0016DA  2               ; INS		$F0
0016DA  2               ; DEL		$F1
0016DA  2               ; HOME		$F2
0016DA  2               ; END		$F3
0016DA  2               ; PGUP		$F4
0016DA  2               ; PGDN		$F5
0016DA  2               ; UP		$F6
0016DA  2               ; DOWN		$F7
0016DA  2               ; LEFT		$F8
0016DA  2               ; RIGHT		$F9
0016DA  2               ; POWER		$FA
0016DA  2               ; SLEEP		$FB
0016DA  2               ; WAKE		$FC
0016DA  2               ; BREAK		$FD
0016DA  2               ;___________________________________________________________________________________________________________________
0016DA  2               ;
0016DA  2               ; CENTRONICS (LPT) INTERFACE DRIVER
0016DA  2               ;___________________________________________________________________________________________________________________
0016DA  2               ;
0016DA  2               ; BYTE OUTPUT
0016DA  2               ;
0016DA  2               LPT_OUT:
0016DA  2  48                   PHA
0016DB  2  A2 FF                LDX     #<LPT_WAITTO
0016DD  2  A0 30                LDY     #>LPT_WAITTO
0016DF  2               :
0016DF  2  20 07 17             JSR     LPT_OST         ; READY TO SEND?
0016E2  2  D0 0D                BNE     :+              ; GO IF READY
0016E4  2  CA                   DEX
0016E5  2  E0 00                CPX     #$00
0016E7  2  D0 F6                BNE     :-              ; LOOP IF NOT READY
0016E9  2  88                   DEY
0016EA  2  C0 00                CPY     #$00
0016EC  2  D0 F1                BNE     :-              ; LOOP IF NOT READY
0016EE  2  68                   PLA
0016EF  2  38                   SEC                     ; SIGNAL ERROR
0016F0  2  60                   RTS
0016F1  2               :
0016F1  2  68                   PLA
0016F2  2  8D F0 E3             STA     LPT_0           ; OUTPUT TO PORT 0 (DATA)
0016F5  2  A9 0D                LDA     #%00001101      ; SELECT & STROBE, LEDS OFF
0016F7  2  8D F2 E3             STA     LPT_2           ; OUTPUT DATA TO PORT
0016FA  2  20 B6 14             JSR     DELAY
0016FD  2  A9 0C                LDA     #%00001100      ; SELECT, LEDS OFF
0016FF  2  8D F2 E3             STA     LPT_2           ; OUTPUT DATA TO PORT
001702  2  20 B6 14             JSR     DELAY
001705  2  18                   CLC
001706  2  60                   RTS
001707  2               ;
001707  2               ; OUTPUT STATUS
001707  2               ;
001707  2               LPT_OST:
001707  2  AD F1 E3             LDA     LPT_1           ; GET STATUS INFO
00170A  2  29 80                AND     #%10000000      ; ISOLATE /BUSY
00170C  2  60                   RTS                     ; DONE
00170D  2               
00170D  1               
