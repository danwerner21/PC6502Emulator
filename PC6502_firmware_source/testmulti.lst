0010E6  2               MULTIOINIT:
0010E6  2               ;
0010E6  2  20 8C 10             JSR     LFCR            ; AND CRLF
0010E9  2  A9 E4                LDA     #<MIOMESSAGE1   ;
0010EB  2  85 41                STA     STRPTR          ;
0010ED  2  A9 14                LDA     #>MIOMESSAGE1   ;
0010EF  2  85 42                STA     STRPTR+1        ;
0010F1  2  20 97 10             JSR     WRSTR           ; DO PROMPT
0010F4  2  20 8C 10             JSR     LFCR            ; AND CRLF
0010F7  2               ; KEYBOARD INITIALIZATION
0010F7  2  A9 D2                LDA     #<MESSAGE2      ;
0010F9  2  85 41                STA     STRPTR          ;
0010FB  2  A9 10                LDA     #>MESSAGE2      ;
0010FD  2  85 42                STA     STRPTR+1        ;
0010FF  2  20 97 10             JSR     WRSTR           ; DO PROMPT
001102  2  A9 E3                LDA     #>MULTIO_BASE   ; GET BASE PORT
001104  2  20 AC 10             JSR     PRINT_BYTE      ; PRINT BASE PORT
001107  2  A9 E0                LDA     #<MULTIO_BASE   ; GET BASE PORT
001109  2  20 AC 10             JSR     PRINT_BYTE      ; PRINT BASE PORT
00110C  2  20 8C 10             JSR     LFCR            ; AND CRLF
00110F  2               ;
00110F  2  20 36 11             JSR     KBD_PROBE       ; DETECT A KEYBOARD
001112  2               
001112  2               ; LPT INITIALIZATION ROUTINE
001112  2  A9 20                LDA     #<MIOMESSAGE5   ;
001114  2  85 41                STA     STRPTR          ;
001116  2  A9 15                LDA     #>MIOMESSAGE5   ;
001118  2  85 42                STA     STRPTR+1        ;
00111A  2  20 97 10             JSR     WRSTR           ; DO PROMPT
00111D  2  20 8C 10             JSR     LFCR            ; AND CRLF
001120  2               
001120  2  A9 00                LDA     #$00
001122  2  8D F0 E3             STA     LPT_0           ; PORT 0 (DATA)
001125  2  A9 08                LDA     #%00001000      ; SELECT AND ASSERT RESET, LEDS OFF
001127  2  8D F2 E3             STA     LPT_2           ; PORT 2 (STATUS)
00112A  2  20 C8 14             JSR     LDELAY          ; HALF SECOND DELAY
00112D  2  A9 0C                LDA     #%00001100      ; SELECT AND DEASSERT RESET, LEDS OFF
00112F  2  8D F2 E3             STA     LPT_2           ; PORT 2 (STATUS)
001132  2               ;
001132  2  18                   CLC                     ; SIGNAL SUCCESS
001133  2  60                   RTS                     ; RETURN
001134  2               :
001134  2  38                   SEC
001135  2  60                   RTS                     ; DONE
001136  2               
001136  2               
001136  2               KBD_PROBE:
001136  2               ;
001136  2  A9 AA                LDA     #$AA            ; CONTROLLER SELF TEST
001138  2  20 A7 11             JSR     KBD_PUTCMD      ; SEND IT
00113B  2  B0 19                BCS     KBD_TIMEOUT1
00113D  2  20 EF 11             JSR     KBD_GETDATA     ; CONTROLLER SHOULD RESPOND WITH $55 (ACK)
001140  2  B0 25                BCS     KBD_TIMEOUT2
001142  2               ;
001142  2  C9 55                CMP     #$55            ; IS IT THERE?
001144  2  F0 32                BEQ     :+              ; IF SO, CONTINUE
001146  2  A9 F2                LDA     #<MIOMESSAGE3   ;
001148  2  85 41                STA     STRPTR          ;
00114A  2  A9 14                LDA     #>MIOMESSAGE3   ;
00114C  2  85 42                STA     STRPTR+1        ;
00114E  2  20 97 10             JSR     WRSTR
001151  2  20 8C 10             JSR     LFCR            ; AND CRLF
001154  2               ;
001154  2               KBD_ERROR:
001154  2  38                   SEC                     ; SET ERROR
001155  2  60                   RTS                     ; BAIL OUT
001156  2               KBD_TIMEOUT1:
001156  2  A9 34                LDA     #<MIOMESSAGE6   ;
001158  2  85 41                STA     STRPTR          ;
00115A  2  A9 15                LDA     #>MIOMESSAGE6   ;
00115C  2  85 42                STA     STRPTR+1        ;
00115E  2  20 97 10             JSR     WRSTR
001161  2  20 8C 10             JSR     LFCR            ; AND CRLF
001164  2  4C 54 11             JMP     KBD_ERROR
001167  2               KBD_TIMEOUT2:
001167  2  A9 52                LDA     #<MIOMESSAGE7   ;
001169  2  85 41                STA     STRPTR          ;
00116B  2  A9 15                LDA     #>MIOMESSAGE7   ;
00116D  2  85 42                STA     STRPTR+1        ;
00116F  2  20 97 10             JSR     WRSTR
001172  2  20 8C 10             JSR     LFCR            ; AND CRLF
001175  2  4C 54 11             JMP     KBD_ERROR
001178  2               
001178  2               ;
001178  2               :
001178  2  A9 0C                LDA     #<MIOMESSAGE4   ;
00117A  2  85 41                STA     STRPTR          ;
00117C  2  A9 15                LDA     #>MIOMESSAGE4   ;
00117E  2  85 42                STA     STRPTR+1        ;
001180  2  20 97 10             JSR     WRSTR
001183  2  20 8C 10             JSR     LFCR            ; AND CRLF
001186  2               
001186  2               ;
001186  2  A9 60                LDA     #$60            ; SET COMMAND REGISTER
001188  2  20 A7 11             JSR     KBD_PUTCMD      ; SEND IT
00118B  2  B0 C7                BCS     KBD_ERROR
00118D  2  A9 20                LDA     #$20            ; XLAT DISABLED, MOUSE DISABLED, NO INTS
00118F  2  20 CB 11             JSR     KBD_PUTDATA     ; SEND IT
001192  2  B0 C0                BCS     KBD_ERROR
001194  2               
001194  2  20 EF 11             JSR     KBD_GETDATA     ; GOBBLE UP $AA FROM POWER UP, AS NEEDED
001197  2  B0 BB                BCS     KBD_ERROR
001199  2               
001199  2  20 2B 12             JSR     KBD_RESET       ; RESET THE KEYBOARD
00119C  2  20 C8 14             JSR     LDELAY          ; WAIT A BIT
00119F  2  20 4A 12             JSR     KBD_SETLEDS     ; UPDATE LEDS BASED ON CURRENT TOGGLE STATE BITS
0011A2  2  20 74 12             JSR     KBD_SETRPT      ; UPDATE REPEAT RATE BASED ON CURRENT SETTING
0011A5  2               
