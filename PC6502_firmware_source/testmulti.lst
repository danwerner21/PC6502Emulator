0011A6  2  60                   RTS
0011A7  2                       .ENDIF
0011A7  2                       .IFDEF  PC6502BIOS
0011A7  2               MULTIOINIT:
0011A7  2                       LDA     #$AA            ; CONTROLLER SELF TEST
0011A7  2                       JSR     KBD_PUTCMD      ; SEND IT
0011A7  2                       BCS     :+
0011A7  2                       JSR     KBD_GETDATA     ; CONTROLLER SHOULD RESPOND WITH $55 (ACK)
0011A7  2                       BCS     :+
0011A7  2               ;
0011A7  2                       CMP     #$55            ; IS IT THERE?
0011A7  2                       BNE     :+              ; IF SO, CONTINUE
0011A7  2                       LDA     #$60            ; SET COMMAND REGISTER
0011A7  2                       JSR     KBD_PUTCMD      ; SEND IT
0011A7  2                       BCS     :+
0011A7  2                       LDA     #$20            ; XLAT DISABLED, MOUSE DISABLED, NO INTS
0011A7  2                       JSR     KBD_PUTDATA     ; SEND IT
0011A7  2                       BCS     :+
0011A7  2               
0011A7  2                       JSR     KBD_GETDATA     ; GOBBLE UP $AA FROM POWER UP, AS NEEDED
0011A7  2                       BCS     :+
0011A7  2               
0011A7  2                       JSR     KBD_RESET       ; RESET THE KEYBOARD
0011A7  2                       JSR     LDELAY          ; WAIT A BIT
0011A7  2                       JSR     KBD_SETLEDS     ; UPDATE LEDS BASED ON CURRENT TOGGLE STATE BITS
0011A7  2                       JSR     KBD_SETRPT      ; UPDATE REPEAT RATE BASED ON CURRENT SETTING
0011A7  2               :
0011A7  2                       RTS
0011A7  2                       .ENDIF
0011A7  2               ;
0011A7  2               ;__________________________________________________________________________________________________
0011A7  2               ; HARDWARE INTERFACE
0011A7  2               ;__________________________________________________________________________________________________
0011A7  2               ;
0011A7  2               ;__________________________________________________________________________________________________
0011A7  2               KBD_PUTCMD:
0011A7  2               ; PUT A CMD BYTE FROM A TO THE KEYBOARD INTERFACE WITH TIMEOUT
0011A7  2               ;
0011A7  2  48                   PHA
0011A8  2  A2 FF                LDX     #<KBD_WAITTO    ; SETUP TO LOOP
0011AA  2  A0 30                LDY     #>KBD_WAITTO    ; SETUP TO LOOP
0011AC  2               KBD_PUTCMD0:
0011AC  2  AD FF E3             LDA     KBD_ST          ; STATUS PORT
0011AF  2  29 02                AND     #$02            ; ISOLATE EMPTY BIT
0011B1  2  C9 00                CMP     #$00
0011B3  2  F0 10                BEQ     KBD_PUTCMD1     ; EMPTY, GO TO WRITE
0011B5  2  20 B6 14             JSR     DELAY           ; WAIT A BIT
0011B8  2  CA                   DEX
0011B9  2  E0 00                CPX     #$00
0011BB  2  D0 EF                BNE     KBD_PUTCMD0     ; LOOP UNTIL COUNTER EXHAUSTED
0011BD  2  88                   DEY
0011BE  2  C0 00                CPY     #$00
0011C0  2  D0 EA                BNE     KBD_PUTCMD0     ; LOOP UNTIL COUNTER EXHAUSTED
0011C2  2  68                   PLA
0011C3  2  38                   SEC                     ; TIMED OUT
0011C4  2  60                   RTS
0011C5  2               KBD_PUTCMD1:
0011C5  2  68                   PLA
0011C6  2  8D FF E3             STA     KBD_CMD         ; WRITE TO COMMAND PORT
0011C9  2  18                   CLC                     ; SIGNAL SUCCESS
0011CA  2  60                   RTS
0011CB  2               ;
0011CB  2               ;__________________________________________________________________________________________________
0011CB  2               KBD_PUTDATA:
0011CB  2               ;
0011CB  2               ; PUT A DATA BYTE FROM A TO THE KEYBOARD INTERFACE WITH TIMEOUT
0011CB  2               ;
0011CB  2  48                   PHA
0011CC  2  A2 FF                LDX     #<KBD_WAITTO    ; SETUP TO LOOP
0011CE  2  A0 30                LDY     #>KBD_WAITTO    ; SETUP TO LOOP
0011D0  2               KBD_PUTDATA0:
0011D0  2  AD FF E3             LDA     KBD_ST          ; STATUS PORT
0011D3  2  29 02                AND     #$02            ; ISOLATE OUTPUT EMPTY BIT
0011D5  2  C9 00                CMP     #$00
0011D7  2  F0 10                BEQ     KBD_PUTDATA1    ; EMPTY, GO TO WRITE
0011D9  2  20 B6 14             JSR     DELAY           ; WAIT A BIT
0011DC  2  CA                   DEX
0011DD  2  E0 00                CPX     #$00
0011DF  2  D0 EF                BNE     KBD_PUTDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
0011E1  2  88                   DEY
0011E2  2  C0 00                CPY     #$00
0011E4  2  D0 EA                BNE     KBD_PUTDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
0011E6  2  68                   PLA
0011E7  2  38                   SEC                     ; TIMED OUT
0011E8  2  60                   RTS
0011E9  2               KBD_PUTDATA1:
0011E9  2  68                   PLA
0011EA  2  8D FE E3             STA     KBD_DAT         ; WRITE TO DATA PORT
0011ED  2  18                   CLC                     ; SIGNAL SUCCESS
0011EE  2  60                   RTS
0011EF  2               ;
0011EF  2               ;__________________________________________________________________________________________________
0011EF  2               KBD_GETDATA:
0011EF  2               ;
0011EF  2               ; GET A RAW DATA BYTE FROM KEYBOARD INTERFACE INTO A WITH TIMEOUT
0011EF  2               ;
0011EF  2  8A                   TXA
0011F0  2  48                   PHA
0011F1  2  98                   TYA
0011F2  2  48                   PHA
0011F3  2  A2 FF                LDX     #<KBD_WAITTO    ; SETUP TO LOOP
0011F5  2  A0 30                LDY     #>KBD_WAITTO    ; SETUP TO LOOP
0011F7  2               KBD_GETDATA0:
0011F7  2  AD FF E3             LDA     KBD_ST          ; GET STATUS PORT
0011FA  2  29 01                AND     #$01            ; ISOLATE INPUT PENDING BIT
0011FC  2  C9 00                CMP     #$00
0011FE  2  D0 15                BNE     KBD_GETDATA1    ; READY, GET DATA
001200  2  20 B6 14             JSR     DELAY           ; WAIT A BIT
001203  2  CA                   DEX
001204  2  E0 00                CPX     #$00
001206  2  D0 EF                BNE     KBD_GETDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
001208  2  88                   DEY
001209  2  C0 00                CPY     #$00
00120B  2  D0 EA                BNE     KBD_GETDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
00120D  2  68                   PLA
00120E  2  A8                   TAY
00120F  2  68                   PLA
001210  2  AA                   TAX
001211  2  A9 00                LDA     #$00
001213  2  38                   SEC                     ; NO DATA, RETURN ZERO
001214  2  60                   RTS
001215  2               KBD_GETDATA1:
001215  2  68                   PLA
001216  2  A8                   TAY
001217  2  68                   PLA
001218  2  AA                   TAX
001219  2               KBD_GETDATA1A:
001219  2  AD FE E3             LDA     KBD_DAT         ; GET DATA PORT
00121C  2  18                   CLC                     ; SET FLAGS
00121D  2  60                   RTS
00121E  2               ;
00121E  2               ;__________________________________________________________________________________________________
00121E  2               KBD_GETDATAX:
00121E  2               ;
00121E  2               ; GET A RAW DATA BYTE FROM KEYBOARD INTERFACE INTO A WITH NO TIMEOUT
00121E  2               ;
00121E  2  AD FF E3             LDA     KBD_ST          ; STATUS PORT
001221  2  29 01                AND     #$01            ; ISOLATE INPUT PENDING BIT
001223  2  C9 00                CMP     #$00
001225  2  D0 F2                BNE     KBD_GETDATA1A   ; BYTE PENDING, GO GET IT
001227  2  A9 00                LDA     #$00
001229  2  38                   SEC                     ; NO DATA, RETURN ZERO
00122A  2  60                   RTS
00122B  2               ;
00122B  2               ;__________________________________________________________________________________________________
00122B  2               ; RESET KEYBOARD
00122B  2               ;__________________________________________________________________________________________________
00122B  2               ;
00122B  2               KBD_RESET:
00122B  2  A9 FF                LDA     #$FF            ; RESET COMMAND
00122D  2  20 CB 11             JSR     KBD_PUTDATA     ; SEND IT
001230  2  20 EF 11             JSR     KBD_GETDATA     ; GET THE ACK
001233  2  A2 00                LDX     #$00            ; SETUP LOOP COUNTER
001235  2  A0 F1                LDY     #$F1            ; SETUP LOOP COUNTER
001237  2               KBD_RESET0:
001237  2  20 EF 11             JSR     KBD_GETDATA     ; TRY TO GET THE RESPONSE
00123A  2  90 0C                BCC     KBD_RESET1      ; GOT A BYTE?  IF SO, GET OUT OF LOOP
00123C  2  CA                   DEX
00123D  2  E0 00                CPX     #$00
00123F  2  D0 F6                BNE     KBD_RESET0      ; LOOP TILL COUNTER EXHAUSTED
001241  2  88                   DEY
001242  2  C0 00                CPY     #$00
001244  2  D0 F1                BNE     KBD_RESET0      ; LOOP TILL COUNTER EXHAUSTED
001246  2  38                   SEC                     ; SIGNAL FAILURE
001247  2  60                   RTS                     ; DONE
001248  2               KBD_RESET1:
001248  2  18                   CLC                     ; SIGNAL SUCCESS (RESPONSE IS IGNORED...)
001249  2  60                   RTS                     ; DONE
00124A  2               ;
00124A  2               ;__________________________________________________________________________________________________
00124A  2               ; UPDATE KEYBOARD LEDS BASED ON CURRENT TOGGLE FLAGS
00124A  2               ;__________________________________________________________________________________________________
00124A  2               ;
00124A  2               KBD_SETLEDS:
00124A  2  A9 ED                LDA     #$ED            ; SET/RESET LED'S COMMAND
00124C  2  20 CB 11             JSR     KBD_PUTDATA     ; SEND THE COMMAND
00124F  2  20 EF 11             JSR     KBD_GETDATA     ; READ THE RESPONSE
001252  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
001254  2  F0 02                BEQ     :+
001256  2               
001256  2  38                   SEC
001257  2  60                   RTS                     ; ABORT IF NO ACK
001258  2               :
001258  2  AD DE 10             LDA     KBD_STATE       ; LOAD THE STATE BYTE
00125B  2  6A                   ROR     A               ; ROTATE TOGGLE KEY BITS AS NEEDED
00125C  2  6A                   ROR     A
00125D  2  6A                   ROR     A
00125E  2  6A                   ROR     A
00125F  2  29 07                AND     #$07            ; CLEAR THE IRRELEVANT BITS
001261  2  20 CB 11             JSR     KBD_PUTDATA     ; SEND THE LED DATA
001264  2  20 EF 11             JSR     KBD_GETDATA     ; READ THE ACK
001267  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
001269  2  F0 02                BEQ     :+
00126B  2               
00126B  2  38                   SEC
00126C  2  60                   RTS                     ; ABORT IF NO ACK
00126D  2               :
00126D  2  A9 00                LDA     #$00            ; A=0
00126F  2  8D E1 10             STA     KBD_STATUS      ; CLEAR STATUS
001272  2  18                   CLC
001273  2  60                   RTS
001274  2               ;
001274  2               ;__________________________________________________________________________________________________
001274  2               ; UPDATE KEYBOARD REPEAT RATE BASED ON CURRENT SETTING
001274  2               ;__________________________________________________________________________________________________
001274  2               ;
001274  2               KBD_SETRPT:
001274  2  A9 F3                LDA     #$F3            ; COMMAND = SET TYPEMATIC RATE/DELAY
001276  2  20 CB 11             JSR     KBD_PUTDATA     ; SEND IT
001279  2  20 EF 11             JSR     KBD_GETDATA     ; GET THE ACK
00127C  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
00127E  2  F0 02                BEQ     :+
001280  2               
001280  2  38                   SEC
001281  2  60                   RTS                     ; ABORT IF NO ACK
001282  2               :
001282  2  AD E2 10             LDA     KBD_REPEAT      ; LOAD THE CURRENT RATE/DELAY BYTE
001285  2  20 CB 11             JSR     KBD_PUTDATA     ; SEND IT
001288  2  20 EF 11             JSR     KBD_GETDATA     ; GET THE ACK
00128B  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
00128D  2  F0 02                BEQ     :+
00128F  2               
00128F  2  38                   SEC
001290  2  60                   RTS                     ; ABORT IF NO ACK
001291  2               :
001291  2  18                   CLC
001292  2  60                   RTS
001293  2               
001293  2               ;__GETKEY__________________________________________________________________________________________
001293  2               ; Get char from Keyboard, return in A
001293  2               ;__________________________________________________________________________________________________
001293  2               KBD_GETKEY:
001293  2  20 D5 12             JSR     KBD_DECODE
001296  2  AD C7 16             LDA     KBD_BUFFERPTR   ; GET CURRENT BUFFER LEN
001299  2  C9 00                CMP     #$00
00129B  2  D0 04                BNE     :+
00129D  2  A9 FF                LDA     #$FF            ;
00129F  2  38                   SEC
0012A0  2  60                   RTS
0012A1  2               :
0012A1  2  8E CD 12             STX     TMPX
0012A4  2  AE C7 16             LDX     KBD_BUFFERPTR
0012A7  2  BD C8 16             LDA     KBD_BUFFER,X
0012AA  2  CE C7 16             DEC     KBD_BUFFERPTR
0012AD  2  AE CD 12             LDX     TMPX
0012B0  2  18                   CLC
0012B1  2  60                   RTS
0012B2  2               
0012B2  2               ;__GETKEYB_________________________________________________________________________________________
0012B2  2               ; Get char from Keyboard, return in A (blocking)
0012B2  2               ;__________________________________________________________________________________________________
0012B2  2               KBD_GETKEYB:
0012B2  2  20 D5 12             JSR     KBD_DECODE
0012B5  2  AD C7 16             LDA     KBD_BUFFERPTR   ; GET CURRENT BUFFER LEN
0012B8  2  C9 00                CMP     #$00
0012BA  2  F0 F6                BEQ     KBD_GETKEYB
0012BC  2               
0012BC  2  8E CD 12             STX     TMPX
0012BF  2  AE C7 16             LDX     KBD_BUFFERPTR
0012C2  2  BD C8 16             LDA     KBD_BUFFER,X
0012C5  2  CE C7 16             DEC     KBD_BUFFERPTR
0012C8  2  AE CD 12             LDX     TMPX
0012CB  2  18                   CLC
0012CC  2  60                   RTS
0012CD  2               TMPX:
0012CD  2  00                   .BYTE   00
0012CE  2               
0012CE  2               
0012CE  2               ;__GETSTATUS_______________________________________________________________________________________
0012CE  2               ; Get Keyboard status
0012CE  2               ;__________________________________________________________________________________________________
0012CE  2               KBD_GETSTATUS:
0012CE  2  20 D5 12             JSR     KBD_DECODE
0012D1  2  AD C7 16             LDA     KBD_BUFFERPTR   ; GET CURRENT BUFFER LEN
0012D4  2  60                   RTS
0012D5  2               
0012D5  2               
0012D5  2               ;
0012D5  2               ;__________________________________________________________________________________________________
0012D5  2               ; DECODING ENGINE
0012D5  2               ;__________________________________________________________________________________________________
0012D5  2               ;
0012D5  2               ;__________________________________________________________________________________________________
0012D5  2               KBD_DECODE:
0012D5  2               ;
0012D5  2               ;  RUN THE DECODING ENGINE UNTIL EITHER: 1) NO MORE SCANCODES ARE AVAILABLE
0012D5  2               ;  FROM THE KEYBOARD, OR 2) A DECODED KEY VALUE IS AVAILABLE
0012D5  2               ;
0012D5  2               ;  RETURNS A=0 AND Z SET IF NO KEYCODE READY, OTHERWISE A DECODED KEY VALUE IS AVAILABLE.
0012D5  2               ;  THE DECODED KEY VALUE AND KEY STATE IS STORED IN KBD_KEYCODE AND KBD_STATE.
0012D5  2               ;
0012D5  2               ;  KBD_STATUS IS NOT CLEARED AT START. IT IS THE JSR ER'S RESPONSIBILITY
0012D5  2               ;  TO CLEAR KBD_STATUS WHEN IT HAS RETRIEVED A PENDING VALUE.  IF DECODE IS JSR ED
0012D5  2               ;  WITH A KEYCODE STILL PENDING, IT WILL JUST RETURN WITHOUT DOING ANYTHING.
0012D5  2               ;
0012D5  2               ; Step 0: Check keycode buffer
0012D5  2               ;   if status[keyrdy]
0012D5  2               ;     return
0012D5  2               ;
0012D5  2               ; Step 1: Get scancode
0012D5  2               ;   if no scancode ready
0012D5  2               ;     return
0012D5  2               ;   read scancode
0012D5  2               ;
0012D5  2               ; Step 2: Detect and handle special keycodes
0012D5  2               ;   if scancode == $AA
0012D5  2               ;     *** handle hot insert somehow ***
0012D5  2               ;
0012D5  2               ; Step 3: Detect and handle scancode prefixes
0012D5  2               ;   if scancode == $E0
0012D5  2               ;     set status[extended]
0012D5  2               ;     goto Step 1
0012D5  2               ;
0012D5  2               ;   if scancode == $E1
0012D5  2               ;     *** handle pause key somehow ***
0012D5  2               ;
0012D5  2               ; Step 4: Detect and flag break event
0012D5  2               ;   *** scancode set #1 variation ***
0012D5  2               ;     set status[break] = high bit of scancode
0012D5  2               ;     clear high order bit
0012D5  2               ;     continue to Step 5
0012D5  2               ;   *** scancode set #2 variation ***
0012D5  2               ;     if scancode == $F0
0012D5  2               ;       set status[break]
0012D5  2               ;       goto Step 1
0012D5  2               ;
0012D5  2               ; Step 5: Map scancode to keycode
0012D5  2               ;   if status[extended]
0012D5  2               ;     apply extended-map[scancode] -> keycode
0012D5  2               ;   else if state[shifted]
0012D5  2               ;     apply shifted-map[scancode] -> keycode
0012D5  2               ;   else
0012D5  2               ;     apply normal-map[scancode] -> keycode
0012D5  2               ;
0012D5  2               ; Step 6: Handle modifier keys
0012D5  2               ;   if keycode is modifier (shift, ctrl, alt, win)
0012D5  2               ;     set (l/r)state[<modifier>] = not status[break]
0012D5  2               ;     clear modifier bits in state
0012D5  2               ;     set state = (lstate OR rstate OR state)
0012D5  2               ;     goto New Key
0012D5  2               ;
0012D5  2               ; Step 7: Complete procesing of key break events
0012D5  2               ;   if status[break]
0012D5  2               ;     goto New Key
0012D5  2               ;
0012D5  2               ; Step 8: Handle toggle keys
0012D5  2               ;   if keycode is toggle (capslock, numlock, scrolllock)
0012D5  2               ;     invert (XOR) state[<toggle>]
0012D5  2               ;     update keyboard LED's
0012D5  2               ;     goto New Key
0012D5  2               ;
0012D5  2               ; Step 9: Adjust keycode for control modifier
0012D5  2               ;   if state[ctrl]
0012D5  2               ;     if keycode is 'a'-'z'
0012D5  2               ;       subtract 20 (clear bit 5) from keycode
0012D5  2               ;     if keycode is '@'-'_'
0012D5  2               ;       subtract 40 (clear bit 6) from keycode
0012D5  2               ;
0012D5  2               ; Step 10: Adjust keycode for caps lock
0012D5  2               ;   if state[capslock]
0012D5  2               ;     if keycode is 'a'-'z' OR 'A'-'Z'
0012D5  2               ;       toggle (XOR) bit 5 of keycode
0012D5  2               ;
0012D5  2               ; Step 11: Handle num pad keys
0012D5  2               ;   clear state[numpad]
0012D5  2               ;   if keycode is numpad
0012D5  2               ;     set state[numpad]
0012D5  2               ;     if state[numlock]
0012D5  2               ;       toggle (XOR) bit 4 of keycode
0012D5  2               ;     apply numpad-map[keycode] -> keycode
0012D5  2               ;
0012D5  2               ; Step 12: Detect unknown/invalid keycodes
0012D5  2               ;   if keycode == $FF
0012D5  2               ;     goto New Key
0012D5  2               ;
0012D5  2               ; Step 13: Done
0012D5  2               ;   set status[keyrdy]
0012D5  2               ;   return
0012D5  2               ;
0012D5  2               ; New Key:
0012D5  2               ;   clear status
0012D5  2               ;   goto Step 1
0012D5  2               ;
0012D5  2               KBD_DEC0:                       ; CHECK KEYCODE BUFFER
0012D5  2               ;        LDA     KBD_STATUS      ; GET CURRENT STATUS
0012D5  2               ;        AND     #KBD_KEYRDY     ; ISOLATE KEY READY FLAG
0012D5  2               ;        BEQ     KBD_DEC1
0012D5  2               ;        SEC
0012D5  2               ;        RTS                     ; ABORT IF KEY IS ALREADY PENDING
0012D5  2               
0012D5  2               KBD_DEC1:                       ; PROCESS NEXT SCANCODE
0012D5  2  20 1E 12             JSR     KBD_GETDATAX    ; GET THE SCANCODE
0012D8  2  90 02                BCC     KBD_DEC2
0012DA  2  38                   SEC
0012DB  2  60                   RTS                     ; NO KEY READY, RETURN WITH A=0, SET ERROR
0012DC  2               
0012DC  2               KBD_DEC2:                       ; DETECT AND HANDLE SPECIAL KEYCODES
0012DC  2  8D DC 10             STA     KBD_SCANCODE    ; SAVE SCANCODE
0012DF  2  C9 AA                CMP     #$AA            ; KEYBOARD INSERTION?
0012E1  2  D0 12                BNE     KBD_DEC3        ; NOPE, BYPASS
0012E3  2  20 C8 14             JSR     LDELAY          ; WAIT A BIT
0012E6  2  20 2B 12             JSR     KBD_RESET       ; RESET KEYBOARD
0012E9  2  20 C8 14             JSR     LDELAY          ; WAIT A BIT
0012EC  2  20 4A 12             JSR     KBD_SETLEDS     ; SET LEDS
0012EF  2  20 74 12             JSR     KBD_SETRPT      ; SET REPEAT RATE
0012F2  2  4C AE 14             JMP     KBD_DECNEW      ; RESTART THE ENGINE
0012F5  2               
0012F5  2               KBD_DEC3:                       ; DETECT AND HANDLE SCANCODE PREFIXES
0012F5  2  C9 E0                CMP     #$E0            ; EXTENDED KEY PREFIX $E0?
0012F7  2  D0 0D                BNE     KBD_DEC3B       ; NOPE MOVE ON
0012F9  2  48                   PHA
0012FA  2  AD E1 10             LDA     KBD_STATUS      ; GET STATUS
0012FD  2  09 01                ORA     #KBD_EXT        ; SET EXTENDED BIT
0012FF  2  8D E1 10             STA     KBD_STATUS      ; SAVE STATUS
001302  2  68                   PLA
001303  2  4C D5 12             JMP     KBD_DEC1        ; LOOP TO DO NEXT SCANCODE
001306  2               
001306  2               KBD_DEC3B:                      ; HANDLE SCANCODE PREFIX $E1 (PAUSE KEY)
001306  2  C9 E1                CMP     #$E1            ; EXTENDED KEY PREFIX $E1
001308  2  D0 10                BNE     KBD_DEC4        ; NOPE MOVE ON
00130A  2  A9 EE                LDA     #$EE            ; MAP TO KEYCODE $EE
00130C  2  8D DD 10             STA     KBD_KEYCODE     ; SAVE IT
00130F  2               ; SWALLOW NEXT 7 SCANCODES
00130F  2  A2 07                LDX     #7              ; LOOP 7 TIMES
001311  2               KBD_DEC3B1:
001311  2  20 EF 11             JSR     KBD_GETDATA     ; RETRIEVE NEXT SCANCODE
001314  2  CA                   DEX
001315  2  D0 FA                BNE     KBD_DEC3B1      ; LOOP AS NEEDED
001317  2  4C 73 13             JMP     KBD_DEC6        ; RESUME AFTER MAPPING
00131A  2               
00131A  2               KBD_DEC4:                       ; DETECT AND FLAG BREAK EVENT
00131A  2  C9 F0                CMP     #$F0            ; BREAK (KEY UP) PREFIX?
00131C  2  D0 0D                BNE     KBD_DEC5        ; NOPE MOVE ON
00131E  2  48                   PHA
00131F  2  AD E1 10             LDA     KBD_STATUS      ; GET STATUS
001322  2  09 02                ORA     #KBD_BREAK      ; SET BREAK BIT
001324  2  8D E1 10             STA     KBD_STATUS      ; SAVE STATUS
001327  2  68                   PLA
001328  2  4C D5 12             JMP     KBD_DEC1        ; LOOP TO DO NEXT SCANCODE
00132B  2               
00132B  2               KBD_DEC5:                       ; MAP SCANCODE TO KEYCODE
00132B  2  AD E1 10             LDA     KBD_STATUS      ; GET STATUS
00132E  2  29 01                AND     #KBD_EXT        ; EXTENDED BIT SET?
001330  2  F0 1F                BEQ     KBD_DEC5C       ; NOPE, MOVE ON
001332  2               
001332  2               ; PERFORM EXTENDED KEY MAPPING
001332  2  A2 00                LDX     #$00             ; GET SCANCODE
001334  2               KBD_DEC5A:
001334  2  BD 79 16             LDA     KBD_MAPEXT,X    ; GET FIRST BYTE OF PAIR FROM EXT MAP TABLE
001337  2  E8                   INX
001338  2  C9 00                CMP     #$00            ; END OF TABLE?
00133A  2  F0 09                BEQ     :+              ; UNKNOWN OR BOGUS, START OVER
00133C  2  CD DC 10             CMP     KBD_SCANCODE    ; DOES MATCH BYTE EQUAL SCANCODE?
00133F  2  F0 07                BEQ     KBD_DEC5B       ; YES! JUMP OUT
001341  2  E8                   INX                     ; BUMP TO START OF NEXT PAIR
001342  2  4C 34 13             JMP     KBD_DEC5A       ; LOOP TO CHECK NEXT TABLE ENTRY
001345  2               :
001345  2  4C AE 14             JMP     KBD_DECNEW
001348  2               KBD_DEC5B:
001348  2  BD 79 16             LDA     KBD_MAPEXT,X    ; GET THE KEYCODE VIA MAPPING TABLE
00134B  2  8D DD 10             STA     KBD_KEYCODE     ; SAVE IT
00134E  2  4C 73 13             JMP     KBD_DEC6
001351  2               
001351  2               KBD_DEC5C:                      ; PERFORM REGULAR KEY (NOT EXTENDED) KEY MAPPING
001351  2  AD DC 10             LDA     KBD_SCANCODE    ; GET THE SCANCODE
001354  2  C9 85                CMP     #KBD_MAPSIZ     ; COMPARE TO SIZE OF TABLE
001356  2  F0 02                BEQ     :+
001358  2  B0 19                BCS     KBD_DEC6        ; PAST END, SKIP OVER LOOKUP
00135A  2               :
00135A  2               ; SETUP POINTER TO MAPPING TABLE BASED ON SHIFTED OR UNSHIFTED STATE
00135A  2  AD DE 10             LDA     KBD_STATE       ; GET STATE
00135D  2  29 01                AND     #KBD_SHIFT      ; SHIFT ACTIVE?
00135F  2  F0 09                BEQ     KBD_DEC5D       ; NON-SHIFTED, MOVE ON
001361  2               
001361  2  AE DC 10             LDX     KBD_SCANCODE    ; GET THE SCANCODE
001364  2  BD F4 15             LDA     KBD_MAPSHIFT,X  ; GET SHIFTED
001367  2  4C 70 13             JMP     :+
00136A  2               KBD_DEC5D:
00136A  2  AE DC 10             LDX     KBD_SCANCODE    ; GET THE SCANCODE
00136D  2  BD 6F 15             LDA     KBD_MAPSTD,X    ; GET STANDARD
001370  2               :
001370  2  8D DD 10             STA     KBD_KEYCODE     ; SAVE KEYCODE
001373  2               
001373  2               KBD_DEC6:                       ; HANDLE MODIFIER KEYS
001373  2  AD DD 10             LDA     KBD_KEYCODE     ; MAKE SURE WE HAVE KEYCODE
001376  2  C9 B8                CMP     #$B8            ; END OF MODIFIER KEYS
001378  2  B0 5F                BCS     KBD_DEC7        ; BYPASS MODIFIER KEY CHECKING
00137A  2  C9 B0                CMP     #$B0            ; START OF MODIFIER KEYS
00137C  2  90 5B                BCC     KBD_DEC7        ; BYPASS MODIFIER KEY CHECKING
00137E  2  A2 04                LDX     #4              ; LOOP COUNTER TO LOOP THRU 4 MODIFIER BITS
001380  2  38                   SEC
001381  2  E9 AF                SBC     #$AF            ; SETUP A TO DECREMENT THROUGH MODIFIER VALUES
001383  2  8D DB 10             STA     TMPKEY
001386  2  A9 00                LDA     #$00            ; SETUP A TO ROATE THROUGH MODIFIER STATE BITS
001388  2  38                   SEC                     ; SET CARRY FOR ROTATE
001389  2               
001389  2               KBD_DEC6A:
001389  2  2A                   ROL     A               ; SHIFT TO NEXT MODIFIER STATE BIT
00138A  2  CE DB 10             DEC     TMPKEY          ; L-MODIFIER?
00138D  2  F0 0B                BEQ     KBD_DEC6B       ; YES, HANDLE L-MODIFIER MAKE/BREAK
00138F  2  CE DB 10             DEC     TMPKEY          ; R-MODIFIER?
001392  2  F0 0B                BEQ     KBD_DEC6C       ; YES, HANDLE R-MODIFIER MAKE/BREAK
001394  2  CA                   DEX
001395  2  D0 F2                BNE     KBD_DEC6A       ; LOOP THRU 4 MODIFIER BITS
001397  2  4C D9 13             JMP     KBD_DEC7        ; FAILSAFE, SHOULD NEVER GET HERE!
00139A  2               
00139A  2               KBD_DEC6B:
00139A  2  A2 00                LDX     #0              ; POINT TO LEFT STATE BYTE
00139C  2  4C A1 13             JMP     KBD_DEC6D       ; CONTINUE
00139F  2               
00139F  2               KBD_DEC6C:
00139F  2  A2 01                LDX     #1              ; POINT TO RIGHT STATE BYTE
0013A1  2               
0013A1  2               KBD_DEC6D:                      ; BRANCH BASED ON WHETHER THIS IS A MAKE OR BREAK EVENT
0013A1  2  8D DB 10             STA     TMPKEY
0013A4  2  AD E1 10             LDA     KBD_STATUS      ; GET STATUS FLAGS
0013A7  2  29 02                AND     #KBD_BREAK      ; BREAK EVENT?
0013A9  2  F0 03                BEQ     KBD_DEC6E       ; NO, HANDLE A MODIFIER KEY MAKE EVENT
0013AB  2  4C BA 13             JMP     KBD_DEC6F       ; YES, HANDLE A MODIFIER BREAK EVENT
0013AE  2               
0013AE  2               KBD_DEC6E:                      ; HANDLE STATE KEY MAKE EVENT
0013AE  2  AD DB 10             LDA     TMPKEY
0013B1  2  1D DF 10             ORA     KBD_LSTATE,X    ; OR IN THE BIT TO SET
0013B4  2  9D DF 10             STA     KBD_LSTATE,X    ; SAVE THE RESULT
0013B7  2  4C C8 13             JMP     KBD_DEC6G       ; CONTINUE
0013BA  2               
0013BA  2               KBD_DEC6F:                      ; HANDLE STATE KEY BREAK EVENT
0013BA  2  AD DB 10             LDA     TMPKEY
0013BD  2  49 FF                EOR     #$FF            ; FLIP ALL BITS TO SETUP FOR A CLEAR OPERATION
0013BF  2  3D DF 10             AND     KBD_LSTATE,X    ; AND IN THE FLIPPED BITS TO CLEAR DESIRED BIT
0013C2  2  9D DF 10             STA     KBD_LSTATE,X    ; SAVE THE RESULT
0013C5  2  4C C8 13             JMP     KBD_DEC6G       ; CONTINUE
0013C8  2               
0013C8  2               KBD_DEC6G:                      ; COALESCE L/R STATE FLAGS
0013C8  2  AD DE 10             LDA     KBD_STATE       ; GET EXISTING STATE BITS
0013CB  2  29 F0                AND     #$F0            ; GET RID OF OLD MODIFIER BITS
0013CD  2  0D DF 10             ORA     KBD_LSTATE      ; MERGE IN LEFT STATE BITS
0013D0  2  0D E0 10             ORA     KBD_RSTATE      ; MERGE IN RIGHT STATE BITS
0013D3  2  8D DE 10             STA     KBD_STATE       ; SAVE IT
0013D6  2               :
0013D6  2  4C AE 14             JMP     KBD_DECNEW      ; DONE WITH CURRENT KEYSTROKE
0013D9  2               
0013D9  2               KBD_DEC7:                       ; COMPLETE PROCESSING OF EXTENDED AND KEY BREAK EVENTS
0013D9  2  AD E1 10             LDA     KBD_STATUS      ; GET CURRENT STATUS FLAGS
0013DC  2  29 02                AND     #KBD_BREAK      ; IS THIS A KEY BREAK EVENT?
0013DE  2  D0 F6                BNE     :-              ; PROCESS NEXT KEY
0013E0  2               
0013E0  2               KBD_DEC8:                       ; HANDLE TOGGLE KEYS
0013E0  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE INTO A
0013E3  2  A0 40                LDY     #KBD_CAPSLCK    ; SETUP E WITH CAPS LOCK STATE BIT
0013E5  2  C9 BC                CMP     #$BC            ; IS THIS THE CAPS LOCK KEY?
0013E7  2  F0 0F                BEQ     KBD_DEC8A       ; YES, GO TO BIT SET ROUTINE
0013E9  2  A0 20                LDY     #KBD_NUMLCK     ; SETUP E WITH NUM LOCK STATE BIT
0013EB  2  C9 BD                CMP     #$BD            ; IS THIS THE NUM LOCK KEY?
0013ED  2  F0 09                BEQ     KBD_DEC8A       ; YES, GO TO BIT SET ROUTINE
0013EF  2  A0 10                LDY     #KBD_SCRLCK     ; SETUP E WITH SCROLL LOCK STATE BIT
0013F1  2  C9 BE                CMP     #$BE            ; IS THIS THE SCROLL LOCK KEY?
0013F3  2  F0 03                BEQ     KBD_DEC8A       ; YES, GO TO BIT SET ROUTINE
0013F5  2  4C 05 14             JMP     KBD_DEC9        ; NOT A TOGGLE KEY, CONTINUE
0013F8  2               
0013F8  2               KBD_DEC8A:                      ; RECORD THE TOGGLE
0013F8  2  98                   TYA
0013F9  2  4D DE 10             EOR     KBD_STATE       ; SET THE TOGGLE KEY BIT FROM ABOVE
0013FC  2  8D DE 10             STA     KBD_STATE       ; SAVE IT
0013FF  2  20 4A 12             JSR     KBD_SETLEDS     ; UPDATE LED LIGHTS ON KBD
001402  2  4C AE 14             JMP     KBD_DECNEW      ; RESTART DECODER FOR A NEW KEY
001405  2               
001405  2               KBD_DEC9:                       ; ADJUST KEYCODE FOR CONTROL MODIFIER
001405  2  AD DE 10             LDA     KBD_STATE       ; GET THE CURRENT STATE BITS
001408  2  29 02                AND     #KBD_CTRL       ; CHECK THE CONTROL BIT
00140A  2  F0 1E                BEQ     KBD_DEC10       ; CONTROL KEY NOT PRESSED, MOVE ON
00140C  2  AD DD 10             LDA     KBD_KEYCODE     ; GET CURRENT KEYCODE IN A
00140F  2  C9 61                CMP     #'a'            ; COMPARE TO LOWERCASE A
001411  2  90 08                BCC     KBD_DEC9A       ; BELOW IT, BYPASS
001413  2  C9 7A                CMP     #'z'            ; COMPARE TO LOWERCASE Z+1
001415  2  F0 02                BEQ     :+
001417  2  B0 02                BCS     KBD_DEC9A       ; ABOVE IT, BYPASS
001419  2               :
001419  2  29 DF                AND     #$DF            ; KEYCODE IN LOWERCASE A-Z RANGE CLEAR BIT 5 TO MAKE IT UPPERCASE
00141B  2               KBD_DEC9A:
00141B  2  C9 40                CMP     #'@'            ; COMPARE TO @
00141D  2  90 0B                BCC     KBD_DEC10       ; BELOW IT, BYPASS
00141F  2  C9 5F                CMP     #'_'            ; COMPARE TO _+1
001421  2  F0 02                BEQ     :+
001423  2  B0 05                BCS     KBD_DEC10       ; ABOVE IT, BYPASS
001425  2               :
001425  2  29 BF                AND     #$BF            ; CONVERT TO CONTROL VALUE BY CLEARING BIT 6
001427  2  8D DD 10             STA     KBD_KEYCODE     ; UPDATE KEYCODE TO CONTROL VALUE
00142A  2               
00142A  2               KBD_DEC10:                      ; ADJUST KEYCODE FOR CAPS LOCK
00142A  2  AD DE 10             LDA     KBD_STATE       ; LOAD THE STATE FLAGS
00142D  2  29 40                AND     #KBD_CAPSLCK    ; CHECK CAPS LOCK
00142F  2  F0 25                BEQ     KBD_DEC11       ; CAPS LOCK NOT ACTIVE, MOVE ON
001431  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE VALUE
001434  2  C9 61                CMP     #'a'            ; COMPARE TO LOWERCASE A
001436  2  90 09                BCC     KBD_DEC10A      ; BELOW IT, BYPASS
001438  2  C9 7A                CMP     #'z'            ; COMPARE TO LOWERCASE Z+1
00143A  2  F0 02                BEQ     :+
00143C  2  B0 03                BCS     KBD_DEC10A      ; ABOVE IT, BYPASS
00143E  2               :
00143E  2  4C 4E 14             JMP     KBD_DEC10B      ; IN RANGE LOWERCASE A-Z, GO TO CASE SWAPPING LOGIC
001441  2               KBD_DEC10A:
001441  2  C9 41                CMP     #'A'            ; COMPARE TO UPPERCASE A
001443  2  90 11                BCC     KBD_DEC11       ; BELOW IT, BYPASS
001445  2  C9 5A                CMP     #'Z'            ; COMPARE TO UPPERCASE Z+1
001447  2  F0 02                BEQ     :+
001449  2  B0 0B                BCS     KBD_DEC11       ; ABOVE IT, BYPASS
00144B  2               :
00144B  2  4C 4E 14             JMP     KBD_DEC10B      ; IN RANGE UPPERCASE A-Z, GO TO CASE SWAPPING LOGIC
00144E  2               KBD_DEC10B:
00144E  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE
001451  2  49 20                EOR     #$20            ; FLIP BIT 5 TO SWAP UPPER/LOWER CASE
001453  2  8D DD 10             STA     KBD_KEYCODE     ; SAVE IT
001456  2               
001456  2               KBD_DEC11:                      ; HANDLE NUM PAD KEYS
001456  2  AD DE 10             LDA     KBD_STATE       ; GET THE CURRENT STATE FLAGS
001459  2  29 7F                AND     #NOT_KBD_NUMPAD ; ASSUME NOT A NUMPAD KEY, CLEAR THE NUMPAD BIT
00145B  2  8D DE 10             STA     KBD_STATE       ; SAVE IT
00145E  2               
00145E  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE
001461  2  29 E0                AND     #%11100000      ; ISOLATE TOP 3 BITS
001463  2  C9 C0                CMP     #%11000000      ; IS IN NUMPAD RANGE?
001465  2  D0 21                BNE     KBD_DEC12       ; NOPE, GET OUT
001467  2               
001467  2  AD DE 10             LDA     KBD_STATE       ; LOAD THE CURRENT STATE FLAGS
00146A  2  09 80                ORA     #KBD_NUMPAD     ; TURN ON THE NUMPAD BIT
00146C  2  8D DE 10             STA     KBD_STATE       ; SAVE IT
00146F  2               
00146F  2  29 20                AND     #KBD_NUMLCK     ; IS NUM LOCK BIT SET?
001471  2  F0 08                BEQ     KBD_DEC11A      ; NO, SKIP NUMLOCK PROCESSING
001473  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE KEYCODE
001476  2  49 10                EOR     #$10            ; FLIP VALUES FOR NUMLOCK
001478  2  8D DD 10             STA     KBD_KEYCODE     ; SAVE IT
00147B  2               
00147B  2               KBD_DEC11A:                     ; APPLY NUMPAD MAPPING
00147B  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE
00147E  2  38                   SEC
00147F  2  E9 C0                SBC     #$C0            ; KEYCODES START AT $C0
001481  2  AA                   TAX
001482  2  BD A7 16             LDA     KBD_MAPNUMPAD,X ; GET IT IN A
001485  2  8D DD 10             STA     KBD_KEYCODE     ; SAVE IT
001488  2               
001488  2               KBD_DEC12:                      ; DETECT UNKNOWN/INVALID KEYCODES
001488  2  AD DD 10             LDA     KBD_KEYCODE     ; GET THE FINAL KEYCODE
00148B  2  C9 FF                CMP     #$FF            ; IS IT $FF (UNKNOWN/INVALID)
00148D  2  F0 1F                BEQ     KBD_DECNEW      ; IF SO, JUST RESTART THE ENGINE
00148F  2               
00148F  2               KBD_DEC13:                      ; DONE - RECORD RESULTS INTO BUFFER
00148F  2  AE C7 16             LDX     KBD_BUFFERPTR
001492  2  E0 10                CPX     #16
001494  2  F0 16                BEQ     KBD_DEC13A
001496  2               :
001496  2  BD C8 16             LDA     KBD_BUFFER,X
001499  2  9D C9 16             STA     KBD_BUFFER+1,X
00149C  2  CA                   DEX
00149D  2  E0 FF                CPX     #$FF
00149F  2  D0 F5                BNE     :-
0014A1  2  AD DD 10             LDA     KBD_KEYCODE
0014A4  2  8D C9 16             STA     KBD_BUFFER+1
0014A7  2  EE C7 16             INC     KBD_BUFFERPTR
0014AA  2  A9 00                LDA     #$00            ; A=0
0014AC  2               KBD_DEC13A:
0014AC  2  18                   CLC                     ; SIGNAL SUCCESS WITH A=1, CARRY CLEAR
0014AD  2  60                   RTS
0014AE  2               
0014AE  2               KBD_DECNEW:                     ; START NEW KEYPRESS (CLEAR ALL STATUS BITS)
