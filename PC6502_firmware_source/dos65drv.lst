00D428  2               ;__SCROLLUP______________________________________________________________________________________________________________________
00D428  2               ;
00D428  2               ;	SCROLL THE SCREEN UP
00D428  2               ;
00D428  2               ;
00D428  2               ;________________________________________________________________________________________________________________________________
00D428  2               ;
00D428  2               SCROLLUP:
00D428  2  A9 B0                LDA     #$B0                    ; SCREEN MEMORY STARTS AT $B000
00D42A  2  85 3C                STA     TEMPWORD+1              ;
00D42C  2  85 3E                STA     TEMPWORD1+1             ;
00D42E  2  A9 B8                LDA     #$B8                    ; COLOR MEMORT STARTS AT $B800
00D430  2  85 40                STA     TEMPWORD2+1             ;
00D432  2  85 45                STA     TEMPWORD3+1             ;
00D434  2  A9 00                LDA     #$00                    ;
00D436  2  85 3B                STA     TEMPWORD                ;
00D438  2  85 3F                STA     TEMPWORD2               ;
00D43A  2               
00D43A  2  AD 4C 06             LDA     VIDEOMODE               ; 1=80 COL, 0=40 COL
00D43D  2  C9 01                CMP     #01
00D43F  2  D0 09                BNE     :+
00D441  2  A9 50                LDA     #80
00D443  2  85 3D                STA     TEMPWORD1
00D445  2  85 44                STA     TEMPWORD3
00D447  2  4C 50 D4             JMP     SCROLLUP_G
00D44A  2               :
00D44A  2  A9 28                LDA     #40
00D44C  2  85 3D                STA     TEMPWORD1
00D44E  2  85 44                STA     TEMPWORD3
00D450  2               
00D450  2               
00D450  2               SCROLLUP_G:
00D450  2  A0 00                LDY     #$00                    ; INDEX ALWAYS =0
00D452  2               ; SCROLL UP 40/80 CHARACTERS AND COLOR
00D452  2               SCROLLUP_G1:
00D452  2  B1 3D                LDA     (TEMPWORD1),Y           ; READ FROM SCREEN+X
00D454  2  91 3B                STA     (TEMPWORD),Y            ; WRITE TO SCREEN
00D456  2  B1 44                LDA     (TEMPWORD3),Y           ; READ FROM COLOR+X
00D458  2  91 3F                STA     (TEMPWORD2),Y           ; WRITE TO COLOR
00D45A  2               
00D45A  2  E6 3F                INC     TEMPWORD2
00D45C  2  D0 02                BNE     :+
00D45E  2  E6 40                INC     TEMPWORD2+1
00D460  2               :
00D460  2  E6 3B                INC     TEMPWORD
00D462  2  D0 02                BNE     :+
00D464  2  E6 3C                INC     TEMPWORD+1
00D466  2               :
