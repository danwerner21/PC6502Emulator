00D54E  1               ;__DFT_CONSOLE___________________________________________________________________________________________________________________
00D54E  1               ;
00D54E  1               ;	      TRANSFER CONSOLE COMMAND TO DESIGNATED CONSOLE
00D54E  1               ;________________________________________________________________________________________________________________________________
00D54E  1               DFT_CONSOLE:
00D54E  1  8D 60 D5             STA     drvtmp
00D551  1  A5 3A                LDA     CONSOLE
00D553  1  18                   CLC
00D554  1  65 32                ADC     farfunct
00D556  1  85 32                STA     farfunct
00D558  1  68                   PLA
00D559  1  68                   PLA
00D55A  1  AD 60 D5             LDA     drvtmp
00D55D  1  4C 00 C0             JMP     FUNCTION_DISPATCHER1
00D560  1               drvtmp:
00D560  1  00                   .BYTE   00
00D561  1               
00D561  1               drv_noop:
00D561  1  60                   RTS
00D562  1               
00D562  1               DFT_CONSOLE_OUT:
00D562  1  48                   PHA
00D563  1  A5 3A                LDA     CONSOLE
00D565  1  85 32                STA     farfunct
00D567  1  68                   PLA
00D568  1  4C 00 C0             JMP     FUNCTION_DISPATCHER1
00D56B  1               
00D56B  1               ;------------------------------------------------------------------------
00D56B  1               LFCR:
00D56B  1  A9 0A                LDA     #10
00D56D  1  20 62 D5             JSR     DFT_CONSOLE_OUT ; PRINT CHAR IN ACC
00D570  1  A9 0D                LDA     #13
00D572  1  20 62 D5             JSR     DFT_CONSOLE_OUT ; PRINT CHAR IN ACC
00D575  1  60                   RTS
00D576  1               
00D576  1               ;__WRSTR_______________________________________________________
00D576  1               ;
00D576  1               ; OUTPUT THE STRING POINTED TO BY OUTSTR TO THE SCREEN
00D576  1               ;
00D576  1               ;______________________________________________________________
00D576  1               WRSTR:
00D576  1  A0 00                LDY     #$00            ; LOAD $00 INTO Y
00D578  1               OUTSTRLP:
00D578  1  B1 41                LDA     (STRPTR),Y      ; LOAD NEXT CHAR FROM STRING INTO ACC
00D57A  1  C9 00                CMP     #$00            ; IS NULL?
00D57C  1  F0 0C                BEQ     ENDOUTSTR       ; YES, END PRINT OUT
00D57E  1  20 62 D5             JSR     DFT_CONSOLE_OUT ; PRINT CHAR IN ACC
00D581  1  E6 41                INC     STRPTR
00D583  1  D0 F3                BNE     OUTSTRLP
00D585  1  E6 42                INC     STRPTR+1
00D587  1  4C 78 D5             JMP     OUTSTRLP        ; DO NEXT CHAR
00D58A  1               ENDOUTSTR:
00D58A  1  60                   RTS                     ; RETURN
00D58B  1               
00D58B  1               PRINT_BYTE:
00D58B  1  8E B0 D5             STX     SAVX            ; save X
00D58E  1  20 9B D5             JSR     ASCTWO          ; get hex chars for byte in X (lower) and A (upper)
00D591  1  20 62 D5             JSR     DFT_CONSOLE_OUT ; output upper nybble
00D594  1  8A                   TXA                     ; transfer lower to A
00D595  1  AE B0 D5             LDX     SAVX            ; restore X
00D598  1  4C 62 D5             JMP     DFT_CONSOLE_OUT ; output lower nybble
00D59B  1               ASCTWO:
00D59B  1  48                   PHA                     ; save byte
00D59C  1  20 A5 D5             JSR     ASCII           ; do low nybble
00D59F  1  AA                   TAX                     ; save in X
00D5A0  1  68                   PLA                     ; restore byte
00D5A1  1  4A                   LSR     A               ; shift upper nybble down
00D5A2  1  4A                   LSR     A
00D5A3  1  4A                   LSR     A
00D5A4  1  4A                   LSR     A
00D5A5  1               ; convert low nybble in A to hex digit
00D5A5  1               ASCII:
00D5A5  1  29 0F                AND     #$0F            ; clear upper nibble
00D5A7  1  C9 0A                CMP     #$0A            ; if less than A, skip next step
00D5A9  1  90 02                BCC     ASC1
00D5AB  1  69 06                ADC     #6              ; skip ascii chars between 9 and A
00D5AD  1               ASC1:
00D5AD  1  69 30                ADC     #$30            ; add ascii char 0 to value
00D5AF  1  60                   RTS
00D5B0  1               SAVX:
00D5B0  1  00                   .BYTE   00
00D5B0  1               
