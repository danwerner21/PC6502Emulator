00D069  2               LPT_OUT:
00D069  2  48                   PHA
00D06A  2  A2 FF                LDX     #<LPT_WAITTO
00D06C  2  A0 30                LDY     #>LPT_WAITTO
00D06E  2               :
00D06E  2  20 96 D0             JSR     LPT_OST         ; READY TO SEND?
00D071  2  D0 0D                BNE     :+              ; GO IF READY
00D073  2  CA                   DEX
00D074  2  E0 00                CPX     #$00
00D076  2  D0 F6                BNE     :-              ; LOOP IF NOT READY
00D078  2  88                   DEY
00D079  2  C0 00                CPY     #$00
00D07B  2  D0 F1                BNE     :-              ; LOOP IF NOT READY
00D07D  2  68                   PLA
00D07E  2  38                   SEC                     ; SIGNAL ERROR
00D07F  2  60                   RTS
00D080  2               :
00D080  2  68                   PLA
00D081  2  8D F0 E3             STA     LPT_0           ; OUTPUT TO PORT 0 (DATA)
00D084  2  A9 0D                LDA     #%00001101      ; SELECT & STROBE, LEDS OFF
00D086  2  8D F2 E3             STA     LPT_2           ; OUTPUT DATA TO PORT
00D089  2  20 45 CE             JSR     DELAY
00D08C  2  A9 0C                LDA     #%00001100      ; SELECT, LEDS OFF
00D08E  2  8D F2 E3             STA     LPT_2           ; OUTPUT DATA TO PORT
00D091  2  20 45 CE             JSR     DELAY
00D094  2  18                   CLC
00D095  2  60                   RTS
00D096  2               ;
00D096  2               ; OUTPUT STATUS
00D096  2               ;
00D096  2               LPT_OST:
00D096  2  AD F1 E3             LDA     LPT_1           ; GET STATUS INFO
00D099  2  29 80                AND     #%10000000      ; ISOLATE /BUSY
00D09B  2  60                   RTS                     ; DONE
