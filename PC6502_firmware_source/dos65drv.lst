00C795  2               ;
00C795  2               ESP_BASE        = PC6502_IO+$100
00C795  2               ESP0_DAT        = ESP_BASE      ;
00C795  2               ESP1_DAT        = ESP_BASE+1    ;
00C795  2               ESP_STAT        = ESP_BASE+2    ;
