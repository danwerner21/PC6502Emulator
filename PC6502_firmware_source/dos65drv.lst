00CA6A  1                       .INCLUDE "bios_multi.asm"
00CA6A  2               ;__MULTI IO DRIVERS______________________________________________________________________________________________________________
00CA6A  2               ;
00CA6A  2               ; 	DOS/65 ISA MULTI IO drivers for 6502PC
00CA6A  2               ;
00CA6A  2               ;	Entry points:
00CA6A  2               ;		MULTIOINIT  - CALLED during OS init
00CA6A  2               ;		KBD_GETKEY  - read a character from the ps/2 keyboard ('A' POINTS TO BYTE)
00CA6A  2               ;		LPT_OUT	    - send a character to the printer
00CA6A  2               ;________________________________________________________________________________________________________________________________
00CA6A  2               ;
00CA6A  2               ;*
00CA6A  2               ;*        HARDWARE I/O ADDRESSES
00CA6A  2               ;*
00CA6A  2               ;
00CA6A  2               MULTIO_BASE     = PC6502_IO+$3E0
00CA6A  2               KBD_DAT         = MULTIO_BASE+$1E
00CA6A  2               KBD_ST          = MULTIO_BASE+$1F
00CA6A  2               KBD_CMD         = MULTIO_BASE+$1F
00CA6A  2               
00CA6A  2               LPT_0           = MULTIO_BASE+$10
00CA6A  2               LPT_1           = MULTIO_BASE+$11
00CA6A  2               LPT_2           = MULTIO_BASE+$12
00CA6A  2               
00CA6A  2               
00CA6A  2               ;__________________________________________________________________________________________________
00CA6A  2               ;
00CA6A  2               ; STATUS BITS (FOR KBD_STATUS)
00CA6A  2               ;
00CA6A  2               KBD_EXT         = $01           ; BIT 0, EXTENDED SCANCODE ACTIVE
00CA6A  2               KBD_BREAK       = $02           ; BIT 1, THIS IS A KEY UP (BREAK) EVENT
00CA6A  2               KBD_KEYRDY      = $80           ; BIT 7, INDICATES A DECODED KEYCODE IS READY
00CA6A  2               ;
00CA6A  2               ; STATE BITS (FOR KBD_STATE, KBD_LSTATE, KBD_RSTATE)
00CA6A  2               ;
00CA6A  2               KBD_SHIFT       = $01           ; BIT 0, SHIFT ACTIVE (PRESSED)
00CA6A  2               KBD_CTRL        = $02           ; BIT 1, CONTROL ACTIVE (PRESSED)
00CA6A  2               KBD_ALT         = $04           ; BIT 2, ALT ACTIVE (PRESSED)
00CA6A  2               KBD_WIN         = $08           ; BIT 3, WIN ACTIVE (PRESSED)
00CA6A  2               KBD_SCRLCK      = $10           ; BIT 4, CAPS LOCK ACTIVE (TOGGLED ON)
00CA6A  2               KBD_NUMLCK      = $20           ; BIT 5, NUM LOCK ACTIVE (TOGGLED ON)
00CA6A  2               KBD_CAPSLCK     = $40           ; BIT 6, SCROLL LOCK ACTIVE (TOGGLED ON)
00CA6A  2               KBD_NUMPAD      = $80           ; BIT 7, NUM PAD KEY (KEY PRESSED IS ON NUM PAD)
00CA6A  2               NOT_KBD_NUMPAD  = $7F           ; BIT 7, NUM PAD KEY (KEY PRESSED IS ON NUM PAD)
00CA6A  2               ;
00CA6A  2               KBD_DEFRPT      = $40           ; DEFAULT REPEAT RATE (.5 SEC DELAY, 30CPS)
00CA6A  2               KBD_DEFSTATE    = KBD_NUMLCK
00CA6A  2               ;
00CA6A  2               ; DEFAULT STATE (NUM LOCK ON)
00CA6A  2               
00CA6A  2               KBD_WAITTO      = $30FF         ; DEFAULT TIMEOUT
00CA6A  2               LPT_WAITTO      = $30FF         ; DEFAULT TIMEOUT
00CA6A  2               ;
00CA6A  2               ;__________________________________________________________________________________________________
00CA6A  2               ; DATA
00CA6A  2               ;__________________________________________________________________________________________________
00CA6A  2               ;
00CA6A  2               TMPKEY:
00CA6A  2  00                   .BYTE   0
00CA6B  2               KBD_SCANCODE:
00CA6B  2  00                   .BYTE   0               ; RAW SCANCODE
00CA6C  2               KBD_KEYCODE:
00CA6C  2  00                   .BYTE   0               ; RESULTANT KEYCODE AFTER DECODING
00CA6D  2               KBD_STATE:
00CA6D  2  20                   .BYTE   KBD_DEFSTATE    ; STATE BITS (SEE ABOVE)
00CA6E  2               KBD_LSTATE:
00CA6E  2  00                   .BYTE   0               ; STATE BITS FOR "LEFT" KEYS
00CA6F  2               KBD_RSTATE:
00CA6F  2  00                   .BYTE   0               ; STATE BITS FOR "RIGHT" KEYS
00CA70  2               KBD_STATUS:
00CA70  2  00                   .BYTE   0               ; CURRENT STATUS BITS (SEE ABOVE)
00CA71  2               KBD_REPEAT:
00CA71  2  40                   .BYTE   KBD_DEFRPT      ; CURRENT REPEAT RATE
00CA72  2               KBD_IDLE:
00CA72  2  00                   .BYTE   0               ; IDLE COUNT
00CA73  2               KBD_TEMP:
00CA73  2  00 00                .BYTE   0,0             ; WORKING STORAGE
00CA75  2               
00CA75  2               ;
00CA75  2               ;  IBM PC STANDARD PARALLEL PORT (SPP):
00CA75  2               ;
00CA75  2               ;  PORT 0 (OUTPUT):
00CA75  2               ;
00CA75  2               ;	D7	D6	D5	D4	D3	D2	D1	D0
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;     | PD7   | PD6   | PD5   | PD4   | PD3   | PD2   | PD1   | PD0   |
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;
00CA75  2               ;  PORT 1 (INPUT):
00CA75  2               ;
00CA75  2               ;	D7	D6	D5	D4	D3	D2	D1	D0
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;     | /BUSY | /ACK  | POUT  | SEL   | /ERR  | 0     | 0     | 0     |
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;
00CA75  2               ;  PORT 2 (OUTPUT):
00CA75  2               ;
00CA75  2               ;	D7	D6	D5	D4	D3	D2	D1	D0
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;     | STAT1 | STAT0 | ENBL  | PINT  | SEL   | RES   | LF    | STB   |
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;
00CA75  2               ;
00CA75  2               ;
00CA75  2               ;
00CA75  2               ;  IEC PORT (OUTPUT):
00CA75  2               ;
00CA75  2               ;	D7	D6	D5	D4	D3	D2	D1	D0
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;     | 0     | 0     | 0     | 0     | 0     | SERDTA| SERCLK| SERATN|
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;
00CA75  2               ;  IEC PORT (OUTPUT):
00CA75  2               ;
00CA75  2               ;	D7	D6	D5	D4	D3	D2	D1	D0
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;     | 0     | 0     | 0     | 0     | 0     | 0     | SERDTA| SERCLK|
00CA75  2               ;     +-------+-------+-------+-------+-------+-------+-------+-------+
00CA75  2               ;
00CA75  2               
00CA75  2                       .IFNDEF PC6502BIOS
00CA75  2               ;__________________________________________________________________________________________________
00CA75  2               ; MULTI IO INITIALIZATION
00CA75  2               ;__________________________________________________________________________________________________
00CA75  2               ;
00CA75  2               MULTIOINIT:
00CA75  2               ;
00CA75  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CA78  2  A9 73                LDA     #<MIOMESSAGE1   ;
00CA7A  2  85 41                STA     STRPTR          ;
00CA7C  2  A9 CE                LDA     #>MIOMESSAGE1   ;
00CA7E  2  85 42                STA     STRPTR+1        ;
00CA80  2  20 76 D5             JSR     WRSTR           ; DO PROMPT
00CA83  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CA86  2               ; KEYBOARD INITIALIZATION
00CA86  2  A9 55                LDA     #<MESSAGE2      ;
00CA88  2  85 41                STA     STRPTR          ;
00CA8A  2  A9 C3                LDA     #>MESSAGE2      ;
00CA8C  2  85 42                STA     STRPTR+1        ;
00CA8E  2  20 76 D5             JSR     WRSTR           ; DO PROMPT
00CA91  2  A9 E3                LDA     #>MULTIO_BASE   ; GET BASE PORT
00CA93  2  20 8B D5             JSR     PRINT_BYTE      ; PRINT BASE PORT
00CA96  2  A9 E0                LDA     #<MULTIO_BASE   ; GET BASE PORT
00CA98  2  20 8B D5             JSR     PRINT_BYTE      ; PRINT BASE PORT
00CA9B  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CA9E  2               ;
00CA9E  2  20 C5 CA             JSR     KBD_PROBE       ; DETECT A KEYBOARD
00CAA1  2               
00CAA1  2               ; LPT INITIALIZATION ROUTINE
00CAA1  2  A9 AF                LDA     #<MIOMESSAGE5   ;
00CAA3  2  85 41                STA     STRPTR          ;
00CAA5  2  A9 CE                LDA     #>MIOMESSAGE5   ;
00CAA7  2  85 42                STA     STRPTR+1        ;
00CAA9  2  20 76 D5             JSR     WRSTR           ; DO PROMPT
00CAAC  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CAAF  2               
00CAAF  2  A9 00                LDA     #$00
00CAB1  2  8D F0 E3             STA     LPT_0           ; PORT 0 (DATA)
00CAB4  2  A9 08                LDA     #%00001000      ; SELECT AND ASSERT RESET, LEDS OFF
00CAB6  2  8D F2 E3             STA     LPT_2           ; PORT 2 (STATUS)
00CAB9  2  20 57 CE             JSR     LDELAY          ; HALF SECOND DELAY
00CABC  2  A9 0C                LDA     #%00001100      ; SELECT AND DEASSERT RESET, LEDS OFF
00CABE  2  8D F2 E3             STA     LPT_2           ; PORT 2 (STATUS)
00CAC1  2               ;
00CAC1  2  18                   CLC                     ; SIGNAL SUCCESS
00CAC2  2  60                   RTS                     ; RETURN
00CAC3  2               :
00CAC3  2  38                   SEC
00CAC4  2  60                   RTS                     ; DONE
00CAC5  2               
00CAC5  2               
00CAC5  2               KBD_PROBE:
00CAC5  2               ;
00CAC5  2  A9 AA                LDA     #$AA            ; CONTROLLER SELF TEST
00CAC7  2  20 36 CB             JSR     KBD_PUTCMD      ; SEND IT
00CACA  2  B0 19                BCS     KBD_TIMEOUT1
00CACC  2  20 7E CB             JSR     KBD_GETDATA     ; CONTROLLER SHOULD RESPOND WITH $55 (ACK)
00CACF  2  B0 25                BCS     KBD_TIMEOUT2
00CAD1  2               ;
00CAD1  2  C9 55                CMP     #$55            ; IS IT THERE?
00CAD3  2  F0 32                BEQ     :+              ; IF SO, CONTINUE
00CAD5  2  A9 81                LDA     #<MIOMESSAGE3   ;
00CAD7  2  85 41                STA     STRPTR          ;
00CAD9  2  A9 CE                LDA     #>MIOMESSAGE3   ;
00CADB  2  85 42                STA     STRPTR+1        ;
00CADD  2  20 76 D5             JSR     WRSTR
00CAE0  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CAE3  2               ;
00CAE3  2               KBD_ERROR:
00CAE3  2  38                   SEC                     ; SET ERROR
00CAE4  2  60                   RTS                     ; BAIL OUT
00CAE5  2               KBD_TIMEOUT1:
00CAE5  2  A9 C3                LDA     #<MIOMESSAGE6   ;
00CAE7  2  85 41                STA     STRPTR          ;
00CAE9  2  A9 CE                LDA     #>MIOMESSAGE6   ;
00CAEB  2  85 42                STA     STRPTR+1        ;
00CAED  2  20 76 D5             JSR     WRSTR
00CAF0  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CAF3  2  4C E3 CA             JMP     KBD_ERROR
00CAF6  2               KBD_TIMEOUT2:
00CAF6  2  A9 E1                LDA     #<MIOMESSAGE7   ;
00CAF8  2  85 41                STA     STRPTR          ;
00CAFA  2  A9 CE                LDA     #>MIOMESSAGE7   ;
00CAFC  2  85 42                STA     STRPTR+1        ;
00CAFE  2  20 76 D5             JSR     WRSTR
00CB01  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CB04  2  4C E3 CA             JMP     KBD_ERROR
00CB07  2               
00CB07  2               ;
00CB07  2               :
00CB07  2  A9 9B                LDA     #<MIOMESSAGE4   ;
00CB09  2  85 41                STA     STRPTR          ;
00CB0B  2  A9 CE                LDA     #>MIOMESSAGE4   ;
00CB0D  2  85 42                STA     STRPTR+1        ;
00CB0F  2  20 76 D5             JSR     WRSTR
00CB12  2  20 6B D5             JSR     LFCR            ; AND CRLF
00CB15  2               
00CB15  2               ;
00CB15  2  A9 60                LDA     #$60            ; SET COMMAND REGISTER
00CB17  2  20 36 CB             JSR     KBD_PUTCMD      ; SEND IT
00CB1A  2  B0 C7                BCS     KBD_ERROR
00CB1C  2  A9 20                LDA     #$20            ; XLAT DISABLED, MOUSE DISABLED, NO INTS
00CB1E  2  20 5A CB             JSR     KBD_PUTDATA     ; SEND IT
00CB21  2  B0 C0                BCS     KBD_ERROR
00CB23  2               
00CB23  2  20 7E CB             JSR     KBD_GETDATA     ; GOBBLE UP $AA FROM POWER UP, AS NEEDED
00CB26  2  B0 BB                BCS     KBD_ERROR
00CB28  2               
00CB28  2  20 BA CB             JSR     KBD_RESET       ; RESET THE KEYBOARD
00CB2B  2  20 57 CE             JSR     LDELAY          ; WAIT A BIT
00CB2E  2  20 D9 CB             JSR     KBD_SETLEDS     ; UPDATE LEDS BASED ON CURRENT TOGGLE STATE BITS
00CB31  2  20 03 CC             JSR     KBD_SETRPT      ; UPDATE REPEAT RATE BASED ON CURRENT SETTING
00CB34  2               
00CB34  2  18                   CLC                     ; SIGNAL SUCCESS
00CB35  2  60                   RTS
00CB36  2                       .ENDIF
00CB36  2                       .IFDEF  PC6502BIOS
00CB36  2               MULTIOINIT:
00CB36  2                       LDA     #$AA            ; CONTROLLER SELF TEST
00CB36  2                       JSR     KBD_PUTCMD      ; SEND IT
00CB36  2                       BCS     :+
00CB36  2                       JSR     KBD_GETDATA     ; CONTROLLER SHOULD RESPOND WITH $55 (ACK)
00CB36  2                       BCS     :+
00CB36  2               ;
00CB36  2                       CMP     #$55            ; IS IT THERE?
00CB36  2                       BNE     :+              ; IF SO, CONTINUE
00CB36  2                       LDA     #$60            ; SET COMMAND REGISTER
00CB36  2                       JSR     KBD_PUTCMD      ; SEND IT
00CB36  2                       BCS     :+
00CB36  2                       LDA     #$20            ; XLAT DISABLED, MOUSE DISABLED, NO INTS
00CB36  2                       JSR     KBD_PUTDATA     ; SEND IT
00CB36  2                       BCS     :+
00CB36  2               
00CB36  2                       JSR     KBD_GETDATA     ; GOBBLE UP $AA FROM POWER UP, AS NEEDED
00CB36  2                       BCS     :+
00CB36  2               
00CB36  2                       JSR     KBD_RESET       ; RESET THE KEYBOARD
00CB36  2                       JSR     LDELAY          ; WAIT A BIT
00CB36  2                       JSR     KBD_SETLEDS     ; UPDATE LEDS BASED ON CURRENT TOGGLE STATE BITS
00CB36  2                       JSR     KBD_SETRPT      ; UPDATE REPEAT RATE BASED ON CURRENT SETTING
00CB36  2               :
00CB36  2                       RTS
00CB36  2                       .ENDIF
00CB36  2               ;
00CB36  2               ;__________________________________________________________________________________________________
00CB36  2               ; HARDWARE INTERFACE
00CB36  2               ;__________________________________________________________________________________________________
00CB36  2               ;
00CB36  2               ;__________________________________________________________________________________________________
00CB36  2               KBD_PUTCMD:
00CB36  2               ; PUT A CMD BYTE FROM A TO THE KEYBOARD INTERFACE WITH TIMEOUT
00CB36  2               ;
00CB36  2  48                   PHA
00CB37  2  A2 FF                LDX     #<KBD_WAITTO    ; SETUP TO LOOP
00CB39  2  A0 30                LDY     #>KBD_WAITTO    ; SETUP TO LOOP
00CB3B  2               KBD_PUTCMD0:
00CB3B  2  AD FF E3             LDA     KBD_ST          ; STATUS PORT
00CB3E  2  29 02                AND     #$02            ; ISOLATE EMPTY BIT
00CB40  2  C9 00                CMP     #$00
00CB42  2  F0 10                BEQ     KBD_PUTCMD1     ; EMPTY, GO TO WRITE
00CB44  2  20 45 CE             JSR     DELAY           ; WAIT A BIT
00CB47  2  CA                   DEX
00CB48  2  E0 00                CPX     #$00
00CB4A  2  D0 EF                BNE     KBD_PUTCMD0     ; LOOP UNTIL COUNTER EXHAUSTED
00CB4C  2  88                   DEY
00CB4D  2  C0 00                CPY     #$00
00CB4F  2  D0 EA                BNE     KBD_PUTCMD0     ; LOOP UNTIL COUNTER EXHAUSTED
00CB51  2  68                   PLA
00CB52  2  38                   SEC                     ; TIMED OUT
00CB53  2  60                   RTS
00CB54  2               KBD_PUTCMD1:
00CB54  2  68                   PLA
00CB55  2  8D FF E3             STA     KBD_CMD         ; WRITE TO COMMAND PORT
00CB58  2  18                   CLC                     ; SIGNAL SUCCESS
00CB59  2  60                   RTS
00CB5A  2               ;
00CB5A  2               ;__________________________________________________________________________________________________
00CB5A  2               KBD_PUTDATA:
00CB5A  2               ;
00CB5A  2               ; PUT A DATA BYTE FROM A TO THE KEYBOARD INTERFACE WITH TIMEOUT
00CB5A  2               ;
00CB5A  2  48                   PHA
00CB5B  2  A2 FF                LDX     #<KBD_WAITTO    ; SETUP TO LOOP
00CB5D  2  A0 30                LDY     #>KBD_WAITTO    ; SETUP TO LOOP
00CB5F  2               KBD_PUTDATA0:
00CB5F  2  AD FF E3             LDA     KBD_ST          ; STATUS PORT
00CB62  2  29 02                AND     #$02            ; ISOLATE OUTPUT EMPTY BIT
00CB64  2  C9 00                CMP     #$00
00CB66  2  F0 10                BEQ     KBD_PUTDATA1    ; EMPTY, GO TO WRITE
00CB68  2  20 45 CE             JSR     DELAY           ; WAIT A BIT
00CB6B  2  CA                   DEX
00CB6C  2  E0 00                CPX     #$00
00CB6E  2  D0 EF                BNE     KBD_PUTDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
00CB70  2  88                   DEY
00CB71  2  C0 00                CPY     #$00
00CB73  2  D0 EA                BNE     KBD_PUTDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
00CB75  2  68                   PLA
00CB76  2  38                   SEC                     ; TIMED OUT
00CB77  2  60                   RTS
00CB78  2               KBD_PUTDATA1:
00CB78  2  68                   PLA
00CB79  2  8D FE E3             STA     KBD_DAT         ; WRITE TO DATA PORT
00CB7C  2  18                   CLC                     ; SIGNAL SUCCESS
00CB7D  2  60                   RTS
00CB7E  2               ;
00CB7E  2               ;__________________________________________________________________________________________________
00CB7E  2               KBD_GETDATA:
00CB7E  2               ;
00CB7E  2               ; GET A RAW DATA BYTE FROM KEYBOARD INTERFACE INTO A WITH TIMEOUT
00CB7E  2               ;
00CB7E  2  8A                   TXA
00CB7F  2  48                   PHA
00CB80  2  98                   TYA
00CB81  2  48                   PHA
00CB82  2  A2 FF                LDX     #<KBD_WAITTO    ; SETUP TO LOOP
00CB84  2  A0 30                LDY     #>KBD_WAITTO    ; SETUP TO LOOP
00CB86  2               KBD_GETDATA0:
00CB86  2  AD FF E3             LDA     KBD_ST          ; GET STATUS PORT
00CB89  2  29 01                AND     #$01            ; ISOLATE INPUT PENDING BIT
00CB8B  2  C9 00                CMP     #$00
00CB8D  2  D0 15                BNE     KBD_GETDATA1    ; READY, GET DATA
00CB8F  2  20 45 CE             JSR     DELAY           ; WAIT A BIT
00CB92  2  CA                   DEX
00CB93  2  E0 00                CPX     #$00
00CB95  2  D0 EF                BNE     KBD_GETDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
00CB97  2  88                   DEY
00CB98  2  C0 00                CPY     #$00
00CB9A  2  D0 EA                BNE     KBD_GETDATA0    ; LOOP UNTIL COUNTER EXHAUSTED
00CB9C  2  68                   PLA
00CB9D  2  A8                   TAY
00CB9E  2  68                   PLA
00CB9F  2  AA                   TAX
00CBA0  2  A9 00                LDA     #$00
00CBA2  2  38                   SEC                     ; NO DATA, RETURN ZERO
00CBA3  2  60                   RTS
00CBA4  2               KBD_GETDATA1:
00CBA4  2  68                   PLA
00CBA5  2  A8                   TAY
00CBA6  2  68                   PLA
00CBA7  2  AA                   TAX
00CBA8  2               KBD_GETDATA1A:
00CBA8  2  AD FE E3             LDA     KBD_DAT         ; GET DATA PORT
00CBAB  2  18                   CLC                     ; SET FLAGS
00CBAC  2  60                   RTS
00CBAD  2               ;
00CBAD  2               ;__________________________________________________________________________________________________
00CBAD  2               KBD_GETDATAX:
00CBAD  2               ;
00CBAD  2               ; GET A RAW DATA BYTE FROM KEYBOARD INTERFACE INTO A WITH NO TIMEOUT
00CBAD  2               ;
00CBAD  2  AD FF E3             LDA     KBD_ST          ; STATUS PORT
00CBB0  2  29 01                AND     #$01            ; ISOLATE INPUT PENDING BIT
00CBB2  2  C9 00                CMP     #$00
00CBB4  2  D0 F2                BNE     KBD_GETDATA1A   ; BYTE PENDING, GO GET IT
00CBB6  2  A9 00                LDA     #$00
00CBB8  2  38                   SEC                     ; NO DATA, RETURN ZERO
00CBB9  2  60                   RTS
00CBBA  2               ;
00CBBA  2               ;__________________________________________________________________________________________________
00CBBA  2               ; RESET KEYBOARD
00CBBA  2               ;__________________________________________________________________________________________________
00CBBA  2               ;
00CBBA  2               KBD_RESET:
00CBBA  2  A9 FF                LDA     #$FF            ; RESET COMMAND
00CBBC  2  20 5A CB             JSR     KBD_PUTDATA     ; SEND IT
00CBBF  2  20 7E CB             JSR     KBD_GETDATA     ; GET THE ACK
00CBC2  2  A2 00                LDX     #$00            ; SETUP LOOP COUNTER
00CBC4  2  A0 F1                LDY     #$F1            ; SETUP LOOP COUNTER
00CBC6  2               KBD_RESET0:
00CBC6  2  20 7E CB             JSR     KBD_GETDATA     ; TRY TO GET THE RESPONSE
00CBC9  2  90 0C                BCC     KBD_RESET1      ; GOT A BYTE?  IF SO, GET OUT OF LOOP
00CBCB  2  CA                   DEX
00CBCC  2  E0 00                CPX     #$00
00CBCE  2  D0 F6                BNE     KBD_RESET0      ; LOOP TILL COUNTER EXHAUSTED
00CBD0  2  88                   DEY
00CBD1  2  C0 00                CPY     #$00
00CBD3  2  D0 F1                BNE     KBD_RESET0      ; LOOP TILL COUNTER EXHAUSTED
00CBD5  2  38                   SEC                     ; SIGNAL FAILURE
00CBD6  2  60                   RTS                     ; DONE
00CBD7  2               KBD_RESET1:
00CBD7  2  18                   CLC                     ; SIGNAL SUCCESS (RESPONSE IS IGNORED...)
00CBD8  2  60                   RTS                     ; DONE
00CBD9  2               ;
00CBD9  2               ;__________________________________________________________________________________________________
00CBD9  2               ; UPDATE KEYBOARD LEDS BASED ON CURRENT TOGGLE FLAGS
00CBD9  2               ;__________________________________________________________________________________________________
00CBD9  2               ;
00CBD9  2               KBD_SETLEDS:
00CBD9  2  A9 ED                LDA     #$ED            ; SET/RESET LED'S COMMAND
00CBDB  2  20 5A CB             JSR     KBD_PUTDATA     ; SEND THE COMMAND
00CBDE  2  20 7E CB             JSR     KBD_GETDATA     ; READ THE RESPONSE
00CBE1  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
00CBE3  2  F0 02                BEQ     :+
00CBE5  2               
00CBE5  2  38                   SEC
00CBE6  2  60                   RTS                     ; ABORT IF NO ACK
00CBE7  2               :
00CBE7  2  AD 6D CA             LDA     KBD_STATE       ; LOAD THE STATE BYTE
00CBEA  2  6A                   ROR     A               ; ROTATE TOGGLE KEY BITS AS NEEDED
00CBEB  2  6A                   ROR     A
00CBEC  2  6A                   ROR     A
00CBED  2  6A                   ROR     A
00CBEE  2  29 07                AND     #$07            ; CLEAR THE IRRELEVANT BITS
00CBF0  2  20 5A CB             JSR     KBD_PUTDATA     ; SEND THE LED DATA
00CBF3  2  20 7E CB             JSR     KBD_GETDATA     ; READ THE ACK
00CBF6  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
00CBF8  2  F0 02                BEQ     :+
00CBFA  2               
00CBFA  2  38                   SEC
00CBFB  2  60                   RTS                     ; ABORT IF NO ACK
00CBFC  2               :
00CBFC  2  A9 00                LDA     #$00            ; A=0
00CBFE  2  8D 70 CA             STA     KBD_STATUS      ; CLEAR STATUS
00CC01  2  18                   CLC
00CC02  2  60                   RTS
00CC03  2               ;
00CC03  2               ;__________________________________________________________________________________________________
00CC03  2               ; UPDATE KEYBOARD REPEAT RATE BASED ON CURRENT SETTING
00CC03  2               ;__________________________________________________________________________________________________
00CC03  2               ;
00CC03  2               KBD_SETRPT:
00CC03  2  A9 F3                LDA     #$F3            ; COMMAND = SET TYPEMATIC RATE/DELAY
00CC05  2  20 5A CB             JSR     KBD_PUTDATA     ; SEND IT
00CC08  2  20 7E CB             JSR     KBD_GETDATA     ; GET THE ACK
00CC0B  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
00CC0D  2  F0 02                BEQ     :+
00CC0F  2               
00CC0F  2  38                   SEC
00CC10  2  60                   RTS                     ; ABORT IF NO ACK
00CC11  2               :
00CC11  2  AD 71 CA             LDA     KBD_REPEAT      ; LOAD THE CURRENT RATE/DELAY BYTE
00CC14  2  20 5A CB             JSR     KBD_PUTDATA     ; SEND IT
00CC17  2  20 7E CB             JSR     KBD_GETDATA     ; GET THE ACK
00CC1A  2  C9 FA                CMP     #$FA            ; MAKE SURE WE GET ACK
00CC1C  2  F0 02                BEQ     :+
00CC1E  2               
00CC1E  2  38                   SEC
00CC1F  2  60                   RTS                     ; ABORT IF NO ACK
00CC20  2               :
00CC20  2  18                   CLC
00CC21  2  60                   RTS
