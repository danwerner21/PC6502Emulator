00D10F  2               ;____________________________________________________________________________________________________
00D10F  2               ;
00D10F  2               RTC_INIT:
00D10F  2  20 6B D5             JSR     LFCR            ; AND CRLF
00D112  2  A9 97                LDA     #<RTCMESSAGE1   ;
00D114  2  85 41                STA     STRPTR          ;
00D116  2  A9 D1                LDA     #>RTCMESSAGE1   ;
00D118  2  85 42                STA     STRPTR+1        ;
00D11A  2  20 76 D5             JSR     WRSTR
00D11D  2  20 6B D5             JSR     LFCR            ; AND CRLF
00D120  2  A9 55                LDA     #<MESSAGE2      ;
00D122  2  85 41                STA     STRPTR          ;
00D124  2  A9 C3                LDA     #>MESSAGE2      ;
00D126  2  85 42                STA     STRPTR+1        ;
00D128  2  20 76 D5             JSR     WRSTR
00D12B  2  A9 EF                LDA     #>RTCBASE
00D12D  2  20 8B D5             JSR     PRINT_BYTE
00D130  2  A9 90                LDA     #<RTCBASE
00D132  2  20 8B D5             JSR     PRINT_BYTE
00D135  2  20 6B D5             JSR     LFCR            ; AND CRLF
00D138  2  A9 9C                LDA     #<RTCMESSAGE2   ;
00D13A  2  85 41                STA     STRPTR          ;
00D13C  2  A9 D1                LDA     #>RTCMESSAGE2   ;
00D13E  2  85 42                STA     STRPTR+1        ;
00D140  2  20 76 D5             JSR     WRSTR
00D143  2  A2 02                LDX     #2
00D145  2  20 E6 D0             JSR     RTC_READ
00D148  2  98                   TYA
00D149  2  20 8B D5             JSR     PRINT_BYTE
00D14C  2  A9 3A                LDA     #':'
00D14E  2  20 62 D5             JSR     DFT_CONSOLE_OUT
00D151  2  A2 01                LDX     #1
00D153  2  20 E6 D0             JSR     RTC_READ
00D156  2  98                   TYA
00D157  2  20 8B D5             JSR     PRINT_BYTE
00D15A  2  A9 3A                LDA     #':'
00D15C  2  20 62 D5             JSR     DFT_CONSOLE_OUT
00D15F  2  A2 00                LDX     #0
00D161  2  20 E6 D0             JSR     RTC_READ
00D164  2  98                   TYA
00D165  2  20 8B D5             JSR     PRINT_BYTE
00D168  2  A9 20                LDA     #' '
00D16A  2  20 62 D5             JSR     DFT_CONSOLE_OUT
00D16D  2  A2 04                LDX     #4
00D16F  2  20 E6 D0             JSR     RTC_READ
00D172  2  98                   TYA
00D173  2  20 8B D5             JSR     PRINT_BYTE
00D176  2  A9 2F                LDA     #'/'
00D178  2  20 62 D5             JSR     DFT_CONSOLE_OUT
00D17B  2  A2 03                LDX     #3
00D17D  2  20 E6 D0             JSR     RTC_READ
00D180  2  98                   TYA
00D181  2  20 8B D5             JSR     PRINT_BYTE
00D184  2  A9 2F                LDA     #'/'
00D186  2  20 62 D5             JSR     DFT_CONSOLE_OUT
00D189  2  A2 06                LDX     #6
00D18B  2  20 E6 D0             JSR     RTC_READ
00D18E  2  98                   TYA
00D18F  2  20 8B D5             JSR     PRINT_BYTE
00D192  2  20 6B D5             JSR     LFCR            ; AND CRLF
00D195  2  60                   RTS
