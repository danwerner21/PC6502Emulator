00C795  2               ;__ESP DRIVERS______________________________________________________________________________________________________________
00C795  2               ;
00C795  2               ; 	CUBIX ISA DUAL ESP IO drivers for 6809PC
00C795  2               ;
00C795  2               ;	Entry points:
00C795  2               ;		ESPINIT     - INIT HARDWARE
00C795  2               ;		ESPVIDEOOUT - OUTPUT A CHARACTER TO VIDEO (ANSI)
00C795  2               ;               ESPPS2IN    - read a character from the ps/2 keyboard ('A' POINTS TO BYTE)
00C795  2               ;               ESPPS2BUFL  - return number of characters in the keyboard buffer in 'A'
00C795  2               ;               ESPCURSORV  - Set Cursor Visibility (A=0 cursor off, A=1 cursor on)
00C795  2               ;		ESPSER0OUT  - OUTPUT A CHARACTER TO Serial 0 ('A' POINTS TO BYTE)
00C795  2               ;               ESPSER0IN   - read a character from Serial 0 ('A' POINTS TO BYTE)
00C795  2               ;               ESPSER0BUFL - return number of characters in the Serial 0 buffer in 'A'
00C795  2               ;		ESPSER1OUT  - OUTPUT A CHARACTER TO Serial 1 ('A' POINTS TO BYTE)
00C795  2               ;               ESPSER1IN   - read a character from Serial 1 ('A' POINTS TO BYTE)
00C795  2               ;               ESPSER1BUFL - return number of characters in the Serial 1 buffer in 'A'
00C795  2               ;		ESPNETCOUT  - OUTPUT A CHARACTER TO Network Console Connection ('A' POINTS TO BYTE)
00C795  2               ;               ESPNETCIN   - read a character from Network Console Connection ('A' POINTS TO BYTE)
00C795  2               ;               ESPNETCBUFL - return number of characters in the Network Connection buffer in 'A'
00C795  2               ;               PUTESP0     - put opcode/data to ESP0
00C795  2               ;               PUTESP1     - put opcode/data to ESP1
00C795  2               ;               GETESP0     - get opcode/data from ESP0
00C795  2               ;               GETESP1     - get opcode/data from ESP1
