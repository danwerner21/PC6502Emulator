00D069  2               ;
00D069  2               ; VALUES 0-127 ARE STANDARD ASCII, SPECIAL KEYS WILL HAVE THE FOLLOWING VALUES:
00D069  2               ;
00D069  2               ; F1		$E0
00D069  2               ; F2		$E1
00D069  2               ; F3		$E2
00D069  2               ; F4		$E3
00D069  2               ; F5		$E4
00D069  2               ; F6		$E5
00D069  2               ; F7		$E6
00D069  2               ; F8		$E7
00D069  2               ; F9		$E8
00D069  2               ; F10		$E9
00D069  2               ; F11		$EA
00D069  2               ; F12		$EB
00D069  2               ; SYSRQ		$EC
00D069  2               ; PRTSC		$ED
00D069  2               ; PAUSE		$EE
00D069  2               ; APP		$EF
00D069  2               ; INS		$F0
00D069  2               ; DEL		$F1
00D069  2               ; HOME		$F2
00D069  2               ; END		$F3
00D069  2               ; PGUP		$F4
00D069  2               ; PGDN		$F5
00D069  2               ; UP		$F6
00D069  2               ; DOWN		$F7
00D069  2               ; LEFT		$F8
00D069  2               ; RIGHT		$F9
00D069  2               ; POWER		$FA
00D069  2               ; SLEEP		$FB
00D069  2               ; WAKE		$FC
00D069  2               ; BREAK		$FD
