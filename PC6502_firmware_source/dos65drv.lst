00CC5D  2               ;__GETSTATUS_______________________________________________________________________________________
00CC5D  2               ; Get Keyboard status
00CC5D  2               ;__________________________________________________________________________________________________
00CC5D  2               KBD_GETSTATUS:
00CC5D  2  20 64 CC             JSR     KBD_DECODE
00CC60  2  AD 56 D0             LDA     KBD_BUFFERPTR   ; GET CURRENT BUFFER LEN
00CC63  2  60                   RTS
00CC64  2               
00CC64  2               
00CC64  2               ;
00CC64  2               ;__________________________________________________________________________________________________
00CC64  2               ; DECODING ENGINE
00CC64  2               ;__________________________________________________________________________________________________
00CC64  2               ;
00CC64  2               ;__________________________________________________________________________________________________
00CC64  2               KBD_DECODE:
00CC64  2               ;
00CC64  2               ;  RUN THE DECODING ENGINE UNTIL EITHER: 1) NO MORE SCANCODES ARE AVAILABLE
00CC64  2               ;  FROM THE KEYBOARD, OR 2) A DECODED KEY VALUE IS AVAILABLE
00CC64  2               ;
00CC64  2               ;  RETURNS A=0 AND Z SET IF NO KEYCODE READY, OTHERWISE A DECODED KEY VALUE IS AVAILABLE.
00CC64  2               ;  THE DECODED KEY VALUE AND KEY STATE IS STORED IN KBD_KEYCODE AND KBD_STATE.
00CC64  2               ;
00CC64  2               ;  KBD_STATUS IS NOT CLEARED AT START. IT IS THE JSR ER'S RESPONSIBILITY
00CC64  2               ;  TO CLEAR KBD_STATUS WHEN IT HAS RETRIEVED A PENDING VALUE.  IF DECODE IS JSR ED
00CC64  2               ;  WITH A KEYCODE STILL PENDING, IT WILL JUST RETURN WITHOUT DOING ANYTHING.
00CC64  2               ;
00CC64  2               ; Step 0: Check keycode buffer
00CC64  2               ;   if status[keyrdy]
00CC64  2               ;     return
00CC64  2               ;
00CC64  2               ; Step 1: Get scancode
00CC64  2               ;   if no scancode ready
00CC64  2               ;     return
00CC64  2               ;   read scancode
00CC64  2               ;
00CC64  2               ; Step 2: Detect and handle special keycodes
00CC64  2               ;   if scancode == $AA
00CC64  2               ;     *** handle hot insert somehow ***
00CC64  2               ;
00CC64  2               ; Step 3: Detect and handle scancode prefixes
00CC64  2               ;   if scancode == $E0
00CC64  2               ;     set status[extended]
00CC64  2               ;     goto Step 1
00CC64  2               ;
00CC64  2               ;   if scancode == $E1
00CC64  2               ;     *** handle pause key somehow ***
00CC64  2               ;
00CC64  2               ; Step 4: Detect and flag break event
00CC64  2               ;   *** scancode set #1 variation ***
00CC64  2               ;     set status[break] = high bit of scancode
00CC64  2               ;     clear high order bit
00CC64  2               ;     continue to Step 5
00CC64  2               ;   *** scancode set #2 variation ***
00CC64  2               ;     if scancode == $F0
00CC64  2               ;       set status[break]
00CC64  2               ;       goto Step 1
00CC64  2               ;
00CC64  2               ; Step 5: Map scancode to keycode
00CC64  2               ;   if status[extended]
00CC64  2               ;     apply extended-map[scancode] -> keycode
00CC64  2               ;   else if state[shifted]
00CC64  2               ;     apply shifted-map[scancode] -> keycode
00CC64  2               ;   else
00CC64  2               ;     apply normal-map[scancode] -> keycode
00CC64  2               ;
00CC64  2               ; Step 6: Handle modifier keys
00CC64  2               ;   if keycode is modifier (shift, ctrl, alt, win)
00CC64  2               ;     set (l/r)state[<modifier>] = not status[break]
00CC64  2               ;     clear modifier bits in state
00CC64  2               ;     set state = (lstate OR rstate OR state)
00CC64  2               ;     goto New Key
00CC64  2               ;
00CC64  2               ; Step 7: Complete procesing of key break events
00CC64  2               ;   if status[break]
00CC64  2               ;     goto New Key
00CC64  2               ;
00CC64  2               ; Step 8: Handle toggle keys
00CC64  2               ;   if keycode is toggle (capslock, numlock, scrolllock)
00CC64  2               ;     invert (XOR) state[<toggle>]
00CC64  2               ;     update keyboard LED's
00CC64  2               ;     goto New Key
00CC64  2               ;
00CC64  2               ; Step 9: Adjust keycode for control modifier
00CC64  2               ;   if state[ctrl]
00CC64  2               ;     if keycode is 'a'-'z'
00CC64  2               ;       subtract 20 (clear bit 5) from keycode
00CC64  2               ;     if keycode is '@'-'_'
00CC64  2               ;       subtract 40 (clear bit 6) from keycode
00CC64  2               ;
00CC64  2               ; Step 10: Adjust keycode for caps lock
00CC64  2               ;   if state[capslock]
00CC64  2               ;     if keycode is 'a'-'z' OR 'A'-'Z'
00CC64  2               ;       toggle (XOR) bit 5 of keycode
00CC64  2               ;
00CC64  2               ; Step 11: Handle num pad keys
00CC64  2               ;   clear state[numpad]
00CC64  2               ;   if keycode is numpad
00CC64  2               ;     set state[numpad]
00CC64  2               ;     if state[numlock]
00CC64  2               ;       toggle (XOR) bit 4 of keycode
00CC64  2               ;     apply numpad-map[keycode] -> keycode
00CC64  2               ;
00CC64  2               ; Step 12: Detect unknown/invalid keycodes
00CC64  2               ;   if keycode == $FF
00CC64  2               ;     goto New Key
00CC64  2               ;
00CC64  2               ; Step 13: Done
00CC64  2               ;   set status[keyrdy]
00CC64  2               ;   return
00CC64  2               ;
00CC64  2               ; New Key:
00CC64  2               ;   clear status
00CC64  2               ;   goto Step 1
00CC64  2               ;
00CC64  2               KBD_DEC0:                       ; CHECK KEYCODE BUFFER
00CC64  2               ;        LDA     KBD_STATUS      ; GET CURRENT STATUS
00CC64  2               ;        AND     #KBD_KEYRDY     ; ISOLATE KEY READY FLAG
00CC64  2               ;        BEQ     KBD_DEC1
00CC64  2               ;        SEC
00CC64  2               ;        RTS                     ; ABORT IF KEY IS ALREADY PENDING
00CC64  2               
00CC64  2               KBD_DEC1:                       ; PROCESS NEXT SCANCODE
00CC64  2  20 AD CB             JSR     KBD_GETDATAX    ; GET THE SCANCODE
00CC67  2  90 02                BCC     KBD_DEC2
00CC69  2  38                   SEC
00CC6A  2  60                   RTS                     ; NO KEY READY, RETURN WITH A=0, SET ERROR
00CC6B  2               
00CC6B  2               KBD_DEC2:                       ; DETECT AND HANDLE SPECIAL KEYCODES
00CC6B  2  8D 6B CA             STA     KBD_SCANCODE    ; SAVE SCANCODE
00CC6E  2  C9 AA                CMP     #$AA            ; KEYBOARD INSERTION?
00CC70  2  D0 12                BNE     KBD_DEC3        ; NOPE, BYPASS
00CC72  2  20 57 CE             JSR     LDELAY          ; WAIT A BIT
00CC75  2  20 BA CB             JSR     KBD_RESET       ; RESET KEYBOARD
00CC78  2  20 57 CE             JSR     LDELAY          ; WAIT A BIT
00CC7B  2  20 D9 CB             JSR     KBD_SETLEDS     ; SET LEDS
00CC7E  2  20 03 CC             JSR     KBD_SETRPT      ; SET REPEAT RATE
00CC81  2  4C 3D CE             JMP     KBD_DECNEW      ; RESTART THE ENGINE
00CC84  2               
00CC84  2               KBD_DEC3:                       ; DETECT AND HANDLE SCANCODE PREFIXES
00CC84  2  C9 E0                CMP     #$E0            ; EXTENDED KEY PREFIX $E0?
00CC86  2  D0 0D                BNE     KBD_DEC3B       ; NOPE MOVE ON
00CC88  2  48                   PHA
00CC89  2  AD 70 CA             LDA     KBD_STATUS      ; GET STATUS
00CC8C  2  09 01                ORA     #KBD_EXT        ; SET EXTENDED BIT
00CC8E  2  8D 70 CA             STA     KBD_STATUS      ; SAVE STATUS
00CC91  2  68                   PLA
00CC92  2  4C 64 CC             JMP     KBD_DEC1        ; LOOP TO DO NEXT SCANCODE
00CC95  2               
00CC95  2               KBD_DEC3B:                      ; HANDLE SCANCODE PREFIX $E1 (PAUSE KEY)
00CC95  2  C9 E1                CMP     #$E1            ; EXTENDED KEY PREFIX $E1
00CC97  2  D0 10                BNE     KBD_DEC4        ; NOPE MOVE ON
00CC99  2  A9 EE                LDA     #$EE            ; MAP TO KEYCODE $EE
00CC9B  2  8D 6C CA             STA     KBD_KEYCODE     ; SAVE IT
00CC9E  2               ; SWALLOW NEXT 7 SCANCODES
00CC9E  2  A2 07                LDX     #7              ; LOOP 7 TIMES
00CCA0  2               KBD_DEC3B1:
00CCA0  2  20 7E CB             JSR     KBD_GETDATA     ; RETRIEVE NEXT SCANCODE
00CCA3  2  CA                   DEX
00CCA4  2  D0 FA                BNE     KBD_DEC3B1      ; LOOP AS NEEDED
00CCA6  2  4C 02 CD             JMP     KBD_DEC6        ; RESUME AFTER MAPPING
00CCA9  2               
00CCA9  2               KBD_DEC4:                       ; DETECT AND FLAG BREAK EVENT
00CCA9  2  C9 F0                CMP     #$F0            ; BREAK (KEY UP) PREFIX?
00CCAB  2  D0 0D                BNE     KBD_DEC5        ; NOPE MOVE ON
00CCAD  2  48                   PHA
00CCAE  2  AD 70 CA             LDA     KBD_STATUS      ; GET STATUS
00CCB1  2  09 02                ORA     #KBD_BREAK      ; SET BREAK BIT
00CCB3  2  8D 70 CA             STA     KBD_STATUS      ; SAVE STATUS
00CCB6  2  68                   PLA
00CCB7  2  4C 64 CC             JMP     KBD_DEC1        ; LOOP TO DO NEXT SCANCODE
00CCBA  2               
00CCBA  2               KBD_DEC5:                       ; MAP SCANCODE TO KEYCODE
00CCBA  2  AD 70 CA             LDA     KBD_STATUS      ; GET STATUS
00CCBD  2  29 01                AND     #KBD_EXT        ; EXTENDED BIT SET?
00CCBF  2  F0 1F                BEQ     KBD_DEC5C       ; NOPE, MOVE ON
00CCC1  2               
00CCC1  2               ; PERFORM EXTENDED KEY MAPPING
00CCC1  2  A2 00                LDX     #$00             ; GET SCANCODE
00CCC3  2               KBD_DEC5A:
00CCC3  2  BD 08 D0             LDA     KBD_MAPEXT,X    ; GET FIRST BYTE OF PAIR FROM EXT MAP TABLE
00CCC6  2  E8                   INX
00CCC7  2  C9 00                CMP     #$00            ; END OF TABLE?
00CCC9  2  F0 09                BEQ     :+              ; UNKNOWN OR BOGUS, START OVER
00CCCB  2  CD 6B CA             CMP     KBD_SCANCODE    ; DOES MATCH BYTE EQUAL SCANCODE?
00CCCE  2  F0 07                BEQ     KBD_DEC5B       ; YES! JUMP OUT
00CCD0  2  E8                   INX                     ; BUMP TO START OF NEXT PAIR
00CCD1  2  4C C3 CC             JMP     KBD_DEC5A       ; LOOP TO CHECK NEXT TABLE ENTRY
00CCD4  2               :
00CCD4  2  4C 3D CE             JMP     KBD_DECNEW
00CCD7  2               KBD_DEC5B:
00CCD7  2  BD 08 D0             LDA     KBD_MAPEXT,X    ; GET THE KEYCODE VIA MAPPING TABLE
00CCDA  2  8D 6C CA             STA     KBD_KEYCODE     ; SAVE IT
00CCDD  2  4C 02 CD             JMP     KBD_DEC6
00CCE0  2               
00CCE0  2               KBD_DEC5C:                      ; PERFORM REGULAR KEY (NOT EXTENDED) KEY MAPPING
00CCE0  2  AD 6B CA             LDA     KBD_SCANCODE    ; GET THE SCANCODE
00CCE3  2  C9 85                CMP     #KBD_MAPSIZ     ; COMPARE TO SIZE OF TABLE
00CCE5  2  F0 02                BEQ     :+
00CCE7  2  B0 19                BCS     KBD_DEC6        ; PAST END, SKIP OVER LOOKUP
00CCE9  2               :
00CCE9  2               ; SETUP POINTER TO MAPPING TABLE BASED ON SHIFTED OR UNSHIFTED STATE
00CCE9  2  AD 6D CA             LDA     KBD_STATE       ; GET STATE
00CCEC  2  29 01                AND     #KBD_SHIFT      ; SHIFT ACTIVE?
00CCEE  2  F0 09                BEQ     KBD_DEC5D       ; NON-SHIFTED, MOVE ON
00CCF0  2               
00CCF0  2  AE 6B CA             LDX     KBD_SCANCODE    ; GET THE SCANCODE
00CCF3  2  BD 83 CF             LDA     KBD_MAPSHIFT,X  ; GET SHIFTED
00CCF6  2  4C FF CC             JMP     :+
00CCF9  2               KBD_DEC5D:
00CCF9  2  AE 6B CA             LDX     KBD_SCANCODE    ; GET THE SCANCODE
00CCFC  2  BD FE CE             LDA     KBD_MAPSTD,X    ; GET STANDARD
00CCFF  2               :
00CCFF  2  8D 6C CA             STA     KBD_KEYCODE     ; SAVE KEYCODE
00CD02  2               
00CD02  2               KBD_DEC6:                       ; HANDLE MODIFIER KEYS
00CD02  2  AD 6C CA             LDA     KBD_KEYCODE     ; MAKE SURE WE HAVE KEYCODE
00CD05  2  C9 B8                CMP     #$B8            ; END OF MODIFIER KEYS
00CD07  2  B0 5F                BCS     KBD_DEC7        ; BYPASS MODIFIER KEY CHECKING
00CD09  2  C9 B0                CMP     #$B0            ; START OF MODIFIER KEYS
00CD0B  2  90 5B                BCC     KBD_DEC7        ; BYPASS MODIFIER KEY CHECKING
00CD0D  2  A2 04                LDX     #4              ; LOOP COUNTER TO LOOP THRU 4 MODIFIER BITS
00CD0F  2  38                   SEC
00CD10  2  E9 AF                SBC     #$AF            ; SETUP A TO DECREMENT THROUGH MODIFIER VALUES
00CD12  2  8D 6A CA             STA     TMPKEY
00CD15  2  A9 00                LDA     #$00            ; SETUP A TO ROATE THROUGH MODIFIER STATE BITS
00CD17  2  38                   SEC                     ; SET CARRY FOR ROTATE
00CD18  2               
00CD18  2               KBD_DEC6A:
00CD18  2  2A                   ROL     A               ; SHIFT TO NEXT MODIFIER STATE BIT
00CD19  2  CE 6A CA             DEC     TMPKEY          ; L-MODIFIER?
00CD1C  2  F0 0B                BEQ     KBD_DEC6B       ; YES, HANDLE L-MODIFIER MAKE/BREAK
00CD1E  2  CE 6A CA             DEC     TMPKEY          ; R-MODIFIER?
00CD21  2  F0 0B                BEQ     KBD_DEC6C       ; YES, HANDLE R-MODIFIER MAKE/BREAK
00CD23  2  CA                   DEX
00CD24  2  D0 F2                BNE     KBD_DEC6A       ; LOOP THRU 4 MODIFIER BITS
00CD26  2  4C 68 CD             JMP     KBD_DEC7        ; FAILSAFE, SHOULD NEVER GET HERE!
00CD29  2               
00CD29  2               KBD_DEC6B:
00CD29  2  A2 00                LDX     #0              ; POINT TO LEFT STATE BYTE
00CD2B  2  4C 30 CD             JMP     KBD_DEC6D       ; CONTINUE
00CD2E  2               
00CD2E  2               KBD_DEC6C:
00CD2E  2  A2 01                LDX     #1              ; POINT TO RIGHT STATE BYTE
00CD30  2               
00CD30  2               KBD_DEC6D:                      ; BRANCH BASED ON WHETHER THIS IS A MAKE OR BREAK EVENT
00CD30  2  8D 6A CA             STA     TMPKEY
00CD33  2  AD 70 CA             LDA     KBD_STATUS      ; GET STATUS FLAGS
00CD36  2  29 02                AND     #KBD_BREAK      ; BREAK EVENT?
00CD38  2  F0 03                BEQ     KBD_DEC6E       ; NO, HANDLE A MODIFIER KEY MAKE EVENT
00CD3A  2  4C 49 CD             JMP     KBD_DEC6F       ; YES, HANDLE A MODIFIER BREAK EVENT
00CD3D  2               
00CD3D  2               KBD_DEC6E:                      ; HANDLE STATE KEY MAKE EVENT
00CD3D  2  AD 6A CA             LDA     TMPKEY
00CD40  2  1D 6E CA             ORA     KBD_LSTATE,X    ; OR IN THE BIT TO SET
00CD43  2  9D 6E CA             STA     KBD_LSTATE,X    ; SAVE THE RESULT
00CD46  2  4C 57 CD             JMP     KBD_DEC6G       ; CONTINUE
00CD49  2               
00CD49  2               KBD_DEC6F:                      ; HANDLE STATE KEY BREAK EVENT
00CD49  2  AD 6A CA             LDA     TMPKEY
00CD4C  2  49 FF                EOR     #$FF            ; FLIP ALL BITS TO SETUP FOR A CLEAR OPERATION
00CD4E  2  3D 6E CA             AND     KBD_LSTATE,X    ; AND IN THE FLIPPED BITS TO CLEAR DESIRED BIT
00CD51  2  9D 6E CA             STA     KBD_LSTATE,X    ; SAVE THE RESULT
00CD54  2  4C 57 CD             JMP     KBD_DEC6G       ; CONTINUE
00CD57  2               
00CD57  2               KBD_DEC6G:                      ; COALESCE L/R STATE FLAGS
00CD57  2  AD 6D CA             LDA     KBD_STATE       ; GET EXISTING STATE BITS
00CD5A  2  29 F0                AND     #$F0            ; GET RID OF OLD MODIFIER BITS
00CD5C  2  0D 6E CA             ORA     KBD_LSTATE      ; MERGE IN LEFT STATE BITS
00CD5F  2  0D 6F CA             ORA     KBD_RSTATE      ; MERGE IN RIGHT STATE BITS
00CD62  2  8D 6D CA             STA     KBD_STATE       ; SAVE IT
00CD65  2               :
00CD65  2  4C 3D CE             JMP     KBD_DECNEW      ; DONE WITH CURRENT KEYSTROKE
00CD68  2               
00CD68  2               KBD_DEC7:                       ; COMPLETE PROCESSING OF EXTENDED AND KEY BREAK EVENTS
00CD68  2  AD 70 CA             LDA     KBD_STATUS      ; GET CURRENT STATUS FLAGS
00CD6B  2  29 02                AND     #KBD_BREAK      ; IS THIS A KEY BREAK EVENT?
00CD6D  2  D0 F6                BNE     :-              ; PROCESS NEXT KEY
00CD6F  2               
00CD6F  2               KBD_DEC8:                       ; HANDLE TOGGLE KEYS
00CD6F  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE INTO A
00CD72  2  A0 40                LDY     #KBD_CAPSLCK    ; SETUP E WITH CAPS LOCK STATE BIT
00CD74  2  C9 BC                CMP     #$BC            ; IS THIS THE CAPS LOCK KEY?
00CD76  2  F0 0F                BEQ     KBD_DEC8A       ; YES, GO TO BIT SET ROUTINE
00CD78  2  A0 20                LDY     #KBD_NUMLCK     ; SETUP E WITH NUM LOCK STATE BIT
00CD7A  2  C9 BD                CMP     #$BD            ; IS THIS THE NUM LOCK KEY?
00CD7C  2  F0 09                BEQ     KBD_DEC8A       ; YES, GO TO BIT SET ROUTINE
00CD7E  2  A0 10                LDY     #KBD_SCRLCK     ; SETUP E WITH SCROLL LOCK STATE BIT
00CD80  2  C9 BE                CMP     #$BE            ; IS THIS THE SCROLL LOCK KEY?
00CD82  2  F0 03                BEQ     KBD_DEC8A       ; YES, GO TO BIT SET ROUTINE
00CD84  2  4C 94 CD             JMP     KBD_DEC9        ; NOT A TOGGLE KEY, CONTINUE
00CD87  2               
00CD87  2               KBD_DEC8A:                      ; RECORD THE TOGGLE
00CD87  2  98                   TYA
00CD88  2  4D 6D CA             EOR     KBD_STATE       ; SET THE TOGGLE KEY BIT FROM ABOVE
00CD8B  2  8D 6D CA             STA     KBD_STATE       ; SAVE IT
00CD8E  2  20 D9 CB             JSR     KBD_SETLEDS     ; UPDATE LED LIGHTS ON KBD
00CD91  2  4C 3D CE             JMP     KBD_DECNEW      ; RESTART DECODER FOR A NEW KEY
00CD94  2               
00CD94  2               KBD_DEC9:                       ; ADJUST KEYCODE FOR CONTROL MODIFIER
00CD94  2  AD 6D CA             LDA     KBD_STATE       ; GET THE CURRENT STATE BITS
00CD97  2  29 02                AND     #KBD_CTRL       ; CHECK THE CONTROL BIT
00CD99  2  F0 1E                BEQ     KBD_DEC10       ; CONTROL KEY NOT PRESSED, MOVE ON
00CD9B  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET CURRENT KEYCODE IN A
00CD9E  2  C9 61                CMP     #'a'            ; COMPARE TO LOWERCASE A
00CDA0  2  90 08                BCC     KBD_DEC9A       ; BELOW IT, BYPASS
00CDA2  2  C9 7A                CMP     #'z'            ; COMPARE TO LOWERCASE Z+1
00CDA4  2  F0 02                BEQ     :+
00CDA6  2  B0 02                BCS     KBD_DEC9A       ; ABOVE IT, BYPASS
00CDA8  2               :
00CDA8  2  29 DF                AND     #$DF            ; KEYCODE IN LOWERCASE A-Z RANGE CLEAR BIT 5 TO MAKE IT UPPERCASE
00CDAA  2               KBD_DEC9A:
00CDAA  2  C9 40                CMP     #'@'            ; COMPARE TO @
00CDAC  2  90 0B                BCC     KBD_DEC10       ; BELOW IT, BYPASS
00CDAE  2  C9 5F                CMP     #'_'            ; COMPARE TO _+1
00CDB0  2  F0 02                BEQ     :+
00CDB2  2  B0 05                BCS     KBD_DEC10       ; ABOVE IT, BYPASS
00CDB4  2               :
00CDB4  2  29 BF                AND     #$BF            ; CONVERT TO CONTROL VALUE BY CLEARING BIT 6
00CDB6  2  8D 6C CA             STA     KBD_KEYCODE     ; UPDATE KEYCODE TO CONTROL VALUE
00CDB9  2               
00CDB9  2               KBD_DEC10:                      ; ADJUST KEYCODE FOR CAPS LOCK
00CDB9  2  AD 6D CA             LDA     KBD_STATE       ; LOAD THE STATE FLAGS
00CDBC  2  29 40                AND     #KBD_CAPSLCK    ; CHECK CAPS LOCK
00CDBE  2  F0 25                BEQ     KBD_DEC11       ; CAPS LOCK NOT ACTIVE, MOVE ON
00CDC0  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE VALUE
00CDC3  2  C9 61                CMP     #'a'            ; COMPARE TO LOWERCASE A
00CDC5  2  90 09                BCC     KBD_DEC10A      ; BELOW IT, BYPASS
00CDC7  2  C9 7A                CMP     #'z'            ; COMPARE TO LOWERCASE Z+1
00CDC9  2  F0 02                BEQ     :+
00CDCB  2  B0 03                BCS     KBD_DEC10A      ; ABOVE IT, BYPASS
00CDCD  2               :
00CDCD  2  4C DD CD             JMP     KBD_DEC10B      ; IN RANGE LOWERCASE A-Z, GO TO CASE SWAPPING LOGIC
00CDD0  2               KBD_DEC10A:
00CDD0  2  C9 41                CMP     #'A'            ; COMPARE TO UPPERCASE A
00CDD2  2  90 11                BCC     KBD_DEC11       ; BELOW IT, BYPASS
00CDD4  2  C9 5A                CMP     #'Z'            ; COMPARE TO UPPERCASE Z+1
00CDD6  2  F0 02                BEQ     :+
00CDD8  2  B0 0B                BCS     KBD_DEC11       ; ABOVE IT, BYPASS
00CDDA  2               :
00CDDA  2  4C DD CD             JMP     KBD_DEC10B      ; IN RANGE UPPERCASE A-Z, GO TO CASE SWAPPING LOGIC
00CDDD  2               KBD_DEC10B:
00CDDD  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE
00CDE0  2  49 20                EOR     #$20            ; FLIP BIT 5 TO SWAP UPPER/LOWER CASE
00CDE2  2  8D 6C CA             STA     KBD_KEYCODE     ; SAVE IT
00CDE5  2               
00CDE5  2               KBD_DEC11:                      ; HANDLE NUM PAD KEYS
00CDE5  2  AD 6D CA             LDA     KBD_STATE       ; GET THE CURRENT STATE FLAGS
00CDE8  2  29 7F                AND     #NOT_KBD_NUMPAD ; ASSUME NOT A NUMPAD KEY, CLEAR THE NUMPAD BIT
00CDEA  2  8D 6D CA             STA     KBD_STATE       ; SAVE IT
00CDED  2               
00CDED  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE
00CDF0  2  29 E0                AND     #%11100000      ; ISOLATE TOP 3 BITS
00CDF2  2  C9 C0                CMP     #%11000000      ; IS IN NUMPAD RANGE?
00CDF4  2  D0 21                BNE     KBD_DEC12       ; NOPE, GET OUT
00CDF6  2               
00CDF6  2  AD 6D CA             LDA     KBD_STATE       ; LOAD THE CURRENT STATE FLAGS
00CDF9  2  09 80                ORA     #KBD_NUMPAD     ; TURN ON THE NUMPAD BIT
00CDFB  2  8D 6D CA             STA     KBD_STATE       ; SAVE IT
00CDFE  2               
00CDFE  2  29 20                AND     #KBD_NUMLCK     ; IS NUM LOCK BIT SET?
00CE00  2  F0 08                BEQ     KBD_DEC11A      ; NO, SKIP NUMLOCK PROCESSING
00CE02  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE KEYCODE
00CE05  2  49 10                EOR     #$10            ; FLIP VALUES FOR NUMLOCK
00CE07  2  8D 6C CA             STA     KBD_KEYCODE     ; SAVE IT
00CE0A  2               
00CE0A  2               KBD_DEC11A:                     ; APPLY NUMPAD MAPPING
00CE0A  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE CURRENT KEYCODE
00CE0D  2  38                   SEC
00CE0E  2  E9 C0                SBC     #$C0            ; KEYCODES START AT $C0
00CE10  2  AA                   TAX
00CE11  2  BD 36 D0             LDA     KBD_MAPNUMPAD,X ; GET IT IN A
00CE14  2  8D 6C CA             STA     KBD_KEYCODE     ; SAVE IT
00CE17  2               
00CE17  2               KBD_DEC12:                      ; DETECT UNKNOWN/INVALID KEYCODES
00CE17  2  AD 6C CA             LDA     KBD_KEYCODE     ; GET THE FINAL KEYCODE
00CE1A  2  C9 FF                CMP     #$FF            ; IS IT $FF (UNKNOWN/INVALID)
00CE1C  2  F0 1F                BEQ     KBD_DECNEW      ; IF SO, JUST RESTART THE ENGINE
00CE1E  2               
00CE1E  2               KBD_DEC13:                      ; DONE - RECORD RESULTS INTO BUFFER
00CE1E  2  AE 56 D0             LDX     KBD_BUFFERPTR
00CE21  2  E0 10                CPX     #16
00CE23  2  F0 16                BEQ     KBD_DEC13A
00CE25  2               :
00CE25  2  BD 57 D0             LDA     KBD_BUFFER,X
00CE28  2  9D 58 D0             STA     KBD_BUFFER+1,X
00CE2B  2  CA                   DEX
00CE2C  2  E0 FF                CPX     #$FF
00CE2E  2  D0 F5                BNE     :-
00CE30  2  AD 6C CA             LDA     KBD_KEYCODE
00CE33  2  8D 58 D0             STA     KBD_BUFFER+1
00CE36  2  EE 56 D0             INC     KBD_BUFFERPTR
00CE39  2  A9 00                LDA     #$00            ; A=0
00CE3B  2               KBD_DEC13A:
00CE3B  2  18                   CLC                     ; SIGNAL SUCCESS WITH A=1, CARRY CLEAR
00CE3C  2  60                   RTS
00CE3D  2               
00CE3D  2               KBD_DECNEW:                     ; START NEW KEYPRESS (CLEAR ALL STATUS BITS)
00CE3D  2  A9 00                LDA     #$00            ; A=0
00CE3F  2  8D 70 CA             STA     KBD_STATUS      ; CLEAR STATUS
00CE42  2  4C 64 CC             JMP     KBD_DEC1        ; RESTART THE ENGINE
