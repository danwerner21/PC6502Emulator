00D1B2  1                       .INCLUDE "bios_video.asm"
00D1B2  2               ;__VIDEO DRIVERS________________________________________________________________________________________________________________
00D1B2  2               ;
00D1B2  2               ; 	Video drivers for the memory mapped video card
00D1B2  2               ;
00D1B2  2               ;	Entry points:
00D1B2  2               ;		VIDEOINIT   - called during OS init
00D1B2  2               ;		WRVID	    - write a byte to video port  ('A' POINTS TO BYTE)
00D1B2  2               ;		SETXY	    - Set the xy position of the cursor (X=X,Y=Y)
00D1B2  2               ;		CLEARSCREEN - Set the xy position of the cursor (X=X,Y=Y)
00D1B2  2               ;		SETCOLOR    - Set the xy position of the cursor (X=X,Y=Y)
00D1B2  2               ;               SCROLLUP    - Scroll the screen up one line
00D1B2  2               ;               SETMODE     - Set 40/80 mode
00D1B2  2               ;________________________________________________________________________________________________________________________________
00D1B2  2               ;
00D1B2  2               
00D1B2  2               VIDEOBANK       = $F8
00D1B2  2               
00D1B2  2               ; DATA STORAGE
00D1B2  2               VIDEOWORK:
00D1B2  2  00 00 00 00          .BYTE   00,00,00,00,00,00
00D1B6  2  00 00        
00D1B8  2               ;*
00D1B8  2               ;* MEMORY MAP
00D1B8  2               ;  VIDEO CARD IS A 32K AREA
00D1B8  2               ;  $0x00 0x01=soft_scanline_emulation, 0x02 NO soft_scanline_emulation
00D1B8  2               ;  $0x01 0x01=page1, 0x02 page2
00D1B8  2               ;  $0x02  character generator write offset (data << 3)
00D1B8  2               ;  $0x03 character generator write DATA
00D1B8  2               ;  $0x04 EXECUTE device command
00D1B8  2               ;        0x00- reset to the default configuration
00D1B8  2               ;        0x01- reset to the saved configuration
00D1B8  2               ;	0x02- save the current configuration
00D1B8  2               ;
00D1B8  2               ;  $0x05  0x01=soft_text=true, 0x02=soft_text=false
00D1B8  2               ;  $0x06 Lores Mode=0X01,NO lores Mode=0x02
00D1B8  2               ;  $0x07 Double Lores Mode=0X01,NO Double lores Mode=0x02
00D1B8  2               ;  $0x08 Hires Mode=0X01,NO Hires Mode=0x02
00D1B8  2               ;  $0x09 Double Hires Mode=0X01,NO Double Hires lores Mode=0x02
00D1B8  2               ;  $0x0A 80COL Mode=0X01,NO 80COL Mode=0x02
00D1B8  2               ;  $0x0B MIXED Mode=0X01,NO MIXED Mode=0x02
00D1B8  2               ;  $0x0C QUAD Hires Mode=0X01,NO QUAD Hires lores Mode=0x02
00D1B8  2               ;  $0x0D MONO Hires Mode=0X01,NO MONO Hires lores Mode=0x02
00D1B8  2               ;
00D1B8  2               ; 	VRAM Memory Map
00D1B8  2               ;	$1000-$177F	40/80 Text Page 1
00D1B8  2               ;	$1800-$1F7F	40/80 Color Page 1
00D1B8  2               ;	$2000-$277F	40/80 Text Page 2
00D1B8  2               ;	$2800-$2F7F	40/80 Color Page 2
00D1B8  2               ;	$2000-$5FFF	HIRES PAGE 1
00D1B8  2               ;	$6000-$8FFF	HIRES PAGE 2
00D1B8  2               ;	$2000-$BFFF	DOUBLE HIRES
00D1B8  2               ;*
00D1B8  2               
00D1B8  2               ;__VIDEOINIT____________________________________________________________________________________________________________________
00D1B8  2               ;
00D1B8  2               ;	INITIALIZE VIDEO CARD
00D1B8  2               ;________________________________________________________________________________________________________________________________
00D1B8  2               ;
00D1B8  2               VIDEOINIT:
00D1B8  2  A9 01                LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
00D1BA  2  A2 0B                LDX     #$0B            ; MAP $BXXX
00D1BC  2  A0 F8                LDY     #VIDEOBANK      ; TO $F8XXX
00D1BE  2  20 F6 FF             JSR     $FFF6           ; CALL SETPAGE
00D1C1  2               
00D1C1  2  A9 00                LDA     #$00
00D1C3  2  8D 06 B0             STA     $B006
00D1C6  2  AD 06 B0             LDA     $B006
00D1C9  2  C9 00                CMP     #$00
00D1CB  2  D0 64                BNE     VIDEOINIT_FAIL
00D1CD  2  A9 FF                LDA     #$FF
00D1CF  2  8D 06 B0             STA     $B006
00D1D2  2  AD 06 B0             LDA     $B006
00D1D5  2  C9 FF                CMP     #$FF
00D1D7  2  D0 58                BNE     VIDEOINIT_FAIL
00D1D9  2               
00D1D9  2  A9 02                LDA     #$02
00D1DB  2  8D 06 B0             STA     $B006           ; CLEAR LORES MODE
00D1DE  2  8D 07 B0             STA     $B007           ; CLEAR DOUBLE LORES MODE
00D1E1  2  8D 08 B0             STA     $B008           ; CLEAR HIRES MODE
00D1E4  2  8D 09 B0             STA     $B009           ; CLEAR DOUBLE HIRES MODE
00D1E7  2  8D 0B B0             STA     $B00B           ; CLEAR MIXED MODE
00D1EA  2  8D 0C B0             STA     $B00C           ; CLEAR QUAD HIRES MODE
00D1ED  2  8D 0D B0             STA     $B00D           ; CLEAR MONO MODE
00D1F0  2               
00D1F0  2  A9 01                LDA     #$01
00D1F2  2  8D 01 B0             STA     $B001           ; SET TEXT MODE PAGE 1
00D1F5  2  8D 05 B0             STA     $B005           ; SET TEXT MODE
00D1F8  2  A9 01                LDA     #$01
00D1FA  2  8D 0A B0             STA     $B00A           ; SET 80COL MODE
00D1FD  2               
00D1FD  2  A9 01                LDA     #$01
00D1FF  2  8D 49 06             STA     SHOWCRSR        ; SHOW CURSOR (1-YES, 0-NO)
00D202  2  A9 1E                LDA     #$1E
00D204  2  8D 4A 06             STA     CURCOLOR        ; CURRENT PRINT COLOR
00D207  2  A9 E1                LDA     #$E1
00D209  2  8D 4B 06             STA     CSRCOLOR        ; CURRENT CURSOR COLOR
00D20C  2  A9 01                LDA     #$01
00D20E  2  8D 4C 06             STA     VIDEOMODE       ; 00=40 COL, 01=80 COL
00D211  2               
00D211  2  20 79 D2             JSR     CLEARSCREEN
00D214  2               
00D214  2  20 6B D5             JSR     LFCR            ; CRLF
00D217  2  A9 21                LDA     #<VIDEOMESSAGE1 ;
00D219  2  85 41                STA     STRPTR          ;
00D21B  2  A9 D5                LDA     #>VIDEOMESSAGE1 ;
00D21D  2  85 42                STA     STRPTR+1        ;
00D21F  2  20 76 D5             JSR     WRSTR
00D222  2               
00D222  2  A9 47                LDA     #<VIDEOMESSAGE3 ;
00D224  2  85 41                STA     STRPTR          ;
00D226  2  A9 D5                LDA     #>VIDEOMESSAGE3 ;
00D228  2  85 42                STA     STRPTR+1        ;
00D22A  2  20 76 D5             JSR     WRSTR
00D22D  2  20 6B D5             JSR     LFCR            ; AND CRLF
00D230  2               
00D230  2  60                   RTS
00D231  2               
00D231  2               VIDEOINIT_FAIL:
00D231  2  20 6B D5             JSR     LFCR            ; CRLF
00D234  2  A9 21                LDA     #<VIDEOMESSAGE1 ;
00D236  2  85 41                STA     STRPTR          ;
00D238  2  A9 D5                LDA     #>VIDEOMESSAGE1 ;
00D23A  2  85 42                STA     STRPTR+1        ;
00D23C  2  20 76 D5             JSR     WRSTR
00D23F  2               
00D23F  2  A9 47                LDA     #<VIDEOMESSAGE3 ;
00D241  2  85 41                STA     STRPTR          ;
00D243  2  A9 D5                LDA     #>VIDEOMESSAGE3 ;
00D245  2  85 42                STA     STRPTR+1        ;
00D247  2  20 76 D5             JSR     WRSTR
00D24A  2  20 6B D5             JSR     LFCR            ; AND CRLF
00D24D  2  60                   RTS
00D24E  2               
00D24E  2               
00D24E  2               ;__SETMODE_______________________________________________________________________________________________________________________
00D24E  2               ;
00D24E  2               ;	SET 40/80 VIDEO MODE  (0=40/1=80)
00D24E  2               ;________________________________________________________________________________________________________________________________
00D24E  2               ;
00D24E  2               SETMODE:
00D24E  2  8D 4C 06             STA     VIDEOMODE
00D251  2  A9 01                LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
00D253  2  A2 0B                LDX     #$0B            ; MAP $BXXX
00D255  2  A0 F8                LDY     #VIDEOBANK      ; TO $F8XXX
00D257  2  20 F6 FF             JSR     $FFF6           ; CALL SETPAGE
00D25A  2  A9 01                LDA     #$01
00D25C  2  8D 01 B0             STA     $B001           ; SET TEXT MODE PAGE 1
00D25F  2  8D 05 B0             STA     $B005           ; SET TEXT MODE
00D262  2  AD 4C 06             LDA     VIDEOMODE
00D265  2  C9 00                CMP     #$00
00D267  2  F0 08                BEQ     :+
00D269  2  A9 01                LDA     #$01
00D26B  2  8D 0A B0             STA     $B00A           ; SET 80COL MODE
00D26E  2  4C 79 D2             JMP     CLEARSCREEN
00D271  2               :
00D271  2  A9 02                LDA     #$02
00D273  2  8D 0A B0             STA     $B00A           ; SET 40COL MODE
00D276  2  4C 79 D2             JMP     CLEARSCREEN
00D279  2               
00D279  2               
00D279  2               ;__CLEARSCREEN___________________________________________________________________________________________________________________
00D279  2               ;
00D279  2               ;	CLEAR VIDEO CARD SCREEN
00D279  2               ;________________________________________________________________________________________________________________________________
00D279  2               ;
00D279  2               CLEARSCREEN:
00D279  2  A9 01                LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
00D27B  2  A2 0B                LDX     #$0B            ; MAP $BXXX
00D27D  2  A0 F9                LDY     #VIDEOBANK+1    ; TO $F8XXX
00D27F  2  20 F6 FF             JSR     $FFF6           ; CALL SETPAGE
00D282  2               
00D282  2  A9 00                LDA     #$00
00D284  2  85 3B                STA     TEMPWORD
00D286  2  A9 B0                LDA     #$B0
00D288  2  85 3C                STA     TEMPWORD+1
00D28A  2  A0 00                LDY     #$00
00D28C  2               ; CLEAR CHAR RAM
00D28C  2               :
00D28C  2  A9 20                LDA     #32
00D28E  2  91 3B                STA     (TEMPWORD),Y
00D290  2  E6 3B                INC     TEMPWORD
00D292  2  D0 F8                BNE     :-
00D294  2  E6 3C                INC     TEMPWORD+1
00D296  2  A5 3C                LDA     TEMPWORD+1
00D298  2  C9 B8                CMP     #$B8
00D29A  2  D0 F0                BNE     :-
00D29C  2               ; CLEAR COLOR   RAM
00D29C  2               :
00D29C  2  AD 4A 06             LDA     CURCOLOR
00D29F  2  91 3B                STA     (TEMPWORD),Y
00D2A1  2  E6 3B                INC     TEMPWORD
00D2A3  2  D0 F7                BNE     :-
00D2A5  2  E6 3C                INC     TEMPWORD+1
00D2A7  2  A5 3C                LDA     TEMPWORD+1
00D2A9  2  C9 C0                CMP     #$C0
00D2AB  2  D0 EF                BNE     :-
00D2AD  2               
00D2AD  2  A9 00                LDA     #$00
00D2AF  2  8D 47 06             STA     CURX
00D2B2  2  8D 48 06             STA     CURY
00D2B5  2               
00D2B5  2  AD 4B 06             LDA     CSRCOLOR
00D2B8  2  8D 00 B8             STA     $B800
