00D09C  2               
00D09C  2               
00D09C  2               ;__RTC DRIVERS___________________________________________________________________________________________________________________
00D09C  2               ;
00D09C  2               ; 	DOS REAL TIME CLOCK drivers
00D09C  2               ;
00D09C  2               ;	Entry points:
00D09C  2               ;		DOSREADRTC   - called to RETURN RTC
00D09C  2               ;________________________________________________________________________________________________________________________________
00D09C  2               ;
00D09C  2               ;*
00D09C  2               ;* HARDWARE I/O ADDRESSES
00D09C  2               ;*
00D09C  2               RTCBASE         = PC6502_IOSPACE+$90;
00D09C  2               
00D09C  2               
00D09C  2               ;__RTC_WRITE____________________________________________________
00D09C  2               ; write a value to the RTC
00D09C  2               ; address in X
00D09C  2               ; value in Y
00D09C  2               ;_______________________________________________________________
00D09C  2               RTC_WRITE:
00D09C  2  E0 07                CPX     #7
00D09E  2  B0 43                BCS     :++
00D0A0  2  E0 06                CPX     #6
00D0A2  2  D0 01                BNE     :+
00D0A4  2  CA                   DEX
00D0A5  2               :
00D0A5  2  8C 96 D1             STY     RTCWORK
00D0A8  2  8A                   TXA
00D0A9  2  18                   CLC
00D0AA  2  2A                   ROL     A               ; ADDRESS * 2
00D0AB  2  29 0F                AND     #$0F            ; CLEAR UPPER BITS
00D0AD  2  AA                   TAX                     ; address in x
00D0AE  2  A9 02                LDA     #$02
00D0B0  2  8D 9F EF             STA     RTCBASE+$0F
00D0B3  2  AD 96 D1             LDA     RTCWORK         ; value in A
00D0B6  2  29 0F                AND     #$0F
00D0B8  2  9D 90 EF             STA     RTCBASE,X       ; SET LOW NIBBLE OF VALUE
00D0BB  2  E8                   INX
00D0BC  2  AD 96 D1             LDA     RTCWORK         ; value in A
00D0BF  2  29 F0                AND     #$F0
00D0C1  2  18                   CLC
00D0C2  2  6A                   ROR     A
00D0C3  2  6A                   ROR     A
00D0C4  2  6A                   ROR     A
00D0C5  2  6A                   ROR     A
00D0C6  2  9D 90 EF             STA     RTCBASE,X       ; SET HIGH NIBBLE OF VALUE
00D0C9  2  A9 00                LDA     #$00
00D0CB  2  8D 9D EF             STA     RTCBASE + $0D
00D0CE  2  8D 9E EF             STA     RTCBASE + $0E
00D0D1  2  A9 01                LDA     #$01
00D0D3  2  8D 9F EF             STA     RTCBASE + $0F
00D0D6  2  A9 05                LDA     #$05
00D0D8  2  8D 9F EF             STA     RTCBASE + $0F
00D0DB  2  A9 04                LDA     #$04
00D0DD  2  8D 9F EF             STA     RTCBASE + $0F
00D0E0  2  A9 00                LDA     #$00
00D0E2  2  60                   RTS
00D0E3  2               :
00D0E3  2  A9 FF                LDA     #$FF
00D0E5  2  60                   RTS
00D0E6  2               
00D0E6  2               
00D0E6  2               ;__RTC_READ______________________________________________________
00D0E6  2               ; read a value from the RTC
00D0E6  2               ; address in X
00D0E6  2               ; value in Y
00D0E6  2               ;_______________________________________________________________
00D0E6  2               RTC_READ:
00D0E6  2  E0 06                CPX     #6
00D0E8  2  D0 01                BNE     :+
00D0EA  2  CA                   DEX
00D0EB  2               :
00D0EB  2  8A                   TXA
00D0EC  2  18                   CLC                     ; CLEAR CARRY
00D0ED  2  2A                   ROL     A               ; ADDRESS * 2
00D0EE  2  29 0F                AND     #$0F            ; CLEAR UPPER BITS
00D0F0  2  AA                   TAX                     ; address in x
00D0F1  2  BD 90 EF             LDA     RTCBASE,X       ; GET LOW NIBBLE OF VALUE
00D0F4  2  29 0F                AND     #$0F
00D0F6  2  8D 96 D1             STA     RTCWORK
00D0F9  2  E8                   INX
00D0FA  2  BD 90 EF             LDA     RTCBASE,X       ; GET HIGH NIBBLE OF VALUE
00D0FD  2  2A                   ROL     A
00D0FE  2  2A                   ROL     A
00D0FF  2  2A                   ROL     A
00D100  2  2A                   ROL     A
00D101  2  29 F0                AND     #$F0
00D103  2  0D 96 D1             ORA     RTCWORK         ; return value in a
00D106  2  A8                   TAY
00D107  2  A9 00                LDA     #$00
00D109  2  60                   RTS
00D10A  2               
00D10A  2               ;_______________________________________________________________
00D10A  2               ; function RTC_BEEP
00D10A  2               ;
00D10A  2               ;_______________________________________________________________
00D10A  2               RTC_BEEP:
00D10A  2  60                   RTS                     ; NOT SUPPORTED NO HARDWARE
00D10B  2               
00D10B  2               ;_______________________________________________________________
00D10B  2               ; function RTC_BUTTON
00D10B  2               ;
00D10B  2               ;_______________________________________________________________
00D10B  2               RTC_BUTTON:
00D10B  2  A9 FF                LDA     #$FF
00D10D  2  60                   RTS                     ; NOT SUPPORTED NO HARDWARE
00D10E  2               
00D10E  2               ;_______________________________________________________________
00D10E  2               ; function RTC_LED
00D10E  2               ;
00D10E  2               ;_______________________________________________________________
00D10E  2               RTC_LED:
00D10E  2  60                   RTS                     ; NOT SUPPORTED NO HARDWARE
