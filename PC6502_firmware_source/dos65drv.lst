00CC22  2               ;__GETKEY__________________________________________________________________________________________
00CC22  2               ; Get char from Keyboard, return in A
00CC22  2               ;__________________________________________________________________________________________________
00CC22  2               KBD_GETKEY:
00CC22  2  20 64 CC             JSR     KBD_DECODE
00CC25  2  AD 56 D0             LDA     KBD_BUFFERPTR   ; GET CURRENT BUFFER LEN
00CC28  2  C9 00                CMP     #$00
00CC2A  2  D0 04                BNE     :+
00CC2C  2  A9 FF                LDA     #$FF            ;
00CC2E  2  38                   SEC
00CC2F  2  60                   RTS
00CC30  2               :
00CC30  2  8E 5C CC             STX     TMPX
00CC33  2  AE 56 D0             LDX     KBD_BUFFERPTR
00CC36  2  BD 57 D0             LDA     KBD_BUFFER,X
00CC39  2  CE 56 D0             DEC     KBD_BUFFERPTR
00CC3C  2  AE 5C CC             LDX     TMPX
00CC3F  2  18                   CLC
00CC40  2  60                   RTS
00CC41  2               
00CC41  2               ;__GETKEYB_________________________________________________________________________________________
00CC41  2               ; Get char from Keyboard, return in A (blocking)
00CC41  2               ;__________________________________________________________________________________________________
00CC41  2               KBD_GETKEYB:
00CC41  2  20 64 CC             JSR     KBD_DECODE
00CC44  2  AD 56 D0             LDA     KBD_BUFFERPTR   ; GET CURRENT BUFFER LEN
00CC47  2  C9 00                CMP     #$00
00CC49  2  F0 F6                BEQ     KBD_GETKEYB
00CC4B  2               
00CC4B  2  8E 5C CC             STX     TMPX
00CC4E  2  AE 56 D0             LDX     KBD_BUFFERPTR
00CC51  2  BD 57 D0             LDA     KBD_BUFFER,X
00CC54  2  CE 56 D0             DEC     KBD_BUFFERPTR
00CC57  2  AE 5C CC             LDX     TMPX
00CC5A  2  18                   CLC
00CC5B  2  60                   RTS
00CC5C  2               TMPX:
00CC5C  2  00                   .BYTE   00
00CC5D  2               
