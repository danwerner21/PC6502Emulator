00D4AD  2               GETVIDEOADDRESS:
00D4AD  2  AD 48 06             LDA     CURY
00D4B0  2  8D B2 D1             STA     VIDEOWORK
00D4B3  2  A9 00                LDA     #$00
00D4B5  2  8D B3 D1             STA     VIDEOWORK+1
00D4B8  2               
00D4B8  2  0E B2 D1             ASL     VIDEOWORK       ; TIMES 2
00D4BB  2  2E B3 D1             ROL     VIDEOWORK+1     ; TIMES 2
00D4BE  2  0E B2 D1             ASL     VIDEOWORK       ; TIMES 4
00D4C1  2  2E B3 D1             ROL     VIDEOWORK+1     ; TIMES 4
00D4C4  2  0E B2 D1             ASL     VIDEOWORK       ; TIMES 8
00D4C7  2  2E B3 D1             ROL     VIDEOWORK+1     ; TIMES 8
00D4CA  2               
00D4CA  2  AD B2 D1             LDA     VIDEOWORK       ; PARK THIS NUMBER FOR THE FUTURE
00D4CD  2  8D B4 D1             STA     VIDEOWORK+2
00D4D0  2  AD B3 D1             LDA     VIDEOWORK+1
00D4D3  2  8D B5 D1             STA     VIDEOWORK+3
00D4D6  2               
00D4D6  2  0E B2 D1             ASL     VIDEOWORK       ; TIMES 16
00D4D9  2  2E B3 D1             ROL     VIDEOWORK+1     ; TIMES 16
00D4DC  2  0E B2 D1             ASL     VIDEOWORK       ; TIMES 32
00D4DF  2  2E B3 D1             ROL     VIDEOWORK+1     ; TIMES 32
00D4E2  2               
00D4E2  2  18                   CLC                     ; ADD THE *32 VALUE WITH THE *8 VALUE TO GET *40 :)
00D4E3  2  AD B2 D1             LDA     VIDEOWORK
00D4E6  2  6D B4 D1             ADC     VIDEOWORK+2
00D4E9  2  8D B6 D1             STA     VIDEOWORK+4
00D4EC  2               
00D4EC  2  AD B3 D1             LDA     VIDEOWORK+1
00D4EF  2  6D B5 D1             ADC     VIDEOWORK+3
00D4F2  2  8D B7 D1             STA     VIDEOWORK+5
00D4F5  2               
00D4F5  2  AD B6 D1             LDA     VIDEOWORK+4     ; PLACE BACK IN VIDEOWORK(+1)
00D4F8  2  8D B2 D1             STA     VIDEOWORK
00D4FB  2  AD B7 D1             LDA     VIDEOWORK+5
00D4FE  2  8D B3 D1             STA     VIDEOWORK+1
00D501  2               
00D501  2  AD 4C 06             LDA     VIDEOMODE       ; IF 40 COLUMN, WE ARE DONE, OTHERWISE DOUBLE AGAIN
00D504  2  C9 00                CMP     #$00
00D506  2  F0 06                BEQ     :+
00D508  2  0E B2 D1             ASL     VIDEOWORK       ; TIMES 2
00D50B  2  2E B3 D1             ROL     VIDEOWORK+1     ; TIMES 2
00D50E  2               :
00D50E  2  18                   CLC                     ; NOW ADD IN X COORD
00D50F  2  AD 47 06             LDA     CURX
00D512  2  6D B2 D1             ADC     VIDEOWORK
00D515  2  8D B2 D1             STA     VIDEOWORK
00D518  2  A9 00                LDA     #$00
00D51A  2  6D B3 D1             ADC     VIDEOWORK+1
00D51D  2  8D B3 D1             STA     VIDEOWORK+1
00D520  2  60                   RTS
