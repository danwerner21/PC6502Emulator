00C795  2               
00C795  2               
00C795  2               ;__________________________________________________________________________________________________
00C795  2               ;
00C795  2               ; STATUS BITS (FOR KBD_STATUS)
00C795  2               ;
00C795  2               ESP0_RDY        = $01           ; BIT 0, ESP0 READY
00C795  2               ESP0_BUSY       = $02           ; BIT 1, ESP0 BUSY
00C795  2               ESP1_RDY        = $08           ; BIT 3, ESP1 READY
00C795  2               ESP1_BUSY       = $10           ; BIT 4, ESP1 BUSY
00C795  2               ;
