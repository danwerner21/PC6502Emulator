00D521  2  4D 45 4D 4F          .BYTE   "MEMORY MAPPED VIDEO:",$0D,$0A
00D525  2  52 59 20 4D  
00D529  2  41 50 50 45  
00D537  2  20 42 41 4E          .BYTE   " BANK=0xF8 "
00D53B  2  4B 3D 30 78  
00D53F  2  46 38 20     
00D542  2  00                   .BYTE   00
