00C796  2               ESPINIT:
00C796  2               ;
00C796  2  20 6B D5             JSR     LFCR            ; AND CRLF
00C799  2  A9 40                LDA     #<ESPMESSAGE1   ;
00C79B  2  85 41                STA     STRPTR          ;
00C79D  2  A9 CA                LDA     #>ESPMESSAGE1   ;
00C79F  2  85 42                STA     STRPTR+1        ;
00C7A1  2  20 76 D5             JSR     WRSTR
00C7A4  2  20 6B D5             JSR     LFCR            ; AND CRLF
00C7A7  2               ; KEYBOARD INITIALIZATION
00C7A7  2  A9 55                LDA     #<MESSAGE2      ;
00C7A9  2  85 41                STA     STRPTR          ;
00C7AB  2  A9 C3                LDA     #>MESSAGE2      ;
00C7AD  2  85 42                STA     STRPTR+1        ;
00C7AF  2  20 76 D5             JSR     WRSTR           ; DO PROMPT
00C7B2  2  A9 E1                LDA     #>ESP_BASE      ; GET BASE PORT
00C7B4  2  20 8B D5             JSR     PRINT_BYTE      ; PRINT BASE PORT
00C7B7  2  A9 00                LDA     #<ESP_BASE      ; GET BASE PORT
00C7B9  2  20 8B D5             JSR     PRINT_BYTE      ; PRINT BASE PORT
