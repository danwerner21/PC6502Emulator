00FB74  2                       .IFNDEF PC6502BIOS
00FB74  2               MESSAGE1:
00FB74  2                       .BYTE   "XT-IDE:"
00FB74  2                       .BYTE   00
00FB74  2               MESSAGE2:
00FB74  2                       .BYTE   " IO=0x"
00FB74  2                       .BYTE   00
00FB74  2               MESSAGE3:
00FB74  2                       .BYTE   " NOT PRESENT"
00FB74  2                       .BYTE   00
00FB74  2               MESSAGE4:
00FB74  2                       .BYTE   " XT-IDE0: BLOCKS="
00FB74  2                       .BYTE   00
00FB74  2               MESSAGE5:
00FB74  2                       .BYTE   " XT-IDE1: BLOCKS="
00FB74  2                       .BYTE   00
00FB74  2               MESSAGE6:
00FB74  2                       .BYTE   "0x"
00FB74  2                       .BYTE   00
00FB74  2               
00FB74  2               ;___IDE_CONVERT_SECTOR_LBA_______________________________________________________________________________
00FB74  2               ;
00FB74  2               ; 	TRANSLATE LBA SECTORS
00FB74  2               ;________________________________________________________________________________________________________
00FB74  2               IDE_CONVERT_SECTOR_LBA:
00FB74  2                       LDA     sektrk          ; LOAD TRACK # (LOW BYTE)
00FB74  2                       AND     #$0F            ; ISOLATE HEAD IN LOW 4 BITS
00FB74  2                       ASL     a               ; MOVE TO HIGH BYTE
00FB74  2                       ASL     a
00FB74  2                       ASL     a
00FB74  2                       ASL     a
00FB74  2                       TAX                     ; PARK IN X
00FB74  2                       LDA     seksec          ; LOAD SECTOR # (LOW BYTE)
00FB74  2                       LSR     A               ;
00FB74  2                       LSR     A               ; DIVIDE BY 4 (FOR BLOCKING)
00FB74  2                       AND     #$0F            ; CLEAR UPPER 4 BITS (JUST 'CAUSE)
00FB74  2                       STA     debsehd         ; STORE IN SECTOR/HEAD
00FB74  2                       TXA                     ; GET HEAD BACK
00FB74  2                       ORA     debsehd
00FB74  2                       STA     debsehd         ; STORE IN SECTOR/HEAD
00FB74  2               
00FB74  2                       LDA     sektrk
00FB74  2                       STA     debcyll         ; STORE IN TRACK (lsb)
00FB74  2                       LDA     sektrk+1
00FB74  2                       STA     debcylm         ; STORE IN TRACK (msb)
00FB74  2               ; REMOVE HEAD FROM TRACK VALUE (DIV/4)
00FB74  2                       LDA     debcylm
00FB74  2                       LSR     A
00FB74  2                       STA     debcylm
00FB74  2                       LDA     debcyll
00FB74  2                       ROR     A
00FB74  2                       STA     debcyll
00FB74  2               
00FB74  2                       LDA     debcylm
00FB74  2                       LSR     A
00FB74  2                       STA     debcylm
00FB74  2                       LDA     debcyll
00FB74  2                       ROR     A
00FB74  2                       STA     debcyll
00FB74  2               
00FB74  2                       LDA     debcylm
00FB74  2                       LSR     A
00FB74  2                       STA     debcylm
00FB74  2                       LDA     debcyll
00FB74  2                       ROR     A
00FB74  2                       STA     debcyll
00FB74  2               
00FB74  2                       LDA     debcylm
00FB74  2                       LSR     A
00FB74  2                       STA     debcylm
00FB74  2                       LDA     debcyll
00FB74  2                       ROR     A
00FB74  2                       STA     debcyll
00FB74  2               ;	ADD SLICE OFFSET
00FB74  2                       LDA     sekdsk          ; GET DRIVE#
00FB74  2                       AND     #7              ; ONLY FIRST 8 DEVICES SUPPORTED
00FB74  2                       ASL     a               ; DOUBLE NUMBER FOR TABLE LOOKUP
00FB74  2                       TAX                     ; MOVE TO X REGISTER
00FB74  2                       INX                     ; WANT SECOND BYTE OF ENTRY
00FB74  2                       LDA     dskcfg,X        ; GET SLICE#
00FB74  2                       STA     slicetmp+1      ; SLICE OFFSET MSB
00FB74  2                       LDA     #0              ; GET SLICE#
00FB74  2                       STA     slicetmp        ; SLICE OFFSET LSB
00FB74  2                       CLC                     ; VOODOO MATH TO TAKE SLICE*$4000
00FB74  2                       ROR     slicetmp+1
00FB74  2                       ROR     slicetmp
00FB74  2                       ROR     slicetmp+1
00FB74  2                       ROR     slicetmp
00FB74  2               
00FB74  2                       LDA     dskcfg,X        ; GET SLICE#
00FB74  2                       CLC
00FB74  2                       ADC     slicetmp
00FB74  2                       STA     slicetmp
00FB74  2                       LDA     #$00            ; LOGIC ERROR FOR SLICES THAT CARRY?
00FB74  2                       ADC     slicetmp+1      ;
00FB74  2                       STA     slicetmp+1      ;
00FB74  2               
00FB74  2               ; ADD SLICE OFFSET TO TRACK #
00FB74  2                       LDA     slicetmp
00FB74  2                       ADC     debcyll
00FB74  2                       STA     debcyll         ; store sum of LSBs
00FB74  2                       LDA     slicetmp+1
00FB74  2                       ADC     debcylm         ; add the MSBs using carry from
00FB74  2                       STA     debcylm         ; the previous calculation
00FB74  2                       RTS
00FB74  2               
00FB74  2                       .ENDIF
00FB74  2               
00FB74  2               ;*__IDE_SETUP_LBA_____________________________________________________________________________________
00FB74  2               ;*
00FB74  2               ;*  SETUP LBA DATA
