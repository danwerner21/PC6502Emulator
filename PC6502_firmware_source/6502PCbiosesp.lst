00FE27  2               
00FE27  2               ;__SETPAGE________________________________________________________
00FE27  2               ;
00FE27  2               ; SETUP MMU FOR A SPECIFIC MAPPED PAGE
00FE27  2               ;
00FE27  2               ; A=BANK TO SWAP
00FE27  2               ; X=MAP PAGE (SPOT IN MEMORY MAP)
00FE27  2               ; Y=DESTINATION PAGE (SPOT IN PHYSICAL MEMORY)
00FE27  2               ;_______________________________________________________________
00FE27  2               SETPAGE:
00FE27  2  85 3B                STA     TEMPWORD
00FE29  2  A9 00                LDA     #$00            ; DISABLE MMU
00FE2B  2  8D E2 EF             STA     PC6502_MMU_ENA
00FE2E  2  A5 3B                LDA     TEMPWORD
00FE30  2  8D E1 EF             STA     PC6502_MAP_SETUP; Fill TASK AREA
00FE33  2  98                   TYA
00FE34  2  9D D0 EF             STA     PC6502_MAP_SPACE,X
00FE37  2  A9 00                LDA     #$00            ; RE-SETUP TASK AREA 0, JUST IN CASE THE ABOVE WRITE CORRUPTED IT
00FE39  2  8D E1 EF             STA     PC6502_MAP_SETUP; Fill TASK AREA
00FE3C  2  8A                   TXA
00FE3D  2  9D D0 EF             STA     PC6502_MAP_SPACE,X
00FE40  2  A9 01                LDA     #$01
00FE42  2  8D E2 EF             STA     PC6502_MMU_ENA  ; ENABLE MMU --- FEEEEEL THE POOOOWERRRR
00FE45  2  60                   RTS
00FE46  2               
00FE46  2               
00FE46  2               
00FE46  2               
00FE46  2               DO_FARCALL_ACTUAL:
00FE46  2  20 1F FE             JSR     PAGE_ENTER
00FE49  2  20 00 C0             JSR     FUNCTION_DISPATCHER
00FE4C  2  4C 17 FE             JMP     PAGE_EXIT
00FE4F  2               
