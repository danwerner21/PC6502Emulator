00FC14  2  8D 12 06             STA     debsehd         ;
00FC17  2  8D 3D 06             STA     currentDrive    ;
00FC1A  2  85 EE                STA     SRC             ; SETUP SOURCE AND DEST POINTERS
00FC1C  2  85 EC                STA     DEST
00FC1E  2  A9 08                LDA     #$08
00FC20  2  85 EF                STA     SRC+1
00FC22  2  A9 04                LDA     #$04
00FC24  2  85 ED                STA     DEST+1
00FC26  2               
