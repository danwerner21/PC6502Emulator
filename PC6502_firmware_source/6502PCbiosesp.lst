00FDE1  1               
00FDE1  1                       .INCLUDE "bios_pager.ASM"
00FDE1  2               ;__BIOS PAGERS__________________________________________________________________________________________________________________
00FDE1  2               ;
00FDE1  2               ; 	Memory Page Management Functions
00FDE1  2               ;
00FDE1  2               ;________________________________________________________________________________________________________________________________
00FDE1  2               ;
00FDE1  2               
00FDE1  2               ;__INITPAGES____________________________________________________
00FDE1  2               ;
00FDE1  2               ; SETUP MMU FOR BIOS PAGED MEMORY OPERATION
00FDE1  2               ;
00FDE1  2               ; SETUP:
00FDE1  2               ; 	TASK 0, NORMAL OPERATION
00FDE1  2               ;       TASK 1, ADDITIONAL RAM PAGED INTO C000-D000 (10,11)
00FDE1  2               ;	TASKS 2-15 -- OPEN FOR OS/USER USE
00FDE1  2               ;_______________________________________________________________
00FDE1  2               ;  The 6502PC has a flexible hardware MMU. There are 64 programmable task contexts, each with 16 4K banks ($BXXX).
00FDE1  2               ;  The MMU has several Registers.
00FDE1  2               ;     $xFE0- Write only-Task Register, Sets which context is active, when the mmu is enabled (0-63)
00FDE1  2               ;     $xFE1- Write only-Setup Register, Sets which context is being setup (exposed in the edit window) (0-63)
00FDE1  2               ;     $xFE2- Write only-Enable Register 0=MMU Disabled, 1=MMU Enabled
00FDE1  2               ;     $xFE4- Read Only- Active Task Register (only lower 6 bits)
00FDE1  2               ;     $xFE6- Read Only- hit ISA TC Bit
00FDE1  2               ;     $xFE7- Read Only- Current IO Page (only lower 4 bits)
00FDE1  2               ;
00FDE1  2               ;     $xfDx- read or write task edit window
00FDE1  2               ;
00FDE1  2               ;_______________________________________________________________
00FDE1  2               INITPAGES:
00FDE1  2  A9 00                LDA     #$00            ; ENSURE MMU IS DISABLED (SHOULD BE ALREADY, BUT . . . )
00FDE3  2  8D E2 EF             STA     PC6502_MMU_ENA
00FDE6  2  A9 01                LDA     #$01
00FDE8  2  8D E1 EF             STA     PC6502_MAP_SETUP; Fill TASK 1
00FDEB  2  20 0B FE             JSR     INITPAGE        ; FILL TASK 1 WITH A 1:1 MAP
00FDEE  2  A9 10                LDA     #$10            ; BUT, MAP Cxxx AND Dxxx TO RAM 10xxx AND 11xxx RATHER THAN RAM
00FDF0  2  8D DC EF             STA     PC6502_MAP_SPACE+$0C
00FDF3  2  A9 11                LDA     #$11
00FDF5  2  8D DD EF             STA     PC6502_MAP_SPACE+$0D
00FDF8  2  A9 00                LDA     #$00
00FDFA  2  8D E1 EF             STA     PC6502_MAP_SETUP; Then do task 0
00FDFD  2  20 0B FE             JSR     INITPAGE        ; FILL TASK 0 WITH A 1:1 MAP
00FE00  2               ;  Why task 1 before task 0??   On some boards every write to the register also writes to task 0
00FE00  2               ;  so it is important to write task 0 last (or not use it)
00FE00  2  A9 00                LDA     #$00
00FE02  2  8D E0 EF             STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
00FE05  2  A9 01                LDA     #$01
00FE07  2  8D E2 EF             STA     PC6502_MMU_ENA  ; ENABLE MMU --- FEEEEEL THE POOOOWERRRR
00FE0A  2  60                   RTS
00FE0B  2               
00FE0B  2               INITPAGE:
00FE0B  2  A2 00                LDX     #$00
00FE0D  2               :
00FE0D  2  8A                   TXA
00FE0E  2  9D D0 EF             STA     PC6502_MAP_SPACE,X; CREATE A 1:1 MAP OF BANK
00FE11  2  E8                   INX
00FE12  2  E0 10                CPX     #$10
00FE14  2  D0 F7                BNE     :-
00FE16  2  60                   RTS
00FE17  2               PAGE_EXIT:
00FE17  2  48                   PHA
00FE18  2  A9 00                LDA     #$00
00FE1A  2  8D E0 EF             STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
00FE1D  2  68                   PLA
00FE1E  2  60                   RTS
00FE1F  2               PAGE_ENTER:
00FE1F  2  48                   PHA
00FE20  2  A9 01                LDA     #$01
00FE22  2  8D E0 EF             STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
00FE25  2  68                   PLA
00FE26  2  60                   RTS
