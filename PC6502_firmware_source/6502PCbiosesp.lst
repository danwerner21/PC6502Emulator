00FE6F  1               ;__OUTSTR______________________________________________________
00FE6F  1               ;
00FE6F  1               ; OUTPUT THE STRING POINTED TO BY OUTSTR TO THE SCREEN
00FE6F  1               ;
00FE6F  1               ;______________________________________________________________
00FE6F  1               OUTSTR:
00FE6F  1  A0 00                LDY     #$00            ; LOAD $00 INTO Y
00FE71  1               OUTSTRLP:
00FE71  1  B1 41                LDA     (STRPTR),Y      ; LOAD NEXT CHAR FROM STRING INTO ACC
00FE73  1  C9 00                CMP     #$00            ; IS NULL?
00FE75  1  F0 0C                BEQ     ENDOUTSTR       ; YES, END PRINT OUT
00FE77  1  20 4F FE             JSR     IOF_OUTCH       ; PRINT CHAR IN ACC
00FE7A  1  E6 41                INC     STRPTR
00FE7C  1  D0 F3                BNE     OUTSTRLP
00FE7E  1  E6 42                INC     STRPTR+1
00FE80  1  4C 71 FE             JMP     OUTSTRLP        ; DO NEXT CHAR
00FE83  1               ENDOUTSTR:
00FE83  1  60                   RTS                     ; RETURN
