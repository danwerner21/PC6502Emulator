00FBA2  2  8D 11 06             STA     debcylm         ;
00FBA5  2  8D 12 06             STA     debsehd         ;
00FBA8  2  8D 3D 06             STA     currentDrive    ;
00FBAB  2  85 EE                STA     SRC             ; SETUP SOURCE AND DEST POINTERS
00FBAD  2  85 EC                STA     DEST
00FBAF  2  A9 04                LDA     #$04
