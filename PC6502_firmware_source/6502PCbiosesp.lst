00F8A1  2               ; -----------------------------------------------------------------------------
00F8A1  2               ; addressing mode table - nybbles provide index into MODE2 table
00F8A1  2               ; for opcodes XXXXXXY0, use XXXXXX as index into table
00F8A1  2               ; for opcodes WWWXXY01  use $40 + XX as index into table
00F8A1  2               ; use right nybble if Y=0; use left nybble if Y=1
00F8A1  2               
00F8A1  2               MODE:
00F8A1  2  40 02 45 03          .BYTE   $40,$02,$45,$03 ; even opcodes
00F8A5  2  D0 08 40 09          .BYTE   $D0,$08,$40,$09
00F8A9  2  30 22 45 33          .BYTE   $30,$22,$45,$33
00F8AD  2  D0 08 40 09          .BYTE   $D0,$08,$40,$09
00F8B1  2  40 02 45 33          .BYTE   $40,$02,$45,$33
00F8B5  2  D0 08 40 09          .BYTE   $D0,$08,$40,$09
00F8B9  2  40 02 45 B3          .BYTE   $40,$02,$45,$B3
00F8BD  2  D0 08 40 09          .BYTE   $D0,$08,$40,$09
00F8C1  2  00 22 44 33          .BYTE   $00,$22,$44,$33
00F8C5  2  D0 8C 44 00          .BYTE   $D0,$8C,$44,$00
00F8C9  2  11 22 44 33          .BYTE   $11,$22,$44,$33
00F8CD  2  D0 8C 44 9A          .BYTE   $D0,$8C,$44,$9A
00F8D1  2  10 22 44 33          .BYTE   $10,$22,$44,$33
00F8D5  2  D0 08 40 09          .BYTE   $D0,$08,$40,$09
00F8D9  2  10 22 44 33          .BYTE   $10,$22,$44,$33
00F8DD  2  D0 08 40 09          .BYTE   $D0,$08,$40,$09
00F8E1  2  62 13 78 A9          .BYTE   $62,$13,$78,$A9 ; opcodes ending in 01
00F8E5  2               
00F8E5  2               ; addressing mode format definitions indexed by nybbles from MODE table
00F8E5  2               
00F8E5  2               ; left 6 bits define which characters appear in the assembly operand
00F8E5  2               ; left 3 bits are before the address; next 3 bits are after
00F8E5  2               
00F8E5  2               ; right-most 2 bits define length of binary operand
00F8E5  2               
00F8E5  2               ; index               654 321
00F8E5  2               ; 1st character       $(# ,),
00F8E5  2               ; 2nd character        $$ X Y    length  format      idx mode
00F8E5  2               MODE2:
00F8E5  2  00                   .BYTE   $00             ; 000 000    00                  0   error
00F8E6  2  21                   .BYTE   $21             ; 001 000    01      #$00        1   immediate
00F8E7  2  81                   .BYTE   $81             ; 100 000    01      $00         2   zero-page
00F8E8  2  82                   .BYTE   $82             ; 100 000    10      $0000       3   absolute
00F8E9  2  00                   .BYTE   $00             ; 000 000    00                  4   implied
00F8EA  2  00                   .BYTE   $00             ; 000 000    00                  5   accumulator
00F8EB  2  59                   .BYTE   $59             ; 010 110    01      ($00,X)     6   indirect,X
00F8EC  2  4D                   .BYTE   $4D             ; 010 011    01      ($00),Y     7   indirect,Y
00F8ED  2  91                   .BYTE   $91             ; 100 100    01      $00,X       8   zero-page,X
00F8EE  2  92                   .BYTE   $92             ; 100 100    10      $0000,X     9   absolute,X
00F8EF  2  86                   .BYTE   $86             ; 100 001    10      $0000,Y     A   absolute,Y
00F8F0  2  4A                   .BYTE   $4A             ; 010 010    10      ($0000)     B   indirect
00F8F1  2  85                   .BYTE   $85             ; 100 001    01      $00,Y       C   zero-page,Y
00F8F2  2  9D                   .BYTE   $9D             ; 100 111    01      $0000*      D   relative
00F8F3  2               
00F8F3  2               ; * relative is special-cased so format bits don't match
00F8F3  2               
00F8F3  2               
00F8F3  2               ; character lookup tables for the format definitions in MODE2
00F8F3  2               
00F8F3  2               CHAR1:
