00F8F6  2  23 28 24             .BYTE   $23,$28,$24     ; "#"  "("  "$"
00F8F9  2               
00F8F9  2               CHAR2:
00F8F9  2  59 00 58             .BYTE   $59,$00,$58     ; "Y"   0   "X"
00F8FC  2  24 24 00             .BYTE   $24,$24,$00     ; "$"  "$"   0
