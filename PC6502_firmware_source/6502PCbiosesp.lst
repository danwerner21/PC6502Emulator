00FBCF  2  91 EC                STA     (DEST),Y
00FBD1  2  C8                   INY
00FBD2  2  C0 00                CPY     #$00
00FBD4  2  D0 F7                BNE     :-
00FBD6  2  E6 ED                INC     DEST+1
00FBD8  2  A9 04                LDA     #$04
00FBDA  2  85 EF                STA     SRC+1
00FBDC  2  EE 12 06             INC     debsehd
00FBDF  2  A5 ED                LDA     DEST+1
00FBE1  2  C9 80                CMP     #$80
00FBE3  2  D0 D2                BNE     BOOT1
00FBE5  2  4C 00 08             JMP     $0800
00FBE8  2               BOOTX:
00FBE8  2  4C D9 F0             JMP     ERROR           ; back to main loop
00FBEB  2               
