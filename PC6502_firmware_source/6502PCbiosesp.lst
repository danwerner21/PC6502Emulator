00F7AF  2               NZERO:
00F7AF  2  E6 CB                INC     DIGCNT          ; increment digit counter
00F7B1  2  09 30                ORA     #$30            ; add numeric value to ascii '0' to get ascii char
00F7B3  2  20 4F FE             JSR     CHROUT          ; output character
00F7B6  2               ZERSUP:
00F7B6  2  CA                   DEX                     ; decrement number of leading zeros
00F7B7  2  D0 DD                BNE     DIGOUT          ; next digit
00F7B9  2  60                   RTS
00F7BA  2               
00F7BA  2               
00F7BA  2               ; -----------------------------------------------------------------------------
00F7BA  2               ; print and clear routines
00F7BA  2               CLINE:
00F7BA  2  20 45 F6             JSR     CRLF
00F7BD  2  4C C3 F7             JMP     SNCLR           ; clear line
00F7C0  2               SNDCLR:
00F7C0  2  20 D3 F7             JSR     SNDMSG
00F7C3  2               SNCLR:
00F7C3  2  A0 28                LDY     #$28            ; loop 40 times
00F7C5  2               SNCLP:
00F7C5  2  A9 20                LDA     #$20            ; output space character
00F7C7  2  20 4F FE             JSR     CHROUT
00F7CA  2  88                   DEY
00F7CB  2  D0 F8                BNE     SNCLP
00F7CD  2  A9 0D                LDA     #13             ; output CR
00F7CF  2  20 4F FE             JSR     CHROUT          ; send CR
00F7D2  2  60                   RTS
00F7D3  2               
00F7D3  2               ; -----------------------------------------------------------------------------
00F7D3  2               ; display message from table
00F7D3  2               SNDMSG:
00F7D3  2  B9 6E F8             LDA     MSGBAS,Y        ; Y contains offset in msg table
00F7D6  2  08                   PHP
00F7D7  2  29 7F                AND     #$7F            ; strip high bit before output
00F7D9  2  20 41 F6             JSR     CHOUT
00F7DC  2  C8                   INY
00F7DD  2  28                   PLP
00F7DE  2  10 F3                BPL     SNDMSG          ; loop until high bit is set
00F7E0  2  60                   RTS
00F7E1  2               
00F7E1  2               ; -----------------------------------------------------------------------------
00F7E1  2               ; check for stop key
00F7E1  2               STOP:
00F7E1  2  20 57 FE             JSR     IOF_CONIN
00F7E4  2  C9 03                CMP     #$03
00F7E6  2  F0 03                BEQ     :+
00F7E8  2  A9 FF                LDA     #$FF
00F7EA  2  60                   RTS
00F7EB  2               :
00F7EB  2  A9 00                LDA     #$00
00F7ED  2  60                   RTS
00F7EE  2               
00F7EE  2               ; -----------------------------------------------------------------------------
00F7EE  2               ; LOAD A MOTOROLA FORMATTED HEX FILE
00F7EE  2               LOADS19:
00F7EE  2  20 63 FE             JSR     IOF_CONINW      ;
00F7F1  2  C9 53                CMP     #'S'            ;
00F7F3  2  D0 F9                BNE     LOADS19         ; FIRST CHAR NOT (S)
00F7F5  2  20 63 FE             JSR     IOF_CONINW      ; READ CHAR
00F7F8  2  C9 39                CMP     #'9'            ;
00F7FA  2  F0 33                BEQ     LOAD21          ;
00F7FC  2  C9 31                CMP     #'1'            ;
00F7FE  2  D0 EE                BNE     LOADS19         ; SECOND CHAR NOT (1)
00F800  2  A9 00                LDA     #$00            ;
00F802  2  85 BC                STA     CKSM            ; ZERO CHECKSUM
00F804  2  20 30 F8             JSR     S19GETBYTE      ; READ BYTE
00F807  2  E9 01                SBC     #$01            ;
00F809  2  85 CB                STA     DIGCNT          ; BYTE COUNT
00F80B  2  20 5D F8             JSR     BADDR           ; BUILD ADDRESS
00F80E  2  A0 00                LDY     #$00            ;
00F810  2               LOAD11:
00F810  2  20 30 F8             JSR     S19GETBYTE      ;
00F813  2  C6 CB                DEC     DIGCNT          ;
00F815  2  F0 0F                BEQ     LOAD15          ; ZERO BYTE COUNT
00F817  2  91 BD                STA     (LOADADR),Y     ; STORE DATA
00F819  2  E6 BD                INC     LOADADR         ; INCREMENT LOWBYTE
00F81B  2  A5 BD                LDA     LOADADR
00F81D  2  C9 00                CMP     #$00
00F81F  2  D0 EF                BNE     LOAD11          ; NOT ZERO?, LOOP
00F821  2  E6 BE                INC     LOADADR+1       ; ZERO, INC HIGH BYTE
00F823  2  4C 10 F8             JMP     LOAD11          ;
00F826  2               
00F826  2               LOAD15:
00F826  2  E6 BC                INC     CKSM            ;
00F828  2  F0 C4                BEQ     LOADS19         ;
00F82A  2               LOAD19:
00F82A  2  A9 3F                LDA     #'?'            ;
00F82C  2  20 4F FE             JSR     IOF_OUTCH       ;
00F82F  2               LOAD21:
00F82F  2  60                   RTS
00F830  2               S19GETBYTE:
00F830  2  20 48 F8             JSR     INHEX           ; GET HEX CHAR
00F833  2  0A                   ASL                     ;
00F834  2  0A                   ASL                     ;
00F835  2  0A                   ASL                     ;
00F836  2  0A                   ASL                     ;
00F837  2  85 BF                STA     LOADWRK         ;
00F839  2  20 48 F8             JSR     INHEX           ;
00F83C  2  29 0F                AND     #$0F            ; MASK TO 4 BITS
00F83E  2  05 BF                ORA     LOADWRK         ;
00F840  2  48                   PHA                     ;
00F841  2  18                   CLC                     ;
00F842  2  65 BC                ADC     CKSM            ;
00F844  2  85 BC                STA     CKSM            ;
00F846  2  68                   PLA                     ;
00F847  2  60                   RTS                     ;
00F848  2               ; INPUT HEX CHAR
00F848  2               INHEX:
00F848  2  20 63 FE             JSR     IOF_CONINW      ;
00F84B  2  48                   PHA                     ;
00F84C  2  20 4F FE             JSR     IOF_OUTCH       ;
00F84F  2  68                   PLA                     ;
00F850  2  C9 3A                CMP     #$3A            ; LESS THAN 9?
00F852  2  B0 02                BCS     INHEX_BIG       ; NO, SKIP NEXT
00F854  2  E9 2F                SBC     #$2F            ; CONVERT 0-9
00F856  2               INHEX_BIG:
00F856  2  C9 41                CMP     #$41            ; A OR MORE?
00F858  2  90 02                BCC     INHEX_SMALL     ; NO, SKIP NEXT
00F85A  2  E9 37                SBC     #$37            ; CONVERT A-F
00F85C  2               INHEX_SMALL:
00F85C  2  60                   RTS                     ;
00F85D  2               ; BUILD ADDRESS
00F85D  2               BADDR:
00F85D  2  20 30 F8             JSR     S19GETBYTE      ; READ 2 FRAMES
00F860  2  85 BE                STA     LOADADR+1       ;
00F862  2  20 30 F8             JSR     S19GETBYTE      ;
00F865  2  85 BD                STA     LOADADR         ;
00F867  2  60                   RTS
00F868  2               LOAD:
00F868  2  20 EE F7             JSR     LOADS19
00F86B  2  4C 8A F0             JMP     STRT            ; back to main loop
00F86E  2               
00F86E  2               
00F86E  2               ; -----------------------------------------------------------------------------
00F86E  2               ; message table; last character has high bit set
00F86E  2               MSGBAS:
00F86E  2               
00F86E  2               MSG2:
00F86E  2  0D                   .BYTE   $0D             ; header for registers
00F86F  2  20 20 20 50          .BYTE   "   PC  SR AC XR YR SP   V1.2"
00F873  2  43 20 20 53  
00F877  2  52 20 41 43  
00F88B  2  8D                   .BYTE   $0D+$80
00F88C  2               MSG3:
00F88C  2  20 BF                .BYTE   $20,$3F+$80     ; syntax error: move right, display "?"
00F88E  2               MSG4:
00F88E  2  2E 2E 53 59          .BYTE   "..SYS"         ; SYS call to enter monitor
00F892  2  53           
00F893  2  A0                   .BYTE   $20+$80
00F894  2               MSG5:
00F894  2  3A A0                .BYTE   $3A,$20+$80     ; ":" then RVS ON for memory ASCII dump
00F896  2               MSG6:
00F896  2  20 45 52 52          .BYTE   " ERRO"         ; I/O error: display " ERROR"
00F89A  2  4F           
00F89B  2  D2                   .BYTE   'R'+$80
00F89C  2               MSG7:
00F89C  2  41 A0                .BYTE   $41,$20+$80     ; assemble next instruction: "A " + addr
00F89E  2               MSG8:
00F89E  2  20 20                .BYTE   "  "            ; pad non-existent byte: skip 3 spaces
00F8A0  2  A0                   .BYTE   $20+$80
