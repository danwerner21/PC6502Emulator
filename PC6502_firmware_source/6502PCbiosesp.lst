00FE57  1               ;______________________________________________________________
00FE57  1               IOF_CONIN:
00FE57  1  A5 3A                LDA     CONSOLE
00FE59  1  C9 09                CMP     #$09
00FE5B  1  D0 03                BNE     :+
00FE5D  1                       .IFDEF ESP
00FE5D  1  4C E9 FC             JMP     ESPPS2IN
00FE60  1                       .ENDIF
00FE60  1               :
00FE60  1  4C DC F9             JMP     RDSER1
