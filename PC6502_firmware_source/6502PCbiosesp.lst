00FE63  1               ;
00FE63  1               ; OUTPUT THE STRING POINTED TO BY OUTSTR TO THE SCREEN
00FE63  1               ;
00FE63  1               ;______________________________________________________________
00FE63  1               IOF_CONINW:
00FE63  1  A5 3A                LDA     CONSOLE
00FE65  1  C9 09                CMP     #$09
00FE67  1  D0 03                BNE     :+
00FE69  1                       .IFDEF ESP
00FE69  1  4C FD FC             JMP     ESPPS2INW
00FE6C  1                       .ENDIF
00FE6C  1               :
00FE6C  1  4C EA F9             JMP     RDSER1W
