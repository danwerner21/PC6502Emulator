00FCDE  1               
00FCDE  1                       .IFDEF ESP
00FCDE  1                       .INCLUDE "bios_esp.asm"
00FCDE  2               ;__ESP DRIVERS______________________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ; 	CUBIX ISA DUAL ESP IO drivers for 6809PC
00FCDE  2               ;
00FCDE  2               ;	Entry points:
00FCDE  2               ;		ESPINIT     - INIT HARDWARE
00FCDE  2               ;		ESPVIDEOOUT - OUTPUT A CHARACTER TO VIDEO (ANSI)
00FCDE  2               ;               ESPPS2IN    - read a character from the ps/2 keyboard ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPPS2BUFL  - return number of characters in the keyboard buffer in 'A'
00FCDE  2               ;               ESPCURSORV  - Set Cursor Visibility (A=0 cursor off, A=1 cursor on)
00FCDE  2               ;		ESPSER0OUT  - OUTPUT A CHARACTER TO Serial 0 ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPSER0IN   - read a character from Serial 0 ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPSER0BUFL - return number of characters in the Serial 0 buffer in 'A'
00FCDE  2               ;		ESPSER1OUT  - OUTPUT A CHARACTER TO Serial 1 ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPSER1IN   - read a character from Serial 1 ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPSER1BUFL - return number of characters in the Serial 1 buffer in 'A'
00FCDE  2               ;		ESPNETCOUT  - OUTPUT A CHARACTER TO Network Console Connection ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPNETCIN   - read a character from Network Console Connection ('A' POINTS TO BYTE)
00FCDE  2               ;               ESPNETCBUFL - return number of characters in the Network Connection buffer in 'A'
00FCDE  2               ;               PUTESP0     - put opcode/data to ESP0
00FCDE  2               ;               PUTESP1     - put opcode/data to ESP1
00FCDE  2               ;               GETESP0     - get opcode/data from ESP0
00FCDE  2               ;               GETESP1     - get opcode/data from ESP1
00FCDE  2               ;________________________________________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ;*
00FCDE  2               ;*        HARDWARE I/O ADDRESSES
00FCDE  2               ;*
00FCDE  2               ;
00FCDE  2               ESP_BASE        = PC6502_IO+$100
00FCDE  2               ESP0_DAT        = ESP_BASE      ;
00FCDE  2               ESP1_DAT        = ESP_BASE+1    ;
00FCDE  2               ESP_STAT        = ESP_BASE+2    ;
00FCDE  2               
00FCDE  2               
00FCDE  2               
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ; STATUS BITS (FOR KBD_STATUS)
00FCDE  2               ;
00FCDE  2               ESP0_RDY        = $01           ; BIT 0, ESP0 READY
00FCDE  2               ESP0_BUSY       = $02           ; BIT 1, ESP0 BUSY
00FCDE  2               ESP1_RDY        = $08           ; BIT 3, ESP1 READY
00FCDE  2               ESP1_BUSY       = $10           ; BIT 4, ESP1 BUSY
00FCDE  2               ;
00FCDE  2                       .IFNDEF PC6502BIOS
00FCDE  2               ;
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; DATA
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               consoleConnect:
00FCDE  2                       .BYTE   00
00FCDE  2               ;
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESP IO INITIALIZATION
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPINIT:
00FCDE  2               ;
00FCDE  2                       JSR     LFCR            ; AND CRLF
00FCDE  2                       LDA     #<ESPMESSAGE1   ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>ESPMESSAGE1   ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR
00FCDE  2                       JSR     LFCR            ; AND CRLF
00FCDE  2               ; KEYBOARD INITIALIZATION
00FCDE  2                       LDA     #<MESSAGE2      ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>MESSAGE2      ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR           ; DO PROMPT
00FCDE  2                       LDA     #>ESP_BASE      ; GET BASE PORT
00FCDE  2                       JSR     PRINT_BYTE      ; PRINT BASE PORT
00FCDE  2                       LDA     #<ESP_BASE      ; GET BASE PORT
00FCDE  2                       JSR     PRINT_BYTE      ; PRINT BASE PORT
00FCDE  2                       JSR     LFCR            ; AND CRLF
00FCDE  2                       JSR     ESP_RESET0      ;
00FCDE  2                       JSR     ESP_RESET1      ;
00FCDE  2               ;
00FCDE  2                       JSR     ESP0_PROBE      ; DETECT ESP0
00FCDE  2                       JSR     LFCR            ; AND CRLF
00FCDE  2                       JSR     ESP1_PROBE      ; DETECT ESP1
00FCDE  2                       JSR     LFCR            ; AND CRLF
00FCDE  2                       RTS                     ; DONE
00FCDE  2               
00FCDE  2               
00FCDE  2               ESP0_PROBE:
00FCDE  2               ;
00FCDE  2                       LDA     #<ESPMESSAGE2   ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>ESPMESSAGE2   ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR
00FCDE  2               
00FCDE  2                       LDA     #$FF            ; ESP IDENTITY PROBE
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2               
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'E'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'S'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'P'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'3'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'2'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'V'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP0
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'1'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       LDA     #<ESPMESSAGE5   ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>ESPMESSAGE5   ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR
00FCDE  2               
00FCDE  2               ESP_RESET0:
00FCDE  2                       LDX     #$20
00FCDE  2               :
00FCDE  2                       LDA     #00
00FCDE  2                       JSR     PUTESP0
00FCDE  2                       DEX
00FCDE  2                       CPX     #$00
00FCDE  2                       BNE     :-
00FCDE  2                       CLC
00FCDE  2                       RTS
00FCDE  2               ;
00FCDE  2               ;
00FCDE  2               ESP_ERROR:
00FCDE  2                       LDA     #<ESPMESSAGE4   ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>ESPMESSAGE4   ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR
00FCDE  2                       RTS
00FCDE  2               
00FCDE  2               ;
00FCDE  2               ESP1_PROBE:
00FCDE  2               ;
00FCDE  2                       LDA     #<ESPMESSAGE3   ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>ESPMESSAGE3   ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR
00FCDE  2               
00FCDE  2                       LDA     #$FF            ; ESP IDENTITY PROBE
00FCDE  2                       JSR     PUTESP1         ; SEND IT
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2               
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'E'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'S'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'P'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'3'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'2'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'V'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       JSR     GETESP1
00FCDE  2                       BCS     ESP_ERROR
00FCDE  2                       CMP     #'1'
00FCDE  2                       BNE     ESP_ERROR
00FCDE  2                       LDA     #<ESPMESSAGE5   ;
00FCDE  2                       STA     STRPTR          ;
00FCDE  2                       LDA     #>ESPMESSAGE5   ;
00FCDE  2                       STA     STRPTR+1        ;
00FCDE  2                       JSR     WRSTR
00FCDE  2               ESP_RESET1:
00FCDE  2                       LDX     #$20
00FCDE  2               :
00FCDE  2                       LDA     #00
00FCDE  2                       JSR     PUTESP1
00FCDE  2                       DEX
00FCDE  2                       CPX     #$00
00FCDE  2                       BNE     :-
00FCDE  2                       CLC
00FCDE  2                       RTS
00FCDE  2               
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPCURSORV  - Set Cursor Visibility (A=0 cursor off, A=1 cursor on)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPCURSORV:
00FCDE  2                       PHA
00FCDE  2                       LDA     #05             ; ESP OPCODE
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       PLA
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       RTS
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPSER0OUT  - OUTPUT A CHARACTER TO Serial 0 ('A' POINTS TO BYTE)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPSER0OUT:
00FCDE  2                       PHA
00FCDE  2                       LDA     #08             ; ESP OPCODE
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       PLA
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       RTS
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPSER0IN   - read a character from Serial 0 ('A' POINTS TO BYTE)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPSER0IN:
00FCDE  2                       LDA     #10             ; ESP IN FROM Serial 0
00FCDE  2                       JMP     ESPCHIN
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPSER1OUT  - OUTPUT A CHARACTER TO Serial 1 ('A' POINTS TO BYTE)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPSER1OUT:
00FCDE  2                       PHA
00FCDE  2                       LDA     #08             ; ESP OPCODE
00FCDE  2                       JSR     PUTESP1         ; SEND IT
00FCDE  2                       PLA
00FCDE  2                       JSR     PUTESP1         ; SEND IT
00FCDE  2                       RTS
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPSER1IN   - read a character from Serial 1 ('A' POINTS TO BYTE)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPSER1IN:
00FCDE  2                       LDA     #10             ; ESP IN FROM Serial 1
00FCDE  2               ESPCH1IN:
00FCDE  2                       JSR     PUTESP1         ; SEND IT
00FCDE  2                       BCS     :+
00FCDE  2                       JSR     GETESP1         ; GET IT
00FCDE  2                       BCS     :+
00FCDE  2                       CMP     #$00
00FCDE  2                       BEQ     :+
00FCDE  2                       RTS
00FCDE  2               :
00FCDE  2                       LDA     #$FF
00FCDE  2                       RTS
00FCDE  2               
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPNETCOUT  - OUTPUT A CHARACTER TO Network Console Connection ('A' POINTS TO BYTE)
00FCDE  2               ;               Connection Stored in 'consoleConnect' value
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPNETCOUT:
00FCDE  2                       PHA
00FCDE  2                       LDA     #25             ; ESP OPCODE
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       LDA     consoleConnect
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       PLA
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       RTS
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPNETCIN   - read a character from Network Console Connection ('A' POINTS TO BYTE)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPNETCIN:
00FCDE  2                       LDA     #26             ; ESP OPCODE
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       LDA     consoleConnect
00FCDE  2                       JMP     ESPCH1IN
00FCDE  2               
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPPS2BUFL - Return number of characters in keyboard buffer
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPPS2BUFL:
00FCDE  2                       LDA     #04             ; opcode to get buffer length
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       BCS     :+
00FCDE  2                       JSR     GETESP0         ; GET IT
00FCDE  2                       BCS     :+
00FCDE  2                       RTS
00FCDE  2               :
00FCDE  2                       LDA     #$00
00FCDE  2                       RTS
00FCDE  2               
00FCDE  2               
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPSER0BUFL - return number of characters in the Serial 0 buffer in 'A'
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPSER0BUFL:
00FCDE  2                       LDA     #11             ; opcode to get buffer length
00FCDE  2                       JSR     PUTESP0         ; SEND IT
00FCDE  2                       BCS     :+
00FCDE  2                       JSR     GETESP0         ; GET IT
00FCDE  2                       BCS     :+
00FCDE  2                       RTS
00FCDE  2               :
00FCDE  2                       LDA     #$00
00FCDE  2                       RTS
00FCDE  2               
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPSER1BUFL - return number of characters in the Serial 1 buffer in 'A'
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPSER1BUFL:
00FCDE  2                       LDA     #11             ; opcode to get buffer length
00FCDE  2               ESP1BUFL:
00FCDE  2                       JSR     PUTESP1         ; SEND IT
00FCDE  2                       BCS     :+
00FCDE  2                       JSR     GETESP1         ; GET IT
00FCDE  2                       BCS     :+
00FCDE  2                       RTS
00FCDE  2               :
00FCDE  2                       LDA     #$00
00FCDE  2                       RTS
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPNETCBUFL - return number of characters in the Network Connection buffer in 'A'
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPNETCBUFL:
00FCDE  2                       LDA     #28             ; opcode to get buffer length
00FCDE  2                       JMP     ESP1BUFL
00FCDE  2               
00FCDE  2                       .ENDIF
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ; ESPVIDEOOUT - output character in 'A' to CRT (ANSI terminal emulation)
00FCDE  2               ;__________________________________________________________________________________________________
00FCDE  2               ;
00FCDE  2               ESPVIDEOOUT:
00FCDE  2  48                   PHA
00FCDF  2  A9 01                LDA     #01             ; ESP OUT TO SCREEN
00FCE1  2  20 05 FD             JSR     PUTESP0         ; SEND IT
00FCE4  2  68                   PLA
00FCE5  2  20 05 FD             JSR     PUTESP0         ; SEND IT
00FCE8  2  60                   RTS
00FCE9  2               ;__________________________________________________________________________________________________
00FCE9  2               ; ESPPS2IN - Fetch character out of Keyboard Buffer into 'A'  ($FF is no characters waiting)
00FCE9  2               ;__________________________________________________________________________________________________
00FCE9  2               ;
00FCE9  2               ESPPS2IN:
00FCE9  2  A9 03                LDA     #03             ; ESP IN FROM PS2
00FCEB  2               ESPCHIN:
00FCEB  2  20 05 FD             JSR     PUTESP0         ; SEND IT
00FCEE  2  B0 0A                BCS     :+
00FCF0  2  20 30 FD             JSR     GETESP0         ; GET IT
00FCF3  2  B0 05                BCS     :+
00FCF5  2  C9 00                CMP     #$00
00FCF7  2  F0 01                BEQ     :+
00FCF9  2  60                   RTS
00FCFA  2               :
00FCFA  2  A9 FF                LDA     #$FF
00FCFC  2  60                   RTS
00FCFD  2               
00FCFD  2               ESPPS2INW:
00FCFD  2  20 E9 FC             JSR     ESPPS2IN
00FD00  2  C9 FF                CMP     #$FF
00FD02  2  F0 F9                BEQ     ESPPS2INW
00FD04  2  60                   RTS
