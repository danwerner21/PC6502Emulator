00F943  2  26 62 94 88          .BYTE   $26,$62,$94,$88 ; JSR PLP BMI SEC
00F947  2  54 44 C8 54          .BYTE   $54,$44,$C8,$54 ; RTI PHA BVC CLI
00F94B  2  68 44 E8 94          .BYTE   $68,$44,$E8,$94 ; RTS PLA BVS SEI
00F94F  2  00 B4 08 84          .BYTE   $00,$B4,$08,$84 ; ??? DEY BCC TYA
00F953  2  74 B4 28 6E          .BYTE   $74,$B4,$28,$6E ; LDY TAY BCS CLV
00F957  2  74 F4 CC 4A          .BYTE   $74,$F4,$CC,$4A ; CPY INY BNE CLD
00F95B  2  72 F2 A4 8A          .BYTE   $72,$F2,$A4,$8A ; CPX INX BEQ SED
00F95F  2               ; XXXYY100 opcodes
00F95F  2  00 AA A2 A2          .BYTE   $00,$AA,$A2,$A2 ; ??? BIT JMP JMP
00F963  2  74 74 74 72          .BYTE   $74,$74,$74,$72 ; STY LDY CPY CPX
00F967  2               ; 1XXX1010 opcodes
00F967  2  44 68 B2 32          .BYTE   $44,$68,$B2,$32 ; TXA TXS TAX TSX
00F96B  2  B2 00 22 00          .BYTE   $B2,$00,$22,$00 ; DEX ??? NOP ???
00F96F  2               ; XXXYYY10 opcodes
00F96F  2  1A 1A 26 26          .BYTE   $1A,$1A,$26,$26 ; ASL ROL LSR ROR
00F973  2  72 72 88 C8          .BYTE   $72,$72,$88,$C8 ; STX LDX DEC INC
00F977  2               ; XXXYYY01 opcodes
00F977  2  C4 CA 26 48          .BYTE   $C4,$CA,$26,$48 ; ORA AND EOR ADC
00F97B  2  44 44 A2 C8          .BYTE   $44,$44,$A2,$C8 ; STA LDA CMP SBC
00F97F  2  0D 20 20 20          .BYTE   $0D,$20,$20,$20
