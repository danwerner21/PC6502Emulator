00FB74  2               ;*____________________________________________________________________________________________________
00FB74  2               IDE_SETUP_LBA:
00FB74  2  AD 3D 06             LDA     currentDrive
00FB77  2  29 01                AND     #$01            ; only want drive cfg
00FB79  2  0A                   ASL     a               ; SHIFT 4
00FB7A  2  0A                   ASL     a               ;
00FB7B  2  0A                   ASL     a               ;
00FB7C  2  0A                   ASL     a               ;
00FB7D  2  09 E0                ORA     #$E0            ; E0=MST  F0=SLV
00FB7F  2  8D 0C E3             STA     XTIDE_DEVICE
00FB82  2               
00FB82  2  AD 11 06             LDA     debcylm
00FB85  2  8D 0A E3             STA     XTIDE_LBAHI
00FB88  2               
00FB88  2  AD 10 06             LDA     debcyll
00FB8B  2  8D 08 E3             STA     XTIDE_LBAMID
00FB8E  2               
00FB8E  2  AD 12 06             LDA     debsehd
00FB91  2  8D 06 E3             STA     XTIDE_LBALOW
00FB94  2               
00FB94  2  A9 01                LDA     #$01
00FB96  2  8D 04 E3             STA     XTIDE_SEC_CNT
00FB99  2  60                   RTS
