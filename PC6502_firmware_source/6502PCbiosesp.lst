00F9BF  1                       .INCLUDE "bios_serial.asm"
00F9BF  2               ;__SERIAL DRIVERS________________________________________________________________________________________________________________
00F9BF  2               ;
00F9BF  2               ; 	serial drivers
00F9BF  2               ;
00F9BF  2               ;	Entry points:
00F9BF  2               ;		SERIALINIT  - called during OS init
00F9BF  2               ;		RDSER1	    - read a byte from serial port ('A' POINTS TO BYTE)
00F9BF  2               ;		WRSER1	    - write a byte from serial port  ('A' POINTS TO BYTE)
00F9BF  2               ;		RDSER1W	    - read a byte from serial port ('A' POINTS TO BYTE, WAIT FOR INPUT)
00F9BF  2               ;		SERIALSTATUS- GET UART STATUS
00F9BF  2               ;________________________________________________________________________________________________________________________________
00F9BF  2               ;
00F9BF  2               
00F9BF  2               
00F9BF  2               ;*
00F9BF  2               ;* HARDWARE I/O ADDRESSES
00F9BF  2               ;*
00F9BF  2               
00F9BF  2               UART1DATA       = PC6502_IOSPACE+$84; SERIAL PORT 1 (I/O Card)
00F9BF  2               UART1STATUS     = PC6502_IOSPACE+$85; SERIAL PORT 1 (I/O Card)
00F9BF  2               UART1COMMAND    = PC6502_IOSPACE+$86; SERIAL PORT 1 (I/O Card)
00F9BF  2               UART1CONTROL    = PC6502_IOSPACE+$87; SERIAL PORT 1 (I/O Card)
00F9BF  2               
00F9BF  2               
00F9BF  2               ;Command Register
00F9BF  2               ;No bit is affected by a software reset, however, all bits are set to zero on a hardware reset.
00F9BF  2               ;Bit 7 6 5  configuration
00F9BF  2               ;    x x 0  no parity bit
00F9BF  2               ;    0 0 1  send and receive with odd parity
00F9BF  2               ;    0 1 1  send and receive with even parity
00F9BF  2               ;    1 0 1  send: parity=1; receive: parity not evaluated
00F9BF  2               ;    1 1 1  send: parity=0; receive: parity not evaluated
00F9BF  2               ;
00F9BF  2               ;Bit 4  0: no echo
00F9BF  2               ;       1: echo (received characters are being sent again,
00F9BF  2               ;                bits 2 and 3 must be 0 for that)
00F9BF  2               ;
00F9BF  2               ;Bit 3 2  sender interr.   RTS level   sender
00F9BF  2               ;    0 0  no               high        off
00F9BF  2               ;    0 1  yes              low         on
00F9BF  2               ;    1 0  no               low         on
00F9BF  2               ;    1 1  no               low         send BRK
00F9BF  2               ;
00F9BF  2               ;Bit 1  0: interrupt gets triggered by bit 3 in status register
00F9BF  2               ;       1: no interrupt
00F9BF  2               ;
00F9BF  2               ;Bit 0  0: disable transceiver and interrupts, /DTR high
00F9BF  2               ;       1: enable transceiver and interrupts, /DTR low
00F9BF  2               ;
00F9BF  2               ;Control Register
00F9BF  2               ;Bits 0 to 3 are set to zero on a software reset, and all bits are set to zero on a hardware reset.
00F9BF  2               ;Bit 7  0: 1 stop bit
00F9BF  2               ;       1: a) with 8 data bits and 1 parity bit: 1 stop bit
00F9BF  2               ;          b) with 5 data bits and no parity bit: 1.5 stop bits
00F9BF  2               ;          c) otherwise 2 stop bits
00F9BF  2               ;
00F9BF  2               ;Bit 6 5  data bits
00F9BF  2               ;    0 0  8
00F9BF  2               ;    0 1  7
00F9BF  2               ;    1 0  6
00F9BF  2               ;    1 1  5
00F9BF  2               ;
00F9BF  2               ;Bit 4  0: external receive clock
00F9BF  2               ;       1: builtin clock as receive clock
00F9BF  2               ;
00F9BF  2               ;Bit 3 2 1 0  baud rate
00F9BF  2               ;    0 0 0 0  1/16 times external clock
00F9BF  2               ;    0 0 0 1  50 bps
00F9BF  2               ;    0 0 1 0  75 bps
00F9BF  2               ;    0 0 1 1  109.92 bps
00F9BF  2               ;    0 1 0 0  134.58 bps
00F9BF  2               ;    0 1 0 1  150 bps
00F9BF  2               ;    0 1 1 0  300 bps
00F9BF  2               ;    0 1 1 1  600 bps
00F9BF  2               ;    1 0 0 0  1200 bps
00F9BF  2               ;    1 0 0 1  1800 bps
00F9BF  2               ;    1 0 1 0  2400 bps
00F9BF  2               ;    1 0 1 1  3600 bps
00F9BF  2               ;    1 1 0 0  4800 bps
00F9BF  2               ;    1 1 0 1  7200 bps
00F9BF  2               ;    1 1 1 0  9600 bps
00F9BF  2               ;    1 1 1 1  19200 bps
00F9BF  2               
00F9BF  2               
00F9BF  2               
00F9BF  2               ;__SERIALINIT____________________________________________________________________________________________________________________
00F9BF  2               ;
00F9BF  2               ;	INITIALIZE SERIAL PORTS
00F9BF  2               ;________________________________________________________________________________________________________________________________
00F9BF  2               ;
00F9BF  2               SERIALINIT:
00F9BF  2  A9 00                LDA     #$00            ; RESET UART
00F9C1  2  8D 85 EF             STA     UART1STATUS     ;
00F9C4  2  A9 0B                LDA     #$0B            ;
00F9C6  2  8D 86 EF             STA     UART1COMMAND    ;
00F9C9  2  A9 1E                LDA     #$1E            ; 9600, 8 BITS, NO PARITY, 1 STOP BIT
00F9CB  2  8D 87 EF             STA     UART1CONTROL    ;
00F9CE  2  60                   RTS
00F9CF  2               
00F9CF  2               
00F9CF  2               
00F9CF  2               ;__WRSER1________________________________________________________________________________________________________________________
00F9CF  2               ;
00F9CF  2               ;	WRITE CHARACTER(A) TO UART
00F9CF  2               ;________________________________________________________________________________________________________________________________
00F9CF  2               ;
00F9CF  2               WRSER1:
00F9CF  2  48                   PHA
00F9D0  2               WRSER1a:
00F9D0  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS
00F9D3  2  29 10                AND     #%00010000      ; IS TX READY
00F9D5  2  F0 F9                BEQ     WRSER1a         ; NO, WAIT FOR IT
00F9D7  2  68                   PLA
00F9D8  2  8D 84 EF             STA     UART1DATA       ; WRITE DATA
00F9DB  2  60                   RTS
00F9DC  2               
00F9DC  2               ;__RDSER1________________________________________________________________________________________________________________________
00F9DC  2               ;
00F9DC  2               ;	READ CHARACTER FROM UART TO (A)
00F9DC  2               ;________________________________________________________________________________________________________________________________
00F9DC  2               ;
00F9DC  2               RDSER1:
00F9DC  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS REGISTER
00F9DF  2  29 08                AND     #%00001000      ; IS RX READY
00F9E1  2  F0 04                BEQ     RDSER1N         ; NO, INDICATE NO CHAR
00F9E3  2  AD 84 EF             LDA     UART1DATA       ; GET DATA CHAR
00F9E6  2  60                   RTS
00F9E7  2               RDSER1N:
00F9E7  2  A9 00                LDA     #$00            ;
00F9E9  2  60                   RTS                     ;
00F9EA  2               
00F9EA  2               ;__RDSER1W_______________________________________________________________________________________________________________________
00F9EA  2               ;
00F9EA  2               ;	READ CHARACTER FROM UART TO (A) - WAIT FOR CHAR
00F9EA  2               ;________________________________________________________________________________________________________________________________
00F9EA  2               ;
00F9EA  2               RDSER1W:
00F9EA  2  20 DC F9             JSR     RDSER1
00F9ED  2  C9 00                CMP     #$00
00F9EF  2  F0 F9                BEQ     RDSER1W
00F9F1  2  29 7F                AND     #$7F
00F9F3  2  60                   RTS
00F9F4  2               
00F9F4  2               ;__SERIALSTATUS__________________________________________________________________________________________________________________
00F9F4  2               ;
00F9F4  2               ;	READ UARD STATUS
00F9F4  2               ;________________________________________________________________________________________________________________________________
00F9F4  2               ;
00F9F4  2               SERIALSTATUS:
00F9F4  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS REGISTER
00F9F7  2  29 08                AND     #%00001000      ; IS RX READY
00F9F9  2  D0 03                BNE     RDSTAT1         ; INDICATE CHAR
00F9FB  2  A9 00                LDA     #$00            ; NO CHAR
00F9FD  2  60                   RTS
00F9FE  2               RDSTAT1:
00F9FE  2  A9 FF                LDA     #$FF            ; DATA CHAR
00FA00  2  60                   RTS
00FA01  2               
00FA01  1                       .INCLUDE "bios_ide.asm"
00FA01  2               ;__IDE DRIVERS___________________________________________________________________________________________________________________
00FA01  2               ;
00FA01  2               ; 	DOS/65 IDE disk drivers 6502PC - XT IDE ISA CARD
00FA01  2               ;
00FA01  2               ;	Entry points:
00FA01  2               ;		XTIDE_INIT   	- CALLED DURING OS INIT
00FA01  2               ;		IDE_READ_SECTOR  - read a sector from drive
00FA01  2               ;		IDE_WRITE_SECTOR - write a sector to drive
00FA01  2               ;________________________________________________________________________________________________________________________________
00FA01  2               ;
00FA01  2               PC6502_IO       = $E000
00FA01  2               
00FA01  2               XTIDE_DATA_LO   = PC6502_IO+$300
00FA01  2               XTIDE_DATA_HI   = PC6502_IO+$301
00FA01  2               XTIDE_ERR       = PC6502_IO+$302
00FA01  2               XTIDE_FECODE    = PC6502_IO+$302
00FA01  2               XTIDE_SEC_CNT   = PC6502_IO+$304
00FA01  2               XTIDE_LBALOW    = PC6502_IO+$306
00FA01  2               XTIDE_LBAMID    = PC6502_IO+$308
00FA01  2               XTIDE_LBAHI     = PC6502_IO+$30A
00FA01  2               XTIDE_DEVICE    = PC6502_IO+$30C
00FA01  2               XTIDE_COMMAND   = PC6502_IO+$30E
00FA01  2               XTIDE_STATUS    = PC6502_IO+$30E
00FA01  2               
00FA01  2               
00FA01  2               
00FA01  2               
00FA01  2               ;IDE COMMAND CONSTANTS.  THESE SHOULD NEVER CHANGE.
00FA01  2               XTIDE_CMD_RECAL = $10
00FA01  2               XTIDE_CMD_READ  = $20
00FA01  2               XTIDE_CMD_WRITE = $30
00FA01  2               XTIDE_CMD_INIT  = $91
00FA01  2               XTIDE_CMD_ID    = $EC
00FA01  2               XTIDE_CMD_FEAT  = $EF
00FA01  2               XTIDE_CMD_SPINDOWN = $E0
00FA01  2               XTIDE_CMD_SPINUP = $E1
00FA01  2               
00FA01  2               
00FA01  2               
00FA01  2                       .IFDEF  PC6502BIOS
00FA01  2               XTIDE_INIT:
00FA01  2               ; RESET PORTS
00FA01  2  A2 00                LDX     #$00
00FA03  2  A9 FF                LDA     #$FF
00FA05  2               :
00FA05  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA08  2  E8                   INX
00FA09  2  E0 31                CPX     #$31
00FA0B  2  D0 F8                BNE     :-
00FA0D  2               
00FA0D  2  A2 00                LDX     #$00
00FA0F  2  A9 00                LDA     #$00
00FA11  2               :
00FA11  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA14  2  E8                   INX
00FA15  2  E0 31                CPX     #$31
00FA17  2  D0 F8                BNE     :-
00FA19  2  20 33 FA             JSR     XTIDE_PROBE
00FA1C  2  A9 E0                LDA     #$E0            ; E0=MST  F0=SLV
00FA1E  2  8D 0C E3             STA     XTIDE_DEVICE
00FA21  2               
00FA21  2  20 B4 FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA24  2  C9 00                CMP     #$00
00FA26  2  D0 0A                BNE     :+
00FA28  2               
00FA28  2  A9 01                LDA     #$01            ; ENABLE 8-BIT MODE (XT-CF-LITE)
00FA2A  2  8D 02 E3             STA     XTIDE_FECODE
00FA2D  2  A9 EF                LDA     #XTIDE_CMD_FEAT
00FA2F  2  8D 0E E3             STA     XTIDE_COMMAND
00FA32  2               :
00FA32  2  60                   RTS
00FA33  2                       .ENDIF
00FA33  2               
00FA33  2               
00FA33  2                       .IFNDEF PC6502BIOS
00FA33  2               XTIDETIMEOUT:
00FA33  2                       .BYTE   $00,$00
00FA33  2               
00FA33  2               
00FA33  2               
00FA33  2               ;__XTIDE_INIT________________________________________________________________________________________
00FA33  2               ;
00FA33  2               ;  INIT AND DISPLAY IDE INFO
00FA33  2               ;____________________________________________________________________________________________________
00FA33  2               ;
00FA33  2               XTIDE_INIT:
00FA33  2                       JSR     LFCR            ; AND CRLF
00FA33  2                       LDA     #<MESSAGE1      ;
00FA33  2                       STA     STRPTR          ;
00FA33  2                       LDA     #>MESSAGE1      ;
00FA33  2                       STA     STRPTR+1        ;
00FA33  2                       JSR     WRSTR
00FA33  2                       JSR     LFCR            ; AND CRLF
00FA33  2               ;
00FA33  2                       LDA     #<MESSAGE2      ;
00FA33  2                       STA     STRPTR          ;
00FA33  2                       LDA     #>MESSAGE2      ;
00FA33  2                       STA     STRPTR+1        ;
00FA33  2                       JSR     WRSTR           ; DO PROMPT
00FA33  2               
00FA33  2                       LDA     #>XTIDE_DATA_LO ; GET BASE PORT
00FA33  2                       JSR     PRINT_BYTE      ; PRINT BASE PORT
00FA33  2                       LDA     #<XTIDE_DATA_LO ; GET BASE PORT
00FA33  2                       JSR     PRINT_BYTE      ; PRINT BASE PORT
00FA33  2               ;
00FA33  2                       JSR     XTIDE_PROBE     ; DETECT AN ATA DEVICE, ABORT IF NOT FOUND
00FA33  2                       CMP     #$00
00FA33  2                       BNE     IDE_ABORT
00FA33  2                       JMP     IDE_PRINT_INFO
00FA33  2               IDE_ABORT:
00FA33  2                       LDA     #<MESSAGE3      ;
00FA33  2                       STA     STRPTR          ;
00FA33  2                       LDA     #>MESSAGE3      ;
00FA33  2                       STA     STRPTR+1        ;
00FA33  2                       JSR     WRSTR           ; DO PROMPT
00FA33  2                       JMP     IDE_INITA
00FA33  2               IDE_PRINT_INFO:
00FA33  2                       JSR     LFCR            ; AND CRLF
00FA33  2                       LDA     #<MESSAGE4      ;
00FA33  2                       STA     STRPTR          ;
00FA33  2                       LDA     #>MESSAGE4      ;
00FA33  2                       STA     STRPTR+1        ;
00FA33  2                       JSR     WRSTR           ; DO PROMPT
00FA33  2                       LDA     #$00
00FA33  2                       JSR     IDE_READ_INFO   ; GET DRIVE INFO, ABORT IF ERROR
00FA33  2                       LDA     #<MESSAGE5      ;
00FA33  2                       STA     STRPTR          ;
00FA33  2                       LDA     #>MESSAGE5      ;
00FA33  2                       STA     STRPTR+1        ;
00FA33  2                       JSR     WRSTR           ; DO PROMPT
00FA33  2                       LDA     #$01
00FA33  2                       JSR     IDE_READ_INFO   ; GET DRIVE INFO, ABORT IF ERROR
00FA33  2               IDE_INITA:
00FA33  2                       RTS                     ; DONE
00FA33  2                       .ENDIF
00FA33  2               ;
00FA33  2               ;__XTIDE_PROBE_______________________________________________________________________________________
00FA33  2               ;
00FA33  2               ;  XTPROBE FOR IDE HARDWARE
00FA33  2               ;____________________________________________________________________________________________________
00FA33  2               ;
00FA33  2               XTIDE_PROBE:
00FA33  2               ;
00FA33  2               ; RESET PORTS
00FA33  2  A2 00                LDX     #$00
00FA35  2  A9 FF                LDA     #$FF
00FA37  2               :
00FA37  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA3A  2  E8                   INX
00FA3B  2  E0 31                CPX     #$31
00FA3D  2  D0 F8                BNE     :-
00FA3F  2               
00FA3F  2  A2 00                LDX     #$00
00FA41  2  A9 00                LDA     #$00
00FA43  2               :
00FA43  2  9D 00 E3             STA     XTIDE_DATA_LO,X
00FA46  2  E8                   INX
00FA47  2  E0 31                CPX     #$31
00FA49  2  D0 F8                BNE     :-
00FA4B  2               ; CHECK SIGNATURE
00FA4B  2  A0 00                LDY     #$00
00FA4D  2  A2 00                LDX     #$00
00FA4F  2               ;       SOMETIMES THE CF-XTIDE WILL ONLY READ 80, THIS CAN BE RESET BY WRITING ZEROS UNTIL VALUES ARE PROPERLY READ
00FA4F  2               :
00FA4F  2  AD 00 E3             LDA     XTIDE_DATA_LO
00FA52  2  C9 80                CMP     #$80
00FA54  2  D0 2F                BNE     :+
00FA56  2  A9 00                LDA     #$00
00FA58  2  8D 00 E3             STA     XTIDE_DATA_LO
00FA5B  2  EA                   NOP
00FA5C  2  8D 01 E3             STA     XTIDE_DATA_HI
00FA5F  2  EA                   NOP
00FA60  2  8D 06 E3             STA     XTIDE_LBALOW
00FA63  2  EA                   NOP
00FA64  2  8D 08 E3             STA     XTIDE_LBAMID
00FA67  2  EA                   NOP
00FA68  2  8D 0A E3             STA     XTIDE_LBAHI
00FA6B  2  EA                   NOP
00FA6C  2  8D 0C E3             STA     XTIDE_DEVICE
00FA6F  2  EA                   NOP
00FA70  2  8D 0E E3             STA     XTIDE_COMMAND
00FA73  2  EA                   NOP
00FA74  2  8D 0E E3             STA     XTIDE_STATUS
00FA77  2  EA                   NOP
00FA78  2  E8                   INX
00FA79  2  E0 00                CPX     #$00
00FA7B  2  D0 D2                BNE     :-
00FA7D  2  C8                   INY
00FA7E  2  C0 03                CPY     #$03
00FA80  2  D0 CD                BNE     :-
00FA82  2  4C 8F FA             JMP     XTIDE_PROBE_FAIL; TIMED OUT
00FA85  2               :
00FA85  2  20 B4 FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA88  2  C9 00                CMP     #$00
00FA8A  2  D0 03                BNE     XTIDE_PROBE_FAIL
00FA8C  2  4C 92 FA             JMP     XTIDE_PROBE_SUCCESS
00FA8F  2               XTIDE_PROBE_FAIL:
00FA8F  2  A9 FF                LDA     #$FF
00FA91  2  60                   RTS
00FA92  2               XTIDE_PROBE_SUCCESS:
00FA92  2  A9 00                LDA     #$00
00FA94  2  60                   RTS                     ; DONE, NOTE THAT A=0 AND Z IS SET
00FA95  2               
00FA95  2                       .IFNDEF PC6502BIOS
00FA95  2               ;*__IDE_READ_INFO___________________________________________________________________________________
00FA95  2               ;*
00FA95  2               ;*  READ IDE INFORMATION
00FA95  2               ;*	CARRY SET ON ERROR
00FA95  2               ;* 	A=MST/SLV
00FA95  2               ;*____________________________________________________________________________________________________
00FA95  2               IDE_READ_INFO:
00FA95  2               ; SET DRIVE BIT
00FA95  2                       AND     #$01            ; ONLY WANT THE 1 BIT (MST/SLV)
00FA95  2                       ASL     A               ; SHIFT 4
00FA95  2                       ASL     A               ;
00FA95  2                       ASL     A               ;
00FA95  2                       ASL     A               ;
00FA95  2                       ORA     #$E0            ; E0=MST  F0=SLV
00FA95  2                       STA     XTIDE_DEVICE
00FA95  2               
00FA95  2                       JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA95  2                       CMP     #$00
00FA95  2                       BNE     IDE_READ_INFO_ABORT
00FA95  2               
00FA95  2                       LDA     #$01            ; ENABLE 8-BIT MODE (XT-CF-LITE)
00FA95  2                       STA     XTIDE_FECODE
00FA95  2                       LDA     #XTIDE_CMD_FEAT
00FA95  2                       STA     XTIDE_COMMAND
00FA95  2               
00FA95  2                       NOP                     ; TINY DELAY, JUST IN CASE
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2                       NOP
00FA95  2               
00FA95  2               
00FA95  2                       LDA     #XTIDE_CMD_ID   ; ID COMMAND
00FA95  2                       STA     XTIDE_COMMAND
00FA95  2               
00FA95  2                       JSR     IDE_WAIT_DRQ    ;WAIT UNTIL IT'S GOT THE DATA
00FA95  2                       CMP     #$00
00FA95  2                       BNE     IDE_READ_INFO_ABORT
00FA95  2               
00FA95  2                       JSR     IDE_READ_BUFFER ; GRAB THE 256 WORDS FROM THE BUFFER
00FA95  2               
00FA95  2                       LDA     #<MESSAGE6      ;
00FA95  2                       STA     STRPTR          ;
00FA95  2                       LDA     #>MESSAGE6      ;
00FA95  2                       STA     STRPTR+1        ;
00FA95  2                       JSR     WRSTR
00FA95  2                       LDA     hstbuf+123
00FA95  2                       JSR     PRINT_BYTE
00FA95  2                       LDA     hstbuf+122
00FA95  2                       JSR     PRINT_BYTE
00FA95  2                       LDA     hstbuf+121
00FA95  2                       JSR     PRINT_BYTE
00FA95  2                       LDA     hstbuf+120
00FA95  2                       JSR     PRINT_BYTE
00FA95  2                       JMP     IDE_READ_INFO_OK
00FA95  2               IDE_READ_INFO_ABORT:
00FA95  2                       LDA     #<MESSAGE3      ;
00FA95  2                       STA     STRPTR          ;
00FA95  2                       LDA     #>MESSAGE3      ;
00FA95  2                       STA     STRPTR+1        ;
00FA95  2                       JSR     WRSTR           ;DO PROMPT
00FA95  2                       JSR     LFCR            ;AND CRLF
00FA95  2                       LDA     #$FF
00FA95  2                       RTS                     ;
00FA95  2               IDE_READ_INFO_OK:
00FA95  2                       JSR     LFCR            ; AND CRLF
00FA95  2                       LDA     #$00
00FA95  2                       RTS
00FA95  2                       .ENDIF
00FA95  2               
00FA95  2               
00FA95  2               ;*__IDE_READ_SECTOR___________________________________________________________________________________
00FA95  2               ;*
00FA95  2               ;*  READ IDE SECTOR (IN LBA) INTO BUFFER
00FA95  2               ;*
00FA95  2               ;*____________________________________________________________________________________________________
00FA95  2               IDE_READ_SECTOR:
00FA95  2                       .IFNDEF PC6502BIOS
00FA95  2                       JSR     IDE_CONVERT_SECTOR_LBA
00FA95  2                       LDA     debsehd         ; STORE CURRENT PARMS
00FA95  2                       CMP     Cdebsehd        ;
00FA95  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA95  2                       LDA     debcylm         ;
00FA95  2                       CMP     Cdebcylm        ;
00FA95  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA95  2                       LDA     debcyll         ;
00FA95  2                       CMP     Cdebcyll        ;
00FA95  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA95  2                       LDA     sekdsk          ;
00FA95  2                       CMP     currentDrive
00FA95  2                       BNE     IDE_READ_SECTOR_DIRTY
00FA95  2                       LDA     #$00            ; ZERO = 1 ON RETURN = OPERATION OK
00FA95  2                       RTS
00FA95  2                       .ENDIF
00FA95  2               IDE_READ_SECTOR_DIRTY:
00FA95  2  20 B4 FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FA98  2  C9 00                CMP     #$00
00FA9A  2  D0 15                BNE     IDE_READ_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FA9C  2               IDE_READ_SECTOR_1:
00FA9C  2  20 74 FB             JSR     IDE_SETUP_LBA   ;TELL IT WHICH SECTOR WE WANT
00FA9F  2  A9 20                LDA     #XTIDE_CMD_READ
00FAA1  2  8D 0E E3             STA     XTIDE_COMMAND
00FAA4  2               
00FAA4  2  20 DD FA             JSR     IDE_WAIT_DRQ    ; WAIT UNTIL IT'S GOT THE DATA
00FAA7  2  C9 00                CMP     #$00
00FAA9  2  D0 06                BNE     IDE_READ_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FAAB  2  20 00 FB             JSR     IDE_READ_BUFFER ; GRAB THE 256 WORDS FROM THE BUFFER
00FAAE  2                       .IFNDEF PC6502BIOS
00FAAE  2                       LDA     debsehd         ; STORE CURRENT PARMS
00FAAE  2                       STA     Cdebsehd        ;
00FAAE  2                       LDA     debcyll         ;
00FAAE  2                       STA     Cdebcyll        ;
00FAAE  2                       LDA     debcylm         ;
00FAAE  2                       STA     Cdebcylm        ;
00FAAE  2                       .ENDIF
00FAAE  2               
00FAAE  2  A9 00                LDA     #$00            ; ZERO = 1 ON RETURN = OPERATION OK
00FAB0  2  60                   RTS
00FAB1  2               IDE_READ_SECTOR_ERROR:
00FAB1  2  A9 FF                LDA     #$FF            ; ZERO = 1 ON RETURN = OPERATION OK
00FAB3  2  60                   RTS
00FAB4  2               
00FAB4  2               
00FAB4  2               ;*__IDE_WAIT_NOT_BUSY_______________________________________________________________________________
00FAB4  2               ;*
00FAB4  2               ;*  WAIT FOR IDE CHANNEL TO BECOME READY
00FAB4  2               ;*
00FAB4  2               ;*____________________________________________________________________________________________________
00FAB4  2               IDE_WAIT_NOT_BUSY:
00FAB4  2  8A                   TXA
00FAB5  2  48                   PHA
00FAB6  2  98                   TYA
00FAB7  2  48                   PHA
00FAB8  2  A9 00                LDA     #$00
00FABA  2  85 F0                STA     XTIDETIMEOUT
00FABC  2  85 F1                STA     XTIDETIMEOUT+1
00FABE  2               IDE_WAIT_NOT_BUSY1:
00FABE  2  AD 0E E3             LDA     XTIDE_STATUS    ;WAIT FOR RDY BIT TO BE SET
00FAC1  2  29 80                AND     #$80
00FAC3  2  C9 00                CMP     #$00
00FAC5  2  F0 0F                BEQ     IDE_WAIT_NOT_BUSY2
00FAC7  2  E6 F0                INC     XTIDETIMEOUT
00FAC9  2  D0 F3                BNE     IDE_WAIT_NOT_BUSY1
00FACB  2  E6 F1                INC     XTIDETIMEOUT+1
00FACD  2  D0 EF                BNE     IDE_WAIT_NOT_BUSY1
00FACF  2  68                   PLA
00FAD0  2  A8                   TAY
00FAD1  2  68                   PLA
00FAD2  2  AA                   TAX
00FAD3  2  A9 FF                LDA     #$FF
00FAD5  2  60                   RTS
00FAD6  2               IDE_WAIT_NOT_BUSY2:
00FAD6  2  68                   PLA
00FAD7  2  A8                   TAY
00FAD8  2  68                   PLA
00FAD9  2  AA                   TAX
00FADA  2  A9 00                LDA     #$00
00FADC  2  60                   RTS
00FADD  2               
00FADD  2               ;*__IDE_WAIT_DRQ______________________________________________________________________________________
00FADD  2               ;*
00FADD  2               ;*	WAIT FOR THE DRIVE TO BE READY TO TRANSFER DATA.
00FADD  2               ;*
00FADD  2               ;*____________________________________________________________________________________________________
00FADD  2               IDE_WAIT_DRQ:
00FADD  2  A9 00                LDA     #$00
00FADF  2  85 F0                STA     XTIDETIMEOUT
00FAE1  2  85 F1                STA     XTIDETIMEOUT+1
00FAE3  2               IDE_WAIT_DRQ1:
00FAE3  2  AD 0E E3             LDA     XTIDE_STATUS    ;WAIT FOR DRQ BIT TO BE SET
00FAE6  2  29 88                AND     #%10001000      ; MASK OFF BUSY(7) AND DRQ(3)
00FAE8  2  C9 08                CMP     #%00001000      ; WE WANT BUSY(7) TO BE 0 AND DRQ (3) TO BE 1
00FAEA  2  F0 11                BEQ     IDE_WAIT_DRQ2
00FAEC  2  29 01                AND     #%00000001      ; IS ERROR?
00FAEE  2  C9 01                CMP     #%00000001      ;
00FAF0  2  F0 08                BEQ     IDE_WAIT_DRQE
00FAF2  2  E6 F0                INC     XTIDETIMEOUT
00FAF4  2  D0 ED                BNE     IDE_WAIT_DRQ1
00FAF6  2  E6 F1                INC     XTIDETIMEOUT+1
00FAF8  2  D0 E9                BNE     IDE_WAIT_DRQ1
00FAFA  2               IDE_WAIT_DRQE:
00FAFA  2  A9 FF                LDA     #$FF
00FAFC  2  60                   RTS
00FAFD  2               IDE_WAIT_DRQ2:
00FAFD  2  A9 00                LDA     #$00
00FAFF  2  60                   RTS
00FB00  2               
00FB00  2               
00FB00  2               ;*__IDE_READ_BUFFER___________________________________________________________________________________
00FB00  2               ;*
00FB00  2               ;*  READ IDE BUFFER LITTLE ENDIAN
00FB00  2               ;*
00FB00  2               ;*____________________________________________________________________________________________________
00FB00  2               IDE_READ_BUFFER:
00FB00  2  A0 00                LDY     #$00            ; INDEX
00FB02  2               :
00FB02  2  AD 00 E3             LDA     XTIDE_DATA_LO
00FB05  2  99 00 04             STA     hstbuf,Y        ;
00FB08  2  C8                   INY
00FB09  2  AD 01 E3             LDA     XTIDE_DATA_HI
00FB0C  2  99 00 04             STA     hstbuf,Y        ;
00FB0F  2  C8                   INY
00FB10  2  C0 00                CPY     #$00            ;
00FB12  2  D0 EE                BNE     :-
00FB14  2               :
00FB14  2               ;
00FB14  2  AD 00 E3             LDA     XTIDE_DATA_LO
00FB17  2  99 00 05             STA     hstbuf+$100,Y   ;
00FB1A  2  C8                   INY
00FB1B  2  AD 01 E3             LDA     XTIDE_DATA_HI
00FB1E  2  99 00 05             STA     hstbuf+$100,Y   ;
00FB21  2  C8                   INY
00FB22  2  C0 00                CPY     #$00            ;
00FB24  2  D0 EE                BNE     :-              ;
00FB26  2  60                   RTS                     ;
00FB27  2               
00FB27  2               ;*__IDE_WRITE_SECTOR__________________________________________________________________________________
00FB27  2               ;*
00FB27  2               ;*  WRITE IDE SECTOR (IN LBA) FROM BUFFER
00FB27  2               ;*
00FB27  2               ;*____________________________________________________________________________________________________
00FB27  2               IDE_WRITE_SECTOR:
00FB27  2                       .IFNDEF PC6502BIOS
00FB27  2                       JSR     IDE_CONVERT_SECTOR_LBA
00FB27  2                       .ENDIF
00FB27  2  20 B4 FA             JSR     IDE_WAIT_NOT_BUSY;MAKE SURE DRIVE IS READY
00FB2A  2  C9 00                CMP     #$00
00FB2C  2  D0 1C                BNE     IDE_WRITE_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FB2E  2  20 74 FB             JSR     IDE_SETUP_LBA   ;TELL IT WHICH SECTOR WE WANT
00FB31  2  A9 30                LDA     #XTIDE_CMD_WRITE
00FB33  2  8D 0E E3             STA     XTIDE_COMMAND
00FB36  2  20 DD FA             JSR     IDE_WAIT_DRQ    ;WAIT UNIT IT WANTS THE DATA
00FB39  2  C9 00                CMP     #$00
00FB3B  2  D0 0D                BNE     IDE_WRITE_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FB3D  2  20 4D FB             JSR     IDE_WRITE_BUFFER;GIVE THE DATA TO THE DRIVE
00FB40  2  20 B4 FA             JSR     IDE_WAIT_NOT_BUSY;WAIT UNTIL THE WRITE IS COMPLETE
00FB43  2  C9 00                CMP     #$00
00FB45  2  D0 03                BNE     IDE_WRITE_SECTOR_ERROR; IF TIMEOUT, REPORT NO IDE PRESENT
00FB47  2                       .IFNDEF PC6502BIOS
00FB47  2                       LDA     #$FF            ; INVALIDATE CACHE
00FB47  2                       STA     Cdebsehd        ;
00FB47  2                       STA     Cdebcyll        ;
00FB47  2                       STA     Cdebcylm        ;
00FB47  2                       .ENDIF
00FB47  2  A9 00                LDA     #$00            ; ZERO = 1 ON RETURN = OPERATION OK
00FB49  2  60                   RTS
00FB4A  2               IDE_WRITE_SECTOR_ERROR:
00FB4A  2  A9 FF                LDA     #$FF
00FB4C  2  60                   RTS
00FB4D  2               
00FB4D  2               ;*__IDE_WRITE_BUFFER___________________________________________________________________________________
00FB4D  2               ;*
00FB4D  2               ;*  WRITE IDE BUFFER LITTLE ENDIAN
00FB4D  2               ;*
00FB4D  2               ;*____________________________________________________________________________________________________
00FB4D  2               IDE_WRITE_BUFFER:
00FB4D  2  A0 00                LDY     #$00            ; INDEX
00FB4F  2               :
00FB4F  2  B9 00 04             LDA     hstbuf,Y        ;
00FB52  2  8D 00 E3             STA     XTIDE_DATA_LO
00FB55  2  C8                   INY
00FB56  2  B9 00 04             LDA     hstbuf,Y        ;
00FB59  2  8D 01 E3             STA     XTIDE_DATA_HI
00FB5C  2  C8                   INY
00FB5D  2  C0 00                CPY     #$00            ;
00FB5F  2  D0 EE                BNE     :-              ;
00FB61  2               :
00FB61  2  B9 00 05             LDA     hstbuf+$100,Y   ;
00FB64  2  8D 00 E3             STA     XTIDE_DATA_LO
00FB67  2  C8                   INY
00FB68  2  B9 00 05             LDA     hstbuf+$100,Y   ;
00FB6B  2  8D 01 E3             STA     XTIDE_DATA_HI
00FB6E  2  C8                   INY
00FB6F  2  C0 00                CPY     #$00            ;
00FB71  2  D0 EE                BNE     :-              ;
00FB73  2  60                   RTS                     ;
