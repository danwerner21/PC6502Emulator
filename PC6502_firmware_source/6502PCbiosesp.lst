00FBED  2  85 41                STA     STRPTR          ;
00FBEF  2  A9 FC                LDA     #>MESSAGE7      ;
00FBF1  2  85 42                STA     STRPTR+1        ;
00FBF3  2  20 6F FE             JSR     OUTSTR
00FBF6  2  20 63 FE             JSR     IOF_CONINW
00FBF9  2  C9 59                CMP     #'Y'
00FBFB  2  F0 0C                BEQ     :+
00FBFD  2               
00FBFD  2  A9 AA                LDA     #<MESSAGE8      ;
00FBFF  2  85 41                STA     STRPTR          ;
00FC01  2  A9 FC                LDA     #>MESSAGE8      ;
00FC03  2  85 42                STA     STRPTR+1        ;
00FC05  2  20 6F FE             JSR     OUTSTR
00FC08  2  00                   BRK
00FC09  2               
00FC09  2               
00FC09  2               :
