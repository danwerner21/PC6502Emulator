000FB4  1  A5 0B                LDA     CSRPOSX         ; ARE WE PAST THE START OF THE ROW?
000FB6  1  C9 FF                CMP     #$FF
000FB8  1  F0 03                BEQ     CHKPOS1A        ; YES, GO UP ONE LINE
000FBA  1  4C 95 0F             JMP     CHKPOS          ; NO, LOOP
