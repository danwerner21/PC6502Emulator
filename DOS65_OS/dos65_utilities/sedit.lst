000E66  1  C9 13                CMP     #LASTROW-1      ; IF NOT, BRANCH TO CSRRIGHT1, OTHERWISE
000E68  1  D0 09                BNE     CRSRRIGHT1      ; SCROLL SCREEN
000E6A  1  A5 0B                LDA     CSRPOSX         ;
000E6C  1  C9 4F                CMP     #MAXCOL-1       ;
000E6E  1  D0 03                BNE     CRSRRIGHT1      ;
000E70  1               ;
000E70  1  20 30 0F             JSR     SCROLLDOWN      ;
000E73  1               ;
000E73  1               CRSRRIGHT1:                     ;
000E73  1  20 FB 11             JSR     GOCSR           ; POSITION CURSOR
