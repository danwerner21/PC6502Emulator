0013C0  1               ;__DOS65LOAD_____________________________________________________________________________________________________________________
0013C0  1               ;
0013C0  1               ; 	LOAD A DOS/65 FILE INTO THE EDIT BUFFER
0013C0  1               ;		FILE IS LOADED INTO 80 COLUMN LINES TO SIMPLIFY SCROLLING
0013C0  1               ;
0013C0  1               ;
0013C0  1               ;________________________________________________________________________________________________________________________________
0013C0  1               ;
0013C0  1               DOS65LOAD:
0013C0  1  A9 00                LDA     #0              ; clear
0013C2  1  8D 27 01             STA     DFLFCB+32       ; record number
0013C5  1  A9 07                LDA     #<DFLFCB        ; Open File
0013C7  1  A0 01                LDY     #>DFLFCB        ;
0013C9  1  A2 0F                LDX     #15             ;
0013CB  1  20 03 01             JSR     PEM             ;
0013CE  1  C9 FF                CMP     #$FF            ; error?, if NOT, continue
0013D0  1  D0 21                BNE     DOS65LOAD_1     ;
0013D2  1               
0013D2  1  A9 00                LDA     #<BUFFER        ; SETUP BUFFER
0013D4  1  85 09                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
0013D6  1  A9 1A                LDA     #>BUFFER        ;
0013D8  1  85 0A                STA     FCBPTR+1        ; STORE DEST BUFFER IN FCBPTR
0013DA  1  A5 09                LDA     FCBPTR          ;
0013DC  1  85 12                STA     CURRENTLEN      ;
0013DE  1  A5 0A                LDA     FCBPTR+1        ;
0013E0  1  85 13                STA     CURRENTLEN+1    ;
0013E2  1  A9 0D                LDA     #13
0013E4  1  4C 79 14             JMP     DOS65LOAD_STOREBT; OPEN EDITOR, BLANK FILE
0013E7  1               
0013E7  1               DOS65LOAD_ERR:
0013E7  1  A9 38                LDA     #<FILEERROR2    ; NO, ERROR OUT
0013E9  1  A0 18                LDY     #>FILEERROR2
0013EB  1  A2 09                LDX     #9              ; Print error message
0013ED  1  20 03 01             JSR     PEM             ;
0013F0  1  4C 00 01             JMP     BOOT            ; WARM BOOT DOS/65
0013F3  1               DOS65LOAD_1:
0013F3  1  A9 00                LDA     #0              ; clear
0013F5  1  8D 27 01             STA     DFLFCB+32       ; record number
0013F8  1  85 12                STA     CURRENTLEN      ; LENGTH COUNTER
0013FA  1  A9 00                LDA     #<BUFFER        ; SETUP BUFFER
0013FC  1  85 09                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
0013FE  1  A9 1A                LDA     #>BUFFER        ;
001400  1  85 0A                STA     FCBPTR+1        ; STORE DEST BUFFER IN FCBPTR
001402  1               
001402  1  A9 EC                LDA     #<FCBBUFFER     ; SETUP BUFFER
001404  1  85 0F                STA     TMPPOS          ;
001406  1  A0 18                LDY     #>FCBBUFFER
001408  1  84 10                STY     TMPPOS+1        ;
00140A  1  A2 1A                LDX     #26             ; Setup Buffer
00140C  1  20 03 01             JSR     PEM
00140F  1               
00140F  1               DOS65LOAD_2:
00140F  1  A9 07                LDA     #<DFLFCB        ; READ record buffer from disk file
001411  1  A0 01                LDY     #>DFLFCB        ;
001413  1  A2 14                LDX     #20             ;
001415  1  20 03 01             JSR     PEM             ;
001418  1  C9 00                CMP     #$00            ; is error or EOF
00141A  1  F0 07                BEQ     DOS65LOAD_3     ;
00141C  1  C9 01                CMP     #$01            ; EOF?
00141E  1  F0 42                BEQ     DOS65LOAD_EOF   ; YES, END
001420  1  4C E7 13             JMP     DOS65LOAD_ERR   ; ERROR, do error handling
001423  1               DOS65LOAD_3:
001423  1  A2 00                LDX     #$00            ; CLEAR COUNTERS
001425  1  A0 00                LDY     #$00            ;
001427  1               DOS65LOAD_3A:
001427  1  B1 0F                LDA     (TMPPOS),Y      ; LOAD BYTE FROM BUFFER
001429  1  C8                   INY                     ; INC BUFFER COUNTER
00142A  1  C9 1A                CMP     #$1A            ; IF EOF, SIGNAL END
00142C  1  F0 39                BEQ     DOS65LOAD_4     ;
00142E  1  C9 0D                CMP     #$0D            ; IF CR PLACE IT IN BUFFER AND PAD WITH SPACES TO MAXCOL
001430  1  F0 12                BEQ     DOS65LOAD_3D    ;
001432  1  C9 20                CMP     #32             ; IF UNPRINTABLE, DO NOT PLACE IN BUFFER
001434  1  90 07                BCC     DOS65LOAD_3C    ;
001436  1  C9 7F                CMP     #127            ;
001438  1  B0 03                BCS     DOS65LOAD_3C    ;
00143A  1  20 79 14             JSR     DOS65LOAD_STOREBT; STORE THE BYTE IN THE BUFFER
00143D  1               DOS65LOAD_3C:
00143D  1  C0 80                CPY     #$80            ; ARE WE AT THE END OF THE SOURCE BUFFER?
00143F  1  D0 E6                BNE     DOS65LOAD_3A    ; NO, LOOP
001441  1               
001441  1  4C 0F 14             JMP     DOS65LOAD_2     ; KEEP GOING!
001444  1               
001444  1               DOS65LOAD_3D:                   ; IN ORDER TO MAKE SCROLLING EASIER <CR> LINES NEED PADDED TO MAXCOL
001444  1  20 79 14             JSR     DOS65LOAD_STOREBT; STORE THE <CR> BYTE
001447  1               DOS65LOAD_3D1:
001447  1  A5 12                LDA     CURRENTLEN      ;
001449  1  F0 10                BEQ     DOS65LOAD_3D2   ; ALREADY WRAPPED TO 0 (79-CHAR LINE), NO PADDING NEEDED
00144B  1  C9 50                CMP     #MAXCOL         ;
00144D  1  F0 0C                BEQ     DOS65LOAD_3D2   ;
00144F  1  A9 00                LDA     #$00            ;
001451  1  81 09                STA     (FCBPTR,X)      ; PLACE CHAR IN BUFFER
001453  1  E6 12                INC     CURRENTLEN      ; INC THE LENGTH COUNTER
001455  1  20 87 14             JSR     DOS65LOAD_STOREBT1; INC THE BUFFER POINTER
001458  1  4C 47 14             JMP     DOS65LOAD_3D1   ;
00145B  1               DOS65LOAD_3D2:
00145B  1  A9 00                LDA     #$00            ;
00145D  1  85 12                STA     CURRENTLEN      ;
00145F  1  4C 3D 14             JMP     DOS65LOAD_3C    ;
001462  1               DOS65LOAD_EOF:
001462  1  A9 0D                LDA     #13
001464  1  20 79 14             JSR     DOS65LOAD_STOREBT
001467  1               
001467  1               DOS65LOAD_4:
001467  1  A9 07                LDA     #<DFLFCB        ; CLOSE FILE
001469  1  A0 01                LDY     #>DFLFCB        ;
00146B  1  A2 10                LDX     #16             ;
00146D  1  20 03 01             JSR     PEM             ;
001470  1  A5 09                LDA     FCBPTR          ;
001472  1  85 12                STA     CURRENTLEN      ;
001474  1  A5 0A                LDA     FCBPTR+1        ;
001476  1  85 13                STA     CURRENTLEN+1    ;
001478  1  60                   RTS
001479  1               
001479  1               
001479  1               DOS65LOAD_STOREBT:
001479  1  81 09                STA     (FCBPTR,X)      ; PLACE CHAR IN BUFFER
00147B  1  E6 12                INC     CURRENTLEN      ; INC THE LENGTH COUNTER
00147D  1  A5 12                LDA     CURRENTLEN      ;
00147F  1  C9 50                CMP     #MAXCOL         ; WRAP THE COUNTER ON MAXCOL
001481  1  D0 04                BNE     DOS65LOAD_STOREBT1;
001483  1  A9 00                LDA     #$00            ;
001485  1  85 12                STA     CURRENTLEN      ;
001487  1               DOS65LOAD_STOREBT1:
001487  1  E6 09                INC     FCBPTR          ; add to base counter
001489  1  D0 10                BNE     DOS65LOAD_STOREBT2
00148B  1  E6 0A                INC     FCBPTR+1        ; yes, carry, inc high byte
00148D  1  A5 0A                LDA     FCBPTR+1        ;
00148F  1  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
001491  1  90 08                BCC     DOS65LOAD_STOREBT2; Less than high byte, OK
001493  1  D0 07                BNE     DOS65LOAD_STOREBTE; Greater than high byte, error
001495  1  A5 09                LDA     FCBPTR          ; High bytes equal, check low byte
001497  1  C9 00                CMP     #<Ram_top       ;
001499  1  B0 01                BCS     DOS65LOAD_STOREBTE; At or past Ram_top, error
00149B  1               DOS65LOAD_STOREBT2:
00149B  1  60                   RTS
00149C  1               DOS65LOAD_STOREBTE:
00149C  1  20 67 14             JSR     DOS65LOAD_4     ; CLOSE FILE
00149F  1  A9 61                LDA     #<FILEERROR3    ; NO, ERROR OUT
0014A1  1  A0 18                LDY     #>FILEERROR3
0014A3  1  A2 09                LDX     #9              ; Print error message
0014A5  1  20 03 01             JSR     PEM             ;
0014A8  1  4C 00 01             JMP     BOOT            ; WARM BOOT DOS/65
0014AB  1               
