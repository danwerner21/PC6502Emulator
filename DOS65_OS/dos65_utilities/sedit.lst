000000r 1               ;
000000r 1               
000000r 1               DFLFCB          = $107          ;DEFAULT FCB
000000r 1               PEM             = $103          ;PEM ENTRY
000000r 1               BOOT            = $100          ;WARM BOOT
000000r 1               TEA             = $800          ;EXECUTION ORG
000000r 1               CCMLNG          = 2048          ;CCM LENGTH
000000r 1               CRSYM           = 32            ;CR SYMBOL
000000r 1               LASTROW         = 20
000000r 1               MAXCOL          = 80
000000r 1               PAGESIZE        = 100           ;PAGE UP/DOWN SIZE (100 * 16 = 1600 bytes)
000000r 1               CR              = 13            ;CARRIAGE RETURN
000000r 1               SPACE           = 32            ;SPACE CHARACTER
000000r 1               DEL             = 127           ;DELETE CHARACTER
000000r 1               EOFCHAR         = $1A           ;DOS/65 END-OF-FILE MARKER
000000r 1               
000000r 1               ;ZERO PAGE
000000r 1               NAMED           = $02           ;"TO" FILE NAMED IF <128
000000r 1               TOIND           = $03           ;"TO" FILE INDEX
000000r 1               FRMIND          = $05           ;"FROM" FILE INDEX
000000r 1               TEMP            = $08           ;
000000r 1               FCBPTR          = $09           ; POINTER TO FCB FOR FILE OPS
000000r 1               CSRPOSX         = $0B           ;
000000r 1               CSRPOSY         = $0C           ;
000000r 1               EDTPOS          = $0D           ;
000000r 1               TMPPOS          = $0F           ;
000000r 1               TEMP1           = $11           ;
000000r 1               CURRENTLEN      = $12           ;
000000r 1               MODE            = $14           ; 0= OVERWRITE MODE, 1= INSERT MODE
000000r 1               
000000r 1               ;MACROS
000000r 1                       .macro SAVE_EDITSTATE
000000r 1                       LDA     CSRPOSX
000000r 1                       PHA
000000r 1                       LDA     CSRPOSY
000000r 1                       PHA
000000r 1                       LDA     EDTPOS
000000r 1                       PHA
000000r 1                       LDA     EDTPOS+1
000000r 1                       PHA
000000r 1                       .endmacro
000000r 1               
000000r 1                       .macro RESTORE_EDITSTATE
000000r 1                       PLA
000000r 1                       STA     EDTPOS+1
000000r 1                       PLA
000000r 1                       STA     EDTPOS
000000r 1                       PLA
000000r 1                       STA     CSRPOSY
000000r 1                       PLA
000000r 1                       STA     CSRPOSX
000000r 1                       .endmacro
000000r 1               
000000r 1                       .macro INC_EDTPOS
000000r 1                       INC     EDTPOS
000000r 1                       BNE     :+
000000r 1                       INC     EDTPOS+1
000000r 1               :
000000r 1                       .endmacro
000000r 1               
000000r 1                       .macro DEC_EDTPOS
000000r 1                       LDA     EDTPOS
000000r 1                       BNE     :+
000000r 1                       DEC     EDTPOS+1
000000r 1               :
000000r 1                       DEC     EDTPOS
000000r 1                       .endmacro
