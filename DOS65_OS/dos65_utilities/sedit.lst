000DE0  1               ;__CRSRUP________________________________________________________________________________________________________________________
000DE0  1               ;
000DE0  1               ; 	MOVE THE CURSOR UP ONE POSITION, DEC THE BUFFER POINTER AND SCROLL UP IF NECESSARY
000DE0  1               ;
000DE0  1               ;________________________________________________________________________________________________________________________________
000DE0  1               ;
000DE0  1               CRSRUP:
000DE0  1  A5 0D                LDA     EDTPOS          ;
000DE2  1  D0 07                BNE     CRSRUP1         ; CHECK TO SEE IF POINTER IS AT THE VERY TOP OF THE
000DE4  1  A5 0E                LDA     EDTPOS+1        ; BUFFER.  IF IT IS, DO NOTHING.
000DE6  1  C9 1A                CMP     #>BUFFER        ;
000DE8  1  D0 01                BNE     CRSRUP1         ;
000DEA  1  60                   RTS                     ;
000DEB  1               CRSRUP1:
000DEB  1  A2 00                LDX     #$00            ;
000DED  1  A5 0C                LDA     CSRPOSY         ; FIRST LINE?
000DEF  1  D0 03                BNE     CRSRUP2         ;
000DF1  1  4C AA 0E             JMP     SCROLLUP        ; YES, SCROLL UP
000DF4  1               
000DF4  1               CRSRUP2:
000DF4  1  A5 0D D0 02          DEC_EDTPOS              ; MOVE POINTER BACK ONE
000DF8  1  C6 0E C6 0D  
000DFC  1  E8                   INX                     ; INC COUNTER
000DFD  1  E0 50                CPX     #MAXCOL         ; HAVE WE GONE BACK MAXCOL POSITIONS?
000DFF  1  D0 F3                BNE     CRSRUP2         ; NO, LOOP
000E01  1               
000E01  1  C6 0C                DEC     CSRPOSY         ;
000E03  1  4C 95 0F             JMP     CHKPOS          ; WE ARE DONE! POSITION THE CURSOR AND EXIT
000E06  1               
000E06  1               
000E06  1               ;__CRSRDN________________________________________________________________________________________________________________________
000E06  1               ;
000E06  1               ; 	MOVE THE CURSOR DOWN ONE POSITION, INC THE BUFFER POINTER AND SCROLL IF NECESSARY
000E06  1               ;
000E06  1               ;________________________________________________________________________________________________________________________________
000E06  1               ;
000E06  1               CRSRDN:
000E06  1               
000E06  1  A5 0C                LDA     CSRPOSY         ; HAVE WE REACHED THE END OF THE SCREEN?
000E08  1  C9 13                CMP     #LASTROW-1      ;
000E0A  1  D0 03                BNE     CRSRDN1         ; NO, JUST MOVE DOWN
000E0C  1  20 30 0F             JSR     SCROLLDOWN      ; SCROLL
000E0F  1               
000E0F  1               CRSRDN1:
000E0F  1  A2 00                LDX     #$00
000E11  1               CRSRDN2:
000E11  1  E6 0D D0 02          INC_EDTPOS              ; MOVE EDTPOS 1 TO THE RIGHT
000E15  1  E6 0E        
000E17  1  E8                   INX
000E18  1  E0 50                CPX     #MAXCOL
000E1A  1  F0 11                BEQ     CRSRDN3         ; YES, DONE
000E1C  1  A5 0E                LDA     EDTPOS+1        ; WILL NEXT MOVE SEND US PAST THE END OF RAM?
000E1E  1  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
000E20  1  90 08                BCC     CRSRDN2A        ; Less than high byte, OK to continue
000E22  1  D0 0E                BNE     CRSRDN4         ; Greater than high byte, stop
000E24  1  A5 0D                LDA     EDTPOS          ; High bytes equal, check low byte
000E26  1  C9 00                CMP     #<Ram_top       ;
000E28  1  B0 08                BCS     CRSRDN4         ; At or past Ram_top, stop
000E2A  1               
000E2A  1               CRSRDN2A:
000E2A  1  4C 11 0E             JMP     CRSRDN2         ; NO, KEEP GOING
000E2D  1               CRSRDN3:
000E2D  1  E6 0C                INC     CSRPOSY         ;
000E2F  1  4C 95 0F             JMP     CHKPOS          ; WE ARE DONE! POSITION THE CURSOR AND EXIT
000E32  1               CRSRDN4:
000E32  1  4C 80 10             JMP     PAINTSCREEN0    ;
