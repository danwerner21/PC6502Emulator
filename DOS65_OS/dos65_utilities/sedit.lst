0009E0  1               ;__INSERTLINE____________________________________________________________________________________________________________________
0009E0  1               ;
0009E0  1               ; 	INSERT ONE LINE AT THE CURRENT POSITION
0009E0  1               ;
0009E0  1               ;________________________________________________________________________________________________________________________________
0009E0  1               ;
0009E0  1               INSERTLINE:
0009E0  1  20 E3 08             JSR     EDITCHECK       ; VERIFY WE ARE NOT PAST EOF
0009E3  1  A5 12                LDA     CURRENTLEN      ;
0009E5  1  85 0F                STA     TMPPOS          ;
0009E7  1  A5 13                LDA     CURRENTLEN+1    ;
0009E9  1  85 10                STA     TMPPOS+1        ; TMPPOS SHOULD BE BOTTOM OF COPY
0009EB  1               
0009EB  1               ; CHECK IF WE HAVE ROOM FOR 80 MORE BYTES BEFORE MODIFYING CURRENTLEN
0009EB  1               ; Calculate CURRENTLEN + 80 to check if result < Ram_top
0009EB  1  A5 12                LDA     CURRENTLEN      ;
0009ED  1  18                   CLC                     ;
0009EE  1  69 50                ADC     #MAXCOL         ; Add 80 to low byte
0009F0  1  85 11                STA     TEMP1           ; Save result low byte temporarily
0009F2  1  A5 13                LDA     CURRENTLEN+1    ;
0009F4  1  69 00                ADC     #$00            ; Add carry to high byte
0009F6  1  85 08                STA     TEMP            ; Save result high byte temporarily
0009F8  1               ; Now TEMP:TEMP1 contains CURRENTLEN + 80
0009F8  1  C9 B8                CMP     #>Ram_top       ; Compare high byte with $B8
0009FA  1  90 08                BCC     INSERTLINE_OK   ; If less than, OK to proceed
0009FC  1  D0 78                BNE     INSERTLINE_ABORT; If greater than, abort (not enough room)
0009FE  1  A5 11                LDA     TEMP1           ; High bytes equal, check low byte
000A00  1  C9 00                CMP     #<Ram_top       ;
000A02  1  B0 72                BCS     INSERTLINE_ABORT; If >= Ram_top, abort (not enough room)
000A04  1               INSERTLINE_OK:
000A04  1               ; Safe to update CURRENTLEN with pre-calculated result
000A04  1  A5 11                LDA     TEMP1           ;
000A06  1  85 12                STA     CURRENTLEN      ;
000A08  1  A5 08                LDA     TEMP            ;
000A0A  1  85 13                STA     CURRENTLEN+1    ;
