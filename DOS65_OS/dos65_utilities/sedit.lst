000E81  1  E6 0E        
000E83  1               ;
000E83  1  A5 0E                LDA     EDTPOS+1        ;
000E85  1  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
000E87  1  90 1E                BCC     CRSRRIGHT2      ; Less than high byte, OK to continue
000E89  1  D0 06                BNE     CRSRRIGHT_BACK  ; Greater than high byte, back off
000E8B  1  A5 0D                LDA     EDTPOS          ; High bytes equal, check low byte
000E8D  1  C9 00                CMP     #<Ram_top       ;
000E8F  1  90 16                BCC     CRSRRIGHT2      ; Less than Ram_top, OK to continue
000E91  1               CRSRRIGHT_BACK:
000E91  1  A5 0D D0 02          DEC_EDTPOS              ; OTHERWISE BACK POINTER OFF ONE
000E95  1  C6 0E C6 0D  
000E99  1               ; AND PLACE CURSOR BACK ONE POSITION
