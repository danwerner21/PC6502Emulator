00139E  1               ;
00139E  1               ;
00139E  1               ;
00139E  1               ;________________________________________________________________________________________________________________________________
00139E  1               ;
00139E  1               CLEARBUFFER:
00139E  1  A9 00                LDA     #<BUFFER        ; SETUP BUFFER
0013A0  1  85 0D                STA     EDTPOS          ;
0013A2  1  A9 1A                LDA     #>BUFFER        ;
0013A4  1  85 0E                STA     EDTPOS+1        ;
0013A6  1  A0 00                LDY     #$00            ;
0013A8  1               
0013A8  1  A9 00                LDA     #$00
0013AA  1               CLEARBUFFER1:
0013AA  1  91 0D                STA     (EDTPOS),Y
0013AC  1  C8                   INY
0013AD  1  D0 FB                BNE     CLEARBUFFER1
0013AF  1  E6 0E                INC     EDTPOS+1
0013B1  1  A6 0E                LDX     EDTPOS+1
0013B3  1  E0 B8                CPX     #>Ram_top       ; are we at the end of RAM?
0013B5  1  90 F3                BCC     CLEARBUFFER1    ; Less than high byte, continue
0013B7  1  D0 06                BNE     CLEARBUFFER_DONE; Greater than high byte, done
0013B9  1  A6 0D                LDX     EDTPOS          ; High bytes equal, check low byte
0013BB  1  E0 00                CPX     #<Ram_top       ;
0013BD  1  90 EB                BCC     CLEARBUFFER1    ; Less than Ram_top, continue
0013BF  1               CLEARBUFFER_DONE:
0013BF  1  60                   RTS
