000D71  1  68                   PLA                     ; Pop character back
000D72  1  20 50 12             JSR     TOCONSOLE       ; Output it
000D75  1  C8                   INY
000D76  1  CA                   DEX
000D77  1  D0 E6                BNE     DELETECHAR4
000D79  1  F0 01                BEQ     DELETECHAR4B    ; Exit when counter exhausted
000D7B  1               DELETECHAR4A:                   ; Exit path that cleans stack
000D7B  1  68                   PLA                     ; Pop unused character
000D7C  1               DELETECHAR4B:
000D7C  1               
000D7C  1               ; clean the rest of the line to avoid artifacts
000D7C  1  A9 97                LDA     #<ERASEEOLSEQ
000D7E  1  A0 12                LDY     #>ERASEEOLSEQ
000D80  1  A2 09                LDX     #9
