00129B  1               ;			01=CRSR DN
00129B  1               ;			02=CRSR LEFT
00129B  1               ;			03=CRSR RIGHT
00129B  1               ;			04=PG DN
00129B  1               ;			05=PG UP
00129B  1               ;			08=BACKSPACE
00129B  1               ;			$30=CR
00129B  1               ;			$11-$24= FUNCTION KEYS
00129B  1               ;		$FF IS NULL OP
00129B  1               ;________________________________________________________________________________________________________________________________
00129B  1               ;
