000D4A  1               ; delete char at cursor (terminal shifts remainder left)
000D4A  1  A9 93                LDA     #<DELCHARSEQ
000D4C  1  A0 12                LDY     #>DELCHARSEQ
000D4E  1  A2 09                LDX     #9
000D50  1  20 03 01             JSR     PEM
000D53  1               
000D53  1               ; redraw rest of line (stop at CR or line end)
000D53  1  A9 4F                LDA     #MAXCOL-1
000D55  1  38                   SEC
000D56  1  ED 95 0D             SBC     DELETECHARTMP   ; remaining cols before wrap
000D59  1  85 11                STA     TEMP1
000D5B  1  A0 00                LDY     #$00
000D5D  1  A2 50                LDX     #MAXCOL         ; limit redraw to full line width
000D5F  1               DELETECHAR4:
000D5F  1  B1 0D                LDA     (EDTPOS),Y      ; Load character
000D61  1  C9 0D                CMP     #13
000D63  1  D0 06                BNE     DELETECHAR4_NOTCR
000D65  1  20 50 12             JSR     TOCONSOLE       ; RENDER THE CR MARKER BEFORE EXITING
000D68  1  4C 7C 0D             JMP     DELETECHAR4B    ; THEN CLEAN UP REST OF LINE
000D6B  1               DELETECHAR4_NOTCR:
000D6B  1  48                   PHA                     ; Push character to preserve it
000D6C  1  98                   TYA                     ; Check if Y >= TEMP1
000D6D  1  C5 11                CMP     TEMP1
