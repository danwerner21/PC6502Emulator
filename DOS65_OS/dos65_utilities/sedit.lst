000D12  1  85 0B                STA     CSRPOSX
000D14  1  20 FB 11             JSR     GOCSR           ; POSITION CURSOR TO COL 0 OF CURRENT ROW
000D17  1  A0 00                LDY     #$00
000D19  1               DELETECHAR_FP2:
000D19  1  B1 0D                LDA     (EDTPOS),Y
000D1B  1  20 50 12             JSR     TOCONSOLE
000D1E  1  E6 0D D0 02          INC_EDTPOS
000D22  1  E6 0E        
000D24  1  A5 0C                LDA     CSRPOSY         ; HAVE WE REACHED THE END OF THE SCREEN?
000D26  1  C9 14                CMP     #LASTROW
000D28  1  D0 EF                BNE     DELETECHAR_FP2
000D2A  1               
000D2A  1  68 85 0E 68          RESTORE_EDITSTATE
000D2E  1  85 0D 68 85  
000D32  1  0C 68 85 0B  
000D36  1  4C FB 11             JMP     GOCSR           ;
000D39  1               
000D39  1               ; FAST DISPLAY UPDATE: USE ANSI DELETE-CHAR (for mid-line deletes)
000D39  1               DELETECHAR_FAST:
