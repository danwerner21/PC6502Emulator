00129B  1               ;__READKB________________________________________________________________________________________________________________________
00129B  1               ;
00129B  1               ; 	READ THE KEYBOARD
00129B  1               ;	A: DATA
00129B  1               ;	Y: COMMAND
00129B  1               ;		0 IS REGULAR CHAR
00129B  1               ;		1 IS FUNCTION KEY
