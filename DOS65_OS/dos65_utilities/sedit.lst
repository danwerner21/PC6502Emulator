000A61  1  A5 0C                LDA     CSRPOSY         ; HAVE WE REACHED THE END OF THE SCREEN?
000A63  1  C9 14                CMP     #LASTROW        ;
000A65  1  D0 EF                BNE     INSERTLINE3     ; NO
000A67  1  68 85 0E 68          RESTORE_EDITSTATE
000A6B  1  85 0D 68 85  
000A6F  1  0C 68 85 0B  
000A73  1  4C FB 11             JMP     GOCSR           ;
000A76  1               
000A76  1               INSERTLINE_ABORT:
000A76  1  60                   RTS
000A77  1               
000A77  1               
000A77  1               
000A77  1               ;__DELETELINE____________________________________________________________________________________________________________________
000A77  1               ;
000A77  1               ; 	DELETE ONE LINE AT THE CURRENT POSITION
000A77  1               ;
000A77  1               ;________________________________________________________________________________________________________________________________
000A77  1               ;
000A77  1               DELETELINE:
000A77  1               ; CHECK THAT CURRENTLEN - MAXCOL WON'T UNDERFLOW PAST BUFFER
000A77  1  A5 12                LDA     CURRENTLEN      ;
000A79  1  38                   SEC                     ;
000A7A  1  E9 50                SBC     #MAXCOL         ;
000A7C  1  85 11                STA     TEMP1           ; SAVE CANDIDATE LOW BYTE
000A7E  1  A5 13                LDA     CURRENTLEN+1    ;
000A80  1  E9 00                SBC     #$00            ;
000A82  1  C9 1A                CMP     #>BUFFER        ; COMPARE HIGH BYTE WITH BUFFER START
000A84  1  90 70                BCC     DELETELINE_ABORT; WOULD GO BELOW BUFFER, ABORT
000A86  1  D0 06                BNE     DELETELINE_OK   ; ABOVE BUFFER PAGE, SAFE
000A88  1  A5 11                LDA     TEMP1           ; HIGH BYTES EQUAL, CHECK LOW BYTE
000A8A  1  C9 00                CMP     #<BUFFER        ;
000A8C  1  90 68                BCC     DELETELINE_ABORT; WOULD GO BELOW BUFFER, ABORT
000A8E  1               DELETELINE_OK:
000A8E  1  A5 0D                LDA     EDTPOS          ;
000A90  1  85 0F                STA     TMPPOS          ;
000A92  1  A5 0E                LDA     EDTPOS+1        ;
000A94  1  85 10                STA     TMPPOS+1        ; TMPPOS SHOULD BE TOP OF COPY
000A96  1               
000A96  1  A5 12                LDA     CURRENTLEN      ; SET CURRENTLEN TO NEW TOP
000A98  1  38                   SEC                     ; (-80)
000A99  1  E9 50                SBC     #MAXCOL         ;
000A9B  1  85 12                STA     CURRENTLEN      ;
000A9D  1  A5 13                LDA     CURRENTLEN+1    ;
000A9F  1  E9 00                SBC     #$00            ;
000AA1  1  85 13                STA     CURRENTLEN+1    ;
000AA3  1               ;
000AA3  1               DELETELINE1:
000AA3  1  A0 50                LDY     #MAXCOL         ;
000AA5  1  B1 0F                LDA     (TMPPOS),Y      ;
000AA7  1  A0 00                LDY     #$00            ;
000AA9  1  91 0F                STA     (TMPPOS),Y      ;
000AAB  1  E6 0F                INC     TMPPOS          ;
000AAD  1  A5 0F                LDA     TMPPOS          ;
000AAF  1  D0 02                BNE     DELETELINE1A    ;
000AB1  1  E6 10                INC     TMPPOS+1        ;
000AB3  1               DELETELINE1A:
000AB3  1  A5 10                LDA     TMPPOS+1        ; COMPARE HIGH BYTES
000AB5  1  C5 13                CMP     CURRENTLEN+1    ;
000AB7  1  90 EA                BCC     DELETELINE1     ; CONTINUE IF TMPPOS+1 < CURRENTLEN+1
000AB9  1  D0 06                BNE     DELETELINE1B    ; EXIT IF TMPPOS+1 > CURRENTLEN+1 (SAFETY CHECK)
000ABB  1  A5 0F                LDA     TMPPOS          ; HIGH BYTES EQUAL, CHECK LOW BYTES
000ABD  1  C5 12                CMP     CURRENTLEN      ;
000ABF  1  90 E2                BCC     DELETELINE1     ; CONTINUE IF TMPPOS < CURRENTLEN
000AC1  1               DELETELINE1B:                   ; EXIT WHEN TMPPOS >= CURRENTLEN
000AC1  1               
000AC1  1  A5 0B 48 A5          SAVE_EDITSTATE
000AC5  1  0C 48 A5 0D  
000AC9  1  48 A5 0E 48  
000ACD  1  A9 00                LDA     #$00            ;
000ACF  1  85 0B                STA     CSRPOSX         ;
000AD1  1  20 FB 11             JSR     GOCSR           ;
000AD4  1  A0 00                LDY     #$00            ;
000AD6  1               DELETELINE3:
000AD6  1  B1 0D                LDA     (EDTPOS),Y      ;
000AD8  1  20 50 12             JSR     TOCONSOLE       ;
000ADB  1  E6 0D D0 02          INC_EDTPOS              ;
000ADF  1  E6 0E        
000AE1  1  A5 0C                LDA     CSRPOSY         ; HAVE WE REACHED THE END OF THE SCREEN?
000AE3  1  C9 14                CMP     #LASTROW        ;
000AE5  1  D0 EF                BNE     DELETELINE3     ; NO
000AE7  1  68 85 0E 68          RESTORE_EDITSTATE
000AEB  1  85 0D 68 85  
000AEF  1  0C 68 85 0B  
000AF3  1  4C FB 11             JMP     GOCSR           ;
000AF6  1               
000AF6  1               DELETELINE_ABORT:
000AF6  1  60                   RTS
000AF7  1               
000AF7  1               ;__INSERTCHAR____________________________________________________________________________________________________________________
000AF7  1               ;
000AF7  1               ; 	INSERT ONE CHAR AT THE CURRENT POSITION
000AF7  1               ;
000AF7  1               ;________________________________________________________________________________________________________________________________
000AF7  1               ;
000AF7  1               INSERTCHAR:
000AF7  1  A5 0D                LDA     EDTPOS          ; STORE CURRENT POSITION
000AF9  1  85 0F                STA     TMPPOS          ;
000AFB  1  A5 0E                LDA     EDTPOS+1        ;
000AFD  1  85 10                STA     TMPPOS+1        ;
000AFF  1               
000AFF  1               ; FIND END OF LINE
000AFF  1  A0 00                LDY     #$00            ;
000B01  1               INSERTCHAR1:
000B01  1               ; FIX: Check full 16-bit boundary, not just high byte
000B01  1  A5 10                LDA     TMPPOS+1        ; CHECK BOUNDARY BEFORE READING
000B03  1  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
000B05  1  90 0E                BCC     INSERTCHAR1A    ; Less than high byte, safe
000B07  1  D0 09                BNE     :+              ; Greater than high byte, abort
000B09  1  A5 0F                LDA     TMPPOS          ; High bytes equal, check low byte
000B0B  1  C9 00                CMP     #<Ram_top       ;
000B0D  1  B0 03                BCS     :+              ; At or past Ram_top, abort
000B0F  1  4C 15 0B             JMP     INSERTCHAR1A
000B12  1               :
000B12  1  4C 8F 0B             JMP     INSERTCHAR_ABORT
000B15  1               INSERTCHAR1A:
000B15  1  B1 0F                LDA     (TMPPOS),Y      ; READ BYTE
000B17  1               
000B17  1  E6 0F                INC     TMPPOS          ; INC POINTER
000B19  1  D0 02                BNE     INSERTCHAR1B    ;
000B1B  1  E6 10                INC     TMPPOS+1        ;
000B1D  1               INSERTCHAR1B:
000B1D  1  C9 0D                CMP     #13             ; AT END?
000B1F  1  F0 03                BEQ     INSERTCHAR2     ; FOUND END
000B21  1  4C 01 0B             JMP     INSERTCHAR1     ;
000B24  1               
000B24  1               INSERTCHAR2:
000B24  1  B1 0F                LDA     (TMPPOS),Y      ; FREE SPACE AT END OF LINE?
000B26  1  F0 11                BEQ     INSERTCHAR3     ; YES, PROCEED WITH INSERT
000B28  1               ; NO FREE SPACE - CHECK IF WE'RE AT EOF (TMPPOS >= CURRENTLEN)
000B28  1  A5 10                LDA     TMPPOS+1        ;
000B2A  1  C5 13                CMP     CURRENTLEN+1    ;
000B2C  1  90 08                BCC     INSERTCHAR2A    ; TMPPOS+1 < CURRENTLEN+1, NOT AT EOF
000B2E  1  D0 5F                BNE     INSERTCHAR_ABORT; TMPPOS+1 > CURRENTLEN+1, PAST EOF - ABORT
000B30  1  A5 0F                LDA     TMPPOS          ; HIGH BYTES EQUAL, CHECK LOW BYTES
000B32  1  C5 12                CMP     CURRENTLEN      ;
000B34  1  B0 59                BCS     INSERTCHAR_ABORT; TMPPOS >= CURRENTLEN, AT OR PAST EOF - ABORT
000B36  1               INSERTCHAR2A:
000B36  1  20 90 0B             JSR     INSERTCHAR5     ; NOT AT EOF, INSERT A LINE
000B39  1               
000B39  1               INSERTCHAR3:
000B39  1  C6 0F                DEC     TMPPOS          ; DEC TMPPOS
000B3B  1  A5 0F                LDA     TMPPOS          ;
000B3D  1  C9 FF                CMP     #$FF            ;
000B3F  1  D0 02                BNE     INSERTCHAR3A    ;
000B41  1  C6 10                DEC     TMPPOS+1        ;
000B43  1               INSERTCHAR3A:
000B43  1  A0 00                LDY     #$00            ; MOVE EVERYTHING UP ONE POS
000B45  1  B1 0F                LDA     (TMPPOS),Y      ;
000B47  1  C8                   INY                     ;
000B48  1  91 0F                STA     (TMPPOS),Y      ;
000B4A  1  A5 10                LDA     TMPPOS+1        ; AT CURRENT POSITION?
000B4C  1  C5 0E                CMP     EDTPOS+1        ;
000B4E  1  D0 E9                BNE     INSERTCHAR3     ; NO, LOOP
000B50  1  A5 0F                LDA     TMPPOS          ;
000B52  1  C5 0D                CMP     EDTPOS          ;
000B54  1  D0 E3                BNE     INSERTCHAR3     ; NO, LOOP
000B56  1               
000B56  1  A0 00                LDY     #$00            ; CLEAR VACATED POSITION SO EDIT_OM
000B58  1  A9 00                LDA     #$00            ; DOES NOT SEE STALE CR FROM PRE-SHIFT
000B5A  1  91 0D                STA     (EDTPOS),Y      ;
000B5C  1               
000B5C  1  A5 0B 48 A5          SAVE_EDITSTATE
000B60  1  0C 48 A5 0D  
000B64  1  48 A5 0E 48  
000B68  1  A0 00                LDY     #$00            ;
000B6A  1  A2 50                LDX     #MAXCOL         ; SAFETY: LIMIT REDRAW TO ONE LINE (80 CHARS)
000B6C  1               INSERTCHAR4:
000B6C  1  B1 0D                LDA     (EDTPOS),Y      ;
000B6E  1  48                   PHA                     ;
000B6F  1  20 50 12             JSR     TOCONSOLE       ;
000B72  1  E6 0D D0 02          INC_EDTPOS              ;
000B76  1  E6 0E        
000B78  1  68                   PLA                     ;
000B79  1  C9 0D                CMP     #13             ; HAVE WE REACHED THE END OF THE ROW?
000B7B  1  F0 03                BEQ     INSERTCHAR4_DONE; YES, EXIT
000B7D  1  CA                   DEX                     ; DECREMENT SAFETY COUNTER
000B7E  1  D0 EC                BNE     INSERTCHAR4     ; CONTINUE IF NOT EXHAUSTED
000B80  1               INSERTCHAR4_DONE:
000B80  1  68 85 0E 68          RESTORE_EDITSTATE
000B84  1  85 0D 68 85  
000B88  1  0C 68 85 0B  
000B8C  1  4C FB 11             JMP     GOCSR           ;
000B8F  1               INSERTCHAR_ABORT:
000B8F  1  60                   RTS                     ;
000B90  1               INSERTCHAR5:
000B90  1  A5 0C                LDA     CSRPOSY         ; HAVE WE REACHED THE END OF THE SCREEN?
000B92  1  C9 13                CMP     #LASTROW-1      ;
000B94  1  D0 03                BNE     INSERTCHAR5A    ; NO
000B96  1  20 30 0F             JSR     SCROLLDOWN      ; SCROLL
000B99  1               INSERTCHAR5A:
000B99  1  A5 0D                LDA     EDTPOS          ;
000B9B  1  48                   PHA                     ;
000B9C  1  A5 0E                LDA     EDTPOS+1        ;
000B9E  1  48                   PHA                     ;
000B9F  1  A5 0B                LDA     CSRPOSX         ;
000BA1  1  48                   PHA                     ;
000BA2  1  A5 0C                LDA     CSRPOSY         ;
000BA4  1  48                   PHA                     ;
000BA5  1  A9 00                LDA     #$00            ;
000BA7  1  85 0B                STA     CSRPOSX         ;
000BA9  1  E6 0C                INC     CSRPOSY         ;
000BAB  1  20 FB 11             JSR     GOCSR           ;
000BAE  1               
000BAE  1  A5 0F                LDA     TMPPOS          ;
000BB0  1  85 0D                STA     EDTPOS          ;
000BB2  1  A5 10                LDA     TMPPOS+1        ;
000BB4  1  85 0E                STA     EDTPOS+1        ;
000BB6  1               
000BB6  1  20 E0 09             JSR     INSERTLINE      ;
000BB9  1  68                   PLA                     ;
000BBA  1  85 0C                STA     CSRPOSY         ;
000BBC  1  68                   PLA                     ;
000BBD  1  85 0B                STA     CSRPOSX         ;
000BBF  1  68                   PLA                     ;
000BC0  1  85 0E                STA     EDTPOS+1        ;
000BC2  1  68                   PLA                     ;
000BC3  1  85 0D                STA     EDTPOS          ;
000BC5  1  4C FB 11             JMP     GOCSR           ;
000BC8  1               
000BC8  1               
000BC8  1               
000BC8  1               
000BC8  1               ;__BACKSPACE_____________________________________________________________________________________________________________________
000BC8  1               ;
000BC8  1               ; 	PERFORM BACKSPACE FUNCTION AT THE CURRENT POSITION
000BC8  1               ;
000BC8  1               ;________________________________________________________________________________________________________________________________
000BC8  1               ;
000BC8  1               BACKSPACE:
000BC8  1  A5 0D                LDA     EDTPOS          ; CHECK IF AT BUFFER START
000BCA  1  D0 07                BNE     BACKSPACE1      ;
000BCC  1  A5 0E                LDA     EDTPOS+1        ;
000BCE  1  C9 1A                CMP     #>BUFFER        ;
000BD0  1  D0 01                BNE     BACKSPACE1      ;
000BD2  1  60                   RTS                     ; AT BUFFER START, DO NOTHING
000BD3  1               BACKSPACE1:
000BD3  1  20 35 0E             JSR     CRSRLEFT
000BD6  1  4C D9 0B             JMP     DELETECHAR
000BD9  1               
000BD9  1               
000BD9  1               ;__DELETECHAR____________________________________________________________________________________________________________________
000BD9  1               ;
000BD9  1               ; 	DELETE ONE CHAR AT THE CURRENT POSITION
000BD9  1               ;
000BD9  1               ;________________________________________________________________________________________________________________________________
000BD9  1               ;
000BD9  1               DELETECHAR:
000BD9  1               ; CHECK IF WE'RE AT OR PAST EOF (NOTHING TO DELETE)
000BD9  1  A5 0E                LDA     EDTPOS+1        ;
000BDB  1  C5 13                CMP     CURRENTLEN+1    ;
000BDD  1  90 0E                BCC     DELETECHAR0A    ; EDTPOS+1 < CURRENTLEN+1, OK
000BDF  1  F0 03                BEQ     DELETECHAR0B    ; HIGH BYTES EQUAL, CHECK LOW BYTE
000BE1  1  4C 94 0D             JMP     DELETECHAR_ABORT; EDTPOS+1 > CURRENTLEN+1, PAST EOF
000BE4  1               DELETECHAR0B:
000BE4  1  A5 0D                LDA     EDTPOS          ;
000BE6  1  C5 12                CMP     CURRENTLEN      ;
000BE8  1  90 03                BCC     DELETECHAR0A    ; EDTPOS < CURRENTLEN, OK
000BEA  1  4C 94 0D             JMP     DELETECHAR_ABORT; EDTPOS >= CURRENTLEN, AT/PAST EOF
000BED  1               
000BED  1               DELETECHAR0A:
000BED  1               ; Save the character we're about to delete to determine repaint strategy
000BED  1  A0 00                LDY     #$00            ;
000BEF  1  B1 0D                LDA     (EDTPOS),Y      ; Read character at cursor
000BF1  1  85 08                STA     TEMP            ; Save it for later
000BF3  1               
000BF3  1               ; SPECIAL CASE: CR AT COLUMN 0 = EMPTY LINE
000BF3  1               ; BYTE-SHIFT WOULD CORRUPT THE 80-COLUMN LINE STRUCTURE
000BF3  1               ; USE DELETELINE TO PROPERLY REMOVE THE ENTIRE 80-BYTE LINE
000BF3  1  C9 0D                CMP     #13             ; DELETING A CR?
000BF5  1  D0 07                BNE     DELETECHAR_SHIFTA; NO, NORMAL DELETE
000BF7  1               
000BF7  1  A5 0B                LDA     CSRPOSX         ; AT COLUMN 0? (EMPTY LINE)
000BF9  1  D0 06                BNE     DELETECHAR_MERGE; NO, MERGE WITH NEXT LINE
000BFB  1  4C 77 0A             JMP     DELETELINE      ; YES, REMOVE ENTIRE EMPTY LINE
000BFE  1               DELETECHAR_SHIFTA:
000BFE  1  4C 8D 0C             JMP     DELETECHAR_SHIFT
000C01  1               ;
000C01  1               ; DELETECHAR_MERGE - MERGE CURRENT LINE WITH NEXT LINE WHEN DELETING CR
000C01  1               ;
000C01  1               ; WHEN THE USER DELETES A CR AT COLUMN > 0, WE MUST:
000C01  1               ;   1. COPY NEXT LINE'S CONTENT TO CURRENT LINE (REPLACING CR + NULLS)
000C01  1               ;   2. WRITE NEW CR AFTER MERGED CONTENT
000C01  1               ;   3. NULL-FILL REMAINDER OF CURRENT LINE
000C01  1               ;   4. DELETE THE NEXT LINE (SHIFT BUFFER UP BY MAXCOL, REDUCE CURRENTLEN)
000C01  1               ;   5. FULL SCREEN REPAINT
000C01  1               ;
000C01  1               DELETECHAR_MERGE:
000C01  1               ; CALCULATE NEXT LINE START: TMPPOS = EDTPOS + (MAXCOL - CSRPOSX)
000C01  1  A9 50                LDA     #MAXCOL         ;
000C03  1  38                   SEC                     ;
000C04  1  E5 0B                SBC     CSRPOSX         ; A = DISTANCE TO NEXT LINE START
000C06  1  18                   CLC                     ;
000C07  1  65 0D                ADC     EDTPOS          ;
000C09  1  85 0F                STA     TMPPOS          ;
000C0B  1  A5 0E                LDA     EDTPOS+1        ;
000C0D  1  69 00                ADC     #$00            ;
000C0F  1  85 10                STA     TMPPOS+1        ; TMPPOS = START OF NEXT LINE
000C11  1               
000C11  1               ; CHECK IF NEXT LINE EXISTS (TMPPOS < CURRENTLEN)
000C11  1  A5 10                LDA     TMPPOS+1        ;
000C13  1  C5 13                CMP     CURRENTLEN+1    ;
000C15  1  90 0B                BCC     DELETECHAR_MERGE_OK; TMPPOS < CURRENTLEN
000C17  1  D0 06                BNE     DELETECHAR_MERGE_ABORT; TMPPOS > CURRENTLEN, NO NEXT LINE
000C19  1  A5 0F                LDA     TMPPOS          ;
000C1B  1  C5 12                CMP     CURRENTLEN      ;
000C1D  1  90 03                BCC     DELETECHAR_MERGE_OK; TMPPOS < CURRENTLEN
000C1F  1               DELETECHAR_MERGE_ABORT:
000C1F  1  4C 94 0D             JMP     DELETECHAR_ABORT; NO NEXT LINE, NOTHING TO MERGE
000C22  1               
000C22  1               DELETECHAR_MERGE_OK:
000C22  1               ; COUNT CONTENT ON NEXT LINE (SCAN FOR CR)
000C22  1  A0 00                LDY     #$00            ;
000C24  1               DELETECHAR_MERGE_COUNT:
000C24  1  B1 0F                LDA     (TMPPOS),Y      ;
000C26  1  C9 0D                CMP     #CR             ; FOUND CR?
000C28  1  F0 05                BEQ     DELETECHAR_MERGE_COUNTED
000C2A  1  C8                   INY                     ;
000C2B  1  C0 50                CPY     #MAXCOL         ; SAFETY: DON'T SCAN PAST LINE
000C2D  1  D0 F5                BNE     DELETECHAR_MERGE_COUNT
000C2F  1               DELETECHAR_MERGE_COUNTED:
000C2F  1               ; Y = NUMBER OF CONTENT BYTES ON NEXT LINE (BEFORE CR)
000C2F  1  84 11                STY     TEMP1           ; SAVE NEXT LINE CONTENT LENGTH
000C31  1               
000C31  1               ; CHECK IF MERGE FITS: CSRPOSX + NEXT_CONTENT < MAXCOL
000C31  1               ; (NEED ROOM FOR AT LEAST THE CR)
000C31  1  98                   TYA                     ;
000C32  1  18                   CLC                     ;
000C33  1  65 0B                ADC     CSRPOSX         ;
000C35  1  C9 50                CMP     #MAXCOL         ; CSRPOSX + NEXT_CONTENT >= MAXCOL?
000C37  1  B0 E6                BCS     DELETECHAR_MERGE_ABORT; YES, CAN'T MERGE - TOO LONG
000C39  1               
000C39  1               ; COPY NEXT LINE CONTENT TO CURRENT LINE AT CURSOR POSITION
000C39  1  A0 00                LDY     #$00            ;
000C3B  1  A6 11                LDX     TEMP1           ; COUNTER = NEXT LINE CONTENT LENGTH
000C3D  1  F0 08                BEQ     DELETECHAR_MERGE_NOCOPY; NOTHING TO COPY (NEXT LINE EMPTY)
000C3F  1               DELETECHAR_MERGE_COPY:
000C3F  1  B1 0F                LDA     (TMPPOS),Y      ; READ FROM NEXT LINE
000C41  1  91 0D                STA     (EDTPOS),Y      ; WRITE TO CURRENT LINE AT CR POSITION
000C43  1  C8                   INY                     ;
000C44  1  CA                   DEX                     ;
000C45  1  D0 F8                BNE     DELETECHAR_MERGE_COPY
000C47  1               
000C47  1               DELETECHAR_MERGE_NOCOPY:
000C47  1               ; WRITE CR AFTER MERGED CONTENT
000C47  1  A9 0D                LDA     #CR             ;
000C49  1  91 0D                STA     (EDTPOS),Y      ; CR AT EDTPOS + NEXT_CONTENT
000C4B  1  C8                   INY                     ;
000C4C  1               
000C4C  1               ; NULL-FILL REST OF CURRENT LINE TO NEXT LINE BOUNDARY
000C4C  1               ; FILL FROM CURRENT Y TO (MAXCOL - CSRPOSX)
000C4C  1  A9 50                LDA     #MAXCOL         ;
000C4E  1  38                   SEC                     ;
000C4F  1  E5 0B                SBC     CSRPOSX         ; A = DISTANCE FROM EDTPOS TO NEXT LINE
000C51  1  85 11                STA     TEMP1           ; REUSE TEMP1 AS FILL LIMIT
000C53  1  A9 00                LDA     #$00            ;
000C55  1               DELETECHAR_MERGE_FILL:
000C55  1  C4 11                CPY     TEMP1           ; REACHED NEXT LINE BOUNDARY?
000C57  1  B0 05                BCS     DELETECHAR_MERGE_DEL; YES, DONE FILLING
000C59  1  91 0D                STA     (EDTPOS),Y      ; WRITE NULL
000C5B  1  C8                   INY                     ;
000C5C  1  D0 F7                BNE     DELETECHAR_MERGE_FILL; ALWAYS TAKEN (Y < 80)
000C5E  1               
000C5E  1               DELETECHAR_MERGE_DEL:
000C5E  1               ; DELETE THE NEXT LINE BY SHIFTING BUFFER UP BY MAXCOL
000C5E  1               ; TMPPOS ALREADY POINTS TO NEXT LINE START
000C5E  1               ; REDUCE CURRENTLEN BY MAXCOL
000C5E  1  A5 12                LDA     CURRENTLEN      ;
000C60  1  38                   SEC                     ;
000C61  1  E9 50                SBC     #MAXCOL         ;
000C63  1  85 12                STA     CURRENTLEN      ;
000C65  1  A5 13                LDA     CURRENTLEN+1    ;
000C67  1  E9 00                SBC     #$00            ;
000C69  1  85 13                STA     CURRENTLEN+1    ;
000C6B  1               
000C6B  1               ; SHIFT LOOP: COPY FROM TMPPOS+MAXCOL TO TMPPOS
000C6B  1               DELETECHAR_MERGE_SHIFT:
000C6B  1  A5 10                LDA     TMPPOS+1        ; CHECK IF DONE
000C6D  1  C5 13                CMP     CURRENTLEN+1    ;
000C6F  1  90 08                BCC     DELETECHAR_MERGE_SHIFT1; TMPPOS < CURRENTLEN, CONTINUE
000C71  1  D0 17                BNE     DELETECHAR_MERGE_DONE; TMPPOS > CURRENTLEN, DONE
000C73  1  A5 0F                LDA     TMPPOS          ;
000C75  1  C5 12                CMP     CURRENTLEN      ;
000C77  1  B0 11                BCS     DELETECHAR_MERGE_DONE; TMPPOS >= CURRENTLEN, DONE
000C79  1               DELETECHAR_MERGE_SHIFT1:
000C79  1  A0 50                LDY     #MAXCOL         ;
000C7B  1  B1 0F                LDA     (TMPPOS),Y      ; READ FROM TMPPOS + MAXCOL
000C7D  1  A0 00                LDY     #$00            ;
000C7F  1  91 0F                STA     (TMPPOS),Y      ; WRITE TO TMPPOS
000C81  1  E6 0F                INC     TMPPOS          ;
000C83  1  D0 E6                BNE     DELETECHAR_MERGE_SHIFT
000C85  1  E6 10                INC     TMPPOS+1        ;
000C87  1  4C 6B 0C             JMP     DELETECHAR_MERGE_SHIFT
000C8A  1               
000C8A  1               DELETECHAR_MERGE_DONE:
000C8A  1  4C F4 0C             JMP     DELETECHAR_FULLREPAINT
000C8D  1               
000C8D  1               DELETECHAR_SHIFT:
000C8D  1  A5 0D                LDA     EDTPOS          ; STORE CURRENT POSITION
000C8F  1  85 0F                STA     TMPPOS          ;
000C91  1  A5 0E                LDA     EDTPOS+1        ;
000C93  1  85 10                STA     TMPPOS+1        ;
000C95  1               
000C95  1               ; MOVE CHARS BACK ONE SPACE UNTIL CR OR EOF
000C95  1               DELETECHAR1:
000C95  1               ; First, check if next byte (TMPPOS+1) is at or past EOF
000C95  1               ; Calculate TMPPOS+1 for comparison
000C95  1  A5 0F                LDA     TMPPOS          ;
000C97  1  18                   CLC                     ;
000C98  1  69 01                ADC     #$01            ;
000C9A  1  85 11                STA     TEMP1           ; TEMP1 = low byte of TMPPOS+1
000C9C  1  A5 10                LDA     TMPPOS+1        ;
000C9E  1  69 00                ADC     #$00            ;
000CA0  1               ; A now has high byte of TMPPOS+1
000CA0  1  C5 13                CMP     CURRENTLEN+1    ;
000CA2  1  90 0E                BCC     DELETECHAR1A    ; TMPPOS+1 < CURRENTLEN, OK to read
000CA4  1  F0 03                BEQ     DELETECHAR1AB   ; HIGH BYTES EQUAL, CHECK LOW BYTE
000CA6  1  4C DA 0C             JMP     DELETECHAR1_EOF ; TMPPOS+1 > CURRENTLEN, past EOF
000CA9  1               DELETECHAR1AB:
000CA9  1  A5 11                LDA     TEMP1           ;
000CAB  1  C5 12                CMP     CURRENTLEN      ;
000CAD  1  90 03                BCC     DELETECHAR1A    ; TMPPOS+1 < CURRENTLEN, OK to read
000CAF  1  4C DA 0C             JMP     DELETECHAR1_EOF ; TMPPOS+1 >= CURRENTLEN, at/past EOF
000CB2  1               
000CB2  1               DELETECHAR1A:
000CB2  1               ; Safe to read from TMPPOS+1
000CB2  1  A0 01                LDY     #$01            ;
000CB4  1  B1 0F                LDA     (TMPPOS),Y      ; Read byte from next position
000CB6  1  C9 0D                CMP     #13             ; CHECK FOR CR
000CB8  1  F0 13                BEQ     DELETECHAR1C    ; FOUND CR, HANDLE IT
000CBA  1  C9 00                CMP     #$00            ; CHECK FOR NULL
000CBC  1  D0 02                BNE     DELETECHAR1B    ;
000CBE  1  A9 20                LDA     #32             ; REPLACE NULLS WITH SPACES
000CC0  1               
000CC0  1               DELETECHAR1B:
000CC0  1  A0 00                LDY     #$00            ;
000CC2  1  91 0F                STA     (TMPPOS),Y      ; Store at current position
000CC4  1  E6 0F                INC     TMPPOS          ; INC POINTER
000CC6  1  D0 CD                BNE     DELETECHAR1     ; NO OVERFLOW, CONTINUE
000CC8  1  E6 10                INC     TMPPOS+1        ; OVERFLOW, INC HIGH BYTE
000CCA  1  4C 95 0C             JMP     DELETECHAR1     ; CONTINUE LOOP
000CCD  1               
000CCD  1               DELETECHAR1C:                   ; FOUND CR
000CCD  1  A0 00                LDY     #$00            ;
000CCF  1  91 0F                STA     (TMPPOS),Y      ; Store CR at current position
000CD1  1  E6 0F                INC     TMPPOS          ; INC POINTER TO POINT PAST CR
000CD3  1  D0 02                BNE     DELETECHAR1D    ; NO OVERFLOW, CONTINUE
000CD5  1  E6 10                INC     TMPPOS+1        ; OVERFLOW, INC HIGH BYTE
000CD7  1               DELETECHAR1D:
000CD7  1  4C E3 0C             JMP     DELETECHAR2     ; EXIT TO CLEANUP
000CDA  1               
000CDA  1               DELETECHAR1_EOF:                ; REACHED EOF WITHOUT FINDING CR
000CDA  1               ; Just null out current position and exit
000CDA  1  A9 00                LDA     #$00            ;
000CDC  1  A0 00                LDY     #$00            ;
000CDE  1  91 0F                STA     (TMPPOS),Y      ;
000CE0  1  4C E3 0C             JMP     DELETECHAR2     ; EXIT TO CLEANUP
000CE3  1               
000CE3  1               
000CE3  1               
000CE3  1               
000CE3  1               DELETECHAR2:
000CE3  1  A9 00                LDA     #$00
000CE5  1  91 0F                STA     (TMPPOS),Y      ;
000CE7  1               
000CE7  1               ; CHECK IF WE DELETED A CR (line merge) OR NULL (blank line) - REQUIRES FULL REPAINT
000CE7  1  A5 08                LDA     TEMP            ; Get the character we deleted
000CE9  1  C9 0D                CMP     #13             ; Was it a CR?
000CEB  1  F0 07                BEQ     DELETECHAR_FULLREPAINT; Yes, need full repaint
000CED  1  C9 00                CMP     #$00            ; Was it a null (blank line)?
000CEF  1  F0 03                BEQ     DELETECHAR_FULLREPAINT; Yes, need full repaint
000CF1  1  4C 39 0D             JMP     DELETECHAR_FAST ; Regular character, use fast update
000CF4  1               
000CF4  1               ; REPAINT FROM CURRENT ROW TO BOTTOM (for deleting CR/null that merges lines)
000CF4  1               DELETECHAR_FULLREPAINT:
000CF4  1  A5 0B 48 A5          SAVE_EDITSTATE
000CF8  1  0C 48 A5 0D  
000CFC  1  48 A5 0E 48  
000D00  1               
000D00  1               ; BACK UP EDTPOS TO COLUMN 0 OF CURRENT ROW
000D00  1  A5 0B                LDA     CSRPOSX
000D02  1  AA                   TAX
000D03  1  F0 0B                BEQ     DELETECHAR_FP1
000D05  1               DELETECHAR_FP0:
