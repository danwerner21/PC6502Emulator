0016D8  1               ;__DOS65SAVE_____________________________________________________________________________________________________________________
0016D8  1               ;
0016D8  1               ; 	SAVE A DOS/65 FILE FROM THE EDIT BUFFER
0016D8  1               ;
0016D8  1               ;
0016D8  1               ;
0016D8  1               ;________________________________________________________________________________________________________________________________
0016D8  1               ;
0016D8  1               DOS65SAVE:
0016D8  1  A9 00                LDA     #0              ; clear
0016DA  1  8D 27 01             STA     DFLFCB+32       ; record number
0016DD  1  A9 07                LDA     #<DFLFCB        ; Open File
0016DF  1  A0 01                LDY     #>DFLFCB        ;
0016E1  1  A2 13                LDX     #19             ;
0016E3  1  20 03 01             JSR     PEM             ;
0016E6  1               
0016E6  1  A9 00                LDA     #0              ; clear
0016E8  1  8D 27 01             STA     DFLFCB+32       ; record number
0016EB  1  A9 07                LDA     #<DFLFCB        ; ATTEMPT TO CREATE File
0016ED  1  A0 01                LDY     #>DFLFCB        ;
0016EF  1  A2 16                LDX     #22             ;
0016F1  1  20 03 01             JSR     PEM             ;
0016F4  1  C9 FF                CMP     #$FF            ; error?, if NOT, continue
0016F6  1  D0 09                BNE     DOS65SAVE_1     ;
0016F8  1               
0016F8  1               DOS65SAVE_ERR:
0016F8  1  A9 2C                LDA     #<FILEERROR2A   ; NO, ERROR OUT
0016FA  1  A0 18                LDY     #>FILEERROR2A
0016FC  1  A2 09                LDX     #9              ; Print error message
0016FE  1  4C 03 01             JMP     PEM             ; RETURN AFTER PRINT
001701  1               DOS65SAVE_1:
001701  1  A9 00                LDA     #0              ; clear
001703  1  8D 27 01             STA     DFLFCB+32       ; record number
001706  1  A9 00                LDA     #<BUFFER        ; SETUP BUFFER
001708  1  85 09                STA     FCBPTR          ; STORE SRC BUFFER IN FCBPTR
00170A  1  A9 1A                LDA     #>BUFFER        ;
00170C  1  85 0A                STA     FCBPTR+1        ; STORE SRC BUFFER IN FCBPTR
00170E  1               
00170E  1  A9 EC                LDA     #<FCBBUFFER     ; SETUP BUFFER
001710  1  85 0F                STA     TMPPOS          ;
001712  1  A0 18                LDY     #>FCBBUFFER
001714  1  84 10                STY     TMPPOS+1        ;
001716  1  A2 1A                LDX     #26             ; Setup Buffer
001718  1  20 03 01             JSR     PEM
00171B  1               
00171B  1  A2 00                LDX     #$00            ;
00171D  1  86 11                STX     TEMP1           ;
00171F  1               DOS65SAVE_2:
00171F  1  A5 0A                LDA     FCBPTR+1        ; COMPARE HIGH BYTES
001721  1  C5 13                CMP     CURRENTLEN+1    ;
001723  1  90 0F                BCC     DOS65SAVE_2B    ; FCBPTR+1 < CURRENTLEN+1, USE ACTUAL DATA
001725  1  D0 08                BNE     DOS65SAVE_2EOF  ; FCBPTR+1 > CURRENTLEN+1, PAST END
001727  1  A5 09                LDA     FCBPTR          ; HIGH BYTES EQUAL, CHECK LOW BYTES
001729  1  C5 12                CMP     CURRENTLEN      ;
00172B  1  90 07                BCC     DOS65SAVE_2B    ; FCBPTR < CURRENTLEN, USE ACTUAL DATA
00172D  1  F0 05                BEQ     DOS65SAVE_2B    ; FCBPTR == CURRENTLEN, USE ACTUAL DATA
00172F  1               DOS65SAVE_2EOF:
00172F  1  A9 1A                LDA     #$1A            ; WE ARE AT END SO PAD WITH EOF
001731  1  4C 46 17             JMP     DOS65SAVE_2C    ;
001734  1               
001734  1               DOS65SAVE_2B:
001734  1  A0 00                LDY     #$00
001736  1  B1 09                LDA     (FCBPTR),Y      ; GET NEXT BUFFER BYTE
001738  1  E6 09                INC     FCBPTR          ; INC 16 BIT BUFFER POINTER
00173A  1  D0 02                BNE     DOS65SAVE_2B1   ;
00173C  1  E6 0A                INC     FCBPTR+1        ;
00173E  1               DOS65SAVE_2B1:
00173E  1  C9 00                CMP     #$00            ; IS NULL?
001740  1  F0 DD                BEQ     DOS65SAVE_2     ; YES SKIP
001742  1  C9 0A                CMP     #10             ; IS LF?
001744  1  F0 D9                BEQ     DOS65SAVE_2     ; YES SKIP
001746  1               
001746  1               DOS65SAVE_2C:
001746  1  A4 11                LDY     TEMP1           ;
001748  1  91 0F                STA     (TMPPOS),Y      ; NO STORE IN BUFFER
00174A  1  E6 11                INC     TEMP1           ; INC BUFFER POINTER
00174C  1  C9 0D                CMP     #13             ; IF NOT CR
00174E  1  D0 03                BNE     DOS65SAVE_2C1   ; CONTINUE
001750  1  20 8A 17             JSR     DOS65SAVE_LF    ; OTHERWISE INSERT LF
001753  1               DOS65SAVE_2C1:
001753  1  A6 11                LDX     TEMP1           ;
001755  1  E0 80                CPX     #$80            ; PAST END?
001757  1  D0 C6                BNE     DOS65SAVE_2     ; NO LOOP TILL BUFFER IS FULL
001759  1               
001759  1               DOS65SAVE_2D:
001759  1  A9 07                LDA     #<DFLFCB        ; WRITE record buffer from disk file
00175B  1  A0 01                LDY     #>DFLFCB        ;
00175D  1  A2 15                LDX     #21             ;
00175F  1  20 03 01             JSR     PEM             ;
001762  1  C9 00                CMP     #$00            ; is SUCCESSFUL?
001764  1  F0 03                BEQ     DOS65SAVE_2D1   ;
001766  1  4C F8 16             JMP     DOS65SAVE_ERR   ; ERROR, do error handling
001769  1               DOS65SAVE_2D1:
001769  1               
001769  1  A5 0A                LDA     FCBPTR+1        ;
00176B  1  C5 13                CMP     CURRENTLEN+1    ; AT END?
00176D  1  90 0B                BCC     DOS65SAVE_3     ; FCBPTR+1 < CURRENTLEN+1, CONTINUE
00176F  1  D0 10                BNE     DOS65SAVE_4     ; FCBPTR+1 > CURRENTLEN+1, CLOSE FILE
001771  1  A5 09                LDA     FCBPTR          ; HIGH BYTES EQUAL, CHECK LOW BYTES
001773  1  C5 12                CMP     CURRENTLEN      ;
001775  1  90 03                BCC     DOS65SAVE_3     ; FCBPTR < CURRENTLEN, CONTINUE
001777  1  4C 81 17             JMP     DOS65SAVE_4     ; FCBPTR >= CURRENTLEN, CLOSE FILE
00177A  1               
00177A  1               DOS65SAVE_3:
00177A  1  A2 00                LDX     #$00            ;
00177C  1  86 11                STX     TEMP1           ;
00177E  1  4C 1F 17             JMP     DOS65SAVE_2     ; SAVE NEXT SECTOR
001781  1               
001781  1               DOS65SAVE_4:
001781  1  A9 07                LDA     #<DFLFCB        ; CLOSE FILE
001783  1  A0 01                LDY     #>DFLFCB        ;
001785  1  A2 10                LDX     #16             ;
001787  1  4C 03 01             JMP     PEM             ; CLOSE AND RETURN
00178A  1               
00178A  1               
00178A  1               DOS65SAVE_LF:
00178A  1               
00178A  1  A6 11                LDX     TEMP1           ;
00178C  1  E0 80                CPX     #$80            ; PAST END?
00178E  1  D0 03                BNE     DOS65SAVE_LFA   ; NO
001790  1  20 9C 17             JSR     DOS65SAVE_LF1   ;
001793  1               DOS65SAVE_LFA:
001793  1  A4 11                LDY     TEMP1           ; WRITE LF
001795  1  A9 0A                LDA     #10             ;
001797  1  91 0F                STA     (TMPPOS),Y      ; NO STORE IN BUFFER
001799  1  E6 11                INC     TEMP1           ; INC BUFFER POINTER
00179B  1  60                   RTS
00179C  1               
00179C  1               DOS65SAVE_LF1:
00179C  1  A9 07                LDA     #<DFLFCB        ; WRITE record buffer from disk file
00179E  1  A0 01                LDY     #>DFLFCB        ;
0017A0  1  A2 15                LDX     #21             ;
0017A2  1  20 03 01             JSR     PEM             ;
0017A5  1  C9 00                CMP     #$00            ; is SUCCESSFUL?
0017A7  1  F0 03                BEQ     DOS65SAVE_LF1A  ;
0017A9  1  4C F8 16             JMP     DOS65SAVE_ERR   ; ERROR, do error handling
0017AC  1               DOS65SAVE_LF1A:
0017AC  1  A2 00                LDX     #$00            ;
0017AE  1  86 11                STX     TEMP1           ;
0017B0  1  60                   RTS
0017B1  1               
0017B1  1               DOS65FCBPREP:
0017B1  1  AD 43 16             LDA     FNBUFFER+1      ; GET ":"
0017B4  1  C9 3A                CMP     #':'            ;
0017B6  1  F0 0C                BEQ     DOS65FCBPREP_1  ; YES, IT WAS A DRIVE, CONTINUE
0017B8  1  A9 05                LDA     #<FILEERROR1    ; NO, ERROR OUT
0017BA  1  A0 18                LDY     #>FILEERROR1
0017BC  1  A2 09                LDX     #9
0017BE  1  20 03 01             JSR     PEM
0017C1  1  A9 FF                LDA     #$FF
0017C3  1  60                   RTS
0017C4  1               DOS65FCBPREP_1:
0017C4  1  AD 42 16             LDA     FNBUFFER        ; GET DRIVE LETTER
0017C7  1  38                   SEC                     ;
0017C8  1  E9 40                SBC     #64             ; PARSE DRIVE NUMBER
0017CA  1  8D 07 01             STA     DFLFCB+0        ; STORE IT IN FCB
0017CD  1               
0017CD  1  A0 01                LDY     #$01            ; POINT Y TO FCB FILE NAME
0017CF  1  A9 20                LDA     #$20            ; LOAD SPACE CHAR INTO A
0017D1  1               DOS65FCBPREP_1A:                ; BLANK OUT FCB
0017D1  1  99 07 01             STA     DFLFCB,Y        ;
0017D4  1  C8                   INY                     ;
0017D5  1  C0 09                CPY     #$09            ; IS DONE
0017D7  1  D0 F8                BNE     DOS65FCBPREP_1A ; NO, LOOP
0017D9  1  A0 01                LDY     #$01            ; POINT Y TO FCB FILE NAME
0017DB  1  A2 00                LDX     #$00            ;
0017DD  1               DOS65FCBPREP_2:                 ; COPY FILE NAME PARAMETER INTO FCB
0017DD  1  BD 44 16             LDA     FNBUFFER+2,X    ;
0017E0  1  E8                   INX                     ;
0017E1  1  C9 2E                CMP     #'.'            ;
0017E3  1  F0 0B                BEQ     DOS65FCBPREP_3  ;
0017E5  1  99 07 01             STA     DFLFCB,Y        ;
0017E8  1  C8                   INY                     ;
0017E9  1  C0 09                CPY     #$09            ;
0017EB  1  F0 03                BEQ     DOS65FCBPREP_3  ;
0017ED  1  4C DD 17             JMP     DOS65FCBPREP_2  ;
0017F0  1               DOS65FCBPREP_3:                 ;
0017F0  1  BD 44 16             LDA     FNBUFFER+2,X    ;
0017F3  1  8D 10 01             STA     DFLFCB+9        ;
0017F6  1  BD 45 16             LDA     FNBUFFER+3,X    ;
0017F9  1  8D 11 01             STA     DFLFCB+10       ;
0017FC  1  BD 46 16             LDA     FNBUFFER+4,X    ;
0017FF  1  8D 12 01             STA     DFLFCB+11       ;
001802  1  A9 00                LDA     #$00            ;
001804  1  60                   RTS                     ;
