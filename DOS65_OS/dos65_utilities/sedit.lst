000A24  1  D0 E6                BNE     INSERTLINE1     ; CONTINUE IF TMPPOS+1 > EDTPOS+1
000A26  1  A5 0F                LDA     TMPPOS          ; HIGH BYTES EQUAL, CHECK LOW BYTES
