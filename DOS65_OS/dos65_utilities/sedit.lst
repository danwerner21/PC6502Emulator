000E37  1  D0 07                BNE     CRSRLEFT1       ; CHECK TO SEE IF POINTER IS AT THE VERY TOP OF THE
000E39  1  A5 0E                LDA     EDTPOS+1        ; BUFFER.  IF IT IS, DO NOTHING.
000E3B  1  C9 1A                CMP     #>BUFFER        ;
000E3D  1  D0 01                BNE     CRSRLEFT1       ;
000E3F  1  60                   RTS                     ;
