0014D0  1  CA                   DEX
0014D1  1  D0 FA                BNE     DOS65SAVEAS2
0014D3  1  8D 42 16             STA     FNBUFFER        ; CLEAR BYTE 0 AS WELL
0014D6  1  20 54 16             JSR     GETFILENAME
0014D9  1  20 B1 17             JSR     DOS65FCBPREP
0014DC  1  C9 FF                CMP     #$FF
0014DE  1  F0 E0                BEQ     DOS65SAVEAS1
0014E0  1               
