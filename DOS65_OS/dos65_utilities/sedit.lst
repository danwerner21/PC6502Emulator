0008E3  1               ;__EDITCHECK_____________________________________________________________________________________________________________________
0008E3  1               ;
0008E3  1               ; 	IF EDTPOS > CURRENTLEN CHANGE CURRENTLEN
0008E3  1               ;
0008E3  1               ;________________________________________________________________________________________________________________________________
0008E3  1               ;
0008E3  1               EDITCHECK:
0008E3  1  48                   PHA
0008E4  1  A5 0E                LDA     EDTPOS+1        ; COMPARE HIGH BYTES FIRST
0008E6  1  C5 13                CMP     CURRENTLEN+1
0008E8  1  90 16                BCC     EDITCHECK_1     ; IF EDTPOS+1 < CURRENTLEN+1, EXIT (EDTPOS < CURRENTLEN)
0008EA  1  D0 06                BNE     EDITCHECK_UPDATE; IF EDTPOS+1 > CURRENTLEN+1, UPDATE (EDTPOS > CURRENTLEN)
0008EC  1  A5 0D                LDA     EDTPOS          ; HIGH BYTES EQUAL, CHECK LOW BYTES
0008EE  1  C5 12                CMP     CURRENTLEN
0008F0  1  90 0E                BCC     EDITCHECK_1     ; IF EDTPOS < CURRENTLEN, EXIT
0008F2  1               
0008F2  1               EDITCHECK_UPDATE:               ; Set WORD CURRENTLEN= WORD EDTPOS
0008F2  1  A5 0E                LDA     EDTPOS+1
0008F4  1  85 13                STA     CURRENTLEN+1
0008F6  1  A5 0D                LDA     EDTPOS
0008F8  1  85 12                STA     CURRENTLEN      ; INCRIMENT WORD CURRENTLEN
0008FA  1  E6 12                INC     CURRENTLEN
0008FC  1  D0 02                BNE     EDITCHECK_1
0008FE  1  E6 13                INC     CURRENTLEN+1
