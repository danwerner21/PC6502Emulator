000AA7  1               ;CLEAR COM POINTER
000AA7  1               CLRCOM:
000AA7  1  A9 00                LDA     #<COMBUF        ;GET LOW
000AA9  1  A0 0C                LDY     #>COMBUF        ;AND HIGH
000AAB  1  85 53                STA     COMPNT          ;POINTER
000AAD  1  84 54                STY     COMPNT+1        ;AND SET
000AAF  1  60                   RTS
000AB0  1               ;INSERT BYTE INTO COM FILE
000AB0  1               INSERT:
000AB0  1  A6 53                LDX     COMPNT          ;COMPARE LOW POINTER
000AB2  1  E4 5F                CPX     COMMAX          ;TO MAX
000AB4  1  D0 0B                BNE     NOCMWR          ;BRANCH IF NOT THERE
000AB6  1  A6 54                LDX     COMPNT+1        ;DO SAME
000AB8  1  E4 60                CPX     COMMAX+1        ;FOR HIGH
000ABA  1  D0 05                BNE     NOCMWR          ;BYTES
000ABC  1  48                   PHA                     ;SAVE BYTE
000ABD  1  20 CC 0A             JSR     WRTBUF          ;WRITE FILE
000AC0  1  68                   PLA                     ;GET BYTE
000AC1  1               NOCMWR:
000AC1  1  A0 00                LDY     #0              ;CLEAR INDEX
000AC3  1  91 53                STA     (COMPNT),Y      ;SAVE BYTE
000AC5  1  E6 53                INC     COMPNT          ;BUMP
000AC7  1  D0 02                BNE     *+4             ;POINTER
000AC9  1  E6 54                INC     COMPNT+1        ;FOR NEXT
000ACB  1  60                   RTS
000ACC  1               ;WRITE COM BUFFER
000ACC  1               WRTBUF:
000ACC  1  20 A7 0A             JSR     CLRCOM          ;CLEAR POINTER
000ACF  1               WRTCLP:
000ACF  1  A5 53                LDA     COMPNT          ;SET
000AD1  1  A4 54                LDY     COMPNT+1        ;POINTER
000AD3  1  A2 1A                LDX     #26             ;AND SET
000AD5  1  20 03 01             JSR     PEM             ;BUFFER ADDRESS
000AD8  1  A5 53                LDA     COMPNT          ;GET LOW POINTER
000ADA  1  C5 5F                CMP     COMMAX          ;COMPARE TO MAX
000ADC  1  D0 09                BNE     DOCWRT          ;WRITE IF NOT THERE
000ADE  1  A5 54                LDA     COMPNT+1        ;ALSO CHECK
000AE0  1  C5 60                CMP     COMMAX+1        ;HIGH POINTER
000AE2  1  D0 03                BNE     DOCWRT          ;WRITE IF DIFFERENT
000AE4  1  4C A7 0A             JMP     CLRCOM          ;ELSE CLEAR POINTER AND EXIT
000AE7  1               DOCWRT:
000AE7  1  20 29 0A             JSR     WRTCOM          ;WRITE RECORD
000AEA  1  C9 00                CMP     #0              ;TEST FOR OK
000AEC  1  F0 03                BEQ     *+5             ;CONTINUE IF OK
000AEE  1  4C 58 0A             JMP     OUTERR          ;ELSE ERROR
000AF1  1  18                   CLC                     ;BUMP
000AF2  1  A5 53                LDA     COMPNT          ;POINTER
000AF4  1  69 80                ADC     #128            ;BY 128
000AF6  1  85 53                STA     COMPNT          ;AND
000AF8  1  90 02                BCC     *+4             ;SAVE FOR
000AFA  1  E6 54                INC     COMPNT+1        ;NEXT
000AFC  1  E6 5C                INC     RECORD          ;ALSO
000AFE  1  D0 02                BNE     *+4             ;BUMP
000B00  1  E6 5D                INC     RECORD+1        ;RECORD COUNT
000B02  1  4C CF 0A             JMP     WRTCLP          ;AND LOOP
