00550E  2               ;----------------------------------------------------------------
00550E  2               ; monster_dies - award XP/gold, drop the slot, maybe win, maybe
00550E  2               ; level up.  Slot in monidx.
00550E  2               ;----------------------------------------------------------------
00550E  2               monster_dies:
00550E  2  A6 2F                LDX     monidx
005510  2  BD A9 6E             LDA     mon_type,X
005513  2  85 21                STA     tmp1            ; type
005515  2               ; XP
005515  2  A8                   TAY
005516  2  B9 4C 48             LDA     mtype_xp,Y
005519  2  18                   CLC
00551A  2  6D 80 6D             ADC     pxp
00551D  2  8D 80 6D             STA     pxp
005520  2  AD 81 6D             LDA     pxp+1
005523  2  69 00                ADC     #0
005525  2  8D 81 6D             STA     pxp+1
005528  2               ; gold drop 0..mtype_gold
005528  2  A4 21                LDY     tmp1
00552A  2  B9 54 48             LDA     mtype_gold,Y
00552D  2  F0 12                BEQ     @nogold
00552F  2  20 8A 0E             JSR     rng_mod         ; 0..gold-1
005532  2  18                   CLC
005533  2  6D 82 6D             ADC     pgold
005536  2  8D 82 6D             STA     pgold
005539  2  AD 83 6D             LDA     pgold+1
00553C  2  69 00                ADC     #0
00553E  2  8D 83 6D             STA     pgold+1
