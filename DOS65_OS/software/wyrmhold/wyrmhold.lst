006B70  2               ;______________________________________________________________________________
006B70  2               ;  shrine.asm - Sunken Shrine transition and Wyrm Key reward
006B70  2               ;______________________________________________________________________________
006B70  2               
006B70  2               ;----------------------------------------------------------------
006B70  2               ; enter_shrine - enter the southern-marsh quest location.
006B70  2               ;----------------------------------------------------------------
006B70  2               enter_shrine:
006B70  2  20 AA 12             JSR     sfx_door
006B73  2  20 C4 1E             JSR     decode_shrine
006B76  2  A9 04                LDA     #LOC_SHRINE
006B78  2  8D 89 6D             STA     loc
006B7B  2  A9 20                LDA     #SHRINEW
006B7D  2  8D 8C 6D             STA     locw
006B80  2  A9 14                LDA     #SHRINEH
006B82  2  8D 8D 6D             STA     loch
006B85  2  AD 7B 6D             LDA     px
006B88  2  8D 8E 6D             STA     owretx
006B8B  2  AD 7C 6D             LDA     py
006B8E  2  8D 8F 6D             STA     owrety
006B91  2               ; begin just east of the stairs-up tile
006B91  2  A9 02                LDA     #2
006B93  2  8D 7B 6D             STA     px
006B96  2  A9 01                LDA     #1
006B98  2  8D 7C 6D             STA     py
006B9B  2  20 4E 4A             JSR     spawn_shrine_monsters
006B9E  2  A9 01                LDA     #1
006BA0  2  8D 97 6D             STA     did_move
006BA3  2  AD 91 6D             LDA     queststate
006BA6  2  C9 01                CMP     #QUEST_FIND_KEY
006BA8  2  D0 0F                BNE     @quiet
006BAA  2  A9 64 A0 6C          PRINTMSG_MSG m_shrine1
006BAE  2  20 CA 40     
006BB1  2  A9 A0 A0 6C          PRINTMSG_MSG m_shrine2
006BB5  2  20 CA 40     
006BB8  2  60                   RTS
006BB9  2               @quiet:
006BB9  2  A9 D5 A0 6C          PRINTMSG_MSG m_shrine_empty
006BBD  2  20 CA 40     
006BC0  2  60                   RTS
006BC1  2               
006BC1  2               ;----------------------------------------------------------------
006BC1  2               ; award_wyrm_key - called when the Wyrm Warden dies.
006BC1  2               ;----------------------------------------------------------------
006BC1  2               award_wyrm_key:
006BC1  2  AD 91 6D             LDA     queststate
006BC4  2  C9 01                CMP     #QUEST_FIND_KEY
006BC6  2  D0 16                BNE     @done
006BC8  2  A9 02                LDA     #QUEST_HAVE_KEY
006BCA  2  8D 91 6D             STA     queststate
006BCD  2  20 3C 12             JSR     sfx_treasure
006BD0  2  A9 11 A0 6D          PRINTMSG_MSG m_key1
006BD4  2  20 CA 40     
006BD7  2  A9 44 A0 6D          PRINTMSG_MSG m_key2
006BDB  2  20 CA 40     
006BDE  2               @done:
006BDE  2  60                   RTS
