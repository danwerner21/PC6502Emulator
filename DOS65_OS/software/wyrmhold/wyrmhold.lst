001EE3  2               
001EE3  2               ;----------------------------------------------------------------
001EE3  2               ; region_from_y - classify an overworld latitude.
001EE3  2               ;   IN : A = overworld y coordinate
001EE3  2               ;   OUT: A = REGION_* id
001EE3  2               ;----------------------------------------------------------------
001EE3  2               region_from_y:
001EE3  2  C9 15                CMP     #REGION_ROW_VALE
001EE5  2  90 0A                BCC     @northreach
001EE7  2  C9 2C                CMP     #REGION_ROW_SUNKEN
001EE9  2  90 03                BCC     @vale
001EEB  2  A9 02                LDA     #REGION_SUNKEN
001EED  2  60                   RTS
001EEE  2               @vale:
001EEE  2  A9 01                LDA     #REGION_VALE
001EF0  2  60                   RTS
001EF1  2               @northreach:
001EF1  2  A9 00                LDA     #REGION_NORTHREACH
001EF3  2  60                   RTS
001EF4  2               
001EF4  2               ;----------------------------------------------------------------
001EF4  2               ; tileat - read the tile code at (tgtx,tgty) from the ACTIVE map.
001EF4  2               ;   IN : tgtx, tgty ; loc (LOC_*) selects map + width
001EF4  2               ;   OUT: A = tile code, also stored in tgttile
001EF4  2               ;        if out of bounds -> returns T_WATER (overworld) / T_WALL (int)
001EF4  2               ;   Trashes ptr, tmp0, tmp1
001EF4  2               ;----------------------------------------------------------------
001EF4  2               tileat:
001EF4  2  AD 89 6D             LDA     loc
001EF7  2  D0 52                BNE     @interior
001EF9  2               ;--- overworld ---
001EF9  2               ; bounds check 0..OWW-1 / 0..OWH-1
001EF9  2  A5 2C                LDA     tgtx
001EFB  2  C9 40                CMP     #OWW
001EFD  2  B0 47                BCS     @oob_world
001EFF  2  A5 2D                LDA     tgty
001F01  2  C9 40                CMP     #OWH
001F03  2  B0 41                BCS     @oob_world
001F05  2               ; offset = tgty*OWW + tgtx  (OWW=64 -> *64)
001F05  2  A5 2D                LDA     tgty
001F07  2  85 10                STA     ptr
001F09  2  A9 00                LDA     #0
001F0B  2  85 11                STA     ptr+1
001F0D  2  06 10                ASL     ptr
001F0F  2  26 11                ROL     ptr+1           ; *2
001F11  2  06 10                ASL     ptr
001F13  2  26 11                ROL     ptr+1           ; *4
001F15  2  06 10                ASL     ptr
001F17  2  26 11                ROL     ptr+1           ; *8
001F19  2  06 10                ASL     ptr
001F1B  2  26 11                ROL     ptr+1           ; *16
001F1D  2  06 10                ASL     ptr
001F1F  2  26 11                ROL     ptr+1           ; *32
001F21  2  06 10                ASL     ptr
001F23  2  26 11                ROL     ptr+1           ; *64
001F25  2  18                   CLC
001F26  2  A5 10                LDA     ptr
001F28  2  65 2C                ADC     tgtx
001F2A  2  85 10                STA     ptr
001F2C  2  A5 11                LDA     ptr+1
001F2E  2  69 00                ADC     #0
001F30  2  85 11                STA     ptr+1
001F32  2               ; ptr += owmap base
001F32  2  18                   CLC
001F33  2  A5 10                LDA     ptr
001F35  2  69 21                ADC     #<owmap
001F37  2  85 10                STA     ptr
001F39  2  A5 11                LDA     ptr+1
001F3B  2  69 6F                ADC     #>owmap
001F3D  2  85 11                STA     ptr+1
001F3F  2  A0 00                LDY     #0
001F41  2  B1 10                LDA     (ptr),Y
001F43  2  85 2E                STA     tgttile
001F45  2  60                   RTS
001F46  2               @oob_world:
001F46  2  A9 03                LDA     #T_WATER
001F48  2  85 2E                STA     tgttile
001F4A  2  60                   RTS
001F4B  2               ;--- interior (town/dungeon): width = locw, height = loch ---
001F4B  2               @interior:
001F4B  2  A5 2C                LDA     tgtx
001F4D  2  CD 8C 6D             CMP     locw
001F50  2  B0 44                BCS     @oob_int
001F52  2  A5 2D                LDA     tgty
001F54  2  CD 8D 6D             CMP     loch
001F57  2  B0 3D                BCS     @oob_int
001F59  2               ; offset = tgty*locw + tgtx  (locw is 32)
001F59  2  A5 2D                LDA     tgty
001F5B  2  85 10                STA     ptr
001F5D  2  A9 00                LDA     #0
001F5F  2  85 11                STA     ptr+1
001F61  2  06 10                ASL     ptr
001F63  2  26 11                ROL     ptr+1           ; *2
001F65  2  06 10                ASL     ptr
001F67  2  26 11                ROL     ptr+1           ; *4
001F69  2  06 10                ASL     ptr
001F6B  2  26 11                ROL     ptr+1           ; *8
001F6D  2  06 10                ASL     ptr
001F6F  2  26 11                ROL     ptr+1           ; *16
001F71  2  06 10                ASL     ptr
001F73  2  26 11                ROL     ptr+1           ; *32  (locw assumed 32)
001F75  2  18                   CLC
001F76  2  A5 10                LDA     ptr
001F78  2  65 2C                ADC     tgtx
001F7A  2  85 10                STA     ptr
001F7C  2  A5 11                LDA     ptr+1
001F7E  2  69 00                ADC     #0
001F80  2  85 11                STA     ptr+1
001F82  2  18                   CLC
001F83  2  A5 10                LDA     ptr
001F85  2  69 21                ADC     #<locmap
001F87  2  85 10                STA     ptr
001F89  2  A5 11                LDA     ptr+1
001F8B  2  69 7F                ADC     #>locmap
001F8D  2  85 11                STA     ptr+1
001F8F  2  A0 00                LDY     #0
001F91  2  B1 10                LDA     (ptr),Y
001F93  2  85 2E                STA     tgttile
001F95  2  60                   RTS
001F96  2               @oob_int:
001F96  2  A9 0A                LDA     #T_WALL
001F98  2  85 2E                STA     tgttile
001F9A  2  60                   RTS
001F9B  2               
001F9B  2               ;----------------------------------------------------------------
001F9B  2               ; settile - write tile code A at (tgtx,tgty) in the active map.
001F9B  2               ;   Used to clear treasure chests once collected, etc.
001F9B  2               ;   Recomputes the address exactly like tileat.
001F9B  2               ;----------------------------------------------------------------
001F9B  2               settile:
001F9B  2  85 21                STA     tmp1            ; new tile
001F9D  2  20 A7 1F             JSR     tile_addr       ; ptr -> cell
001FA0  2  A0 00                LDY     #0
001FA2  2  A5 21                LDA     tmp1
001FA4  2  91 10                STA     (ptr),Y
001FA6  2  60                   RTS
001FA7  2               
001FA7  2               ; tile_addr - compute ptr -> active-map cell for (tgtx,tgty).
001FA7  2               ; (assumes in-bounds; callers that might be OOB use tileat first)
001FA7  2               tile_addr:
001FA7  2  AD 89 6D             LDA     loc
001FAA  2  D0 3B                BNE     @int
001FAC  2  A5 2D                LDA     tgty
001FAE  2  85 10                STA     ptr
001FB0  2  A9 00                LDA     #0
001FB2  2  85 11                STA     ptr+1
001FB4  2  06 10                ASL     ptr
001FB6  2  26 11                ROL     ptr+1
001FB8  2  06 10                ASL     ptr
001FBA  2  26 11                ROL     ptr+1
001FBC  2  06 10                ASL     ptr
001FBE  2  26 11                ROL     ptr+1
001FC0  2  06 10                ASL     ptr
001FC2  2  26 11                ROL     ptr+1
001FC4  2  06 10                ASL     ptr
001FC6  2  26 11                ROL     ptr+1
001FC8  2  06 10                ASL     ptr
001FCA  2  26 11                ROL     ptr+1           ; *64
001FCC  2  18                   CLC
001FCD  2  A5 10                LDA     ptr
001FCF  2  65 2C                ADC     tgtx
001FD1  2  85 10                STA     ptr
001FD3  2  A5 11                LDA     ptr+1
001FD5  2  69 00                ADC     #0
001FD7  2  85 11                STA     ptr+1
001FD9  2  18                   CLC
001FDA  2  A5 10                LDA     ptr
001FDC  2  69 21                ADC     #<owmap
001FDE  2  85 10                STA     ptr
001FE0  2  A5 11                LDA     ptr+1
001FE2  2  69 6F                ADC     #>owmap
001FE4  2  85 11                STA     ptr+1
001FE6  2  60                   RTS
001FE7  2               @int:
001FE7  2  A5 2D                LDA     tgty
001FE9  2  85 10                STA     ptr
001FEB  2  A9 00                LDA     #0
001FED  2  85 11                STA     ptr+1
001FEF  2  06 10                ASL     ptr
001FF1  2  26 11                ROL     ptr+1
001FF3  2  06 10                ASL     ptr
001FF5  2  26 11                ROL     ptr+1
001FF7  2  06 10                ASL     ptr
001FF9  2  26 11                ROL     ptr+1
001FFB  2  06 10                ASL     ptr
001FFD  2  26 11                ROL     ptr+1
001FFF  2  06 10                ASL     ptr
002001  2  26 11                ROL     ptr+1           ; *32
002003  2  18                   CLC
002004  2  A5 10                LDA     ptr
002006  2  65 2C                ADC     tgtx
002008  2  85 10                STA     ptr
00200A  2  A5 11                LDA     ptr+1
00200C  2  69 00                ADC     #0
00200E  2  85 11                STA     ptr+1
002010  2  18                   CLC
002011  2  A5 10                LDA     ptr
002013  2  69 21                ADC     #<locmap
002015  2  85 10                STA     ptr
002017  2  A5 11                LDA     ptr+1
002019  2  69 7F                ADC     #>locmap
00201B  2  85 11                STA     ptr+1
00201D  2  60                   RTS
00201E  2               
00201E  2               ;----------------------------------------------------------------
