005260  2               ;----------------------------------------------------------------
005260  2               ; enter_town - switch to the town interior map.
005260  2               ;----------------------------------------------------------------
005260  2               enter_town:
005260  2               ; identify the landmark before effects or map decoding use scratch state
005260  2  A9 00                LDA     #TOWN_EASTMERE
005262  2  A6 2D                LDX     tgty
005264  2  E0 27                CPX     #VALEHAVEN_Y
005266  2  D0 02                BNE     @town_selected
005268  2  A9 01                LDA     #TOWN_VALEHAVEN
00526A  2               @town_selected:
00526A  2  8D 8A 6D             STA     town_id
00526D  2  20 AA 12             JSR     sfx_door
005270  2  20 55 1E             JSR     decode_town
005273  2  A9 01                LDA     #LOC_TOWN
005275  2  8D 89 6D             STA     loc
005278  2  A9 20                LDA     #TOWNW
00527A  2  8D 8C 6D             STA     locw
00527D  2  A9 14                LDA     #TOWNH
00527F  2  8D 8D 6D             STA     loch
005282  2               ; remember overworld position to restore on exit
005282  2  AD 7B 6D             LDA     px
005285  2  8D 8E 6D             STA     owretx
005288  2  AD 7C 6D             LDA     py
00528B  2  8D 8F 6D             STA     owrety
00528E  2               ; place player just inside, one tile NORTH of the door so the
00528E  2               ; exit '+' is visible directly south of the player on entry.
00528E  2  A9 0E                LDA     #14
005290  2  8D 7B 6D             STA     px
005293  2  A9 11                LDA     #TOWNH-3
005295  2  8D 7C 6D             STA     py
005298  2               ; towns have no monsters
005298  2  20 8C 48             JSR     mon_clear_all
00529B  2  A9 01                LDA     #1
00529D  2  8D 97 6D             STA     did_move
0052A0  2  AD 8A 6D             LDA     town_id
0052A3  2  F0 08                BEQ     @eastmere_msg
0052A5  2  A9 6B A0 59          PRINTMSG_MSG m_valehaven
0052A9  2  20 CA 40     
0052AC  2  60                   RTS
0052AD  2               @eastmere_msg:
0052AD  2  A9 30 A0 59          PRINTMSG_MSG m_eastmere
0052B1  2  20 CA 40     
0052B4  2  60                   RTS
0052B5  2               
0052B5  2               ;----------------------------------------------------------------
0052B5  2               ; enter_castle - switch to Wyrmhold Castle's audience chamber.
0052B5  2               ;----------------------------------------------------------------
0052B5  2               enter_castle:
0052B5  2  20 AA 12             JSR     sfx_door
0052B8  2  20 A5 1E             JSR     decode_castle
0052BB  2  A9 03                LDA     #LOC_CASTLE
0052BD  2  8D 89 6D             STA     loc
0052C0  2  A9 20                LDA     #CASTLEW
0052C2  2  8D 8C 6D             STA     locw
0052C5  2  A9 14                LDA     #CASTLEH
0052C7  2  8D 8D 6D             STA     loch
0052CA  2  AD 7B 6D             LDA     px
0052CD  2  8D 8E 6D             STA     owretx
0052D0  2  AD 7C 6D             LDA     py
0052D3  2  8D 8F 6D             STA     owrety
0052D6  2               ; enter on the carpet, immediately north of the exit
0052D6  2  A9 0F                LDA     #15
0052D8  2  8D 7B 6D             STA     px
0052DB  2  A9 11                LDA     #CASTLEH-3
0052DD  2  8D 7C 6D             STA     py
0052E0  2  20 8C 48             JSR     mon_clear_all
0052E3  2  A9 01                LDA     #1
0052E5  2  8D 97 6D             STA     did_move
0052E8  2  A9 F5 A0 68          PRINTMSG_MSG m_castle
0052EC  2  20 CA 40     
0052EF  2  60                   RTS
0052F0  2               
0052F0  2               ;----------------------------------------------------------------
0052F0  2               ; enter_dungeon - dispatch cave landmarks. The southern-marsh cave
0052F0  2               ; is the Sunken Shrine; the dragon's lair stays sealed until the
0052F0  2               ; Wyrm Key has been returned to King Aldren.
0052F0  2               ;----------------------------------------------------------------
0052F0  2               enter_dungeon:
0052F0  2  A5 2C                LDA     tgtx
0052F2  2  C9 14                CMP     #KEY_SITE_X
0052F4  2  D0 1B                BNE     @dragon
0052F6  2  A5 2D                LDA     tgty
0052F8  2  C9 3A                CMP     #KEY_SITE_Y
0052FA  2  D0 15                BNE     @dragon
0052FC  2  AD 91 6D             LDA     queststate
0052FF  2  C9 01                CMP     #QUEST_FIND_KEY
005301  2  90 03                BCC     @shrine_dormant
005303  2  4C 70 6B             JMP     enter_shrine
005306  2               @shrine_dormant:
005306  2  20 FB 10             JSR     sfx_blocked
005309  2  A9 DF A0 6B          PRINTMSG_MSG m_shrine_dormant
00530D  2  20 CA 40     
005310  2  60                   RTS
005311  2               @dragon:
005311  2  AD 91 6D             LDA     queststate
005314  2  C9 03                CMP     #QUEST_DUNG_OPEN
005316  2  B0 0B                BCS     @enter
005318  2  20 FB 10             JSR     sfx_blocked
00531B  2  A9 25 A0 6C          PRINTMSG_MSG m_dung_sealed
00531F  2  20 CA 40     
005322  2  60                   RTS
005323  2               @enter:
005323  2  20 AA 12             JSR     sfx_door
005326  2  20 86 1E             JSR     decode_dung
005329  2  A9 02                LDA     #LOC_DUNG
00532B  2  8D 89 6D             STA     loc
00532E  2  A9 20                LDA     #DUNGW
005330  2  8D 8C 6D             STA     locw
005333  2  A9 14                LDA     #DUNGH
005335  2  8D 8D 6D             STA     loch
005338  2  AD 7B 6D             LDA     px
00533B  2  8D 8E 6D             STA     owretx
00533E  2  AD 7C 6D             LDA     py
005341  2  8D 8F 6D             STA     owrety
005344  2               ; start just east of the stairs-up '<' (at 1,1) so the exit
005344  2               ; is visible immediately to the west of the player.
005344  2  A9 02                LDA     #2
005346  2  8D 7B 6D             STA     px
005349  2  A9 01                LDA     #1
00534B  2  8D 7C 6D             STA     py
00534E  2  20 0A 4A             JSR     spawn_dungeon_monsters
005351  2  A9 01                LDA     #1
005353  2  8D 97 6D             STA     did_move
005356  2  AD 91 6D             LDA     queststate
005359  2  C9 04                CMP     #QUEST_DRAGON_DEAD
00535B  2  B0 0F                BCS     @silent_lair
00535D  2  A9 A6 A0 59          PRINTMSG_MSG m_dungeon
005361  2  20 CA 40     
005364  2  A9 E3 A0 59          PRINTMSG_MSG m_dragon_wakes
005368  2  20 CA 40     
00536B  2  60                   RTS
00536C  2               @silent_lair:
00536C  2  A9 13 A0 5A          PRINTMSG_MSG m_dungeon_empty
005370  2  20 CA 40     
005373  2  60                   RTS
005374  2               
005374  2               ;----------------------------------------------------------------
005374  2               ; leave_interior - return to the overworld at the saved position.
005374  2               ;----------------------------------------------------------------
005374  2               leave_interior:
005374  2  20 AA 12             JSR     sfx_door
005377  2  A9 00                LDA     #BREATH_NONE
005379  2  8D 92 6D             STA     boss_breath_dir
00537C  2  20 36 1E             JSR     decode_world
00537F  2  A9 00                LDA     #LOC_WORLD
005381  2  8D 89 6D             STA     loc
005384  2  AD 8E 6D             LDA     owretx
005387  2  8D 7B 6D             STA     px
00538A  2  AD 8F 6D             LDA     owrety
00538D  2  8D 7C 6D             STA     py
005390  2  20 21 49             JSR     restore_overworld_monsters
005393  2  A9 01                LDA     #1
005395  2  8D 97 6D             STA     did_move
005398  2  A9 4F A0 5A          PRINTMSG_MSG m_world
00539C  2  20 CA 40     
00539F  2  60                   RTS
0053A0  2               
0053A0  1                       .INCLUDE "combat.asm"
0053A0  2               ;______________________________________________________________________________
0053A0  2               ;  combat.asm - bump combat resolution, leveling, message builder
0053A0  2               ;______________________________________________________________________________
0053A0  2               
0053A0  2               ;----------------------------------------------------------------
0053A0  2               ; Message builder.  Compose a line in mbuf then push to the log.
0053A0  2               ;   mb_reset            - start a new line
0053A0  2               ;   mb_str  (A=lo,Y=hi) - append a 0-terminated string
0053A0  2               ;   mb_num  (A=byte)    - append a 0..255 value in decimal
0053A0  2               ;   mb_mname(A=type)    - append a monster type name
0053A0  2               ;   mb_flush            - push mbuf into the scrolling log
0053A0  2               ;----------------------------------------------------------------
0053A0  2               mb_reset:
0053A0  2  A9 00                LDA     #0
0053A2  2  8D A8 6E             STA     mblen
0053A5  2  60                   RTS
0053A6  2               
0053A6  2               mb_str:
0053A6  2  85 1C                STA     strp
0053A8  2  84 1D                STY     strp+1
0053AA  2  A0 00                LDY     #0
0053AC  2               @s:
0053AC  2  B1 1C                LDA     (strp),Y
0053AE  2  F0 0C                BEQ     @done
0053B0  2  AE A8 6E             LDX     mblen
0053B3  2  9D 48 6E             STA     mbuf,X
0053B6  2  EE A8 6E             INC     mblen
0053B9  2  C8                   INY
0053BA  2  D0 F0                BNE     @s
0053BC  2               @done:
0053BC  2  60                   RTS
0053BD  2               
0053BD  2               ; append A (0..255) as decimal
0053BD  2               mb_num:
0053BD  2  85 1E                STA     numarg
0053BF  2  A9 00                LDA     #0
0053C1  2  85 1F                STA     numarg+1
0053C3  2               mb_num16:
0053C3  2               ; find highest place
0053C3  2  A0 08                LDY     #8
0053C5  2               @find:
0053C5  2  A5 1F                LDA     numarg+1
0053C7  2  D9 B8 40             CMP     nums+1,Y
0053CA  2  90 09                BCC     @nx
0053CC  2  D0 0B                BNE     @start
0053CE  2  A5 1E                LDA     numarg
0053D0  2  D9 B7 40             CMP     nums,Y
0053D3  2  B0 04                BCS     @start
0053D5  2               @nx:
0053D5  2  88                   DEY
0053D6  2  88                   DEY
0053D7  2  D0 EC                BNE     @find
0053D9  2               @start:
0053D9  2  A9 30                LDA     #'0'
0053DB  2  85 28                STA     numspace
0053DD  2               @dig:
0053DD  2  A5 1F                LDA     numarg+1
0053DF  2  D9 B8 40             CMP     nums+1,Y
0053E2  2  90 1E                BCC     @out
0053E4  2  D0 09                BNE     @noc
0053E6  2  A5 1E                LDA     numarg
0053E8  2  F9 B7 40             SBC     nums,Y
0053EB  2  90 15                BCC     @out
0053ED  2  B0 05                BCS     @sub
0053EF  2               @noc:
0053EF  2  A5 1E                LDA     numarg
0053F1  2  F9 B7 40             SBC     nums,Y
0053F4  2               @sub:
0053F4  2  E6 28                INC     numspace
0053F6  2  85 1E                STA     numarg
0053F8  2  A5 1F                LDA     numarg+1
0053FA  2  F9 B8 40             SBC     nums+1,Y
0053FD  2  85 1F                STA     numarg+1
0053FF  2  4C DD 53             JMP     @dig
005402  2               @out:
005402  2  A5 28                LDA     numspace
005404  2  AE A8 6E             LDX     mblen
005407  2  9D 48 6E             STA     mbuf,X
00540A  2  EE A8 6E             INC     mblen
00540D  2  88                   DEY
00540E  2  88                   DEY
00540F  2  10 C8                BPL     @start
005411  2  60                   RTS
005412  2               
005412  2               ; append a monster type name (A = type id)
005412  2               mb_mname:
005412  2  0A                   ASL     A
005413  2  AA                   TAX
005414  2  BD 40 57             LDA     mon_names,X
005417  2  BC 41 57             LDY     mon_names+1,X
00541A  2  4C A6 53             JMP     mb_str
00541D  2               
00541D  2               mb_flush:
00541D  2  AE A8 6E             LDX     mblen
005420  2  A9 00                LDA     #0
005422  2  9D 48 6E             STA     mbuf,X          ; NUL terminate
005425  2  A9 48                LDA     #<mbuf
005427  2  A0 6E                LDY     #>mbuf
005429  2  4C CA 40             JMP     msg_print
00542C  2               
00542C  2               ;----------------------------------------------------------------
00542C  2               ; player_attacks_monster - X = monster slot.
00542C  2               ;   Fists are weak, daggers can critically strike, swords are
00542C  2               ;   reliable, and axes have the widest damage range.
00542C  2               ;----------------------------------------------------------------
00542C  2               player_attacks_monster:
00542C  2  86 2F                STX     monidx
00542E  2  A9 00                LDA     #0
005430  2  8D 96 6D             STA     attack_flags
005433  2  AE 87 6D             LDX     pweapon
005436  2  E0 01                CPX     #1
005438  2  F0 10                BEQ     @dagger
00543A  2  E0 02                CPX     #2
00543C  2  F0 2E                BEQ     @sword
00543E  2  E0 03                CPX     #3
005440  2  F0 35                BEQ     @axe
005442  2               ; fists: 1..2
005442  2  A9 02                LDA     #2
005444  2  20 9A 0E             JSR     rng_d
005447  2  4C 7C 54             JMP     @rolled
00544A  2               @dagger:
00544A  2               ; dagger: 1..4, with a one-in-four critical strike for +4
00544A  2  A9 04                LDA     #4
00544C  2  20 9A 0E             JSR     rng_d
00544F  2  85 20                STA     tmp0
005451  2  A9 04                LDA     #4
005453  2  20 9A 0E             JSR     rng_d
005456  2  C9 01                CMP     #1
005458  2  D0 0D                BNE     @dagger_normal
00545A  2  A9 01                LDA     #ATTACK_CRITICAL
00545C  2  8D 96 6D             STA     attack_flags
00545F  2  A5 20                LDA     tmp0
005461  2  18                   CLC
005462  2  69 04                ADC     #4
005464  2  4C 7C 54             JMP     @rolled
005467  2               @dagger_normal:
005467  2  A5 20                LDA     tmp0
005469  2  4C 7C 54             JMP     @rolled
00546C  2               @sword:
00546C  2               ; sword: reliable 4..7
00546C  2  A9 04                LDA     #4
00546E  2  20 9A 0E             JSR     rng_d
005471  2  18                   CLC
005472  2  69 03                ADC     #3
005474  2  4C 7C 54             JMP     @rolled
005477  2               @axe:
005477  2               ; axe: volatile 1..12
005477  2  A9 0C                LDA     #12
005479  2  20 9A 0E             JSR     rng_d
00547C  2               @rolled:
00547C  2  85 24                STA     cnt0            ; preserve damage while checking terrain
00547E  2  AD 89 6D             LDA     loc
005481  2  D0 22                BNE     @damage_ready
005483  2  AD 7B 6D             LDA     px
005486  2  85 2C                STA     tgtx
005488  2  AD 7C 6D             LDA     py
00548B  2  85 2D                STA     tgty
00548D  2  20 F4 1E             JSR     tileat
005490  2  A5 2E                LDA     tgttile
005492  2  C9 0F                CMP     #T_HILLS
005494  2  D0 0F                BNE     @damage_ready
005496  2  18                   CLC
005497  2  A5 24                LDA     cnt0
005499  2  69 02                ADC     #2
00549B  2  85 24                STA     cnt0
00549D  2  AD 96 6D             LDA     attack_flags
0054A0  2  09 02                ORA     #ATTACK_HIGH
0054A2  2  8D 96 6D             STA     attack_flags
0054A5  2               @damage_ready:
0054A5  2  A5 24                LDA     cnt0
0054A7  2  85 20                STA     tmp0            ; final damage
0054A9  2               ; subtract from monster hp
0054A9  2  A6 2F                LDX     monidx
0054AB  2  38                   SEC
0054AC  2  BD CD 6E             LDA     mon_hp,X
0054AF  2  E5 20                SBC     tmp0
0054B1  2  9D CD 6E             STA     mon_hp,X
