00613F  2  20 48 43             JSR     name_weapon
006142  2  A5 1C                LDA     strp
006144  2  A4 1D                LDY     strp+1
006146  2  20 A2 3E             JSR     prmsg
006149  2  A9 FE A0 62          PRINTMSG t_dash
00614D  2  20 A2 3E     
006150  2  AD 87 6D             LDA     pweapon
006153  2  0A                   ASL     A
006154  2  AA                   TAX
006155  2  BD 16 63             LDA     weapon_traits,X
006158  2  BC 17 63             LDY     weapon_traits+1,X
00615B  2  4C A2 3E             JMP     prmsg
00615E  2               
00615E  2               shop_print_armor_status:
00615E  2  A9 0D A0 63          PRINTMSG t_shop_armor
006162  2  20 A2 3E     
006165  2  AD 88 6D             LDA     parmor
006168  2  20 55 43             JSR     name_armor
00616B  2  A5 1C                LDA     strp
00616D  2  A4 1D                LDY     strp+1
00616F  2  20 A2 3E             JSR     prmsg
006172  2  A9 FE A0 62          PRINTMSG t_dash
006176  2  20 A2 3E     
006179  2  AD 88 6D             LDA     parmor
00617C  2  0A                   ASL     A
00617D  2  AA                   TAX
00617E  2  BD 57 63             LDA     armor_traits,X
006181  2  BC 58 63             LDY     armor_traits+1,X
006184  2  4C A2 3E             JMP     prmsg
