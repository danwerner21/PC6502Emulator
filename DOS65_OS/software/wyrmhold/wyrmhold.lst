0055E3  2               ;----------------------------------------------------------------
0055E3  2               ; monster_attacks_player - monster in slot monidx strikes.
0055E3  2               ;   Damage = 1..mtype_atk, reduced by armor.  Apply to phealth.
0055E3  2               ;----------------------------------------------------------------
0055E3  2               monster_attacks_player:
0055E3  2  A6 2F                LDX     monidx
0055E5  2  BD A9 6E             LDA     mon_type,X
0055E8  2  85 21                STA     tmp1            ; type
0055EA  2  A8                   TAY
0055EB  2  B9 44 48             LDA     mtype_atk,Y
0055EE  2  20 9A 0E             JSR     rng_d           ; 1..atk
0055F1  2  85 20                STA     tmp0            ; raw damage
0055F3  2               ; armor reduces by armor index (0..3)
0055F3  2  AE 88 6D             LDX     parmor
0055F6  2  BD 3C 57             LDA     arm_def,X
0055F9  2  85 22                STA     tmp2
0055FB  2  38                   SEC
0055FC  2  A5 20                LDA     tmp0
0055FE  2  E5 22                SBC     tmp2
005600  2  10 02                BPL     @ok
005602  2  A9 01                LDA     #1              ; minimum 1 damage
005604  2               @ok:
005604  2  D0 02                BNE     @guard
005606  2  A9 01                LDA     #1
005608  2               @guard:
005608  2  AE 95 6D             LDX     guard_active
00560B  2  F0 0B                BEQ     @apply
00560D  2  38                   SEC
00560E  2  E9 02                SBC     #2
005610  2  10 02                BPL     :+
005612  2  A9 01                LDA     #1
005614  2               :
005614  2  D0 02                BNE     @apply
005616  2  A9 01                LDA     #1
005618  2               @apply:
005618  2  85 20                STA     tmp0
00561A  2               ; subtract from phealth (floor at 0)
00561A  2  38                   SEC
00561B  2  AD 7D 6D             LDA     phealth
00561E  2  E5 20                SBC     tmp0
005620  2  B0 02                BCS     @sethp
005622  2  A9 00                LDA     #0
005624  2               @sethp:
005624  2  8D 7D 6D             STA     phealth
005627  2               ; message "Orc hits you for N!"
005627  2  20 A0 53             JSR     mb_reset
00562A  2  A9 9D                LDA     #<c_the
00562C  2  A0 57                LDY     #>c_the
