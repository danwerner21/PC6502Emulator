005638  2  A0 57                LDY     #>c_hitsyou
00563A  2  20 A6 53             JSR     mb_str
00563D  2  A5 20                LDA     tmp0
00563F  2  20 BD 53             JSR     mb_num
005642  2  A9 9B                LDA     #<c_bang
005644  2  A0 57                LDY     #>c_bang
005646  2  20 A6 53             JSR     mb_str
005649  2  20 1D 54             JSR     mb_flush
00564C  2               ; snake bites may inflict four turns of poison
00564C  2  A5 21                LDA     tmp1
00564E  2  C9 02                CMP     #M_SNAKE
005650  2  D0 31                BNE     @normal_sfx
005652  2  AE 88 6D             LDX     parmor
005655  2  E0 01                CPX     #1
005657  2  D0 04                BNE     @normal_venom
005659  2               ; leather armor reduces the poison chance from one-in-three to one-in-six
005659  2  A9 06                LDA     #6
00565B  2  D0 02                BNE     @roll_venom
00565D  2               @normal_venom:
00565D  2  A9 03                LDA     #3
00565F  2               @roll_venom:
00565F  2  20 9A 0E             JSR     rng_d
005662  2  C9 01                CMP     #1
005664  2  D0 1D                BNE     @normal_sfx
005666  2  AD 93 6D             LDA     poison_turns
005669  2  D0 08                BNE     @refresh_poison
00566B  2  A9 84                LDA     #$84            ; high bit skips the immediate status tick
00566D  2  8D 93 6D             STA     poison_turns
005670  2  4C 78 56             JMP     @poisoned
005673  2               @refresh_poison:
005673  2  A9 04                LDA     #4              ; refreshed poison still ticks this turn
005675  2  8D 93 6D             STA     poison_turns
005678  2               @poisoned:
005678  2  20 9B 11             JSR     sfx_poison
00567B  2  A9 21 A0 5B          PRINTMSG_MSG m_poisoned
00567F  2  20 CA 40     
005682  2  60                   RTS
