0068A0  2  A9 4B A0 6A          PRINTMSG_MSG c_unlock1
0068A4  2  20 CA 40     
0068A7  2  A9 85 A0 6A          PRINTMSG_MSG c_unlock2
0068AB  2  20 CA 40     
0068AE  2  60                   RTS
0068AF  2               @finale:
0068AF  2  A9 05                LDA     #QUEST_COMPLETE
0068B1  2  8D 91 6D             STA     queststate
