000B51  1  2B 2D 2D 2D          .BYTE   "+--------------------------------+",0
000B55  1  2D 2D 2D 2D  
000B59  1  2D 2D 2D 2D  
000B74  1               ttl_by:
000B74  1  41 6E 73 77          .BYTE   "Answer the summons of Wyrmhold Castle",0
000B78  1  65 72 20 74  
000B7C  1  68 65 20 73  
