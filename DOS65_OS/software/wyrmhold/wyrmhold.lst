0056A5  2  D0 09                BNE     @subtract
0056A7  2  AD 82 6D             LDA     pgold
0056AA  2  C5 20                CMP     tmp0
0056AC  2  B0 02                BCS     @subtract
0056AE  2  85 20                STA     tmp0
