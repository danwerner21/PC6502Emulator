00686D  2  A9 DC A0 69          PRINTMSG_MSG c_reminder1
006871  2  20 CA 40     
006874  2  A9 19 A0 6A          PRINTMSG_MSG c_reminder2
006878  2  20 CA 40     
00687B  2  60                   RTS
00687C  2               @unlock:
00687C  2  A9 03                LDA     #QUEST_DUNG_OPEN
00687E  2  8D 91 6D             STA     queststate
006881  2               ; royal reward: full healing and fresh provisions
006881  2  AD 7E 6D             LDA     pmaxhp
006884  2  8D 7D 6D             STA     phealth
006887  2  A9 00                LDA     #0
006889  2  8D 93 6D             STA     poison_turns
00688C  2  18                   CLC
00688D  2  AD 84 6D             LDA     pfood
006890  2  69 64                ADC     #100
006892  2  8D 84 6D             STA     pfood
006895  2  AD 85 6D             LDA     pfood+1
006898  2  69 00                ADC     #0
00689A  2  8D 85 6D             STA     pfood+1
