0056B4  2  E5 20                SBC     tmp0
0056B6  2  8D 82 6D             STA     pgold
0056B9  2  AD 83 6D             LDA     pgold+1
0056BC  2  E9 00                SBC     #0
0056BE  2  8D 83 6D             STA     pgold+1
0056C1  2  A6 2F                LDX     monidx
0056C3  2  A9 01                LDA     #1
0056C5  2  9D D9 6E             STA     mon_state,X
0056C8  2  20 A0 53             JSR     mb_reset
