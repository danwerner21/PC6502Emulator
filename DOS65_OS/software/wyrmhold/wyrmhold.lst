0043A7  2               ;----------------------------------------------------------------
0043A7  2               ; In-game help panel. Opening and closing it consumes no game turn.
0043A7  2               ;----------------------------------------------------------------
0043A7  2               HELP_X0         = 3
0043A7  2               HELP_X1         = 42
0043A7  2               HELP_Y0         = 3
0043A7  2               HELP_Y1         = 17
0043A7  2               
0043A7  2               help_menu:
0043A7  2  20 B1 43             JSR     help_draw
0043AA  2  20 F0 44             JSR     drainkeys       ; do not close on a buffered '?' repeat
0043AD  2  20 D6 44             JSR     getkey_block
0043B0  2  60                   RTS
0043B1  2               
0043B1  2               help_draw:
0043B1  2               ; Paint a bordered overlay inside the viewport.
0043B1  2  20 42 3D             JSR     vid_enter
0043B4  2  A9 03                LDA     #HELP_Y0
0043B6  2  85 27                STA     rowidx
0043B8  2               @bgrow:
0043B8  2  A5 27                LDA     rowidx
0043BA  2  20 57 3D             JSR     rowbase
0043BD  2  A0 03                LDY     #HELP_X0
0043BF  2               @bgcol:
0043BF  2  C0 03                CPY     #HELP_X0
0043C1  2  F0 19                BEQ     @edge
0043C3  2  C0 2A                CPY     #HELP_X1
0043C5  2  F0 15                BEQ     @edge
0043C7  2  A5 27                LDA     rowidx
0043C9  2  C9 03                CMP     #HELP_Y0
0043CB  2  F0 0F                BEQ     @edge
0043CD  2  C9 11                CMP     #HELP_Y1
0043CF  2  F0 0B                BEQ     @edge
0043D1  2  A9 20                LDA     #space
0043D3  2  91 14                STA     (vptr),Y
0043D5  2  A9 1F                LDA     #C_SHOPBG
0043D7  2  91 16                STA     (cptr),Y
0043D9  2  4C E4 43             JMP     @bgnext
0043DC  2               @edge:
0043DC  2  A9 20                LDA     #space
0043DE  2  91 14                STA     (vptr),Y
0043E0  2  A9 1B                LDA     #C_SHOPBRD
0043E2  2  91 16                STA     (cptr),Y
0043E4  2               @bgnext:
0043E4  2  C8                   INY
0043E5  2  C0 2B                CPY     #HELP_X1+1
0043E7  2  D0 D6                BNE     @bgcol
0043E9  2  E6 27                INC     rowidx
0043EB  2  A5 27                LDA     rowidx
0043ED  2  C9 12                CMP     #HELP_Y1+1
0043EF  2  D0 C7                BNE     @bgrow
0043F1  2  20 51 3D             JSR     vid_exit
0043F4  2               
0043F4  2  A9 1E                LDA     #C_SHOPTTL
0043F6  2  8D 4A 06             STA     CURCOLOR
0043F9  2  A2 10                LDX     #HELP_X0+13
0043FB  2  A0 03                LDY     #HELP_Y0
0043FD  2  20 90 3E             JSR     locate
004400  2  A9 FD A0 46          PRINTMSG help_title
004404  2  20 A2 3E     
004407  2               
004407  2  A9 1F                LDA     #C_SHOPTXT
004409  2  8D 4A 06             STA     CURCOLOR
00440C  2  A2 05                LDX     #HELP_X0+2
00440E  2  A0 05                LDY     #HELP_Y0+2
004410  2  20 90 3E             JSR     locate
004413  2  A9 0D A0 47          PRINTMSG help_move
004417  2  20 A2 3E     
00441A  2  A2 05                LDX     #HELP_X0+2
00441C  2  A0 06                LDY     #HELP_Y0+3
00441E  2  20 90 3E             JSR     locate
004421  2  A9 26 A0 47          PRINTMSG help_actions
004425  2  20 A2 3E     
004428  2  A2 05                LDX     #HELP_X0+2
00442A  2  A0 07                LDY     #HELP_Y0+4
00442C  2  20 90 3E             JSR     locate
00442F  2  A9 48 A0 47          PRINTMSG help_combat
004433  2  20 A2 3E     
004436  2  A2 05                LDX     #HELP_X0+2
004438  2  A0 09                LDY     #HELP_Y0+6
