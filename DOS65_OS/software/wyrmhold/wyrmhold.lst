000E2F  1               
000E2F  1               ;==============================================================================
000E2F  1               ; Include the rest of the engine
000E2F  1               ;==============================================================================
000E2F  1                       .INCLUDE "rng.asm"
000E2F  2               ;______________________________________________________________________________
000E2F  2               ;  rng.asm - 16-bit xorshift pseudo-random generator
000E2F  2               ;______________________________________________________________________________
000E2F  2               
000E2F  2               ;----------------------------------------------------------------
000E2F  2               ; rng_seed - initialise the generator (avoid all-zero state).
000E2F  2               ;----------------------------------------------------------------
000E2F  2               rng_seed:
000E2F  2  A9 A3                LDA     #$A3
000E31  2  85 30                STA     seedlo
000E33  2  A9 1C                LDA     #$1C
000E35  2  85 31                STA     seedhi
000E37  2  A9 00                LDA     #0
000E39  2  85 33                STA     seed2lo
000E3B  2  85 34                STA     seed2hi
000E3D  2  60                   RTS
000E3E  2               
000E3E  2               ;----------------------------------------------------------------
000E3E  2               ; rng_timing_tick - increment the title-screen timing counter.
000E3E  2               ;----------------------------------------------------------------
000E3E  2               rng_timing_tick:
000E3E  2  E6 33                INC     seed2lo
000E40  2  D0 02                BNE     @done
000E42  2  E6 34                INC     seed2hi
000E44  2               @done:
000E44  2  60                   RTS
000E45  2               
000E45  2               ;----------------------------------------------------------------
000E45  2               ; rng_mix_timing - mix title wait time and accepted key into the
000E45  2               ;                  generator, then diffuse the new state.
000E45  2               ;                  IN: keych = accepted title-screen key
000E45  2               ;----------------------------------------------------------------
000E45  2               rng_mix_timing:
000E45  2  A5 30                LDA     seedlo
000E47  2  45 33                EOR     seed2lo
000E49  2  45 29                EOR     keych
000E4B  2  85 30                STA     seedlo
000E4D  2               
000E4D  2  A5 29                LDA     keych
000E4F  2  0A                   ASL     A
000E50  2  45 31                EOR     seedhi
000E52  2  45 34                EOR     seed2hi
000E54  2  85 31                STA     seedhi
000E56  2               
000E56  2               ; The xorshift generator must never enter its all-zero lockup state.
000E56  2  A5 30                LDA     seedlo
000E58  2  05 31                ORA     seedhi
000E5A  2  D0 08                BNE     @diffuse
000E5C  2  A9 A3                LDA     #$A3
000E5E  2  85 30                STA     seedlo
000E60  2  A9 1C                LDA     #$1C
000E62  2  85 31                STA     seedhi
000E64  2               @diffuse:
000E64  2  20 6A 0E             JSR     rng_next
000E67  2  4C 6A 0E             JMP     rng_next
000E6A  2               
000E6A  2               ;----------------------------------------------------------------
000E6A  2               ; rng_next - advance the 16-bit xorshift state, return low byte
000E6A  2               ;            in A.  (xorshift: x ^= x<<7; x ^= x>>9; x ^= x<<8)
000E6A  2               ;----------------------------------------------------------------
000E6A  2               rng_next:
000E6A  2               ; x ^= x << 7
000E6A  2  A5 31                LDA     seedhi
000E6C  2  4A                   LSR     A               ; carry = bit7 of hi after some shifts...
000E6D  2               ; Implement x<<7 via: shift left 7 = shift right 1 then swap?
000E6D  2               ; Simpler: do a byte-wise xorshift that is "good enough".
000E6D  2               ; x ^= x << 7
000E6D  2  A5 30                LDA     seedlo
000E6F  2  0A                   ASL     A
000E70  2  0A                   ASL     A
000E71  2  0A                   ASL     A
000E72  2  0A                   ASL     A
000E73  2  0A                   ASL     A
000E74  2  0A                   ASL     A
000E75  2  0A                   ASL     A               ; lo << 7 (only bit0 survives into bit7)
000E76  2  45 31                EOR     seedhi
000E78  2  85 31                STA     seedhi
000E7A  2               ; x ^= x >> 9  (>>9 of 16-bit = hi >> 1 into lo)
000E7A  2  A5 31                LDA     seedhi
000E7C  2  4A                   LSR     A
000E7D  2  45 30                EOR     seedlo
000E7F  2  85 30                STA     seedlo
000E81  2               ; x ^= x << 8  (swap bytes contribution: lo ^ into hi)
000E81  2  A5 30                LDA     seedlo
000E83  2  45 31                EOR     seedhi
000E85  2  85 31                STA     seedhi
000E87  2  A5 30                LDA     seedlo
000E89  2  60                   RTS
000E8A  2               
000E8A  2               ;----------------------------------------------------------------
000E8A  2               ; rng_mod - return a value 0..A-1 in A.  IN: A = modulus (1..255)
000E8A  2               ;           (uses repeated subtraction mask via AND for powers of
000E8A  2               ;            two is faster, but generic mod via subtract loop here)
000E8A  2               ;----------------------------------------------------------------
000E8A  2               rng_mod:
000E8A  2  85 23                STA     tmp3            ; modulus
000E8C  2  20 6A 0E             JSR     rng_next        ; A = random byte
000E8F  2               ; reduce A mod tmp3 by subtraction
000E8F  2               @rm:
000E8F  2  C5 23                CMP     tmp3
000E91  2  90 06                BCC     @done
000E93  2  38                   SEC
000E94  2  E5 23                SBC     tmp3
000E96  2  4C 8F 0E             JMP     @rm
000E99  2               @done:
000E99  2  60                   RTS
000E9A  2               
000E9A  2               ;----------------------------------------------------------------
000E9A  2               ; rng_d - roll a die: return 1..A in A.  IN: A = sides (1..255)
000E9A  2               ;----------------------------------------------------------------
000E9A  2               rng_d:
000E9A  2  20 8A 0E             JSR     rng_mod
000E9D  2  18                   CLC
000E9E  2  69 01                ADC     #1
000EA0  2  60                   RTS
000EA1  2               
000EA1  1                       .INCLUDE "sound.asm"
000EA1  2               ;______________________________________________________________________________
000EA1  2               ;  sound.asm - AY-3-8910 PSG sound effects and cooperative music player
000EA1  2               ;
000EA1  2               ;  PSG access ported from software/dbasic/ay38910.asm (PPI at $E230).
000EA1  2               ;  psgwr: A=register, Y=value        psgrd: A=register -> Y=value
000EA1  2               ;
000EA1  2               ;  AY register map:
000EA1  2               ;    0/1  ch A tone period (lo / hi 4 bits)
000EA1  2               ;    2/3  ch B tone period
000EA1  2               ;    4/5  ch C tone period
000EA1  2               ;    6    noise period (5 bits)
000EA1  2               ;    7    mixer: bit clear = enabled. 0-2 tone A/B/C, 3-5 noise A/B/C
000EA1  2               ;    8/9/10 ch A/B/C volume (0-15, bit4 = use envelope)
000EA1  2               ;    11/12 envelope period
000EA1  2               ;    13   envelope shape
000EA1  2               ;______________________________________________________________________________
000EA1  2               
000EA1  2               PPI_BASE        = $E230
000EA1  2               ppiPortA        = PPI_BASE+0
000EA1  2               ppiPortB        = PPI_BASE+1
000EA1  2               ppiPortC        = PPI_BASE+2
000EA1  2               ppiControl      = PPI_BASE+3
000EA1  2               
000EA1  2               ;----------------------------------------------------------------
000EA1  2               ; psg_init - put the PSG into a known, silent state
000EA1  2               ;----------------------------------------------------------------
000EA1  2               psg_init:
000EA1  2  A9 80                LDA     #%10000000
000EA3  2  8D 33 E2             STA     ppiControl
000EA6  2  A9 10                LDA     #%00010000
000EA8  2  8D 32 E2             STA     ppiPortC
000EAB  2  A9 00                LDA     #$00
000EAD  2  8D 31 E2             STA     ppiPortB
000EB0  2  20 B4 0E             JSR     clrpsg
000EB3  2  60                   RTS
000EB4  2               
000EB4  2               ;----------------------------------------------------------------
000EB4  2               ; clrpsg - zero all 16 registers, then disable all channels
000EB4  2               ;----------------------------------------------------------------
000EB4  2               clrpsg:
000EB4  2  A2 00                LDX     #00
000EB6  2  A0 00                LDY     #00
000EB8  2               @cp1:
000EB8  2  8A                   TXA
000EB9  2  20 E6 0E             JSR     psgwr
000EBC  2  E8                   INX
000EBD  2  E0 10                CPX     #16
000EBF  2  D0 F7                BNE     @cp1
000EC1  2  A9 07                LDA     #07
000EC3  2  A0 3F                LDY     #%00111111      ; all tone + noise disabled
000EC5  2  20 E6 0E             JSR     psgwr
000EC8  2  60                   RTS
000EC9  2               
000EC9  2               ;----------------------------------------------------------------
000EC9  2               ; psg_silence - silence all three channels (volumes -> 0)
000EC9  2               ;----------------------------------------------------------------
000EC9  2               psg_silence:
000EC9  2  A9 08                LDA     #8
000ECB  2  A0 00                LDY     #0
000ECD  2  20 E6 0E             JSR     psgwr
000ED0  2  A9 09                LDA     #9
000ED2  2  A0 00                LDY     #0
000ED4  2  20 E6 0E             JSR     psgwr
000ED7  2  A9 0A                LDA     #10
000ED9  2  A0 00                LDY     #0
000EDB  2  20 E6 0E             JSR     psgwr
000EDE  2  A9 07                LDA     #07
000EE0  2  A0 3F                LDY     #%00111111
000EE2  2  20 E6 0E             JSR     psgwr
000EE5  2  60                   RTS
000EE6  2               
000EE6  2               ;----------------------------------------------------------------
000EE6  2               ; psgwr - write Y into PSG register A     (trashes A)
000EE6  2               ;----------------------------------------------------------------
000EE6  2               psgwr:
000EE6  2  8D 31 E2             STA     ppiPortB        ; select register
000EE9  2  A9 1C                LDA     #%00011100      ; latch address
000EEB  2  8D 32 E2             STA     ppiPortC
000EEE  2  8D 32 E2             STA     ppiPortC
000EF1  2  8D 32 E2             STA     ppiPortC
000EF4  2  A9 10                LDA     #%00010000      ; inactive
000EF6  2  8D 32 E2             STA     ppiPortC
000EF9  2  8D 32 E2             STA     ppiPortC
000EFC  2  8D 32 E2             STA     ppiPortC
000EFF  2  98                   TYA
000F00  2  8D 31 E2             STA     ppiPortB        ; store data
000F03  2  8D 31 E2             STA     ppiPortB
000F06  2  8D 31 E2             STA     ppiPortB
000F09  2  A9 14                LDA     #%00010100      ; latch data
000F0B  2  8D 32 E2             STA     ppiPortC
000F0E  2  8D 32 E2             STA     ppiPortC
000F11  2  8D 32 E2             STA     ppiPortC
000F14  2  A9 10                LDA     #%00010000      ; inactive
000F16  2  8D 32 E2             STA     ppiPortC
000F19  2  60                   RTS
000F1A  2               
000F1A  2               ;----------------------------------------------------------------
000F1A  2               ; psgrd - read PSG register A into Y      (trashes A)
000F1A  2               ;----------------------------------------------------------------
000F1A  2               psgrd:
000F1A  2  8D 31 E2             STA     ppiPortB        ; select register
000F1D  2  A9 1C                LDA     #%00011100      ; latch address
000F1F  2  8D 32 E2             STA     ppiPortC
000F22  2  8D 32 E2             STA     ppiPortC
000F25  2  8D 32 E2             STA     ppiPortC
000F28  2  A9 10                LDA     #%00010000      ; inactive
000F2A  2  8D 32 E2             STA     ppiPortC
000F2D  2  8D 32 E2             STA     ppiPortC
000F30  2  A9 82                LDA     #%10000010
000F32  2  8D 33 E2             STA     ppiControl
000F35  2  A9 18                LDA     #%00011000      ; latch data
000F37  2  8D 32 E2             STA     ppiPortC
000F3A  2  8D 32 E2             STA     ppiPortC
000F3D  2  8D 32 E2             STA     ppiPortC
000F40  2  AD 31 E2             LDA     ppiPortB        ; read data
000F43  2  A8                   TAY
000F44  2  A9 80                LDA     #%10000000
000F46  2  8D 33 E2             STA     ppiControl
000F49  2  A9 10                LDA     #%00010000      ; inactive
000F4B  2  8D 32 E2             STA     ppiPortC
000F4E  2  60                   RTS
000F4F  2               
000F4F  2               ;----------------------------------------------------------------
000F4F  2               ; tone_on - start a tone on channel A.
000F4F  2               ;   ptr (16-bit) = 12-bit tone period (lo in ptr, hi in ptr+1)
000F4F  2               ;   tmp0         = volume (0-15)
000F4F  2               ;----------------------------------------------------------------
000F4F  2               tone_on:
000F4F  2  A9 00                LDA     #0              ; ch A period low
000F51  2  A4 10                LDY     ptr
000F53  2  20 E6 0E             JSR     psgwr
000F56  2  A9 01                LDA     #1              ; ch A period high
000F58  2  A4 11                LDY     ptr+1
000F5A  2  20 E6 0E             JSR     psgwr
000F5D  2  A9 07                LDA     #07             ; mixer: enable tone A only
000F5F  2  A0 3E                LDY     #%00111110
000F61  2  20 E6 0E             JSR     psgwr
000F64  2  A9 08                LDA     #8              ; ch A volume
000F66  2  A4 20                LDY     tmp0
000F68  2  20 E6 0E             JSR     psgwr
000F6B  2  60                   RTS
000F6C  2               
000F6C  2               ;----------------------------------------------------------------
000F6C  2               ; busywait - crude delay.  X = outer count.
000F6C  2               ;----------------------------------------------------------------
000F6C  2               busywait:
000F6C  2               @bw0:
000F6C  2  A0 00                LDY     #0
000F6E  2               @bw1:
000F6E  2  A9 00                LDA     #0
000F70  2               @bw2:
000F70  2  18                   CLC
000F71  2  69 01                ADC     #1
000F73  2  C9 28                CMP     #40
000F75  2  D0 F9                BNE     @bw2
000F77  2  C8                   INY
000F78  2  D0 F4                BNE     @bw1
000F7A  2  CA                   DEX
000F7B  2  D0 EF                BNE     @bw0
000F7D  2  60                   RTS
000F7E  2               
000F7E  2               ;----------------------------------------------------------------
000F7E  2               ; mus_finewait - a short, fine-grained delay for tempo trimming.
000F7E  2               ; Spins MUS_FINEDELAY outer times, 256 inner each.  Much smaller
000F7E  2               ; than one busywait pass, so it gives sub-step tempo control.
000F7E  2               ;----------------------------------------------------------------
000F7E  2               mus_finewait:
000F7E  2  A2 46                LDX     #MUS_FINEDELAY
000F80  2  F0 08                BEQ     @done
000F82  2               @fw0:
000F82  2  A0 00                LDY     #0
000F84  2               @fw1:
000F84  2  C8                   INY
000F85  2  D0 FD                BNE     @fw1
000F87  2  CA                   DEX
000F88  2  D0 F8                BNE     @fw0
000F8A  2               @done:
000F8A  2  60                   RTS
000F8B  2               
000F8B  2               ;----------------------------------------------------------------
000F8B  2               ; SFX helpers.  Each plays a short, self-contained sound and
000F8B  2               ; silences the PSG afterwards.  All preserve nothing - callers
000F8B  2               ; must save anything they need.
000F8B  2               ;----------------------------------------------------------------
000F8B  2               
000F8B  2               ; sfx_move - very short low blip
000F8B  2               sfx_move:
000F8B  2  A9 40 85 10          SETW16  ptr, $0240
000F8F  2  A9 02 85 11  
000F93  2  A9 06                LDA     #6
000F95  2  85 20                STA     tmp0
000F97  2  20 4F 0F             JSR     tone_on
000F9A  2  A2 02                LDX     #2
000F9C  2  20 6C 0F             JSR     busywait
000F9F  2  4C C9 0E             JMP     psg_silence
000FA2  2               
000FA2  2               ; sfx_guard - short steady brace tone
000FA2  2               sfx_guard:
000FA2  2  A9 00 85 10          SETW16  ptr, $0200
000FA6  2  A9 02 85 11  
000FAA  2  A9 08                LDA     #8
000FAC  2  85 20                STA     tmp0
000FAE  2  20 4F 0F             JSR     tone_on
000FB1  2  A2 03                LDX     #3
000FB3  2  20 6C 0F             JSR     busywait
000FB6  2  4C C9 0E             JMP     psg_silence
000FB9  2               
000FB9  2               ; sfx_guard_hit - clipped impact when a guarded blow lands
000FB9  2               sfx_guard_hit:
000FB9  2  A9 80 85 10          SETW16  ptr, $0180
000FBD  2  A9 01 85 11  
000FC1  2  A9 07                LDA     #7
000FC3  2  85 20                STA     tmp0
000FC5  2  20 4F 0F             JSR     tone_on
000FC8  2  A2 01                LDX     #1
000FCA  2  20 6C 0F             JSR     busywait
000FCD  2  A9 06                LDA     #6
000FCF  2  A0 0E                LDY     #14
000FD1  2  20 E6 0E             JSR     psgwr
000FD4  2  A9 07                LDA     #7
000FD6  2  A0 37                LDY     #%00110111
000FD8  2  20 E6 0E             JSR     psgwr
000FDB  2  A9 08                LDA     #8
000FDD  2  A0 05                LDY     #5
000FDF  2  20 E6 0E             JSR     psgwr
000FE2  2  A2 01                LDX     #1
000FE4  2  20 6C 0F             JSR     busywait
000FE7  2  4C C9 0E             JMP     psg_silence
000FEA  2               
000FEA  2               ; sfx_talk - soft two-note prompt for town guidance
000FEA  2               sfx_talk:
000FEA  2  A9 00 85 10          SETW16  ptr, $0300
000FEE  2  A9 03 85 11  
000FF2  2  A9 05                LDA     #5
000FF4  2  85 20                STA     tmp0
000FF6  2  20 4F 0F             JSR     tone_on
000FF9  2  A2 01                LDX     #1
000FFB  2  20 6C 0F             JSR     busywait
000FFE  2  A9 80 85 10          SETW16  ptr, $0280
001002  2  A9 02 85 11  
001006  2  A9 05                LDA     #5
001008  2  85 20                STA     tmp0
00100A  2  20 4F 0F             JSR     tone_on
00100D  2  A2 01                LDX     #1
00100F  2  20 6C 0F             JSR     busywait
001012  2  4C C9 0E             JMP     psg_silence
001015  2               
001015  2               ; sfx_ford - short splash for the reed ford shortcut
001015  2               sfx_ford:
001015  2  A9 06                LDA     #6
001017  2  A0 0C                LDY     #12
001019  2  20 E6 0E             JSR     psgwr
00101C  2  A9 07                LDA     #7
00101E  2  A0 37                LDY     #%00110111
001020  2  20 E6 0E             JSR     psgwr
001023  2  A9 08                LDA     #8
001025  2  A0 08                LDY     #8
001027  2  20 E6 0E             JSR     psgwr
00102A  2  A2 02                LDX     #2
00102C  2  20 6C 0F             JSR     busywait
00102F  2  A9 60 85 10          SETW16  ptr, $0260
001033  2  A9 02 85 11  
001037  2  A9 05                LDA     #5
001039  2  85 20                STA     tmp0
00103B  2  20 4F 0F             JSR     tone_on
00103E  2  A2 01                LDX     #1
001040  2  20 6C 0F             JSR     busywait
001043  2  4C C9 0E             JMP     psg_silence
001046  2               
001046  2               ; sfx_steal - quick sly dip for thief theft
001046  2               sfx_steal:
001046  2  A9 80 85 10          SETW16  ptr, $0180
00104A  2  A9 01 85 11  
00104E  2  A9 06                LDA     #6
001050  2  85 20                STA     tmp0
001052  2  20 4F 0F             JSR     tone_on
001055  2  A2 01                LDX     #1
001057  2  20 6C 0F             JSR     busywait
00105A  2  A9 40 85 10          SETW16  ptr, $0240
00105E  2  A9 02 85 11  
001062  2  A9 05                LDA     #5
