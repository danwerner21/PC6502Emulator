000000r 1               ;______________________________________________________________________________
000000r 1               ;  WYRMHOLD  -  an original top-down fantasy RPG for the 6502PC / DOS/65
000000r 1               ;
000000r 1               ;  Written in 6502 assembly (ca65).  Uses the memory-mapped video card
000000r 1               ;  (direct VRAM via MMU paging, the SpeedScript way) and the AY-3-8910
000000r 1               ;  PSG for a title melody and sound effects.
000000r 1               ;
000000r 1               ;  Program loads at $0800 (DOS/65 TEA) and exits back to DOS with JMP $0100.
000000r 1               ;______________________________________________________________________________
000000r 1                       .PSC02
000000r 1               
000000r 1                       .SEGMENT "TEA"
000000r 1                       .ORG    $0800
000800  1               
000800  1                       .INCLUDE "macro.asm"
000800  2               ;______________________________________________________________________________
000800  2               ;  macro.asm - 16-bit helpers and a FARCALL convenience macro
000800  2               ;  Style follows software/speedscript/macro.asm
000800  2               ;______________________________________________________________________________
000800  2               
000800  2               ; Copy a 16-bit value src -> dst
000800  2                       .MACRO  COPY16  src, dst
000800  2                       LDA     src
000800  2                       STA     dst
000800  2                       LDA     src+1
000800  2                       STA     dst+1
000800  2                       .ENDMACRO
000800  2               
000800  2               ; left = left + right (16-bit)
000800  2                       .MACRO  ADD16   left,right
000800  2                       CLC
000800  2                       LDA     left
000800  2                       ADC     right
000800  2                       STA     left
000800  2                       LDA     left+1
000800  2                       ADC     right+1
000800  2                       STA     left+1
000800  2                       .ENDMACRO
000800  2               
000800  2               ; left = left - right (16-bit)
000800  2                       .MACRO  SUB16   left,right
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     left
000800  2                       LDA     left+1
000800  2                       SBC     right+1
000800  2                       STA     left+1
000800  2                       .ENDMACRO
000800  2               
000800  2               ; Set a 16-bit zero-page word to an immediate constant.
000800  2                       .MACRO  SETW16  dst, value
000800  2                       LDA     #<(value)
000800  2                       STA     dst
000800  2                       LDA     #>(value)
000800  2                       STA     dst+1
000800  2                       .ENDMACRO
000800  2               
000800  2               ; Issue a FARCALL: store function number then JSR DO_FARCALL.
000800  2               ; Pass any X/Y/A arguments BEFORE invoking (this macro only touches A).
000800  2                       .MACRO  FARCALL func
000800  2                       LDA     #func
000800  2                       STA     farfunct
000800  2                       JSR     DO_FARCALL
000800  2                       .ENDMACRO
000800  2               
000800  2               ; Print a zero-terminated message via the firmware console (FARCALL chrout).
000800  2               ; message = address of a 0-terminated string.
000800  2                       .MACRO  PRINTMSG message
000800  2                       LDA     #<message
000800  2                       LDY     #>message
000800  2                       JSR     prmsg
000800  2                       .ENDMACRO
000800  2               
000800  2               ; Push a message into the scrolling message log at the bottom.
000800  2                       .MACRO  PRINTMSG_MSG message
000800  2                       LDA     #<message
000800  2                       LDY     #>message
000800  2                       JSR     msg_print
000800  2                       .ENDMACRO
000800  2               
000800  2               ; Set the shop status-line pointer (shopstat) to a message address.
000800  2                       .MACRO  SETSTAT message
000800  2                       LDA     #<message
000800  2                       STA     shopstat
000800  2                       LDA     #>message
000800  2                       STA     shopstat+1
000800  2                       .ENDMACRO
000800  2               
000800  1                       .INCLUDE "defines.asm"
000800  2               ;______________________________________________________________________________
000800  2               ;  defines.asm - system equates, constants and game state
000800  2               ;______________________________________________________________________________
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; DOS/65 system entry points
000800  2               ;----------------------------------------------------------------
000800  2               DFLFCB          = $107          ; DEFAULT FCB
000800  2               PEM             = $103          ; PEM ENTRY
000800  2               BOOT            = $100          ; WARM BOOT (exit back to DOS/65)
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Memory-mapped video state (firmware-shared, fixed addresses)
000800  2               ;----------------------------------------------------------------
000800  2               CURX            = $0647         ; current cursor column
000800  2               CURY            = $0648         ; current cursor row
000800  2               SHOWCRSR        = $0649         ; show cursor (1=yes,0=no)
000800  2               CURCOLOR        = $064A         ; current print color
000800  2               CSRCOLOR        = $064B         ; current cursor color
000800  2               BVIDEOMODE      = $064C         ; current video mode (0=40,1=80)
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; FARCALL dispatch
000800  2               ;----------------------------------------------------------------
000800  2               DO_FARCALL      = $FFF0
000800  2               farfunct        = $32           ; zero-page: FARCALL function number
000800  2               
000800  2               ; MMU / video paging
000800  2               SETPAGE         = $FFF6         ; A=task, X=bank, Y=physical page
000800  2               VIDEOBANK       = $F8           ; base physical page for video RAM
000800  2               PC6502_ACT_TASK = $EFE0         ; MMU active task register (write only)
000800  2               VIDTEXT_PAGE    = $01+VIDEOBANK ; physical page for text page 1 ($F9)
000800  2               
000800  2               ; FARCALL function numbers (see 6502PC_firmware/dos65drv.asm)
000800  2               FC_CHROUT       = 19
000800  2               FC_CHRIN        = 20            ; non-blocking, returns A=key or $FF
000800  2               FC_LOCATE       = 37            ; X=col, Y=row
000800  2               FC_SCNCLR       = 38
000800  2               FC_COLOR        = 39            ; X=color, Y=cursor color
000800  2               FC_SCROLLDN     = 56
000800  2               FC_SETMODE      = 57
000800  2               FC_PAINTCSR     = 58
000800  2               FC_UNPAINTCSR   = 59
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Video memory window (we map sub-page $F9 into CPU bank $A,
000800  2               ; matching software/speedscript/screen.asm).
000800  2               ;   text  chars : $A000 + row*80 + col
000800  2               ;   color cells : $A800 + row*80 + col   (low nibble fg, high nibble bg)
000800  2               ;----------------------------------------------------------------
000800  2               VRAM_TEXT       = $A000
000800  2               VRAM_COLOR      = $A800
000800  2               SCRW            = 80
000800  2               SCRH            = 24
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Color values.  color byte = (bg<<4) | fg
000800  2               ; Base palette nibbles (typical 4-bit IRGB-ish ordering used by the card)
000800  2               ;----------------------------------------------------------------
000800  2               CO_BLACK        = $0
000800  2               CO_BLUE         = $1
000800  2               CO_GREEN        = $2
000800  2               CO_TURQ         = $3
000800  2               CO_RED          = $4
000800  2               CO_VIOLET       = $5
000800  2               CO_BROWN        = $6
000800  2               CO_CYAN         = $7
000800  2               CO_GREY         = $8
000800  2               CO_BRBLUE       = $9
000800  2               CO_BRGREEN      = $A
000800  2               CO_BRTURQ       = $B
000800  2               CO_BRRED        = $C
000800  2               CO_BRPURPLE     = $D
000800  2               CO_BRYELLOW     = $E
000800  2               CO_BRWHITE      = $F
000800  2               
000800  2               ; convenience: build a color byte from fg,bg nibbles
000800  2                       .DEFINE COLOR(fg,bg) (((bg)<<4)|(fg))
000800  2               
000800  2               ; named cell colors used throughout the game
000800  2               ; Terrain uses colored backgrounds so adjoining cells read as landscape,
000800  2               ; while the brighter foreground pixels provide texture and landmarks.
000800  2               C_GRASS         = COLOR(CO_BRGREEN, CO_GREEN)
000800  2               C_WATER         = COLOR(CO_BRTURQ,  CO_BLUE)
000800  2               C_FOREST        = COLOR(CO_BRGREEN, CO_BLACK)
000800  2               C_MOUNT         = COLOR(CO_BRWHITE, CO_GREY)
000800  2               C_TOWN          = COLOR(CO_BRYELLOW,CO_RED)
000800  2               C_CASTLE        = COLOR(CO_BRWHITE, CO_GREY)
000800  2               C_DUNG          = COLOR(CO_BRTURQ,  CO_BLACK)
000800  2               C_ROAD          = COLOR(CO_BRYELLOW,CO_RED)
000800  2               C_BRIDGE        = COLOR(CO_BRYELLOW,CO_BLUE)
000800  2               C_FLOOR         = COLOR(CO_GREY,    CO_BLACK)
000800  2               C_WALL          = COLOR(CO_BRWHITE, CO_GREY)
000800  2               C_HILLS         = COLOR(CO_BRYELLOW,CO_GREEN)
000800  2               C_MARSH         = COLOR(CO_BRGREEN, CO_BLUE)
000800  2               C_TREAS         = COLOR(CO_BRYELLOW,CO_BLACK)
000800  2               C_PLAYER        = COLOR(CO_BRWHITE, CO_BLACK)
000800  2               C_MONST         = COLOR(CO_BRRED,   CO_BLACK)
000800  2               C_BOSS          = COLOR(CO_BRRED,   CO_RED)
000800  2               C_BREATH        = COLOR(CO_BRYELLOW,CO_RED)
000800  2               C_BORDER        = COLOR(CO_BRTURQ,  CO_BLACK)
000800  2               C_PANEL         = COLOR(CO_BRWHITE, CO_BLACK)
000800  2               C_PANELHDR      = COLOR(CO_BRYELLOW,CO_BLUE)
000800  2               C_STATUSWARN    = COLOR(CO_BRYELLOW,CO_BLACK)
000800  2               C_MSG           = COLOR(CO_BRWHITE, CO_BLACK)
000800  2               C_TITLE         = COLOR(CO_BRYELLOW,CO_BLACK)
000800  2               C_BLANK         = COLOR(CO_GREY,    CO_BLACK)
000800  2               
000800  2               ; town-specific map palettes.  These recolor shared interior tiles so the
000800  2               ; two towns feel different without needing more permanent glyphs.
000800  2               C_EAST_FLOOR    = COLOR(CO_BRYELLOW,CO_BLACK)
000800  2               C_EAST_WALL     = COLOR(CO_BRWHITE, CO_BLUE)
000800  2               C_EAST_WATER    = COLOR(CO_BRTURQ,  CO_BLUE)
000800  2               C_EAST_SHOP     = COLOR(CO_BRYELLOW,CO_RED)
000800  2               C_EAST_EXIT     = COLOR(CO_BLACK,   CO_BRYELLOW)
000800  2               C_VALE_FLOOR    = COLOR(CO_BRGREEN, CO_BLACK)
000800  2               C_VALE_WALL     = COLOR(CO_BRWHITE, CO_GREY)
000800  2               C_VALE_WATER    = COLOR(CO_BRTURQ,  CO_BLACK)
000800  2               C_VALE_SHOP     = COLOR(CO_BRYELLOW,CO_GREEN)
000800  2               C_VALE_EXIT     = COLOR(CO_BLACK,   CO_BRGREEN)
000800  2               
000800  2               ; shop panel colors (blue panel with bright text)
000800  2               C_SHOPBG        = COLOR(CO_BRWHITE, CO_BLUE)
000800  2               C_SHOPBRD       = COLOR(CO_BRTURQ,  CO_BLUE)
000800  2               C_SHOPTTL       = COLOR(CO_BRYELLOW,CO_BLUE)
000800  2               C_SHOPTXT       = COLOR(CO_BRWHITE, CO_BLUE)
000800  2               C_SHOPST        = COLOR(CO_BRGREEN, CO_BLUE)
000800  2               
000800  2               ; exit tiles (town door / dungeon stairs) - bright so they stand out
000800  2               C_EXIT          = COLOR(CO_BLACK,   CO_BRGREEN)
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Tile codes (index into terrain tables).  Stored in map data.
000800  2               ;----------------------------------------------------------------
000800  2               T_GRASS         = 0
000800  2               T_FOREST        = 1
000800  2               T_MOUNT         = 2
000800  2               T_WATER         = 3
000800  2               T_TOWN          = 4
000800  2               T_DUNG          = 5
000800  2               T_CASTLE        = 6
000800  2               T_ROAD          = 7
000800  2               T_BRIDGE        = 8
000800  2               T_FLOOR         = 9             ; dungeon/town floor
000800  2               T_WALL          = 10            ; dungeon/town wall (impassable)
000800  2               T_DOOR          = 11            ; exit tile (leave town/dungeon)
000800  2               T_TREAS         = 12            ; treasure chest
000800  2               T_UPSTAIR       = 13            ; leave dungeon
000800  2               T_SHOP          = 14            ; shop counter inside a town
000800  2               T_HILLS         = 15            ; passable rolling foothills
000800  2               T_MARSH         = 16            ; passable wetland
000800  2               NUM_TILES       = 17
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Small custom glyphs used by the title scene. Gameplay uses the
000800  2               ; 2x2 metatile glyphs in the upper half of the character set below.
000800  2               ;----------------------------------------------------------------
000800  2               G_GRASS         = 1
000800  2               G_FOREST        = 2
000800  2               G_MOUNT         = 3
000800  2               G_WATER         = 4
000800  2               G_TOWN          = 5
000800  2               G_DUNG          = 6
000800  2               G_CASTLE        = 7
000800  2               G_ROAD          = 8
000800  2               G_BRIDGE        = 9
000800  2               G_FLOOR         = 10
000800  2               G_WALL          = 11
000800  2               G_DOOR          = 12
000800  2               G_TREAS         = 13
000800  2               G_UPSTAIR       = 14
000800  2               G_SHOP          = 15
000800  2               
000800  2               G_PLAYER        = 16
000800  2               
000800  2               ; monster glyphs
000800  2               G_ORC           = 17
000800  2               G_SNAKE         = 18
000800  2               G_SKELETON      = 19
000800  2               G_THIEF         = 20
000800  2               G_TROLL         = 21
000800  2               G_BOSS          = 22
000800  2               
000800  2               G_HILLS         = 23
000800  2               G_MARSH         = 24
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Gameplay metatile glyphs. Each world tile occupies four adjacent
000800  2               ; character cells:
000800  2               ;   base+0 base+1
000800  2               ;   base+2 base+3
000800  2               ;
000800  2               ; Terrain bases are computed as MG_TERRAIN_BASE + tile_code*4.
000800  2               ; $80..$DF stays clear of printable ASCII used by the UI.
000800  2               ; The DBASIC PATTERN implementation accepts character numbers 0..255.
000800  2               ;----------------------------------------------------------------
000800  2               MG_TERRAIN_BASE = $80
000800  2               
000800  2               MG_GRASS        = MG_TERRAIN_BASE+(T_GRASS*4)
000800  2               MG_FOREST       = MG_TERRAIN_BASE+(T_FOREST*4)
000800  2               MG_MOUNT        = MG_TERRAIN_BASE+(T_MOUNT*4)
000800  2               MG_WATER        = MG_TERRAIN_BASE+(T_WATER*4)
000800  2               MG_TOWN         = MG_TERRAIN_BASE+(T_TOWN*4)
000800  2               MG_DUNG         = MG_TERRAIN_BASE+(T_DUNG*4)
000800  2               MG_CASTLE       = MG_TERRAIN_BASE+(T_CASTLE*4)
000800  2               MG_ROAD         = MG_TERRAIN_BASE+(T_ROAD*4)
000800  2               MG_BRIDGE       = MG_TERRAIN_BASE+(T_BRIDGE*4)
000800  2               MG_FLOOR        = MG_TERRAIN_BASE+(T_FLOOR*4)
000800  2               MG_WALL         = MG_TERRAIN_BASE+(T_WALL*4)
000800  2               MG_DOOR         = MG_TERRAIN_BASE+(T_DOOR*4)
000800  2               MG_TREAS        = MG_TERRAIN_BASE+(T_TREAS*4)
000800  2               MG_UPSTAIR      = MG_TERRAIN_BASE+(T_UPSTAIR*4)
000800  2               MG_SHOP         = MG_TERRAIN_BASE+(T_SHOP*4)
000800  2               MG_HILLS        = MG_TERRAIN_BASE+(T_HILLS*4)
000800  2               MG_MARSH        = MG_TERRAIN_BASE+(T_MARSH*4)
000800  2               
000800  2               MG_PLAYER       = $C4
000800  2               MG_ORC          = $C8
000800  2               MG_SNAKE        = $CC
000800  2               MG_SKELETON     = $D0
000800  2               MG_THIEF        = $D4
000800  2               MG_TROLL        = $D8
000800  2               MG_BOSS         = $DC
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Terrain variant metatiles ($E0..$EF). A few high-traffic field
000800  2               ; terrains get a 2nd art variant so large regions don't show an
000800  2               ; obvious grid. render_view picks variant 0 (the MG_* base above)
000800  2               ; or variant 1 (these) from a position hash. Tiles without a
000800  2               ; variant entry here are left to fall through to their base.
000800  2               ;   NOTE: depends on the video card redefining glyphs >= $80; the
000800  2               ;   $E0+ range is verified on hardware at build time.
000800  2               ;----------------------------------------------------------------
000800  2               MGV_GRASS       = $E0
000800  2               MGV_FOREST      = $E4
000800  2               MGV_WATER       = $E8
000800  2               MGV_MOUNT       = $EC
000800  2               ; $F0..$F3 is the Wyrm Warden, $F4..$F7 is dragon breath,
000800  2               ; and $F8..$FF remains free.
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Monster type ids
000800  2               ;----------------------------------------------------------------
000800  2               M_NONE          = 0
000800  2               M_ORC           = 1
000800  2               M_SNAKE         = 2
000800  2               M_SKELETON      = 3
000800  2               M_THIEF         = 4
000800  2               M_TROLL         = 5
000800  2               M_BOSS          = 6
000800  2               M_WARDEN        = 7
000800  2               NUM_MTYPE       = 8
000800  2               MAXMON          = 12            ; max simultaneously active monsters
000800  2               
000800  2               ; player attack feedback flags
000800  2               ATTACK_CRITICAL = $01
000800  2               ATTACK_HIGH     = $02           ; attacking from hills
000800  2               
000800  2               ; dedicated miniboss artwork in the remaining high glyph range
000800  2               MG_WARDEN       = $F0
000800  2               MG_BREATH       = $F4
000800  2               
000800  2               ; dragon breath directions
000800  2               BREATH_NONE     = 0
000800  2               BREATH_UP       = 1
000800  2               BREATH_DOWN     = 2
000800  2               BREATH_LEFT     = 3
000800  2               BREATH_RIGHT    = 4
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Viewport geometry (left map window). Gameplay world tiles are
000800  2               ; rendered as 2x2 character-cell metatiles.
000800  2               ;   frame at col 0..VPW+1, rows 0..VPH+1  (top bar handled separately)
000800  2               ;----------------------------------------------------------------
000800  2               VPW             = 44            ; viewport interior width in screen cells
000800  2               VPH             = 20            ; viewport interior height (rows 1..20)
000800  2               VPX0            = 1             ; first interior column (screen)
000800  2               VPY0            = 1             ; first interior row (screen)
000800  2               VPTW            = VPW/2         ; viewport width in world tiles
000800  2               VPTH            = VPH/2         ; viewport height in world tiles
000800  2               VPCX            = 11            ; player world-tile column within viewport
000800  2               VPCY            = 5             ; player world-tile row within viewport
000800  2               
000800  2               ; panel geometry (right side)
000800  2               PANX            = 48            ; panel text start column
000800  2               PANW            = 31
000800  2               
000800  2               ; message log geometry (bottom two rows)
000800  2               MSGY0           = 22
000800  2               MSGROWS         = 2
000800  2               
000800  2               ; map dimensions
000800  2               OWW             = 64            ; overworld width
000800  2               OWH             = 64            ; overworld height
000800  2               TOWNW           = 32            ; town map width
000800  2               TOWNH           = 20            ; town map height
000800  2               DUNGW           = 32            ; dungeon map width
000800  2               DUNGH           = 20            ; dungeon map height
000800  2               CASTLEW         = 32            ; castle audience chamber width
000800  2               CASTLEH         = 20            ; castle audience chamber height
000800  2               SHRINEW         = 32            ; Sunken Shrine width
000800  2               SHRINEH         = 20            ; Sunken Shrine height
000800  2               
000800  2               ; world/location ids (which map is active)
000800  2               LOC_WORLD       = 0
000800  2               LOC_TOWN        = 1
000800  2               LOC_DUNG        = 2
000800  2               LOC_CASTLE      = 3
000800  2               LOC_SHRINE      = 4
000800  2               
000800  2               ; town identities and their overworld landmarks
000800  2               TOWN_EASTMERE   = 0
000800  2               TOWN_VALEHAVEN  = 1
000800  2               NUM_TOWNS       = 2
