006825  2               ;______________________________________________________________________________
006825  2               ;  castle.asm - Wyrmhold Castle interaction and opening commission
006825  2               ;______________________________________________________________________________
006825  2               
006825  2               ;----------------------------------------------------------------
006825  2               ; castle_use - contextual USE action inside the audience chamber.
006825  2               ;----------------------------------------------------------------
006825  2               castle_use:
006825  2  20 CB 68             JSR     ruler_adjacent
006828  2  B0 0B                BCS     @ruler
00682A  2  20 FB 10             JSR     sfx_blocked
00682D  2  A9 2D A0 69          PRINTMSG_MSG c_approach
006831  2  20 CA 40     
006834  2  60                   RTS
006835  2               @ruler:
006835  2  AD 91 6D             LDA     queststate
006838  2  C9 00                CMP     #QUEST_NONE
00683A  2  F0 17                BEQ     @commission
00683C  2  C9 01                CMP     #QUEST_FIND_KEY
00683E  2  F0 2A                BEQ     @reminder
006840  2  C9 02                CMP     #QUEST_HAVE_KEY
006842  2  F0 38                BEQ     @unlock
006844  2  C9 04                CMP     #QUEST_DRAGON_DEAD
006846  2  F0 67                BEQ     @finale
006848  2               ; QUEST_DUNG_OPEN while the dragon still lives
006848  2  20 EA 0F             JSR     sfx_talk
00684B  2  A9 BF A0 6A          PRINTMSG_MSG c_open
00684F  2  20 CA 40     
006852  2  60                   RTS
006853  2               @commission:
006853  2  A9 01                LDA     #QUEST_FIND_KEY
006855  2  8D 91 6D             STA     queststate
006858  2  20 73 12             JSR     sfx_levelup
00685B  2  A9 62 A0 69          PRINTMSG_MSG c_commission1
00685F  2  20 CA 40     
006862  2  A9 97 A0 69          PRINTMSG_MSG c_commission2
006866  2  20 CA 40     
006869  2  60                   RTS
00686A  2               @reminder:
