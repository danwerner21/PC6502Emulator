00134F  2               
00134F  2               ;==============================================================================
00134F  2               ;  Cooperative 3-channel title music player with hardware envelope.
00134F  2               ;
00134F  2               ;  Three independent voice tracks play simultaneously:
00134F  2               ;     channel A = lead melody   (uses the AY envelope generator so each
00134F  2               ;                                note has a soft attack/decay shape)
00134F  2               ;     channel B = counter/harmony (fixed mid volume)
00134F  2               ;     channel C = bass line       (fixed mid volume)
00134F  2               ;
00134F  2               ;  Each track is a list of events: (note, duration) byte pairs.
00134F  2               ;     note 0      = rest (silence this channel for the duration)
00134F  2               ;     note 1..47  = index into note_lo/note_hi period tables
00134F  2               ;     note $FF    = end marker -> loop the track from its start
00134F  2               ;     duration    = number of music ticks to hold (1..254)
00134F  2               ;
00134F  2               ;  music_tick is called once per title spin-loop iteration.  It paces
00134F  2               ;  itself with a short delay, then advances all three voices.
00134F  2               ;==============================================================================
00134F  2               
00134F  2               ; Tempo: each music tick waits busywait(1) plus an extra fine spin of
00134F  2               ; MUS_FINEDELAY * 256 loops.  delay=1 alone (FINE=0) was a little fast;
00134F  2               ; FINE=128 is about 1.5x slower.  Raise/lower MUS_FINEDELAY to taste.
00134F  2               MUS_TICKDELAY   = 1             ; busywait outer count per music tick
00134F  2               MUS_FINEDELAY   = 70            ; extra fine delay (0..255), tempo trim
00134F  2               
00134F  2               ; envelope shape values (reg 13)
00134F  2               ENV_DECAY       = %00000000     ; \____  single decay then off (plucky)
00134F  2               ENV_RAMP        = %00001000     ; \\\\   repeating saw (sustained pulse)
00134F  2               ENV_PERIOD      = $1800         ; 16-bit envelope period (attack/decay len)
00134F  2               MUS_VOL_B       = 8             ; harmony volume (gentle, under the lead)
00134F  2               MUS_VOL_C       = 13            ; bass volume (strong, so it is audible)
00134F  2               
00134F  2               ;----------------------------------------------------------------
00134F  2               ; music_start - reset all three voice cursors and program the AY
00134F  2               ; for music: all three tone channels enabled, envelope set up for
00134F  2               ; the lead.
00134F  2               ;----------------------------------------------------------------
00134F  2               music_start:
00134F  2               ; voice cursors -> track starts
00134F  2  A9 18 8D 98          SETW16  mvA_ptr, trackA
001353  2  6D A9 15 8D  
001357  2  99 6D        
001359  2  A9 55 8D 9B          SETW16  mvB_ptr, trackB
00135D  2  6D A9 15 8D  
001361  2  9C 6D        
001363  2  A9 68 8D 9E          SETW16  mvC_ptr, trackC
001367  2  6D A9 15 8D  
00136B  2  9F 6D        
00136D  2               ; all hold-counters = 0 so every voice fetches on the first tick.
00136D  2               ; (must load #0 fresh each time - SETW16 above left A non-zero,
00136D  2               ;  which is why B/C previously got garbage counts and went silent)
00136D  2  A9 00                LDA     #0
00136F  2  8D 9A 6D             STA     mvA_cnt
001372  2  8D 9D 6D             STA     mvB_cnt
001375  2  8D A0 6D             STA     mvC_cnt
001378  2               
001378  2               ; mixer: enable tone on A, B, C (noise off)  -> bits 0..2 clear
001378  2  A9 07                LDA     #07
00137A  2  A0 38                LDY     #%00111000
00137C  2  20 E6 0E             JSR     psgwr
00137F  2               ; envelope period (regs 11/12) - sets attack/decay length.
00137F  2               ; longer = the plucked lead note rings out for more of its
00137F  2               ; duration before fading.  Tune ENV_PERIOD to taste.
00137F  2  A9 0B                LDA     #11
001381  2  A0 00                LDY     #<ENV_PERIOD
001383  2  20 E6 0E             JSR     psgwr
001386  2  A9 0C                LDA     #12
001388  2  A0 18                LDY     #>ENV_PERIOD
00138A  2  20 E6 0E             JSR     psgwr
00138D  2               ; channel A volume register = use envelope (bit4 set)
00138D  2  A9 08                LDA     #8
00138F  2  A0 10                LDY     #%00010000
001391  2  20 E6 0E             JSR     psgwr
001394  2               ; channel B: gentle harmony pad ; channel C: strong bass
001394  2  A9 09                LDA     #9
001396  2  A0 08                LDY     #MUS_VOL_B
001398  2  20 E6 0E             JSR     psgwr
00139B  2  A9 0A                LDA     #10
00139D  2  A0 0D                LDY     #MUS_VOL_C
00139F  2  20 E6 0E             JSR     psgwr
0013A2  2  60                   RTS
0013A3  2               
0013A3  2               ;----------------------------------------------------------------
0013A3  2               ; music_tick - advance all three voices by one tick.
0013A3  2               ;----------------------------------------------------------------
0013A3  2               music_tick:
0013A3  2  A2 01                LDX     #MUS_TICKDELAY
0013A5  2  20 6C 0F             JSR     busywait
0013A8  2  20 7E 0F             JSR     mus_finewait    ; fine tempo trim
0013AB  2               
0013AB  2               ; --- voice A (lead, envelope) ---
0013AB  2  AD 9A 6D             LDA     mvA_cnt
0013AE  2  F0 06                BEQ     @nextA
0013B0  2  CE 9A 6D             DEC     mvA_cnt
0013B3  2  4C 0B 14             JMP     @doB
0013B6  2               @nextA:
0013B6  2  A9 18 85 18          SETW16  srcp, trackA    ; (loop base, used if end marker hit)
0013BA  2  A9 15 85 19  
0013BE  2  AD 98 6D             LDA     mvA_ptr
0013C1  2  85 12                STA     ptr2
0013C3  2  AD 99 6D             LDA     mvA_ptr+1
0013C6  2  85 13                STA     ptr2+1
0013C8  2  20 B4 14             JSR     mus_fetch       ; -> tmp0=note, tmp1=dur, ptr2 advanced
0013CB  2               ; program channel A tone (regs 0/1) from the note
0013CB  2  A6 20                LDX     tmp0
0013CD  2  F0 1B                BEQ     @restA          ; rest
0013CF  2  20 E0 14             JSR     note_period     ; -> ptr = period for note X
0013D2  2  A9 00                LDA     #0
0013D4  2  A4 10                LDY     ptr
0013D6  2  20 E6 0E             JSR     psgwr
0013D9  2  A9 01                LDA     #1
0013DB  2  A4 11                LDY     ptr+1
0013DD  2  20 E6 0E             JSR     psgwr
0013E0  2               ; (re)trigger the envelope by rewriting the shape register
0013E0  2  A9 0D                LDA     #13
0013E2  2  A0 00                LDY     #ENV_DECAY
0013E4  2  20 E6 0E             JSR     psgwr
0013E7  2  4C F1 13             JMP     @setA
0013EA  2               @restA:
0013EA  2               ; silence A for the rest: drop its volume to 0 (no envelope)
0013EA  2  A9 08                LDA     #8
0013EC  2  A0 00                LDY     #0
0013EE  2  20 E6 0E             JSR     psgwr
0013F1  2               @setA:
0013F1  2               ; for a non-rest, make sure A uses the envelope again
0013F1  2  A5 20                LDA     tmp0
0013F3  2  F0 07                BEQ     @cntA
0013F5  2  A9 08                LDA     #8
0013F7  2  A0 10                LDY     #%00010000
0013F9  2  20 E6 0E             JSR     psgwr
0013FC  2               @cntA:
0013FC  2  A5 21                LDA     tmp1
0013FE  2  8D 9A 6D             STA     mvA_cnt
001401  2  A5 12                LDA     ptr2
001403  2  8D 98 6D             STA     mvA_ptr
001406  2  A5 13                LDA     ptr2+1
001408  2  8D 99 6D             STA     mvA_ptr+1
00140B  2               
00140B  2               @doB:
00140B  2               ; --- voice B (harmony, fixed volume on channel B) ---
00140B  2  AD 9D 6D             LDA     mvB_cnt
00140E  2  F0 06                BEQ     @nextB
001410  2  CE 9D 6D             DEC     mvB_cnt
001413  2  4C 60 14             JMP     @doC
001416  2               @nextB:
001416  2  A9 55 85 18          SETW16  srcp, trackB
00141A  2  A9 15 85 19  
00141E  2  AD 9B 6D             LDA     mvB_ptr
001421  2  85 12                STA     ptr2
001423  2  AD 9C 6D             LDA     mvB_ptr+1
001426  2  85 13                STA     ptr2+1
001428  2  20 B4 14             JSR     mus_fetch
00142B  2  A6 20                LDX     tmp0
00142D  2  F0 1B                BEQ     @restB
00142F  2  20 E0 14             JSR     note_period
001432  2  A9 02                LDA     #2
001434  2  A4 10                LDY     ptr
001436  2  20 E6 0E             JSR     psgwr
001439  2  A9 03                LDA     #3
00143B  2  A4 11                LDY     ptr+1
00143D  2  20 E6 0E             JSR     psgwr
001440  2  A9 09                LDA     #9              ; restore B volume
001442  2  A0 08                LDY     #MUS_VOL_B
001444  2  20 E6 0E             JSR     psgwr
001447  2  4C 51 14             JMP     @cntB
00144A  2               @restB:
00144A  2  A9 09                LDA     #9
00144C  2  A0 00                LDY     #0
00144E  2  20 E6 0E             JSR     psgwr
001451  2               @cntB:
001451  2  A5 21                LDA     tmp1
001453  2  8D 9D 6D             STA     mvB_cnt
001456  2  A5 12                LDA     ptr2
001458  2  8D 9B 6D             STA     mvB_ptr
00145B  2  A5 13                LDA     ptr2+1
00145D  2  8D 9C 6D             STA     mvB_ptr+1
001460  2               
001460  2               @doC:
001460  2               ; --- voice C (bass, fixed volume on channel C) ---
001460  2  AD A0 6D             LDA     mvC_cnt
001463  2  F0 04                BEQ     @nextC
001465  2  CE A0 6D             DEC     mvC_cnt
001468  2  60                   RTS
001469  2               @nextC:
001469  2  A9 68 85 18          SETW16  srcp, trackC
00146D  2  A9 15 85 19  
001471  2  AD 9E 6D             LDA     mvC_ptr
001474  2  85 12                STA     ptr2
001476  2  AD 9F 6D             LDA     mvC_ptr+1
001479  2  85 13                STA     ptr2+1
00147B  2  20 B4 14             JSR     mus_fetch
00147E  2  A6 20                LDX     tmp0
001480  2  F0 1B                BEQ     @restC
001482  2  20 E0 14             JSR     note_period
001485  2  A9 04                LDA     #4
001487  2  A4 10                LDY     ptr
001489  2  20 E6 0E             JSR     psgwr
00148C  2  A9 05                LDA     #5
00148E  2  A4 11                LDY     ptr+1
001490  2  20 E6 0E             JSR     psgwr
001493  2  A9 0A                LDA     #10             ; restore C volume
001495  2  A0 0D                LDY     #MUS_VOL_C
001497  2  20 E6 0E             JSR     psgwr
00149A  2  4C A4 14             JMP     @cntC
00149D  2               @restC:
00149D  2  A9 0A                LDA     #10
00149F  2  A0 00                LDY     #0
0014A1  2  20 E6 0E             JSR     psgwr
0014A4  2               @cntC:
0014A4  2  A5 21                LDA     tmp1
0014A6  2  8D A0 6D             STA     mvC_cnt
0014A9  2  A5 12                LDA     ptr2
0014AB  2  8D 9E 6D             STA     mvC_ptr
0014AE  2  A5 13                LDA     ptr2+1
0014B0  2  8D 9F 6D             STA     mvC_ptr+1
0014B3  2  60                   RTS
0014B4  2               
0014B4  2               ;----------------------------------------------------------------
0014B4  2               ; mus_fetch - read one (note,dur) event from the track at ptr2.
0014B4  2               ;   IN : ptr2 -> current event ; srcp -> track loop base
0014B4  2               ;   OUT: tmp0 = note, tmp1 = duration, ptr2 advanced past the event.
0014B4  2               ;        On an $FF end marker, ptr2 is reset to srcp and the first
0014B4  2               ;        event of the track is returned.
0014B4  2               ;----------------------------------------------------------------
0014B4  2               mus_fetch:
0014B4  2  A0 00                LDY     #0
0014B6  2  B1 12                LDA     (ptr2),Y
0014B8  2  C9 FF                CMP     #$FF
0014BA  2  D0 0C                BNE     @ok
0014BC  2               ; loop: reset ptr2 to track base (srcp)
0014BC  2  A5 18                LDA     srcp
0014BE  2  85 12                STA     ptr2
0014C0  2  A5 19                LDA     srcp+1
0014C2  2  85 13                STA     ptr2+1
0014C4  2  A0 00                LDY     #0
0014C6  2  B1 12                LDA     (ptr2),Y
0014C8  2               @ok:
0014C8  2  85 20                STA     tmp0            ; note
0014CA  2  C8                   INY
0014CB  2  B1 12                LDA     (ptr2),Y
0014CD  2               ; The voice loops "fetch when counter hits 0", and the fetch
0014CD  2               ; tick itself is the first tick of the note.  So a note must
0014CD  2               ; hold for (dur-1) MORE ticks after the fetch tick to last
0014CD  2               ; exactly dur ticks.  Subtract 1 here.  (All durations are >=2,
0014CD  2               ; so no underflow.)  This keeps voices with different note
0014CD  2               ; counts the same real length - otherwise B/C drift away from
0014CD  2               ; the lead because they have fewer/more notes per loop.
0014CD  2  38                   SEC
0014CE  2  E9 01                SBC     #1
0014D0  2  85 21                STA     tmp1            ; duration - 1
0014D2  2               ; advance ptr2 by 2
0014D2  2  18                   CLC
0014D3  2  A5 12                LDA     ptr2
0014D5  2  69 02                ADC     #2
0014D7  2  85 12                STA     ptr2
0014D9  2  A5 13                LDA     ptr2+1
0014DB  2  69 00                ADC     #0
0014DD  2  85 13                STA     ptr2+1
0014DF  2  60                   RTS
0014E0  2               
0014E0  2               ;----------------------------------------------------------------
0014E0  2               ; note_period - look up the 16-bit AY tone period for note X (1..N)
0014E0  2               ;   OUT: ptr = period (lo/hi).  Note index is 1-based.
0014E0  2               ;----------------------------------------------------------------
0014E0  2               note_period:
0014E0  2  CA                   DEX                     ; tables are 0-based
0014E1  2  BD EC 14             LDA     note_lo,X
0014E4  2  85 10                STA     ptr
0014E6  2  BD 02 15             LDA     note_hi,X
0014E9  2  85 11                STA     ptr+1
0014EB  2  60                   RTS
0014EC  2               
0014EC  2               ;----------------------------------------------------------------
0014EC  2               ; Note period tables (16-bit AY tone periods), two+ octaves.
0014EC  2               ; Note numbers (1-based) used by the tracks:
0014EC  2               ;   1=C3  2=D3 3=E3 4=F3 5=G3 6=A3 7=B3
0014EC  2               ;   8=C4  9=D4 10=E4 11=F4 12=G4 13=A4 14=B4
0014EC  2               ;  15=C5 16=D5 17=E5 18=F5 19=G5 20=A5 21=B5
0014EC  2               ;  22=C6
0014EC  2               ; (a diatonic C-major set is plenty for a heroic theme)
0014EC  2               ;----------------------------------------------------------------
0014EC  2               note_lo:
0014EC  2  F0 82 20 F4          .BYTE   <1008, <898, <800, <756, <672, <600, <534; C3..B3
0014F0  2  A0 58 16     
0014F3  2  F8 C2 90 7A          .BYTE   <504,  <450, <400, <378, <336, <300, <267; C4..B4
0014F7  2  50 2C 0B     
0014FA  2  FC E1 C8 BD          .BYTE   <252,  <225, <200, <189, <168, <150, <133; C5..B5
0014FE  2  A8 96 85     
001501  2  7E                   .BYTE   <126            ; C6
001502  2               note_hi:
001502  2  03 03 03 02          .BYTE   >1008, >898, >800, >756, >672, >600, >534
001506  2  02 02 02     
001509  2  01 01 01 01          .BYTE   >504,  >450, >400, >378, >336, >300, >267
00150D  2  01 01 01     
001510  2  00 00 00 00          .BYTE   >252,  >225, >200, >189, >168, >150, >133
001514  2  00 00 00     
001517  2  00                   .BYTE   >126
001518  2               
001518  2               ; note name -> index defines for readable tracks
001518  2               N_REST          = 0
001518  2               C3              = 1
001518  2               D3              = 2
001518  2               E3              = 3
001518  2               F3              = 4
001518  2               G3              = 5
001518  2               A3              = 6
001518  2               B3              = 7
001518  2               C4              = 8
001518  2               D4              = 9
001518  2               E4              = 10
001518  2               F4              = 11
001518  2               G4              = 12
001518  2               A4              = 13
001518  2               B4              = 14
001518  2               C5              = 15
001518  2               D5              = 16
001518  2               E5              = 17
001518  2               F5              = 18
001518  2               G5              = 19
001518  2               A5              = 20
001518  2               B5              = 21
001518  2               C6              = 22
001518  2               
001518  2               ;----------------------------------------------------------------
001518  2               ; The theme: a stately heroic tune in C major, 3 voices.
001518  2               ; Durations are in ticks; the three tracks are written so their
001518  2               ; total lengths line up over each phrase.
001518  2               ;----------------------------------------------------------------
001518  2               
001518  2               ; --- Channel A : lead melody ---
001518  2               ; Every phrase line totals 16 ticks so the lead stays locked in step
001518  2               ; with the 16-tick harmony (B) and bass (C) lines.  (Line 1 was 20
001518  2               ; ticks before, which drifted B/C out of phase each loop.)
001518  2               trackA:
001518  2  0C 04 0F 04          .BYTE   G4,4,  C5,4,  E5,4,  G5,2,  E5,2; 16
00151C  2  11 04 13 02  
001520  2  11 02        
001522  2  12 04 11 04          .BYTE   F5,4,  E5,4,  D5,8; 16
001526  2  10 08        
001528  2  11 04 13 04          .BYTE   E5,4,  G5,4,  C6,6,  B5,2; 16
00152C  2  16 06 15 02  
001530  2  14 04 13 04          .BYTE   A5,4,  G5,4,  E5,8; 16
001534  2  11 08        
001536  2  12 04 14 04          .BYTE   F5,4,  A5,4,  G5,4,  E5,4; 16
00153A  2  13 04 11 04  
00153E  2  10 04 12 04          .BYTE   D5,4,  F5,4,  E5,8; 16
001542  2  11 08        
001544  2  0F 04 11 04          .BYTE   C5,4,  E5,4,  G5,4,  C6,4; 16
001548  2  13 04 16 04  
00154C  2  13 04 11 04          .BYTE   G5,4,  E5,4,  C5,8; 16
001550  2  0F 08        
001552  2  00 04                .BYTE   N_REST,4
001554  2  FF                   .BYTE   $FF
001555  2               
001555  2               ; --- Channel B : sustained harmony, one note per phrase line.
001555  2               ;     To stay consonant under a diatonic melody we use the FIFTH of
001555  2               ;     each chord (perfect fifths never clash), in octave 4.
001555  2               ;     Chords per line:  C  G  C  Am  F  G  C  C
001555  2               ;     Fifths:           G  D  G  E   C  D  G  G
001555  2               trackB:
001555  2  0C 10                .BYTE   G4,16           ; C chord  (5th = G)
001557  2  09 10                .BYTE   D4,16           ; G chord  (5th = D)
001559  2  0C 10                .BYTE   G4,16           ; C chord
00155B  2  0A 10                .BYTE   E4,16           ; Am chord (5th = E)
00155D  2  08 10                .BYTE   C4,16           ; F chord  (5th = C)
00155F  2  09 10                .BYTE   D4,16           ; G chord
001561  2  0C 10                .BYTE   G4,16           ; C chord
001563  2  0C 10                .BYTE   G4,16           ; C chord
001565  2  00 04                .BYTE   N_REST,4
001567  2  FF                   .BYTE   $FF
001568  2               
001568  2               ; --- Channel C : bass - the ROOT of each chord, re-struck halfway
001568  2               ;     for a gentle pulse.  Same progression: C G C Am F G C C
001568  2               trackC:
001568  2  01 08 01 08          .BYTE   C3,8,  C3,8     ; C
00156C  2  05 08 05 08          .BYTE   G3,8,  G3,8     ; G
001570  2  01 08 01 08          .BYTE   C3,8,  C3,8     ; C
001574  2  06 08 06 08          .BYTE   A3,8,  A3,8     ; Am
001578  2  04 08 04 08          .BYTE   F3,8,  F3,8     ; F
00157C  2  05 08 05 08          .BYTE   G3,8,  G3,8     ; G
001580  2  01 08 01 08          .BYTE   C3,8,  C3,8     ; C
001584  2  01 08 01 08          .BYTE   C3,8,  C3,8     ; C
001588  2  00 04                .BYTE   N_REST,4
00158A  2  FF                   .BYTE   $FF
00158B  2               
00158B  1                       .INCLUDE "tiles.asm"
00158B  2               ;______________________________________________________________________________
00158B  2               ;  tiles.asm - custom 8x8 character bitmaps for terrain, items, monsters
00158B  2               ;
00158B  2               ;  The memory-mapped video card has a writable character generator.
00158B  2               ;  To redefine character N (see V_PATTERN in dbasic/screencmds.asm):
00158B  2               ;     1. map video sub-page $F8 (VIDEOBANK) into CPU bank $A
00158B  2               ;     2. write N to VideoCharGenOffset ($A002)
00158B  2               ;     3. write 8 scanline bytes to VideoCharGenData ($A003)
00158B  2               ;        (the hardware auto-advances through the 8 rows of the glyph)
00158B  2               ;
00158B  2               ;  Each bitmap is authored as 8 bytes, top row first, with bit7 as
00158B  2               ;  the leftmost pixel. The video character generator displays bit0
00158B  2               ;  on the left, so chargen_init reverses each scanline before upload.
00158B  2               ;  Small title glyphs use control codes 1..31. Gameplay metatiles
00158B  2               ;  use $80..$DF. Printable ASCII used by the UI remains intact.
00158B  2               ;______________________________________________________________________________
00158B  2               
00158B  2               VideoCharGenOffset = $A002
00158B  2               VideoCharGenData = $A003
00158B  2               
00158B  2               ;----------------------------------------------------------------
00158B  2               ; cg_enter / cg_exit - map the character-generator RAM (page $F8)
00158B  2               ; into bank $A and select task 1 (mirrors PAGE_ENTER/PAGE_EXIT).
00158B  2               ;----------------------------------------------------------------
00158B  2               cg_enter:
00158B  2  A9 01                LDA     #$01            ; task 01 (driver)
00158D  2  A2 0A                LDX     #$0A            ; CPU bank $A
00158F  2  A0 F8                LDY     #VIDEOBANK      ; physical page $F8 (char generator)
001591  2  20 F6 FF             JSR     SETPAGE
001594  2  A9 01                LDA     #$01
001596  2  8D E0 EF             STA     PC6502_ACT_TASK
001599  2  60                   RTS
00159A  2               cg_exit:
00159A  2  A9 00                LDA     #$00
00159C  2  8D E0 EF             STA     PC6502_ACT_TASK
00159F  2  60                   RTS
0015A0  2               
0015A0  2               ;----------------------------------------------------------------
0015A0  2               ; reverse_glyph_byte - convert authored bit7-left rows to the
0015A0  2               ; character generator's bit0-left display order.
0015A0  2               ;   IN/OUT: A = scanline byte
0015A0  2               ;   trashes X,tmp0; preserves Y
0015A0  2               ;----------------------------------------------------------------
0015A0  2               reverse_glyph_byte:
0015A0  2  85 20                STA     tmp0
0015A2  2  A9 00                LDA     #0
0015A4  2  A2 08                LDX     #8
0015A6  2               @bit:
0015A6  2  46 20                LSR     tmp0
0015A8  2  2A                   ROL     A
0015A9  2  CA                   DEX
0015AA  2  D0 FA                BNE     @bit
0015AC  2  60                   RTS
0015AD  2               
0015AD  2               ;----------------------------------------------------------------
0015AD  2               ; chargen_init - upload every custom glyph bitmap.
0015AD  2               ;
0015AD  2               ; Driven by a table of (charcode, 8 bytes) records.  The table ends
0015AD  2               ; with a $00 charcode marker (code 0 is never one of ours).
0015AD  2               ;----------------------------------------------------------------
0015AD  2               chargen_init:
0015AD  2  20 8B 15             JSR     cg_enter
0015B0  2  A9 E3 85 18          SETW16  srcp, glyphtab
0015B4  2  A9 15 85 19  
0015B8  2               @rec:
0015B8  2  A0 00                LDY     #0
0015BA  2  B1 18                LDA     (srcp),Y        ; char code
0015BC  2  F0 22                BEQ     @done           ; 0 = end of table
0015BE  2  8D 02 A0             STA     VideoCharGenOffset
0015C1  2               ; write the 8 scanline bytes
0015C1  2  A0 01                LDY     #1
0015C3  2               @row:
0015C3  2  B1 18                LDA     (srcp),Y
0015C5  2  20 A0 15             JSR     reverse_glyph_byte
0015C8  2  8D 03 A0             STA     VideoCharGenData
0015CB  2  C8                   INY
0015CC  2  C0 09                CPY     #9
0015CE  2  D0 F3                BNE     @row
0015D0  2               ; advance srcp by 9 (1 code + 8 data)
0015D0  2  18                   CLC
0015D1  2  A5 18                LDA     srcp
0015D3  2  69 09                ADC     #9
0015D5  2  85 18                STA     srcp
0015D7  2  A5 19                LDA     srcp+1
0015D9  2  69 00                ADC     #0
0015DB  2  85 19                STA     srcp+1
0015DD  2  4C B8 15             JMP     @rec
0015E0  2               @done:
0015E0  2  4C 9A 15             JMP     cg_exit
0015E3  2               
0015E3  2               ;----------------------------------------------------------------
0015E3  2               ; Glyph bitmap table: each row is  code, b0..b7
0015E3  2               ;----------------------------------------------------------------
0015E3  2               glyphtab:
0015E3  2               
0015E3  2               ; --- terrain ---------------------------------------------------
0015E3  2               ; Terrain uses colored backgrounds and brighter foreground texture.
0015E3  2               ; Adjoining cells therefore read as continuous landscape.
0015E3  2               
0015E3  2               ; grass: sparse blades over a green field
0015E3  2  01                   .BYTE   G_GRASS
0015E4  2  00                   .BYTE   %00000000
0015E5  2  10                   .BYTE   %00010000
0015E6  2  02                   .BYTE   %00000010
0015E7  2  40                   .BYTE   %01000000
