000800  2               space           = 32
000800  2               ESC             = 27
000800  2               CR              = 13
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Zero-page allocation.  $00-$31 are largely free for the TEA;
000800  2               ; $32 (farfunct) is reserved by the system.  We use a contiguous
000800  2               ; block below it and a high block ($F0-$FE scratch pointers) the
000800  2               ; same way speedscript does.
000800  2               ;----------------------------------------------------------------
000800  2               ; 16-bit scratch pointers
000800  2               ptr             = $10           ; general pointer (2)
000800  2               ptr2            = $12           ; general pointer (2)
000800  2               vptr            = $14           ; video text pointer (2)
000800  2               cptr            = $16           ; video color pointer (2)
000800  2               srcp            = $18           ; source pointer (2)
000800  2               dstp            = $1A           ; dest pointer (2)
000800  2               strp            = $1C           ; string pointer for prmsg (2)
000800  2               numarg          = $1E           ; 16-bit number for displaynum (2)
000800  2               
000800  2               ; 8-bit scratch
000800  2               tmp0            = $20
000800  2               tmp1            = $21
000800  2               tmp2            = $22
000800  2               tmp3            = $23
000800  2               cnt0            = $24
000800  2               cnt1            = $25
000800  2               colidx          = $26           ; saved column index
000800  2               rowidx          = $27           ; saved row index
000800  2               numspace        = $28           ; displaynum digit accumulator
000800  2               keych           = $29           ; last key read
000800  2               dx              = $2A           ; signed move delta x
000800  2               dy              = $2B           ; signed move delta y
000800  2               tgtx            = $2C           ; target tile x
000800  2               tgty            = $2D           ; target tile y
000800  2               tgttile         = $2E           ; tile code at target
000800  2               monidx          = $2F           ; current monster index
000800  2               seedlo          = $30           ; RNG state low
000800  2               seedhi          = $31           ; RNG state high
000800  2               ; $32 = farfunct (system)
000800  2               seed2lo         = $33           ; title timing counter low
000800  2               seed2hi         = $34           ; title timing counter high
000800  2               
000800  2               ;----------------------------------------------------------------
000800  2               ; Game state (in TEA RAM, defined as labels in wyrmhold.asm BSS area)
000800  2               ; declared here as equates is not possible; real storage is in the
000800  2               ; .SEGMENT "TEA" at the end of wyrmhold.asm.  See gamevars there.
000800  2               ;----------------------------------------------------------------
000800  2               
000800  1               
000800  1               ;==============================================================================
000800  1               ; Entry point
000800  1               ;==============================================================================
000800  1               BEGIN:
000800  1  D8                   CLD
000801  1  20 A1 0E             JSR     psg_init
000804  1  20 2F 0E             JSR     rng_seed
000807  1               ; All direct-VRAM rendering below assumes 80-byte screen rows.
000807  1               ; Establish that mode before uploading glyphs or drawing anything.
000807  1  A9 39                LDA     #FC_SETMODE
000809  1  85 32                STA     farfunct
00080B  1  A9 01                LDA     #1              ; 80-column text mode
00080D  1  20 F0 FF             JSR     DO_FARCALL
000810  1  20 AD 15             JSR     chargen_init    ; upload custom terrain/monster tiles
000813  1               ; hide the firmware text cursor; we draw our own world
000813  1  A9 00                LDA     #0
000815  1  8D 49 06             STA     SHOWCRSR
000818  1               title_loop_outer:
000818  1  20 24 08             JSR     title_screen    ; returns when a key is pressed
00081B  1  20 51 08             JSR     new_game
00081E  1  20 77 08             JSR     game_loop       ; returns on death / victory / quit
000821  1               ; game_loop decides what to do; if it returns we go to DOS
000821  1  4C C2 0A             JMP     exit_to_dos
000824  1               
000824  1               ;==============================================================================
000824  1               ; Title screen - draws a banner, plays the melody, waits for a key.
000824  1               ;==============================================================================
000824  1               title_screen:
000824  1  20 F4 1A             JSR     draw_title_scene; full graphical title (title.asm)
000827  1               
000827  1               ; Settle period: for the first stretch of the title we PLAY the
000827  1               ; music but ignore (and keep draining) any keys.  This swallows
000827  1               ; the Enter typed to launch the program - on re-runs that key is
000827  1               ; sometimes delivered just after we start, and without this it
000827  1               ; would dismiss the title instantly (the "no intro on 2nd run"
000827  1               ; bug).
000827  1  20 4F 13             JSR     music_start
00082A  1  A2 28                LDX     #40             ; settle ticks
00082C  1               @settle:
00082C  1  DA                   PHX
00082D  1  20 A3 13             JSR     music_tick
000830  1  20 3E 0E             JSR     rng_timing_tick
000833  1  20 E2 44             JSR     getkey          ; read & discard whatever shows up
000836  1  FA                   PLX
000837  1  CA                   DEX
000838  1  D0 F2                BNE     @settle
00083A  1  20 F0 44             JSR     drainkeys       ; clear anything still buffered
00083D  1               @spin:
00083D  1  20 A3 13             JSR     music_tick
000840  1  20 3E 0E             JSR     rng_timing_tick
000843  1  20 E2 44             JSR     getkey
000846  1  F0 F5                BEQ     @spin
000848  1  85 29                STA     keych
00084A  1  20 45 0E             JSR     rng_mix_timing
00084D  1  20 C9 0E             JSR     psg_silence
000850  1  60                   RTS
000851  1               
000851  1               ;==============================================================================
000851  1               ; new_game - initialise all game state and draw the initial screen.
000851  1               ;==============================================================================
000851  1               new_game:
000851  1  20 F3 4D             JSR     player_init
000854  1  20 36 1E             JSR     decode_world
000857  1  A9 00                LDA     #LOC_WORLD
000859  1  8D 89 6D             STA     loc
00085C  1  20 66 49             JSR     spawn_overworld_monsters
00085F  1  20 FA 3D             JSR     draw_frame
000862  1  20 29 41             JSR     msg_clear
000865  1  A9 36 A0 0C          PRINTMSG_MSG intro_msg
000869  1  20 CA 40     
00086C  1  20 70 08             JSR     full_redraw
00086F  1  60                   RTS
000870  1               
000870  1               ;==============================================================================
000870  1               ; full_redraw - viewport + panel.
000870  1               ;==============================================================================
000870  1               full_redraw:
000870  1  20 DD 3E             JSR     render_view
000873  1  20 3B 41             JSR     draw_panel
000876  1  60                   RTS
000877  1               
000877  1               ;==============================================================================
000877  1               ; game_loop - the main turn loop.
000877  1               ;==============================================================================
000877  1               game_loop:
000877  1               @loop:
000877  1               ; check end conditions first
000877  1  AD 90 6D             LDA     bosskilled
00087A  1  F0 03                BEQ     @alive
00087C  1  4C D9 09             JMP     victory
00087F  1               @alive:
00087F  1  AD 7D 6D             LDA     phealth
000882  1  D0 03                BNE     @hasfood
000884  1  4C 59 0A             JMP     game_over_hp
000887  1               @hasfood:
000887  1  AD 84 6D             LDA     pfood
00088A  1  0D 85 6D             ORA     pfood+1
00088D  1  D0 03                BNE     @input
00088F  1  4C 60 0A             JMP     game_over_food
000892  1               
000892  1               @input:
000892  1  20 E2 44             JSR     getkey
000895  1  F0 E0                BEQ     @loop           ; no key - idle (no time passes)
000897  1  85 29                STA     keych
000899  1               
000899  1               ; movement keys -> set dx,dy then try_move
000899  1  A9 00                LDA     #0
00089B  1  85 2A                STA     dx
00089D  1  85 2B                STA     dy
00089F  1               
00089F  1  A5 29                LDA     keych
0008A1  1  C9 77                CMP     #'w'
0008A3  1  D0 03                BNE     :+
0008A5  1  4C 41 09             JMP     @up
0008A8  1               :
0008A8  1  C9 57                CMP     #'W'
0008AA  1  D0 03                BNE     :+
0008AC  1  4C 41 09             JMP     @up
0008AF  1               :
0008AF  1  C9 6B                CMP     #'k'
0008B1  1  D0 03                BNE     :+
0008B3  1  4C 41 09             JMP     @up
0008B6  1               :
0008B6  1  C9 73                CMP     #'s'
0008B8  1  D0 03                BNE     :+
0008BA  1  4C 48 09             JMP     @down
0008BD  1               :
0008BD  1  C9 53                CMP     #'S'
0008BF  1  D0 03                BNE     :+
0008C1  1  4C 48 09             JMP     @down
0008C4  1               :
0008C4  1  C9 6A                CMP     #'j'
0008C6  1  D0 03                BNE     :+
0008C8  1  4C 48 09             JMP     @down
0008CB  1               :
0008CB  1  C9 61                CMP     #'a'
0008CD  1  D0 03                BNE     :+
0008CF  1  4C 4F 09             JMP     @left
0008D2  1               :
0008D2  1  C9 41                CMP     #'A'
0008D4  1  D0 03                BNE     :+
0008D6  1  4C 4F 09             JMP     @left
0008D9  1               :
0008D9  1  C9 68                CMP     #'h'
0008DB  1  D0 03                BNE     :+
0008DD  1  4C 4F 09             JMP     @left
0008E0  1               :
0008E0  1  C9 64                CMP     #'d'
0008E2  1  D0 03                BNE     :+
0008E4  1  4C 56 09             JMP     @right
0008E7  1               :
0008E7  1  C9 44                CMP     #'D'
0008E9  1  D0 03                BNE     :+
0008EB  1  4C 56 09             JMP     @right
0008EE  1               :
0008EE  1  C9 6C                CMP     #'l'
0008F0  1  D0 03                BNE     :+
0008F2  1  4C 56 09             JMP     @right
0008F5  1               :
0008F5  1               
0008F5  1  C9 67                CMP     #'g'
0008F7  1  D0 03                BNE     :+
0008F9  1  4C 60 09             JMP     @guard
0008FC  1               :
0008FC  1  C9 47                CMP     #'G'
0008FE  1  D0 03                BNE     :+
000900  1  4C 60 09             JMP     @guard
000903  1               :
000903  1  C9 74                CMP     #'t'
000905  1  D0 03                BNE     :+
000907  1  4C 8E 09             JMP     @use
00090A  1               :
00090A  1  C9 54                CMP     #'T'
00090C  1  D0 03                BNE     :+
00090E  1  4C 8E 09             JMP     @use
000911  1               :
000911  1  C9 70                CMP     #'p'
000913  1  D0 03                BNE     :+
000915  1  4C 75 09             JMP     @potion
000918  1               :
000918  1  C9 50                CMP     #'P'
00091A  1  D0 03                BNE     :+
00091C  1  4C 75 09             JMP     @potion
00091F  1               :
00091F  1  C9 3F                CMP     #'?'
000921  1  D0 03                BNE     :+
000923  1  4C A7 09             JMP     @help
000926  1               :
000926  1  C9 71                CMP     #'q'
000928  1  D0 03                BNE     :+
00092A  1  4C B6 09             JMP     @quit
00092D  1               :
00092D  1  C9 51                CMP     #'Q'
00092F  1  D0 03                BNE     :+
000931  1  4C B6 09             JMP     @quit
000934  1               :
000934  1  20 FB 10             JSR     sfx_blocked
000937  1  A9 9D A0 0C          PRINTMSG_MSG bad_key
00093B  1  20 CA 40     
00093E  1  4C 77 08             JMP     @loop           ; unknown key
000941  1               
000941  1               @up:
000941  1  A9 FF                LDA     #$FF            ; dy = -1
000943  1  85 2B                STA     dy
000945  1  4C 5A 09             JMP     @domove
000948  1               @down:
000948  1  A9 01                LDA     #1
00094A  1  85 2B                STA     dy
00094C  1  4C 5A 09             JMP     @domove
00094F  1               @left:
00094F  1  A9 FF                LDA     #$FF
000951  1  85 2A                STA     dx
000953  1  4C 5A 09             JMP     @domove
000956  1               @right:
000956  1  A9 01                LDA     #1
000958  1  85 2A                STA     dx
00095A  1               @domove:
00095A  1  20 58 4E             JSR     try_move
00095D  1  4C 78 09             JMP     @doturn
000960  1               @guard:
000960  1  A9 01                LDA     #1
000962  1  8D 95 6D             STA     guard_active
000965  1  8D 97 6D             STA     did_move
000968  1  20 A2 0F             JSR     sfx_guard
00096B  1  A9 DE A0 5B          PRINTMSG_MSG m_guard
00096F  1  20 CA 40     
000972  1  4C 78 09             JMP     @doturn
000975  1               @potion:
000975  1  20 D3 50             JSR     drink_potion
000978  1               @doturn:
000978  1               ; if a turn was consumed, monsters and status effects act
000978  1  AD 97 6D             LDA     did_move
00097B  1  F0 06                BEQ     @after
00097D  1  20 D9 4A             JSR     mon_act
000980  1  20 E5 56             JSR     process_status
000983  1               @after:
000983  1  A9 00                LDA     #0
000985  1  8D 95 6D             STA     guard_active
000988  1  20 70 08             JSR     full_redraw
00098B  1  4C 77 08             JMP     @loop
00098E  1               
00098E  1               @use:
00098E  1  A9 00                LDA     #0
000990  1  8D 97 6D             STA     did_move
000993  1  20 D4 5D             JSR     use_action
000996  1  AD 97 6D             LDA     did_move
000999  1  F0 06                BEQ     @use_redraw
00099B  1  20 D9 4A             JSR     mon_act
00099E  1  20 E5 56             JSR     process_status
0009A1  1               @use_redraw:
0009A1  1  20 70 08             JSR     full_redraw
0009A4  1  4C 77 08             JMP     @loop
0009A7  1               
0009A7  1               @help:
0009A7  1  20 EA 0F             JSR     sfx_talk
0009AA  1  20 A7 43             JSR     help_menu
0009AD  1  20 70 08             JSR     full_redraw
0009B0  1  20 F9 40             JSR     msg_redraw
0009B3  1  4C 77 08             JMP     @loop
0009B6  1               
0009B6  1               @quit:
0009B6  1  20 C6 09             JSR     confirm_quit
0009B9  1  F0 0A                BEQ     @doquit         ; Z=1 means Yes
0009BB  1  A9 88 A0 0C          PRINTMSG_MSG q_stay
0009BF  1  20 CA 40     
0009C2  1  4C 77 08             JMP     @loop
0009C5  1               @doquit:
0009C5  1  60                   RTS
0009C6  1               
0009C6  1               ;==============================================================================
0009C6  1               ; confirm_quit - ask Y/N. Returns Z=1 if quitting.
0009C6  1               ;==============================================================================
0009C6  1               confirm_quit:
0009C6  1  20 29 41             JSR     msg_clear
0009C9  1  A9 75 A0 0C          PRINTMSG_MSG q_quit
0009CD  1  20 CA 40     
0009D0  1  20 B0 44             JSR     yorn            ; Z=1 if yes
0009D3  1  08                   PHP
0009D4  1  20 29 41             JSR     msg_clear
0009D7  1  28                   PLP
0009D8  1  60                   RTS
0009D9  1               
0009D9  1               ;==============================================================================
0009D9  1               ; End-game screens
0009D9  1               ;==============================================================================
0009D9  1               victory:
0009D9  1  20 BE 3D             JSR     cls_vram
0009DC  1  A2 20                LDX     #32
0009DE  1  A0 06                LDY     #6
0009E0  1  20 90 3E             JSR     locate
0009E3  1  A9 0E                LDA     #C_TITLE
0009E5  1  8D 4A 06             STA     CURCOLOR
0009E8  1  A9 AF A0 0C          PRINTMSG win1
0009EC  1  20 A2 3E     
0009EF  1  A2 10                LDX     #16
0009F1  1  A0 09                LDY     #9
0009F3  1  20 90 3E             JSR     locate
0009F6  1  A9 0F                LDA     #C_PANEL
0009F8  1  8D 4A 06             STA     CURCOLOR
0009FB  1  A9 C0 A0 0C          PRINTMSG win2
0009FF  1  20 A2 3E     
000A02  1  A2 13                LDX     #19
000A04  1  A0 0B                LDY     #11
000A06  1  20 90 3E             JSR     locate
000A09  1  A9 ED A0 0C          PRINTMSG win3
000A0D  1  20 A2 3E     
000A10  1  A2 0D                LDX     #13
000A12  1  A0 0D                LDY     #13
000A14  1  20 90 3E             JSR     locate
000A17  1  A9 16 A0 0D          PRINTMSG win4
000A1B  1  20 A2 3E     
000A1E  1  A2 18                LDX     #24
000A20  1  A0 10                LDY     #16
000A22  1  20 90 3E             JSR     locate
000A25  1  A9 0B                LDA     #COLOR(CO_BRTURQ, CO_BLACK)
000A27  1  8D 4A 06             STA     CURCOLOR
000A2A  1  A9 4B A0 0D          PRINTMSG win_credit1
000A2E  1  20 A2 3E     
000A31  1  A2 1B                LDX     #27
000A33  1  A0 11                LDY     #17
000A35  1  20 90 3E             JSR     locate
000A38  1  A9 68 A0 0D          PRINTMSG win_credit2
000A3C  1  20 A2 3E     
000A3F  1  A2 20                LDX     #32
000A41  1  A0 14                LDY     #20
000A43  1  20 90 3E             JSR     locate
000A46  1  A9 0F                LDA     #C_PANEL
000A48  1  8D 4A 06             STA     CURCOLOR
000A4B  1  A9 1E A0 0E          PRINTMSG anykey
000A4F  1  20 A2 3E     
000A52  1  20 08 13             JSR     sfx_win
000A55  1  20 D6 44             JSR     getkey_block
000A58  1  60                   RTS
000A59  1               
000A59  1               game_over_hp:
000A59  1  A9 E3                LDA     #<go_hp
000A5B  1  A0 0D                LDY     #>go_hp
000A5D  1  4C 64 0A             JMP     game_over_common
000A60  1               game_over_food:
000A60  1  A9 FE                LDA     #<go_food
000A62  1  A0 0D                LDY     #>go_food
000A64  1               ; fall through
000A64  1               game_over_common:
000A64  1               ; stash the cause-string pointer somewhere that survives both
000A64  1               ; cls_vram and prmsg. NOT strp (prmsg uses it as scratch) and NOT
000A64  1               ; tmp0 (rowbase, called by cls_vram, clobbers it) - parking it in
000A64  1               ; either reprinted the "THOU HAST FALLEN" banner a second time
000A64  1               ; instead of the cause line. numarg is untouched on this path.
000A64  1  85 1E                STA     numarg
000A66  1  84 1F                STY     numarg+1
000A68  1  20 BE 3D             JSR     cls_vram
000A6B  1  A2 1B                LDX     #27
000A6D  1  A0 06                LDY     #6
000A6F  1  20 90 3E             JSR     locate
000A72  1  A9 0C                LDA     #COLOR(CO_BRRED, CO_BLACK)
000A74  1  8D 4A 06             STA     CURCOLOR
000A77  1  A9 85 A0 0D          PRINTMSG over1
000A7B  1  20 A2 3E     
000A7E  1  A2 10                LDX     #16
000A80  1  A0 09                LDY     #9
000A82  1  20 90 3E             JSR     locate
000A85  1  A9 0F                LDA     #C_PANEL
000A87  1  8D 4A 06             STA     CURCOLOR
000A8A  1  A5 1E                LDA     numarg
000A8C  1  A4 1F                LDY     numarg+1
000A8E  1  20 A2 3E             JSR     prmsg
000A91  1  A2 15                LDX     #21
000A93  1  A0 0C                LDY     #12
000A95  1  20 90 3E             JSR     locate
000A98  1  A9 9E A0 0D          PRINTMSG over2
000A9C  1  20 A2 3E     
000A9F  1  A2 17                LDX     #23
000AA1  1  A0 0E                LDY     #14
000AA3  1  20 90 3E             JSR     locate
000AA6  1  A9 C4 A0 0D          PRINTMSG over3
000AAA  1  20 A2 3E     
000AAD  1  A2 20                LDX     #32
000AAF  1  A0 12                LDY     #18
000AB1  1  20 90 3E             JSR     locate
000AB4  1  A9 1E A0 0E          PRINTMSG anykey
000AB8  1  20 A2 3E     
000ABB  1  20 D1 12             JSR     sfx_lose
000ABE  1  20 D6 44             JSR     getkey_block
000AC1  1  60                   RTS
000AC2  1               
000AC2  1               ;==============================================================================
000AC2  1               ; exit_to_dos
000AC2  1               ;==============================================================================
000AC2  1               exit_to_dos:
000AC2  1  20 C9 0E             JSR     psg_silence
000AC5  1               ; restore a normal console: 80-col, default colors, cursor on
000AC5  1  A9 39                LDA     #FC_SETMODE
000AC7  1  85 32                STA     farfunct
000AC9  1  A9 01                LDA     #1
000ACB  1  20 F0 FF             JSR     DO_FARCALL
000ACE  1  A2 08                LDX     #C_BLANK
000AD0  1  A0 E1                LDY     #CSRCOLOR_DEF
000AD2  1  A9 27 85 32          FARCALL FC_COLOR
000AD6  1  20 F0 FF     
000AD9  1  A9 26 85 32          FARCALL FC_SCNCLR
000ADD  1  20 F0 FF     
000AE0  1  A9 01                LDA     #1
000AE2  1  8D 49 06             STA     SHOWCRSR
000AE5  1  4C 00 01             JMP     BOOT            ; back to DOS/65
000AE8  1               
000AE8  1               CSRCOLOR_DEF    = $E1
000AE8  1               
