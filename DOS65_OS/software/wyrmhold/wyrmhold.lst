001AF4  2               
001AF4  1                       .INCLUDE "title.asm"
001AF4  2               ;______________________________________________________________________________
001AF4  2               ;  title.asm - graphical title screen
001AF4  2               ;
001AF4  2               ;  Composes a colorful scene with direct-VRAM fills, the custom terrain
001AF4  2               ;  tiles, a big block-letter "WYRMHOLD" logo, and a dragon, rather than
001AF4  2               ;  plain ASCII text.
001AF4  2               ;______________________________________________________________________________
001AF4  2               
001AF4  2               ; big-letter logo geometry
001AF4  2               BL_W            = 5             ; cells per letter (incl. 1 col gap handled by caller)
001AF4  2               BL_H            = 5             ; rows per letter
001AF4  2               BL_ROW          = 3             ; top screen row of the logo
001AF4  2               BL_COL          = 8             ; left screen col of the logo
001AF4  2               
001AF4  2               ;----------------------------------------------------------------
001AF4  2               ; draw_title_scene - paint the whole title screen.
001AF4  2               ;----------------------------------------------------------------
001AF4  2               draw_title_scene:
001AF4  2  20 BE 3D             JSR     cls_vram
001AF7  2  20 42 3D             JSR     vid_enter
001AFA  2               
001AFA  2                       ; --- sky band (rows 0..9) : deep blue background ---
001AFA  2  A9 00                LDA     #0
001AFC  2  85 27                STA     rowidx
001AFE  2               @sky:
001AFE  2  A5 27                LDA     rowidx
001B00  2  85 21                STA     tmp1
001B02  2  A9 00                LDA     #0
001B04  2  85 22                STA     tmp2
001B06  2  A9 20                LDA     #space
001B08  2  85 23                STA     tmp3
001B0A  2  A9 1F                LDA     #COLOR(CO_BRWHITE, CO_BLUE)
001B0C  2  85 26                STA     colidx
001B0E  2  A9 50                LDA     #SCRW
001B10  2  85 24                STA     cnt0
001B12  2  20 E4 3D             JSR     fillrow_vram
001B15  2  E6 27                INC     rowidx
001B17  2  A5 27                LDA     rowidx
001B19  2  C9 0A                CMP     #10
001B1B  2  D0 E1                BNE     @sky
001B1D  2               
001B1D  2                       ; sprinkle a few "stars" in the sky (asterisks)
001B1D  2  A9 2E                LDA     #'.'
001B1F  2  85 23                STA     tmp3
001B21  2  A9 1F                LDA     #COLOR(CO_BRWHITE, CO_BLUE)
001B23  2  85 26                STA     colidx
001B25  2  A2 00                LDX     #0
001B27  2               @stars:
001B27  2  BD 21 1D             LDA     star_row,X
001B2A  2  85 21                STA     tmp1
001B2C  2  BD 2B 1D             LDA     star_col,X
001B2F  2  85 22                STA     tmp2
001B31  2  DA                   PHX
001B32  2  20 AE 3D             JSR     putcell
001B35  2  FA                   PLX
001B36  2  E8                   INX
001B37  2  E0 0A                CPX     #NSTARS
001B39  2  D0 EC                BNE     @stars
001B3B  2               
001B3B  2                       ; --- ground band (rows 16..23) : green ---
001B3B  2  A9 10                LDA     #16
001B3D  2  85 27                STA     rowidx
001B3F  2               @grnd:
001B3F  2  A5 27                LDA     rowidx
001B41  2  85 21                STA     tmp1
001B43  2  A9 00                LDA     #0
001B45  2  85 22                STA     tmp2
001B47  2  A9 01                LDA     #G_GRASS
001B49  2  85 23                STA     tmp3
001B4B  2  A9 2A                LDA     #C_GRASS
001B4D  2  85 26                STA     colidx
001B4F  2  A9 50                LDA     #SCRW
001B51  2  85 24                STA     cnt0
001B53  2  20 E4 3D             JSR     fillrow_vram
001B56  2  E6 27                INC     rowidx
001B58  2  A5 27                LDA     rowidx
001B5A  2  C9 18                CMP     #24
001B5C  2  D0 E1                BNE     @grnd
001B5E  2               
001B5E  2                       ; --- a mountain range across the horizon (row 15) ---
001B5E  2  A9 0F                LDA     #15
001B60  2  85 21                STA     tmp1
001B62  2  A9 00                LDA     #0
001B64  2  85 22                STA     tmp2
001B66  2  A9 03                LDA     #G_MOUNT
001B68  2  85 23                STA     tmp3
001B6A  2  A9 8F                LDA     #C_MOUNT
001B6C  2  85 26                STA     colidx
001B6E  2  A9 50                LDA     #SCRW
001B70  2  85 24                STA     cnt0
001B72  2  20 E4 3D             JSR     fillrow_vram
001B75  2               
001B75  2  20 51 3D             JSR     vid_exit
001B78  2               
001B78  2                       ; --- scenery objects (single tiles) via putcell helper ---
001B78  2  20 D9 1B             JSR     draw_scenery
001B7B  2               
001B7B  2                       ; --- the big block-letter logo ---
001B7B  2  20 58 1C             JSR     draw_logo
001B7E  2               
001B7E  2                       ; --- text: subtitle, prompt, controls (colored) ---
001B7E  2  A2 1A                LDX     #26
001B80  2  A0 0A                LDY     #10
001B82  2  20 90 3E             JSR     locate
001B85  2  A9 0B                LDA     #COLOR(CO_BRTURQ, CO_BLACK)
001B87  2  8D 4A 06             STA     CURCOLOR
001B8A  2  A9 74 A0 0B          PRINTMSG ttl_by
001B8E  2  20 A2 3E     
001B91  2               
001B91  2  A2 20                LDX     #32
001B93  2  A0 0B                LDY     #11
001B95  2  20 90 3E             JSR     locate
001B98  2  A9 0F                LDA     #COLOR(CO_BRWHITE, CO_BLACK)
001B9A  2  8D 4A 06             STA     CURCOLOR
001B9D  2  A9 9A A0 0B          PRINTMSG ttl_version
001BA1  2  20 A2 3E     
001BA4  2               
001BA4  2  A2 17                LDX     #23
001BA6  2  A0 12                LDY     #18
001BA8  2  20 90 3E             JSR     locate
001BAB  2  A9 0E                LDA     #COLOR(CO_BRYELLOW, CO_BLACK)
001BAD  2  8D 4A 06             STA     CURCOLOR
001BB0  2  A9 AA A0 0B          PRINTMSG ttl_prompt
001BB4  2  20 A2 3E     
001BB7  2               
001BB7  2  A2 14                LDX     #20
001BB9  2  A0 15                LDY     #21
001BBB  2  20 90 3E             JSR     locate
001BBE  2  A9 0F                LDA     #COLOR(CO_BRWHITE, CO_BLACK)
001BC0  2  8D 4A 06             STA     CURCOLOR
001BC3  2  A9 CB A0 0B          PRINTMSG ttl_keys1
001BC7  2  20 A2 3E     
001BCA  2  A2 14                LDX     #20
001BCC  2  A0 16                LDY     #22
001BCE  2  20 90 3E             JSR     locate
001BD1  2  A9 FF A0 0B          PRINTMSG ttl_keys2
001BD5  2  20 A2 3E     
001BD8  2  60                   RTS
001BD9  2               
001BD9  2               ;----------------------------------------------------------------
001BD9  2               ; draw_scenery - place tile objects on the landscape: forests, a
001BD9  2               ; castle, a lake, and a big dragon (boss glyph) menacing the scene.
001BD9  2               ;----------------------------------------------------------------
001BD9  2               draw_scenery:
001BD9  2  20 42 3D             JSR     vid_enter
001BDC  2                       ; forests dotted along the ground (row 16/17)
001BDC  2  A2 00                LDX     #0
001BDE  2               @trees:
001BDE  2  BD 35 1D             LDA     tree_row,X
001BE1  2  85 21                STA     tmp1
001BE3  2  BD 3E 1D             LDA     tree_col,X
001BE6  2  85 22                STA     tmp2
001BE8  2  A9 02                LDA     #G_FOREST
001BEA  2  85 23                STA     tmp3
001BEC  2  A9 0A                LDA     #C_FOREST
001BEE  2  85 26                STA     colidx
001BF0  2  DA                   PHX
001BF1  2  20 AE 3D             JSR     putcell
001BF4  2  FA                   PLX
001BF5  2  E8                   INX
001BF6  2  E0 09                CPX     #NTREES
001BF8  2  D0 E4                BNE     @trees
001BFA  2               
001BFA  2                       ; a castle on the left hill (row 14-15 area)
001BFA  2  A9 0E                LDA     #14
001BFC  2  85 21                STA     tmp1
001BFE  2  A9 06                LDA     #6
001C00  2  85 22                STA     tmp2
001C02  2  A9 07                LDA     #G_CASTLE
001C04  2  85 23                STA     tmp3
001C06  2  A9 8F                LDA     #C_CASTLE
001C08  2  85 26                STA     colidx
001C0A  2  20 AE 3D             JSR     putcell
001C0D  2  A9 0E                LDA     #14
001C0F  2  85 21                STA     tmp1
001C11  2  A9 07                LDA     #7
001C13  2  85 22                STA     tmp2
001C15  2  20 AE 3D             JSR     putcell
001C18  2               
001C18  2                       ; a small lake on the right (row 17)
001C18  2  A9 11                LDA     #17
001C1A  2  85 21                STA     tmp1
001C1C  2  A9 3E                LDA     #62
001C1E  2  85 22                STA     tmp2
001C20  2  A9 04                LDA     #G_WATER
001C22  2  85 23                STA     tmp3
001C24  2  A9 1B                LDA     #C_WATER
001C26  2  85 26                STA     colidx
001C28  2  A9 0A                LDA     #10
001C2A  2  85 24                STA     cnt0
001C2C  2  20 E4 3D             JSR     fillrow_vram
001C2F  2               
001C2F  2                       ; the DRAGON - big and red, hovering at the right of the sky
001C2F  2  A9 0C                LDA     #12
001C31  2  85 21                STA     tmp1
001C33  2  A9 3C                LDA     #60
001C35  2  85 22                STA     tmp2
001C37  2  A9 16                LDA     #G_BOSS
001C39  2  85 23                STA     tmp3
001C3B  2  A9 1C                LDA     #COLOR(CO_BRRED, CO_BLUE)
001C3D  2  85 26                STA     colidx
001C3F  2  20 AE 3D             JSR     putcell
001C42  2                       ; a second dragon, smaller/left, different color
001C42  2  A9 06                LDA     #6
001C44  2  85 21                STA     tmp1
001C46  2  A9 42                LDA     #66
001C48  2  85 22                STA     tmp2
001C4A  2  A9 16                LDA     #G_BOSS
001C4C  2  85 23                STA     tmp3
001C4E  2  A9 1E                LDA     #COLOR(CO_BRYELLOW, CO_BLUE)
001C50  2  85 26                STA     colidx
001C52  2  20 AE 3D             JSR     putcell
001C55  2               
001C55  2  4C 51 3D             JMP     vid_exit
001C58  2               
001C58  2               ;----------------------------------------------------------------
001C58  2               ; draw_logo - stamp the big block-letter "WYRMHOLD" logo using
001C58  2               ; solid wall tiles in bright gold.  Each letter is a 5x5 bitmap
001C58  2               ; (5 bytes, top bit = leftmost of 5 columns).  Letters are spaced
001C58  2               ; BL_W+1 columns apart.
001C58  2               ;----------------------------------------------------------------
001C58  2               draw_logo:
001C58  2  20 42 3D             JSR     vid_enter
001C5B  2  A9 00                LDA     #0
001C5D  2  8D A3 6D             STA     logo_li         ; letter index
001C60  2               @letter:
001C60  2  AD A3 6D             LDA     logo_li
001C63  2  C9 08                CMP     #8              ; 8 letters
001C65  2  90 03                BCC     :+
001C67  2  4C F6 1C             JMP     @done
001C6A  2               :
001C6A  2                       ; pointer to this letter's 5 bytes:  logo_font + li*5
001C6A  2  AD A3 6D             LDA     logo_li
001C6D  2  85 20                STA     tmp0
001C6F  2  0A                   ASL     A               ; *2
001C70  2  0A                   ASL     A               ; *4
001C71  2  18                   CLC
001C72  2  65 20                ADC     tmp0            ; *5
001C74  2  A8                   TAY                     ; Y = li*5 offset into logo_font
001C75  2                       ; left screen column for this letter = BL_COL + li*(BL_W+1)
001C75  2  AD A3 6D             LDA     logo_li
001C78  2  85 20                STA     tmp0
001C7A  2  0A                   ASL     A               ; *2
001C7B  2  0A                   ASL     A               ; *4
001C7C  2  18                   CLC
001C7D  2  65 20                ADC     tmp0            ; *5
001C7F  2  18                   CLC
001C80  2  6D A3 6D             ADC     logo_li         ; + li  -> li*6
001C83  2  18                   CLC
001C84  2  69 08                ADC     #BL_COL
001C86  2  8D A4 6D             STA     logo_lx         ; base column
001C89  2                       ; draw 5 rows
001C89  2  A9 00                LDA     #0
001C8B  2  8D A5 6D             STA     logo_ry
001C8E  2               @row:
001C8E  2  AD A5 6D             LDA     logo_ry
001C91  2  C9 05                CMP     #BL_H
001C93  2  B0 5B                BCS     @nextletter
001C95  2                       ; fetch the bitmap byte for (li,row): logo_font[li*5 + row]
001C95  2  98                   TYA
001C96  2  18                   CLC
001C97  2  6D A5 6D             ADC     logo_ry
001C9A  2  AA                   TAX
001C9B  2  BD F9 1C             LDA     logo_font,X
001C9E  2  8D A7 6D             STA     logo_bits       ; 5 bits, bit4..bit0 = cols 0..4
001CA1  2                       ; draw 5 columns
001CA1  2  A9 00                LDA     #0
001CA3  2  8D A6 6D             STA     logo_cx
001CA6  2               @col:
001CA6  2  AD A6 6D             LDA     logo_cx
001CA9  2  C9 05                CMP     #BL_W
001CAB  2  B0 32                BCS     @nextrow
001CAD  2                       ; test bit (4 - cx) of logo_bits
001CAD  2  A9 10                LDA     #%00010000      ; bit4 mask
001CAF  2  AE A6 6D             LDX     logo_cx
001CB2  2  F0 04                BEQ     @havemask
001CB4  2               @shr:
001CB4  2  4A                   LSR     A
001CB5  2  CA                   DEX
001CB6  2  D0 FC                BNE     @shr
001CB8  2               @havemask:
001CB8  2  2D A7 6D             AND     logo_bits
001CBB  2  F0 1C                BEQ     @blank
001CBD  2                       ; set pixel -> solid gold block
001CBD  2  AD A5 6D             LDA     logo_ry
001CC0  2  18                   CLC
001CC1  2  69 03                ADC     #BL_ROW
001CC3  2  85 21                STA     tmp1            ; screen row
001CC5  2  AD A4 6D             LDA     logo_lx
001CC8  2  18                   CLC
001CC9  2  6D A6 6D             ADC     logo_cx
001CCC  2  85 22                STA     tmp2            ; screen col
001CCE  2  A9 0B                LDA     #G_WALL
001CD0  2  85 23                STA     tmp3
001CD2  2  A9 4E                LDA     #COLOR(CO_BRYELLOW, CO_RED)
001CD4  2  85 26                STA     colidx
001CD6  2  20 AE 3D             JSR     putcell
001CD9  2               @blank:
001CD9  2  EE A6 6D             INC     logo_cx
001CDC  2  4C A6 1C             JMP     @col
001CDF  2               @nextrow:
001CDF  2  EE A5 6D             INC     logo_ry
001CE2  2                       ; Y must be reloaded (clobbered above): recompute li*5
001CE2  2  AD A3 6D             LDA     logo_li
001CE5  2  85 20                STA     tmp0
001CE7  2  0A                   ASL     A
001CE8  2  0A                   ASL     A
001CE9  2  18                   CLC
001CEA  2  65 20                ADC     tmp0
001CEC  2  A8                   TAY
001CED  2  4C 8E 1C             JMP     @row
001CF0  2               @nextletter:
001CF0  2  EE A3 6D             INC     logo_li
001CF3  2  4C 60 1C             JMP     @letter
001CF6  2               @done:
001CF6  2  4C 51 3D             JMP     vid_exit
001CF9  2               
001CF9  2               ;----------------------------------------------------------------
001CF9  2               ; Big-letter 5x5 font for  W Y R M H O L D  (bit4..bit0 = 5 cols)
001CF9  2               ;----------------------------------------------------------------
001CF9  2               logo_font:
001CF9  2                       ; W
001CF9  2  11                   .BYTE   %10001
001CFA  2  11                   .BYTE   %10001
001CFB  2  15                   .BYTE   %10101
001CFC  2  1B                   .BYTE   %11011
001CFD  2  11                   .BYTE   %10001
001CFE  2                       ; Y
001CFE  2  11                   .BYTE   %10001
001CFF  2  0A                   .BYTE   %01010
001D00  2  04                   .BYTE   %00100
001D01  2  04                   .BYTE   %00100
001D02  2  04                   .BYTE   %00100
001D03  2                       ; R
001D03  2  1E                   .BYTE   %11110
001D04  2  11                   .BYTE   %10001
001D05  2  1E                   .BYTE   %11110
001D06  2  12                   .BYTE   %10010
001D07  2  11                   .BYTE   %10001
001D08  2                       ; M
001D08  2  11                   .BYTE   %10001
001D09  2  1B                   .BYTE   %11011
001D0A  2  15                   .BYTE   %10101
001D0B  2  11                   .BYTE   %10001
001D0C  2  11                   .BYTE   %10001
001D0D  2                       ; H
001D0D  2  11                   .BYTE   %10001
001D0E  2  11                   .BYTE   %10001
001D0F  2  1F                   .BYTE   %11111
001D10  2  11                   .BYTE   %10001
001D11  2  11                   .BYTE   %10001
001D12  2                       ; O
001D12  2  0E                   .BYTE   %01110
001D13  2  11                   .BYTE   %10001
001D14  2  11                   .BYTE   %10001
001D15  2  11                   .BYTE   %10001
001D16  2  0E                   .BYTE   %01110
001D17  2                       ; L
001D17  2  10                   .BYTE   %10000
001D18  2  10                   .BYTE   %10000
001D19  2  10                   .BYTE   %10000
001D1A  2  10                   .BYTE   %10000
001D1B  2  1F                   .BYTE   %11111
001D1C  2                       ; D
001D1C  2  1E                   .BYTE   %11110
001D1D  2  11                   .BYTE   %10001
001D1E  2  11                   .BYTE   %10001
001D1F  2  11                   .BYTE   %10001
001D20  2  1E                   .BYTE   %11110
001D21  2               
001D21  2               ;----------------------------------------------------------------
001D21  2               ; decorative element positions
001D21  2               ;----------------------------------------------------------------
001D21  2               NSTARS  = 10
001D21  2               star_row:
001D21  2  01 02 00 03          .BYTE   1, 2, 0, 3, 1, 2, 0, 4, 1, 3
001D25  2  01 02 00 04  
001D29  2  01 03        
001D2B  2               star_col:
001D2B  2  04 0C 16 1E          .BYTE   4, 12, 22, 30, 44, 52, 58, 16, 70, 74
001D2F  2  2C 34 3A 10  
001D33  2  46 4A        
001D35  2               
001D35  2               NTREES  = 9
001D35  2               tree_row:
001D35  2  10 11 10 10          .BYTE   16, 17, 16, 16, 17, 16, 17, 16, 16
001D39  2  11 10 11 10  
001D3D  2  10           
001D3E  2               tree_col:
001D3E  2  12 18 1E 26          .BYTE   18, 24, 30, 38, 44, 50, 14, 56, 34
001D42  2  2C 32 0E 38  
001D46  2  22           
001D47  2               
001D47  1                       .INCLUDE "world.asm"
001D47  2               ;______________________________________________________________________________
001D47  2               ;  world.asm - map data, tile property tables and lookup helpers
001D47  2               ;
001D47  2               ;  Maps are authored as ASCII rows for readability and converted to
001D47  2               ;  tile codes once at startup (map_decode).  The decoded tile grids
001D47  2               ;  live in RAM (owmap / locmap).  Authoring characters:
001D47  2               ;     . grass   & forest  ^ mountain  ~ water   h hills   % marsh
001D47  2               ;     T town    O dungeon C castle    : road    = bridge
001D47  2               ;     space->grass
001D47  2               ;  For interiors (town/dungeon/castle/shrine):
001D47  2               ;     . floor   # wall     + door(exit)  $ treasure  < stairs up
001D47  2               ;     S shop    ~ water
001D47  2               ;______________________________________________________________________________
001D47  2               
001D47  2               ;----------------------------------------------------------------
001D47  2               ; Tile color table  (tile code -> color byte)
001D47  2               ;----------------------------------------------------------------
001D47  2               tile_color:
001D47  2  2A                   .BYTE   C_GRASS         ; 0
001D48  2  0A                   .BYTE   C_FOREST        ; 1
001D49  2  8F                   .BYTE   C_MOUNT         ; 2
001D4A  2  1B                   .BYTE   C_WATER         ; 3
001D4B  2  4E                   .BYTE   C_TOWN          ; 4
001D4C  2  0B                   .BYTE   C_DUNG          ; 5
001D4D  2  8F                   .BYTE   C_CASTLE        ; 6
001D4E  2  4E                   .BYTE   C_ROAD          ; 7
001D4F  2  1E                   .BYTE   C_BRIDGE        ; 8
001D50  2  08                   .BYTE   C_FLOOR         ; 9
001D51  2  8F                   .BYTE   C_WALL          ; 10
001D52  2  A0                   .BYTE   C_EXIT          ; 11 door (bright = exit)
001D53  2  0E                   .BYTE   C_TREAS         ; 12
001D54  2  A0                   .BYTE   C_EXIT          ; 13 stairs (bright = exit)
001D55  2  4E                   .BYTE   C_TOWN          ; 14 shop
001D56  2  2E                   .BYTE   C_HILLS         ; 15
001D57  2  1A                   .BYTE   C_MARSH         ; 16
001D58  2               
001D58  2               ; Interior town palettes reuse the same tile codes but give each town a
001D58  2               ; distinct read: Eastmere is bright coastal stone, Valehaven is deep green.
001D58  2               eastmere_tile_color:
001D58  2  2A                   .BYTE   C_GRASS         ; 0
001D59  2  0A                   .BYTE   C_FOREST        ; 1
001D5A  2  8F                   .BYTE   C_MOUNT         ; 2
001D5B  2  1B                   .BYTE   C_EAST_WATER    ; 3
001D5C  2  4E                   .BYTE   C_TOWN          ; 4
001D5D  2  0B                   .BYTE   C_DUNG          ; 5
001D5E  2  8F                   .BYTE   C_CASTLE        ; 6
001D5F  2  4E                   .BYTE   C_ROAD          ; 7
001D60  2  1E                   .BYTE   C_BRIDGE        ; 8
001D61  2  0E                   .BYTE   C_EAST_FLOOR    ; 9
001D62  2  1F                   .BYTE   C_EAST_WALL     ; 10
001D63  2  E0                   .BYTE   C_EAST_EXIT     ; 11 door
001D64  2  0E                   .BYTE   C_TREAS         ; 12
001D65  2  E0                   .BYTE   C_EAST_EXIT     ; 13 stairs
001D66  2  4E                   .BYTE   C_EAST_SHOP     ; 14 shop
001D67  2  2E                   .BYTE   C_HILLS         ; 15
001D68  2  1A                   .BYTE   C_MARSH         ; 16
001D69  2               
001D69  2               valehaven_tile_color:
001D69  2  2A                   .BYTE   C_GRASS         ; 0
001D6A  2  0A                   .BYTE   C_FOREST        ; 1
001D6B  2  8F                   .BYTE   C_MOUNT         ; 2
001D6C  2  0B                   .BYTE   C_VALE_WATER    ; 3
001D6D  2  4E                   .BYTE   C_TOWN          ; 4
001D6E  2  0B                   .BYTE   C_DUNG          ; 5
001D6F  2  8F                   .BYTE   C_CASTLE        ; 6
001D70  2  4E                   .BYTE   C_ROAD          ; 7
001D71  2  1E                   .BYTE   C_BRIDGE        ; 8
001D72  2  0A                   .BYTE   C_VALE_FLOOR    ; 9
001D73  2  8F                   .BYTE   C_VALE_WALL     ; 10
001D74  2  A0                   .BYTE   C_VALE_EXIT     ; 11 door
001D75  2  0E                   .BYTE   C_TREAS         ; 12
001D76  2  A0                   .BYTE   C_VALE_EXIT     ; 13 stairs
001D77  2  2E                   .BYTE   C_VALE_SHOP     ; 14 shop
001D78  2  2E                   .BYTE   C_HILLS         ; 15
001D79  2  1A                   .BYTE   C_MARSH         ; 16
001D7A  2               
001D7A  2               ;----------------------------------------------------------------
001D7A  2               ; Tile variant table  (tile code -> alternate metatile base, or 0)
001D7A  2               ; A non-zero entry means this terrain has a 2nd art variant; the
001D7A  2               ; renderer may use it instead of the MG_* base for some map cells
001D7A  2               ; to break up the repeating-grid look. 0 = no variant (use base).
001D7A  2               ;----------------------------------------------------------------
001D7A  2               tile_variant:
001D7A  2  E0                   .BYTE   MGV_GRASS       ; 0  grass
001D7B  2  E4                   .BYTE   MGV_FOREST      ; 1  forest
001D7C  2  EC                   .BYTE   MGV_MOUNT       ; 2  mountain
001D7D  2  E8                   .BYTE   MGV_WATER       ; 3  water
001D7E  2  00                   .BYTE   0               ; 4  town
001D7F  2  00                   .BYTE   0               ; 5  dungeon
001D80  2  00                   .BYTE   0               ; 6  castle
001D81  2  00                   .BYTE   0               ; 7  road
001D82  2  00                   .BYTE   0               ; 8  bridge
001D83  2  00                   .BYTE   0               ; 9  floor
001D84  2  00                   .BYTE   0               ; 10 wall
001D85  2  00                   .BYTE   0               ; 11 door
001D86  2  00                   .BYTE   0               ; 12 treasure
001D87  2  00                   .BYTE   0               ; 13 stairs
001D88  2  00                   .BYTE   0               ; 14 shop
001D89  2  00                   .BYTE   0               ; 15 hills
001D8A  2  00                   .BYTE   0               ; 16 marsh
001D8B  2               
001D8B  2               ;----------------------------------------------------------------
001D8B  2               ; Tile property table  (tile code -> property bits)
001D8B  2               ;   bit0 PASS    passable on foot
001D8B  2               ;   bit1 WATER   water (impassable without ship)
001D8B  2               ;   bit2 TOWN    stepping here enters a town
001D8B  2               ;   bit3 DUNG    stepping here enters the dungeon
001D8B  2               ;   bit4 EXIT    stepping here leaves the interior (town/dungeon)
001D8B  2               ;   bit5 TREAS   treasure to collect
001D8B  2               ;   bit6 SHOP    shop counter (open shop when adjacent/entering)
001D8B  2               ;   bit7 CASTLE  stepping here enters Wyrmhold Castle
001D8B  2               ;----------------------------------------------------------------
001D8B  2               P_PASS          = $01
001D8B  2               P_WATER         = $02
001D8B  2               P_TOWN          = $04
001D8B  2               P_DUNG          = $08
001D8B  2               P_EXIT          = $10
001D8B  2               P_TREAS         = $20
001D8B  2               P_SHOP          = $40
001D8B  2               P_CASTLE        = $80
001D8B  2               
001D8B  2               tile_prop:
001D8B  2  01                   .BYTE   P_PASS          ; 0 grass
001D8C  2  01                   .BYTE   P_PASS          ; 1 forest (passable, slow flavor)
001D8D  2  00                   .BYTE   $00             ; 2 mountain (blocked)
001D8E  2  02                   .BYTE   P_WATER         ; 3 water (blocked on foot)
001D8F  2  05                   .BYTE   P_PASS|P_TOWN   ; 4 town
001D90  2  09                   .BYTE   P_PASS|P_DUNG   ; 5 dungeon
001D91  2  81                   .BYTE   P_PASS|P_CASTLE ; 6 castle
001D92  2  01                   .BYTE   P_PASS          ; 7 road
001D93  2  01                   .BYTE   P_PASS          ; 8 bridge
001D94  2  01                   .BYTE   P_PASS          ; 9 floor
001D95  2  00                   .BYTE   $00             ; 10 wall
001D96  2  11                   .BYTE   P_PASS|P_EXIT   ; 11 door (exit interior)
001D97  2  21                   .BYTE   P_PASS|P_TREAS  ; 12 treasure
001D98  2  11                   .BYTE   P_PASS|P_EXIT   ; 13 stairs up (exit dungeon)
001D99  2  41                   .BYTE   P_PASS|P_SHOP   ; 14 shop
001D9A  2  01                   .BYTE   P_PASS          ; 15 hills
001D9B  2  01                   .BYTE   P_PASS          ; 16 marsh
001D9C  2               
001D9C  2               ;----------------------------------------------------------------
001D9C  2               ; Authoring char -> tile code translation (used by map_decode).
001D9C  2               ; Two parallel tables: chars[] and codes[], terminated by $00.
001D9C  2               ; The current decoder supplies the map-specific default tile:
001D9C  2               ; grass outdoors and floor indoors. Thus '.' and unknown/space
001D9C  2               ; characters become the appropriate default without a table entry.
001D9C  2               ;----------------------------------------------------------------
001D9C  2               dec_chars:
001D9C  2  26 5E 7E 54          .BYTE   "&^~TOC:=#+$<Sh%", $00
001DA0  2  4F 43 3A 3D  
001DA4  2  23 2B 24 3C  
001DAC  2               dec_codes:
001DAC  2  01                   .BYTE   T_FOREST        ; &
001DAD  2  02                   .BYTE   T_MOUNT         ; ^
001DAE  2  03                   .BYTE   T_WATER         ; ~
001DAF  2  04                   .BYTE   T_TOWN          ; T
001DB0  2  05                   .BYTE   T_DUNG          ; O
001DB1  2  06                   .BYTE   T_CASTLE        ; C
001DB2  2  07                   .BYTE   T_ROAD          ; :
001DB3  2  08                   .BYTE   T_BRIDGE        ; =
001DB4  2  0A                   .BYTE   T_WALL          ; #
001DB5  2  0B                   .BYTE   T_DOOR          ; +
001DB6  2  0C                   .BYTE   T_TREAS         ; $
001DB7  2  0D                   .BYTE   T_UPSTAIR       ; <
001DB8  2  0E                   .BYTE   T_SHOP          ; S
001DB9  2  0F                   .BYTE   T_HILLS         ; h
001DBA  2  10                   .BYTE   T_MARSH         ; %
001DBB  2               
001DBB  2               ; map a single authoring char (A) to a tile code -> A
001DBB  2               xlate_char:
001DBB  2  85 20                STA     tmp0
001DBD  2  A2 00                LDX     #0
001DBF  2               @f:
001DBF  2  BD 9C 1D             LDA     dec_chars,X
001DC2  2  F0 07                BEQ     @nf
001DC4  2  C5 20                CMP     tmp0
001DC6  2  F0 06                BEQ     @ok
001DC8  2  E8                   INX
001DC9  2  D0 F4                BNE     @f
001DCB  2               @nf:
001DCB  2  A5 25                LDA     cnt1            ; map-specific default tile
001DCD  2  60                   RTS
001DCE  2               @ok:
001DCE  2  BD AC 1D             LDA     dec_codes,X
001DD1  2  60                   RTS
001DD2  2               
001DD2  2               ;----------------------------------------------------------------
001DD2  2               ; map_decode - translate an authored ASCII map into a tile grid,
001DD2  2               ; row by row.  Each source row is a NUL-terminated string.  Rows
001DD2  2               ; shorter than the map width are padded with the map default; longer
001DD2  2               ; rows are truncated.  This makes exact source-row width unimportant.
001DD2  2               ;
001DD2  2               ;   IN : srcp -> first source row (rows packed back-to-back, each
001DD2  2               ;                NUL-terminated)
001DD2  2               ;        dstp -> destination tile-code buffer (width*height bytes)
001DD2  2               ;        tmp2 =  map width   (<=255)
001DD2  2               ;        tmp3 =  map height  (<=255)
001DD2  2               ;        cnt1 = default tile (grass outdoors, floor indoors)
001DD2  2               ;----------------------------------------------------------------
001DD2  2               ; NOTE: the column counter is kept in cnt0 (memory), NOT in X,
001DD2  2               ; because xlate_char clobbers X (it uses X as a search index).
001DD2  2               map_decode:
001DD2  2  A9 00                LDA     #0
001DD4  2  85 27                STA     rowidx          ; row counter
001DD6  2               @nextrow:
001DD6  2  A5 27                LDA     rowidx
001DD8  2  C5 23                CMP     tmp3
001DDA  2  B0 59                BCS     @done
001DDC  2  A9 00                LDA     #0
001DDE  2  85 24                STA     cnt0            ; column within row
001DE0  2               @col:
001DE0  2  A5 24                LDA     cnt0
001DE2  2  C5 22                CMP     tmp2
001DE4  2  B0 1E                BCS     @rowfull
001DE6  2               ; cnt0 tracks column for width logic; srcp is the read head.
001DE6  2  A0 00                LDY     #0
001DE8  2  B1 18                LDA     (srcp),Y
001DEA  2  F0 27                BEQ     @padrow         ; early NUL -> pad rest with grass
001DEC  2  20 BB 1D             JSR     xlate_char      ; A=tile code (clobbers X)
001DEF  2  A0 00                LDY     #0
001DF1  2  91 1A                STA     (dstp),Y
001DF3  2               ; advance read head and dest
001DF3  2  E6 18                INC     srcp
001DF5  2  D0 02                BNE     :+
001DF7  2  E6 19                INC     srcp+1
001DF9  2               :
001DF9  2  E6 1A                INC     dstp
001DFB  2  D0 02                BNE     :+
001DFD  2  E6 1B                INC     dstp+1
001DFF  2               :
001DFF  2  E6 24                INC     cnt0
001E01  2  4C E0 1D             JMP     @col
001E04  2               @rowfull:
001E04  2               ; consume any extra source chars up to the terminating NUL
001E04  2               @skip:
001E04  2  A0 00                LDY     #0
001E06  2  B1 18                LDA     (srcp),Y
001E08  2  F0 20                BEQ     @aftrow
001E0A  2  E6 18                INC     srcp
001E0C  2  D0 F6                BNE     @skip
001E0E  2  E6 19                INC     srcp+1
001E10  2  4C 04 1E             JMP     @skip
001E13  2               @padrow:
001E13  2               ; fill remaining columns (cnt0..width-1) with the map default
001E13  2               @pad:
001E13  2  A5 24                LDA     cnt0
001E15  2  C5 22                CMP     tmp2
001E17  2  B0 11                BCS     @aftrow
001E19  2  A5 25                LDA     cnt1
001E1B  2  A0 00                LDY     #0
001E1D  2  91 1A                STA     (dstp),Y
001E1F  2  E6 1A                INC     dstp
001E21  2  D0 02                BNE     :+
001E23  2  E6 1B                INC     dstp+1
001E25  2               :
001E25  2  E6 24                INC     cnt0
001E27  2  4C 13 1E             JMP     @pad
001E2A  2               @aftrow:
001E2A  2               ; step srcp past the row terminator NUL
001E2A  2  E6 18                INC     srcp
001E2C  2  D0 02                BNE     :+
001E2E  2  E6 19                INC     srcp+1
001E30  2               :
001E30  2  E6 27                INC     rowidx
001E32  2  4C D6 1D             JMP     @nextrow
001E35  2               @done:
001E35  2  60                   RTS
001E36  2               
001E36  2               ;----------------------------------------------------------------
001E36  2               ; decode_world / decode_town / decode_dung / decode_castle / decode_shrine
001E36  2               ;----------------------------------------------------------------
001E36  2               decode_world:
001E36  2  A9 1E 85 18          SETW16  srcp, ow_src
001E3A  2  A9 20 85 19  
001E3E  2  A9 21 85 1A          SETW16  dstp, owmap
001E42  2  A9 6F 85 1B  
001E46  2  A9 00                LDA     #T_GRASS
001E48  2  85 25                STA     cnt1
001E4A  2  A9 40                LDA     #OWW
001E4C  2  85 22                STA     tmp2
001E4E  2  A9 40                LDA     #OWH
001E50  2  85 23                STA     tmp3
001E52  2  4C D2 1D             JMP     map_decode
001E55  2               
001E55  2               decode_town:
001E55  2  AD 8A 6D             LDA     town_id
001E58  2  C9 01                CMP     #TOWN_VALEHAVEN
001E5A  2  F0 0B                BEQ     @valehaven
001E5C  2  A9 5E 85 18          SETW16  srcp, eastmere_src
001E60  2  A9 30 85 19  
001E64  2  4C 6F 1E             JMP     @decode
001E67  2               @valehaven:
001E67  2  A9 F2 85 18          SETW16  srcp, valehaven_src
001E6B  2  A9 32 85 19  
001E6F  2               @decode:
001E6F  2  A9 21 85 1A          SETW16  dstp, locmap
001E73  2  A9 7F 85 1B  
