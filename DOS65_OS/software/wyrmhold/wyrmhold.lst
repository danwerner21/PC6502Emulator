0068CA  2  60                   RTS
0068CB  2               
0068CB  2               ;----------------------------------------------------------------
0068CB  2               ; ruler_adjacent - C=1 if player is orthogonally adjacent to the
0068CB  2               ; ruler's throne. The throne itself is a wall and cannot be entered.
0068CB  2               ;----------------------------------------------------------------
0068CB  2               ruler_adjacent:
0068CB  2  AD 7B 6D             LDA     px
0068CE  2  C9 0F                CMP     #CASTLE_RULER_X
0068D0  2  D0 0D                BNE     @side
0068D2  2  AD 7C 6D             LDA     py
0068D5  2  C9 03                CMP     #CASTLE_RULER_Y-1
0068D7  2  F0 1A                BEQ     @yes
0068D9  2  C9 05                CMP     #CASTLE_RULER_Y+1
0068DB  2  F0 16                BEQ     @yes
0068DD  2  18                   CLC
0068DE  2  60                   RTS
0068DF  2               @side:
0068DF  2  AD 7C 6D             LDA     py
0068E2  2  C9 04                CMP     #CASTLE_RULER_Y
0068E4  2  D0 0B                BNE     @no
0068E6  2  AD 7B 6D             LDA     px
0068E9  2  C9 0E                CMP     #CASTLE_RULER_X-1
0068EB  2  F0 06                BEQ     @yes
0068ED  2  C9 10                CMP     #CASTLE_RULER_X+1
0068EF  2  F0 02                BEQ     @yes
0068F1  2               @no:
0068F1  2  18                   CLC
0068F2  2  60                   RTS
0068F3  2               @yes:
0068F3  2  38                   SEC
0068F4  2  60                   RTS
