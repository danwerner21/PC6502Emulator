00482C  1                       .INCLUDE "entity.asm"
00482C  2               ;______________________________________________________________________________
00482C  2               ;  entity.asm - monsters: table, spawning, simple AI, rendering
00482C  2               ;
00482C  2               ;  Parallel arrays of MAXMON slots.  A slot with mon_type == M_NONE
00482C  2               ;  is empty.  Monsters live on the currently active map (overworld
00482C  2               ;  or dungeon).  Towns have no monsters.
00482C  2               ;______________________________________________________________________________
00482C  2               
00482C  2               ;----------------------------------------------------------------
00482C  2               ; Per-monster-type stat tables (indexed by M_* id)
00482C  2               ;   mtype_glyph : 2x2 metatile base glyph
00482C  2               ;   mtype_color : color cell
00482C  2               ;   mtype_hp    : starting HP
00482C  2               ;   mtype_atk   : attack dice sides (damage 1..atk)
00482C  2               ;   mtype_xp    : XP awarded on kill
00482C  2               ;   mtype_gold  : gold dropped (max; rolled 0..gold)
00482C  2               ;----------------------------------------------------------------
00482C  2               mtype_glyph:
00482C  2  20                   .BYTE   ' '             ; 0 none
00482D  2  C8                   .BYTE   MG_ORC          ; 1 orc
00482E  2  CC                   .BYTE   MG_SNAKE        ; 2 snake
00482F  2  D0                   .BYTE   MG_SKELETON     ; 3 skeleton
004830  2  D4                   .BYTE   MG_THIEF        ; 4 thief
004831  2  D8                   .BYTE   MG_TROLL        ; 5 troll
004832  2  DC                   .BYTE   MG_BOSS         ; 6 boss (dragon)
004833  2  F0                   .BYTE   MG_WARDEN       ; 7 Wyrm Warden
004834  2               mtype_color:
004834  2  0C                   .BYTE   C_MONST         ; 0
004835  2  0C                   .BYTE   COLOR(CO_BRRED, CO_BLACK); orc
004836  2  0E                   .BYTE   COLOR(CO_BRYELLOW,CO_BLACK); snake
004837  2  0F                   .BYTE   COLOR(CO_BRWHITE,CO_BLACK); skeleton
004838  2  05                   .BYTE   COLOR(CO_VIOLET,CO_BLACK); thief
004839  2  0B                   .BYTE   COLOR(CO_BRTURQ,CO_BLACK); troll
00483A  2  4C                   .BYTE   C_BOSS          ; boss
00483B  2  0D                   .BYTE   COLOR(CO_BRPURPLE,CO_BLACK); Wyrm Warden
00483C  2               mtype_hp:
00483C  2  00 06 04 08          .BYTE   0, 6, 4, 8, 5, 14, 40, 24
004840  2  05 0E 28 18  
004844  2               mtype_atk:
004844  2  00 04 03 05          .BYTE   0, 4, 3, 5, 3, 7, 12, 8
004848  2  03 07 0C 08  
00484C  2               mtype_xp:
00484C  2  00 03 02 05          .BYTE   0, 3, 2, 5, 4, 10, 50, 25
004850  2  04 0A 32 19  
004854  2               mtype_gold:
004854  2  00 04 01 03          .BYTE   0, 4, 1, 3, 12, 8, 40, 0
004858  2  0C 08 28 00  
00485C  2               
00485C  2               ; Weighted overworld encounters: eight entries per region. The
00485C  2               ; second set is used after the dragon's lair is unlocked.
00485C  2               region_encounters:
00485C  2               ; early Northreach, Wyrmhold Vale, Sunken March
00485C  2  01 01 01 03          .BYTE   M_ORC, M_ORC, M_ORC, M_SKELETON
004860  2  03 03 04 05          .BYTE   M_SKELETON, M_SKELETON, M_THIEF, M_TROLL
004864  2  01 01 02 02          .BYTE   M_ORC, M_ORC, M_SNAKE, M_SNAKE
004868  2  03 04 04 05          .BYTE   M_SKELETON, M_THIEF, M_THIEF, M_TROLL
00486C  2  02 02 02 04          .BYTE   M_SNAKE, M_SNAKE, M_SNAKE, M_THIEF
004870  2  04 05 05 03          .BYTE   M_THIEF, M_TROLL, M_TROLL, M_SKELETON
004874  2               ; late Northreach, Wyrmhold Vale, Sunken March
004874  2  01 01 03 03          .BYTE   M_ORC, M_ORC, M_SKELETON, M_SKELETON
004878  2  03 05 05 04          .BYTE   M_SKELETON, M_TROLL, M_TROLL, M_THIEF
00487C  2  01 02 03 04          .BYTE   M_ORC, M_SNAKE, M_SKELETON, M_THIEF
004880  2  04 05 05 05          .BYTE   M_THIEF, M_TROLL, M_TROLL, M_TROLL
004884  2  02 02 04 03          .BYTE   M_SNAKE, M_SNAKE, M_THIEF, M_SKELETON
004888  2  05 05 05 05          .BYTE   M_TROLL, M_TROLL, M_TROLL, M_TROLL
00488C  2               
00488C  2               ;----------------------------------------------------------------
00488C  2               ; mon_clear_all - empty every monster slot.
00488C  2               ;----------------------------------------------------------------
00488C  2               mon_clear_all:
00488C  2  A2 00                LDX     #0
00488E  2  A9 00                LDA     #M_NONE
004890  2               @c:
004890  2  9D A9 6E             STA     mon_type,X
004893  2  9D D9 6E             STA     mon_state,X
004896  2  E8                   INX
004897  2  E0 0C                CPX     #MAXMON
004899  2  D0 F5                BNE     @c
00489B  2  60                   RTS
00489C  2               
00489C  2               ;----------------------------------------------------------------
00489C  2               ; mon_find_free - find an empty slot.  Returns X = slot, C=1 ok,
00489C  2               ;                 C=0 if table full.
00489C  2               ;----------------------------------------------------------------
00489C  2               mon_find_free:
00489C  2  A2 00                LDX     #0
00489E  2               @f:
00489E  2  BD A9 6E             LDA     mon_type,X
0048A1  2  C9 00                CMP     #M_NONE
0048A3  2  F0 07                BEQ     @found
0048A5  2  E8                   INX
0048A6  2  E0 0C                CPX     #MAXMON
0048A8  2  D0 F4                BNE     @f
0048AA  2  18                   CLC
0048AB  2  60                   RTS
0048AC  2               @found:
0048AC  2  38                   SEC
0048AD  2  60                   RTS
0048AE  2               
0048AE  2               ;----------------------------------------------------------------
0048AE  2               ; mon_spawn - create a monster.
0048AE  2               ;   IN: A=type, tgtx=x, tgty=y
0048AE  2               ;   Sets hp from the type table.  No-op if table full.
0048AE  2               ;----------------------------------------------------------------
0048AE  2               mon_spawn:
0048AE  2  85 20                STA     tmp0            ; type
0048B0  2  20 9C 48             JSR     mon_find_free
0048B3  2  90 1C                BCC     @full
0048B5  2  A5 20                LDA     tmp0
0048B7  2  9D A9 6E             STA     mon_type,X
0048BA  2  A5 2C                LDA     tgtx
0048BC  2  9D B5 6E             STA     mon_x,X
0048BF  2  A5 2D                LDA     tgty
0048C1  2  9D C1 6E             STA     mon_y,X
0048C4  2  A4 20                LDY     tmp0
0048C6  2  B9 3C 48             LDA     mtype_hp,Y
0048C9  2  9D CD 6E             STA     mon_hp,X
0048CC  2  A9 00                LDA     #0
0048CE  2  9D D9 6E             STA     mon_state,X
0048D1  2               @full:
0048D1  2  60                   RTS
0048D2  2               
0048D2  2               ;----------------------------------------------------------------
0048D2  2               ; mon_at - is there a live monster at (tgtx,tgty)?
0048D2  2               ;          Returns X = slot and C=1 if found, else C=0.
0048D2  2               ;----------------------------------------------------------------
0048D2  2               mon_at:
0048D2  2  A2 00                LDX     #0
0048D4  2               @a:
0048D4  2  BD A9 6E             LDA     mon_type,X
0048D7  2  C9 00                CMP     #M_NONE
0048D9  2  F0 10                BEQ     @nextslot
0048DB  2  BD B5 6E             LDA     mon_x,X
0048DE  2  C5 2C                CMP     tgtx
0048E0  2  D0 09                BNE     @nextslot
0048E2  2  BD C1 6E             LDA     mon_y,X
0048E5  2  C5 2D                CMP     tgty
0048E7  2  D0 02                BNE     @nextslot
0048E9  2  38                   SEC
0048EA  2  60                   RTS
0048EB  2               @nextslot:
0048EB  2  E8                   INX
0048EC  2  E0 0C                CPX     #MAXMON
0048EE  2  D0 E4                BNE     @a
0048F0  2  18                   CLC
0048F1  2  60                   RTS
0048F2  2               
0048F2  2               ;----------------------------------------------------------------
0048F2  2               ; mon_kill - remove monster in slot X.
0048F2  2               ;----------------------------------------------------------------
0048F2  2               mon_kill:
0048F2  2  A9 00                LDA     #M_NONE
0048F4  2  9D A9 6E             STA     mon_type,X
0048F7  2  9D D9 6E             STA     mon_state,X
0048FA  2  60                   RTS
0048FB  2               
0048FB  2               ;----------------------------------------------------------------
0048FB  2               ; save_overworld_monsters / restore_overworld_monsters
0048FB  2               ; Preserve the roaming group while an interior reuses mon_*.
0048FB  2               ;----------------------------------------------------------------
0048FB  2               save_overworld_monsters:
0048FB  2  A2 00                LDX     #0
0048FD  2               @save:
0048FD  2  BD A9 6E             LDA     mon_type,X
004900  2  9D E5 6E             STA     ow_mon_type,X
004903  2  BD B5 6E             LDA     mon_x,X
004906  2  9D F1 6E             STA     ow_mon_x,X
004909  2  BD C1 6E             LDA     mon_y,X
00490C  2  9D FD 6E             STA     ow_mon_y,X
00490F  2  BD CD 6E             LDA     mon_hp,X
004912  2  9D 09 6F             STA     ow_mon_hp,X
004915  2  BD D9 6E             LDA     mon_state,X
004918  2  9D 15 6F             STA     ow_mon_state,X
00491B  2  E8                   INX
00491C  2  E0 0C                CPX     #MAXMON
00491E  2  D0 DD                BNE     @save
004920  2  60                   RTS
004921  2               
004921  2               restore_overworld_monsters:
004921  2  A2 00                LDX     #0
004923  2               @restore:
004923  2  BD E5 6E             LDA     ow_mon_type,X
004926  2  9D A9 6E             STA     mon_type,X
004929  2  BD F1 6E             LDA     ow_mon_x,X
00492C  2  9D B5 6E             STA     mon_x,X
00492F  2  BD FD 6E             LDA     ow_mon_y,X
004932  2  9D C1 6E             STA     mon_y,X
004935  2  BD 09 6F             LDA     ow_mon_hp,X
004938  2  9D CD 6E             STA     mon_hp,X
00493B  2  BD 15 6F             LDA     ow_mon_state,X
00493E  2  9D D9 6E             STA     mon_state,X
004941  2  E8                   INX
004942  2  E0 0C                CPX     #MAXMON
004944  2  D0 DD                BNE     @restore
004946  2               ; only reinforce a world reduced below three living monsters
004946  2  20 55 49             JSR     count_live_monsters
004949  2  C9 03                CMP     #3
00494B  2  B0 07                BCS     @done
00494D  2  A9 04                LDA     #4              ; four placement attempts, not four guarantees
00494F  2  85 24                STA     cnt0
004951  2  4C 6D 49             JMP     spawn_overworld_attempts
004954  2               @done:
004954  2  60                   RTS
004955  2               
004955  2               ; count_live_monsters - return live slot count in A.
004955  2               count_live_monsters:
004955  2  A2 00                LDX     #0
004957  2  A0 00                LDY     #0
004959  2               @count:
004959  2  BD A9 6E             LDA     mon_type,X
00495C  2  F0 01                BEQ     @next
00495E  2  C8                   INY
00495F  2               @next:
00495F  2  E8                   INX
004960  2  E0 0C                CPX     #MAXMON
004962  2  D0 F5                BNE     @count
004964  2  98                   TYA
004965  2  60                   RTS
004966  2               
004966  2               ;----------------------------------------------------------------
004966  2               ; spawn_overworld_monsters - scatter a handful of monsters on the
004966  2               ; overworld at random passable land tiles near the player.
004966  2               ;----------------------------------------------------------------
004966  2               spawn_overworld_monsters:
004966  2  20 8C 48             JSR     mon_clear_all
004969  2  A9 04                LDA     #4              ; only a few roaming monsters at a time
00496B  2  85 24                STA     cnt0
00496D  2               spawn_overworld_attempts:
00496D  2               @loop:
00496D  2               ; place in a ring roughly 6..21 tiles from the player: far
00496D  2               ; enough not to crowd you, near enough to be encountered.
00496D  2               ; offset = (rand(0..15) + 6), sign random per axis.
00496D  2  A9 10                LDA     #16
00496F  2  20 8A 0E             JSR     rng_mod
004972  2  18                   CLC
004973  2  69 06                ADC     #6              ; 6..21
004975  2  85 21                STA     tmp1            ; magnitude
004977  2  20 6A 0E             JSR     rng_next        ; random sign bit
00497A  2  29 01                AND     #1
00497C  2  F0 09                BEQ     @xplus
00497E  2  AD 7B 6D             LDA     px
004981  2  38                   SEC
004982  2  E5 21                SBC     tmp1
004984  2  4C 8D 49             JMP     @setx
004987  2               @xplus:
004987  2  AD 7B 6D             LDA     px
00498A  2  18                   CLC
00498B  2  65 21                ADC     tmp1
00498D  2               @setx:
00498D  2  85 2C                STA     tgtx
00498F  2  A9 10                LDA     #16
004991  2  20 8A 0E             JSR     rng_mod
004994  2  18                   CLC
004995  2  69 06                ADC     #6
004997  2  85 21                STA     tmp1
004999  2  20 6A 0E             JSR     rng_next
00499C  2  29 01                AND     #1
00499E  2  F0 09                BEQ     @yplus
0049A0  2  AD 7C 6D             LDA     py
0049A3  2  38                   SEC
0049A4  2  E5 21                SBC     tmp1
0049A6  2  4C AF 49             JMP     @sety
0049A9  2               @yplus:
0049A9  2  AD 7C 6D             LDA     py
0049AC  2  18                   CLC
0049AD  2  65 21                ADC     tmp1
0049AF  2               @sety:
0049AF  2  85 2D                STA     tgty
0049B1  2               ; reject the player's own tile (don't spawn on top of you)
0049B1  2  A5 2C                LDA     tgtx
0049B3  2  CD 7B 6D             CMP     px
0049B6  2  D0 07                BNE     @okpos
0049B8  2  A5 2D                LDA     tgty
0049BA  2  CD 7C 6D             CMP     py
0049BD  2  F0 43                BEQ     @skip
0049BF  2               @okpos:
0049BF  2               ; must be passable grass/forest (not water/mountain/town...)
0049BF  2  20 F4 1E             JSR     tileat
0049C2  2  A6 2E                LDX     tgttile
0049C4  2  BD 8B 1D             LDA     tile_prop,X
0049C7  2  29 01                AND     #P_PASS
0049C9  2  F0 37                BEQ     @skip
0049CB  2  BD 8B 1D             LDA     tile_prop,X
0049CE  2  29 8C                AND     #(P_TOWN|P_DUNG|P_CASTLE)
0049D0  2  D0 30                BNE     @skip           ; don't sit on a location entrance
0049D2  2               ; not already occupied by a monster?
0049D2  2  20 D2 48             JSR     mon_at
0049D5  2  B0 2B                BCS     @skip
0049D7  2               ; select a weighted encounter for this monster's region. Once the
0049D7  2               ; lair is open, use the tougher second half of the encounter table.
0049D7  2  A9 08                LDA     #REGION_ENC_SIZE
0049D9  2  20 8A 0E             JSR     rng_mod
0049DC  2  85 22                STA     tmp2
0049DE  2  A5 2D                LDA     tgty
0049E0  2  20 E3 1E             JSR     region_from_y
0049E3  2  0A                   ASL     A
0049E4  2  0A                   ASL     A
0049E5  2  0A                   ASL     A               ; region * REGION_ENC_SIZE
0049E6  2  85 23                STA     tmp3
0049E8  2  AD 91 6D             LDA     queststate
0049EB  2  C9 03                CMP     #QUEST_DUNG_OPEN
0049ED  2  90 07                BCC     @encounter_index
0049EF  2  A5 23                LDA     tmp3
0049F1  2  18                   CLC
0049F2  2  69 18                ADC     #REGION_LATE_OFS
0049F4  2  85 23                STA     tmp3
0049F6  2               @encounter_index:
0049F6  2  A5 23                LDA     tmp3
0049F8  2  18                   CLC
0049F9  2  65 22                ADC     tmp2
0049FB  2  A8                   TAY
0049FC  2  B9 5C 48             LDA     region_encounters,Y
0049FF  2  20 AE 48             JSR     mon_spawn
004A02  2               @skip:
004A02  2  C6 24                DEC     cnt0
004A04  2  F0 03                BEQ     @done
004A06  2  4C 6D 49             JMP     @loop
004A09  2               @done:
004A09  2  60                   RTS
004A0A  2               
004A0A  2               ;----------------------------------------------------------------
004A0A  2               ; spawn_dungeon_monsters - populate the three authored dungeon zones.
004A0A  2               ;----------------------------------------------------------------
004A0A  2               spawn_dungeon_monsters:
004A0A  2  20 8C 48             JSR     mon_clear_all
004A0D  2  A9 00                LDA     #BREATH_NONE
004A0F  2  8D 92 6D             STA     boss_breath_dir
004A12  2               ; once slain, the dragon and its guards do not return
004A12  2  AD 91 6D             LDA     queststate
004A15  2  C9 04                CMP     #QUEST_DRAGON_DEAD
004A17  2  B0 34                BCS     @done
004A19  2               ; the dragon waits in the open southern chamber
004A19  2  A9 1B                LDA     #DRAGON_X
004A1B  2  85 2C                STA     tgtx
004A1D  2  A9 12                LDA     #DRAGON_Y
004A1F  2  85 2D                STA     tgty
004A21  2  A9 06                LDA     #M_BOSS
004A23  2  20 AE 48             JSR     mon_spawn
004A26  2               ; one authored guard in each approach zone
004A26  2  A9 09                LDA     #9
004A28  2  85 2C                STA     tgtx
004A2A  2  A9 05                LDA     #5
004A2C  2  85 2D                STA     tgty
004A2E  2  A9 03                LDA     #M_SKELETON
004A30  2  20 AE 48             JSR     mon_spawn
004A33  2  A9 0E                LDA     #14
004A35  2  85 2C                STA     tgtx
004A37  2  A9 0B                LDA     #11
004A39  2  85 2D                STA     tgty
004A3B  2  A9 04                LDA     #M_THIEF
004A3D  2  20 AE 48             JSR     mon_spawn
004A40  2  A9 17                LDA     #23
004A42  2  85 2C                STA     tgtx
004A44  2  A9 0F                LDA     #15
004A46  2  85 2D                STA     tgty
004A48  2  A9 05                LDA     #M_TROLL
004A4A  2  20 AE 48             JSR     mon_spawn
004A4D  2               @done:
004A4D  2  60                   RTS
004A4E  2               
004A4E  2               ;----------------------------------------------------------------
004A4E  2               ; spawn_shrine_monsters - the Wyrm Warden appears only while the
004A4E  2               ; key quest is active. Once defeated, the shrine remains cleared.
004A4E  2               ;----------------------------------------------------------------
004A4E  2               spawn_shrine_monsters:
004A4E  2  20 8C 48             JSR     mon_clear_all
004A51  2  AD 91 6D             LDA     queststate
004A54  2  C9 01                CMP     #QUEST_FIND_KEY
004A56  2  D0 0D                BNE     @done
004A58  2  A9 1B                LDA     #WARDEN_X
004A5A  2  85 2C                STA     tgtx
004A5C  2  A9 11                LDA     #WARDEN_Y
004A5E  2  85 2D                STA     tgty
004A60  2  A9 07                LDA     #M_WARDEN
004A62  2  20 AE 48             JSR     mon_spawn
004A65  2               @done:
004A65  2  60                   RTS
004A66  2               
004A66  2               ;----------------------------------------------------------------
004A66  2               ; draw_monsters_vram - overlay all visible monsters in the viewport.
004A66  2               ; Called by render_view while video is paged in.
004A66  2               ;----------------------------------------------------------------
004A66  2               draw_monsters_vram:
004A66  2  A2 00                LDX     #0
004A68  2  86 2F                STX     monidx
004A6A  2               @dm:
004A6A  2  A6 2F                LDX     monidx
004A6C  2  BD A9 6E             LDA     mon_type,X
004A6F  2  C9 00                CMP     #M_NONE
004A71  2  F0 1A                BEQ     @next
004A73  2               ; set world coords + glyph/color, then plot if visible
004A73  2  BD B5 6E             LDA     mon_x,X
004A76  2  85 2C                STA     tgtx
004A78  2  BD C1 6E             LDA     mon_y,X
004A7B  2  85 2D                STA     tgty
004A7D  2  BC A9 6E             LDY     mon_type,X
004A80  2  B9 2C 48             LDA     mtype_glyph,Y
004A83  2  85 24                STA     cnt0            ; glyph (cnt0/cnt1 survive rowbase)
004A85  2  B9 34 48             LDA     mtype_color,Y
004A88  2  85 25                STA     cnt1            ; color
004A8A  2  20 21 40             JSR     plot_view_cell
004A8D  2               @next:
004A8D  2  E6 2F                INC     monidx
004A8F  2  A5 2F                LDA     monidx
004A91  2  C9 0C                CMP     #MAXMON
004A93  2  D0 D5                BNE     @dm
004A95  2  60                   RTS
004A96  2               
004A96  2               ;----------------------------------------------------------------
004A96  2               ; draw_dragon_telegraph_vram - overlay the warned fire lane while
004A96  2               ; the dragon is preparing a breath attack.
004A96  2               ; Called by render_view while video is paged in.
004A96  2               ;----------------------------------------------------------------
004A96  2               draw_dragon_telegraph_vram:
004A96  2  AD 89 6D             LDA     loc
004A99  2  C9 02                CMP     #LOC_DUNG
004A9B  2  D0 3B                BNE     @done
004A9D  2  AD 92 6D             LDA     boss_breath_dir
004AA0  2  F0 36                BEQ     @done
004AA2  2               ; find the live dragon
004AA2  2  A2 00                LDX     #0
004AA4  2               @find:
004AA4  2  BD A9 6E             LDA     mon_type,X
004AA7  2  C9 06                CMP     #M_BOSS
004AA9  2  F0 06                BEQ     @found
004AAB  2  E8                   INX
004AAC  2  E0 0C                CPX     #MAXMON
004AAE  2  D0 F4                BNE     @find
004AB0  2  60                   RTS
004AB1  2               @found:
004AB1  2  BD B5 6E             LDA     mon_x,X
004AB4  2  85 2C                STA     tgtx
004AB6  2  BD C1 6E             LDA     mon_y,X
004AB9  2  85 2D                STA     tgty
004ABB  2               @lane:
004ABB  2  20 5D 4C             JSR     dragon_advance_target
004ABE  2  20 F4 1E             JSR     tileat
004AC1  2  A6 2E                LDX     tgttile
004AC3  2  BD 8B 1D             LDA     tile_prop,X
004AC6  2  29 01                AND     #P_PASS
004AC8  2  F0 0E                BEQ     @done
004ACA  2  A9 F4                LDA     #MG_BREATH
004ACC  2  85 24                STA     cnt0
004ACE  2  A9 4E                LDA     #C_BREATH
004AD0  2  85 25                STA     cnt1
004AD2  2  20 21 40             JSR     plot_view_cell
004AD5  2  4C BB 4A             JMP     @lane
004AD8  2               @done:
004AD8  2  60                   RTS
004AD9  2               
004AD9  2               ;----------------------------------------------------------------
004AD9  2               ; mon_act - move/attack for every monster (called once per turn).
004AD9  2               ; Monsters in LOC_TOWN never act (towns are safe).
004AD9  2               ;   A monster adjacent to the player attacks; otherwise it steps
004AD9  2               ;   one tile toward the player if the destination is passable and
004AD9  2               ;   unoccupied.
004AD9  2               ;----------------------------------------------------------------
004AD9  2               mon_act:
004AD9  2  EE 94 6D             INC     turn_phase
004ADC  2  AD 89 6D             LDA     loc
004ADF  2  C9 01                CMP     #LOC_TOWN
004AE1  2  D0 01                BNE     :+
004AE3  2  60                   RTS                     ; safe in town
004AE4  2               :
004AE4  2  A2 00                LDX     #0
004AE6  2  86 2F                STX     monidx
004AE8  2               @ma:
004AE8  2  A6 2F                LDX     monidx
004AEA  2  BD A9 6E             LDA     mon_type,X
004AED  2  C9 00                CMP     #M_NONE
004AEF  2  F0 3F                BEQ     @next
004AF1  2  C9 02                CMP     #M_SNAKE
004AF3  2  D0 06                BNE     @ckskeleton
004AF5  2  20 3C 4B             JSR     snake_act
004AF8  2  4C 30 4B             JMP     @next
004AFB  2               @ckskeleton:
004AFB  2  C9 03                CMP     #M_SKELETON
004AFD  2  D0 06                BNE     @ckthief
004AFF  2  20 3F 4B             JSR     skeleton_act
004B02  2  4C 30 4B             JMP     @next
004B05  2               @ckthief:
004B05  2  C9 04                CMP     #M_THIEF
004B07  2  D0 06                BNE     @cktroll
004B09  2  20 79 4B             JSR     thief_act
004B0C  2  4C 30 4B             JMP     @next
004B0F  2               @cktroll:
004B0F  2  C9 05                CMP     #M_TROLL
004B11  2  D0 06                BNE     @ckwarden
004B13  2  20 8E 4B             JSR     troll_act
004B16  2  4C 30 4B             JMP     @next
004B19  2               @ckwarden:
004B19  2  C9 07                CMP     #M_WARDEN
004B1B  2  D0 06                BNE     @ckdragon
004B1D  2  20 78 4C             JSR     warden_act
004B20  2  4C 30 4B             JMP     @next
004B23  2               @ckdragon:
004B23  2  C9 06                CMP     #M_BOSS
004B25  2  D0 06                BNE     @normal
004B27  2  20 B2 4B             JSR     dragon_act
004B2A  2  4C 30 4B             JMP     @next
004B2D  2               @normal:
004B2D  2               ; distance to player: dxv = px - mon_x ; dyv = py - mon_y
004B2D  2               ; adjacency test (|dx|<=1 && |dy|<=1 && not both 0)
004B2D  2  20 B0 4C             JSR     mon_step_or_attack
004B30  2               @next:
004B30  2  E6 2F                INC     monidx
004B32  2  A5 2F                LDA     monidx
004B34  2  C9 0C                CMP     #MAXMON
004B36  2  F0 03                BEQ     @ret
004B38  2  4C E8 4A             JMP     @ma
004B3B  2               @ret:
004B3B  2  60                   RTS
004B3C  2               
004B3C  2               ;----------------------------------------------------------------
004B3C  2               ; Ordinary monster identities.
004B3C  2               ;----------------------------------------------------------------
004B3C  2               
004B3C  2               ; Snakes surge up to two cells per turn, like a weaker Warden.
004B3C  2               snake_act:
004B3C  2  4C 78 4C             JMP     warden_act
004B3F  2               
004B3F  2               ; Skeletons hold their ground until the player comes within four
004B3F  2               ; cells, then remain awake and pursue normally.
004B3F  2               skeleton_act:
004B3F  2  A6 2F                LDX     monidx
004B41  2  BD D9 6E             LDA     mon_state,X
004B44  2  D0 2F                BNE     @awake
004B46  2  38                   SEC
004B47  2  AD 7B 6D             LDA     px
004B4A  2  FD B5 6E             SBC     mon_x,X
004B4D  2  20 E9 4D             JSR     abs_a
004B50  2  C9 05                CMP     #5
004B52  2  B0 24                BCS     @done
004B54  2  A6 2F                LDX     monidx
004B56  2  38                   SEC
004B57  2  AD 7C 6D             LDA     py
004B5A  2  FD C1 6E             SBC     mon_y,X
004B5D  2  20 E9 4D             JSR     abs_a
004B60  2  C9 05                CMP     #5
004B62  2  B0 14                BCS     @done
004B64  2  A6 2F                LDX     monidx
004B66  2  A9 01                LDA     #1
004B68  2  9D D9 6E             STA     mon_state,X
004B6B  2  20 CA 10             JSR     sfx_wake
004B6E  2  A9 8E A0 5B          PRINTMSG_MSG m_skeleton_wakes
004B72  2  20 CA 40     
004B75  2               @awake:
004B75  2  4C B0 4C             JMP     mon_step_or_attack
004B78  2               @done:
004B78  2  60                   RTS
004B79  2               
004B79  2               ; Thieves approach until adjacent, steal once, then flee.
004B79  2               thief_act:
004B79  2  A6 2F                LDX     monidx
004B7B  2  BD D9 6E             LDA     mon_state,X
004B7E  2  F0 03                BEQ     @hunting
004B80  2  4C 77 4D             JMP     mon_step_away
004B83  2               @hunting:
004B83  2  20 8C 4C             JSR     mon_is_adjacent
004B86  2  90 03                BCC     @approach
004B88  2  4C 90 56             JMP     thief_steals_player
004B8B  2               @approach:
004B8B  2  4C B0 4C             JMP     mon_step_or_attack
004B8E  2               
004B8E  2               ; Trolls act every other turn and recover one HP before acting.
004B8E  2               troll_act:
004B8E  2  AD 94 6D             LDA     turn_phase
004B91  2  29 01                AND     #1
004B93  2  D0 1C                BNE     @done
004B95  2  A6 2F                LDX     monidx
004B97  2  A0 05                LDY     #M_TROLL
004B99  2  BD CD 6E             LDA     mon_hp,X
004B9C  2  D9 3C 48             CMP     mtype_hp,Y
004B9F  2  B0 0D                BCS     @act
004BA1  2  FE CD 6E             INC     mon_hp,X
004BA4  2  20 8B 10             JSR     sfx_regen
004BA7  2  A9 BC A0 5B          PRINTMSG_MSG m_troll_regens
004BAB  2  20 CA 40     
004BAE  2               @act:
004BAE  2  4C B0 4C             JMP     mon_step_or_attack
004BB1  2               @done:
004BB1  2  60                   RTS
004BB2  2               
004BB2  2               ;----------------------------------------------------------------
004BB2  2               ; dragon_act - breathe down a warned straight lane on the following
004BB2  2               ; turn, otherwise warn when the player is in clear line of sight.
004BB2  2               ; The dragon uses normal melee and pursuit when no breath is ready.
004BB2  2               ;----------------------------------------------------------------
004BB2  2               dragon_act:
004BB2  2  AD 92 6D             LDA     boss_breath_dir
004BB5  2  F0 03                BEQ     @ready
004BB7  2  4C 13 4C             JMP     dragon_fire_breath
004BBA  2               @ready:
004BBA  2  20 8C 4C             JSR     mon_is_adjacent
004BBD  2  B0 05                BCS     @normal
004BBF  2  20 C8 4B             JSR     dragon_prepare_breath
004BC2  2  B0 03                BCS     @done
004BC4  2               @normal:
004BC4  2  4C B0 4C             JMP     mon_step_or_attack
004BC7  2               @done:
004BC7  2  60                   RTS
004BC8  2               
004BC8  2               ; dragon_prepare_breath - arm a breath attack if the player and
004BC8  2               ; dragon share a clear row or column. Returns C=1 when armed.
004BC8  2               dragon_prepare_breath:
004BC8  2  A6 2F                LDX     monidx
004BCA  2  BD C1 6E             LDA     mon_y,X
004BCD  2  CD 7C 6D             CMP     py
004BD0  2  D0 10                BNE     @vertical
004BD2  2               ; same row
004BD2  2  BD B5 6E             LDA     mon_x,X
004BD5  2  CD 7B 6D             CMP     px
004BD8  2  90 04                BCC     @right
004BDA  2  A9 03                LDA     #BREATH_LEFT
004BDC  2  D0 1A                BNE     @armed
004BDE  2               @right:
004BDE  2  A9 04                LDA     #BREATH_RIGHT
004BE0  2  D0 16                BNE     @armed
004BE2  2               @vertical:
004BE2  2  BD B5 6E             LDA     mon_x,X
004BE5  2  CD 7B 6D             CMP     px
004BE8  2  D0 27                BNE     @no
004BEA  2  BD C1 6E             LDA     mon_y,X
004BED  2  CD 7C 6D             CMP     py
004BF0  2  90 04                BCC     @down
004BF2  2  A9 01                LDA     #BREATH_UP
004BF4  2  D0 02                BNE     @armed
004BF6  2               @down:
004BF6  2  A9 02                LDA     #BREATH_DOWN
004BF8  2               @armed:
004BF8  2  8D 92 6D             STA     boss_breath_dir
004BFB  2  20 30 4C             JSR     dragon_line_hits_player
004BFE  2  90 0C                BCC     @blocked
004C00  2  20 C4 11             JSR     sfx_breath_warn
004C03  2  A9 AF A0 5A          PRINTMSG_MSG m_breath_warn
004C07  2  20 CA 40     
004C0A  2  38                   SEC
004C0B  2  60                   RTS
004C0C  2               @blocked:
004C0C  2  A9 00                LDA     #BREATH_NONE
004C0E  2  8D 92 6D             STA     boss_breath_dir
004C11  2               @no:
004C11  2  18                   CLC
004C12  2  60                   RTS
004C13  2               
004C13  2               ; dragon_fire_breath - resolve the prepared lane after the player
004C13  2               ; has had one turn to step clear.
004C13  2               dragon_fire_breath:
004C13  2  20 30 4C             JSR     dragon_line_hits_player
004C16  2  90 08                BCC     @miss
004C18  2  A9 00                LDA     #BREATH_NONE
004C1A  2  8D 92 6D             STA     boss_breath_dir
004C1D  2  4C 08 57             JMP     dragon_fire_player
004C20  2               @miss:
004C20  2  A9 00                LDA     #BREATH_NONE
004C22  2  8D 92 6D             STA     boss_breath_dir
004C25  2  20 EF 11             JSR     sfx_breath
004C28  2  A9 E5 A0 5A          PRINTMSG_MSG m_breath_miss
004C2C  2  20 CA 40     
004C2F  2  60                   RTS
004C30  2               
004C30  2               ; dragon_line_hits_player - trace the prepared lane from the dragon
004C30  2               ; until blocked. Returns C=1 if the player is currently in it.
004C30  2               dragon_line_hits_player:
004C30  2  A6 2F                LDX     monidx
004C32  2  BD B5 6E             LDA     mon_x,X
004C35  2  85 2C                STA     tgtx
004C37  2  BD C1 6E             LDA     mon_y,X
004C3A  2  85 2D                STA     tgty
004C3C  2               @trace:
004C3C  2  20 5D 4C             JSR     dragon_advance_target
004C3F  2  20 F4 1E             JSR     tileat
004C42  2  A6 2E                LDX     tgttile
004C44  2  BD 8B 1D             LDA     tile_prop,X
004C47  2  29 01                AND     #P_PASS
004C49  2  F0 10                BEQ     @no
004C4B  2  A5 2C                LDA     tgtx
004C4D  2  CD 7B 6D             CMP     px
004C50  2  D0 EA                BNE     @trace
004C52  2  A5 2D                LDA     tgty
004C54  2  CD 7C 6D             CMP     py
004C57  2  D0 E3                BNE     @trace
004C59  2  38                   SEC
004C5A  2  60                   RTS
004C5B  2               @no:
004C5B  2  18                   CLC
004C5C  2  60                   RTS
004C5D  2               
004C5D  2               ; dragon_advance_target - move tgtx/tgty one cell in the prepared
004C5D  2               ; breath direction.
004C5D  2               dragon_advance_target:
004C5D  2  AD 92 6D             LDA     boss_breath_dir
004C60  2  C9 01                CMP     #BREATH_UP
004C62  2  F0 0B                BEQ     @up
004C64  2  C9 02                CMP     #BREATH_DOWN
004C66  2  F0 0A                BEQ     @down
004C68  2  C9 03                CMP     #BREATH_LEFT
004C6A  2  F0 09                BEQ     @left
004C6C  2  E6 2C                INC     tgtx
004C6E  2  60                   RTS
004C6F  2               @up:
004C6F  2  C6 2D                DEC     tgty
004C71  2  60                   RTS
004C72  2               @down:
004C72  2  E6 2D                INC     tgty
004C74  2  60                   RTS
004C75  2               @left:
004C75  2  C6 2C                DEC     tgtx
004C77  2  60                   RTS
004C78  2               
004C78  2               ;----------------------------------------------------------------
004C78  2               ; warden_act - the Wyrm Warden surges up to two tiles per turn.
004C78  2               ; It stops after closing to melee range, so it attacks at most once
004C78  2               ; per turn while remaining much harder to outrun than normal foes.
004C78  2               ;----------------------------------------------------------------
004C78  2               warden_act:
004C78  2  20 8C 4C             JSR     mon_is_adjacent
004C7B  2  B0 0B                BCS     @attack
004C7D  2  20 B0 4C             JSR     mon_step_or_attack
004C80  2  20 8C 4C             JSR     mon_is_adjacent
004C83  2  B0 06                BCS     @done
004C85  2  4C B0 4C             JMP     mon_step_or_attack
004C88  2               @attack:
004C88  2  4C B0 4C             JMP     mon_step_or_attack
004C8B  2               @done:
004C8B  2  60                   RTS
004C8C  2               
004C8C  2               ; mon_is_adjacent - C=1 if monster in monidx is beside the player.
004C8C  2               mon_is_adjacent:
004C8C  2  A6 2F                LDX     monidx
004C8E  2  38                   SEC
004C8F  2  AD 7B 6D             LDA     px
004C92  2  FD B5 6E             SBC     mon_x,X
004C95  2  20 E9 4D             JSR     abs_a
004C98  2  C9 02                CMP     #2
004C9A  2  B0 12                BCS     @no
004C9C  2  A6 2F                LDX     monidx
004C9E  2  38                   SEC
004C9F  2  AD 7C 6D             LDA     py
004CA2  2  FD C1 6E             SBC     mon_y,X
004CA5  2  20 E9 4D             JSR     abs_a
004CA8  2  C9 02                CMP     #2
004CAA  2  B0 02                BCS     @no
004CAC  2  38                   SEC
004CAD  2  60                   RTS
004CAE  2               @no:
004CAE  2  18                   CLC
004CAF  2  60                   RTS
004CB0  2               
004CB0  2               ; mon_step_or_attack - for monster in slot monidx (X on entry).
004CB0  2               mon_step_or_attack:
004CB0  2               ; forests conceal the player from distant pursuers
004CB0  2  A9 00                LDA     #0
004CB2  2  85 25                STA     cnt1
004CB4  2  AD 89 6D             LDA     loc
004CB7  2  D0 15                BNE     @distance
004CB9  2  AD 7B 6D             LDA     px
004CBC  2  85 2C                STA     tgtx
004CBE  2  AD 7C 6D             LDA     py
004CC1  2  85 2D                STA     tgty
004CC3  2  20 F4 1E             JSR     tileat
004CC6  2  A5 2E                LDA     tgttile
004CC8  2  C9 01                CMP     #T_FOREST
004CCA  2  D0 02                BNE     @distance
004CCC  2  E6 25                INC     cnt1
004CCE  2               @distance:
004CCE  2               ; compute signed dx = px - mon_x  -> tmp0 ; dy -> tmp1
004CCE  2  A6 2F                LDX     monidx
004CD0  2  38                   SEC
004CD1  2  AD 7B 6D             LDA     px
004CD4  2  FD B5 6E             SBC     mon_x,X
004CD7  2  85 20                STA     tmp0            ; dx (signed)
004CD9  2  38                   SEC
004CDA  2  AD 7C 6D             LDA     py
004CDD  2  FD C1 6E             SBC     mon_y,X
004CE0  2  85 21                STA     tmp1            ; dy (signed)
004CE2  2               ; |dx| <= 1 ?
004CE2  2  A5 20                LDA     tmp0
004CE4  2  20 E9 4D             JSR     abs_a
004CE7  2  85 22                STA     tmp2            ; |dx|
004CE9  2  A5 21                LDA     tmp1
004CEB  2  20 E9 4D             JSR     abs_a
004CEE  2  85 23                STA     tmp3            ; |dy|
004CF0  2               ; while concealed, monsters outside a five-cell square lose track
004CF0  2  A5 25                LDA     cnt1
004CF2  2  F0 12                BEQ     @adjacency
004CF4  2  A5 22                LDA     tmp2
004CF6  2  C9 06                CMP     #6
004CF8  2  90 03                BCC     :+
004CFA  2  4C 76 4D             JMP     @done
004CFD  2               :
004CFD  2  A5 23                LDA     tmp3
004CFF  2  C9 06                CMP     #6
004D01  2  90 03                BCC     :+
004D03  2  4C 76 4D             JMP     @done
004D06  2               :
004D06  2               @adjacency:
004D06  2               ; adjacency: |dx|<=1 and |dy|<=1
004D06  2  A5 22                LDA     tmp2
004D08  2  C9 02                CMP     #2
004D0A  2  B0 09                BCS     @move
004D0C  2  A5 23                LDA     tmp3
004D0E  2  C9 02                CMP     #2
004D10  2  B0 03                BCS     @move
004D12  2               ; adjacent (and since one of them is the player, not same cell)
004D12  2               ; -> attack the player
004D12  2  4C E3 55             JMP     monster_attacks_player; in combat.asm
004D15  2               @move:
004D15  2               ; step one tile toward player along the larger axis
004D15  2               ; choose step in x: sign of dx
004D15  2  A6 2F                LDX     monidx
004D17  2  BD B5 6E             LDA     mon_x,X
004D1A  2  85 2C                STA     tgtx
004D1C  2  BD C1 6E             LDA     mon_y,X
004D1F  2  85 2D                STA     tgty
004D21  2               ; prefer horizontal if |dx|>=|dy|
004D21  2  A5 22                LDA     tmp2
004D23  2  C5 23                CMP     tmp3
004D25  2  90 10                BCC     @vert
004D27  2               ; horizontal step
004D27  2  A5 20                LDA     tmp0
004D29  2  F0 0C                BEQ     @vert           ; dx==0 -> try vertical
004D2B  2  30 05                BMI     @left
004D2D  2  E6 2C                INC     tgtx
004D2F  2  4C 44 4D             JMP     @trymove
004D32  2               @left:
004D32  2  C6 2C                DEC     tgtx
004D34  2  4C 44 4D             JMP     @trymove
004D37  2               @vert:
004D37  2  A5 21                LDA     tmp1
004D39  2  F0 3B                BEQ     @done           ; dy==0 too -> no move
004D3B  2  30 05                BMI     @up
004D3D  2  E6 2D                INC     tgty
004D3F  2  4C 44 4D             JMP     @trymove
004D42  2               @up:
004D42  2  C6 2D                DEC     tgty
004D44  2               @trymove:
004D44  2               ; passable terrain?
004D44  2  20 F4 1E             JSR     tileat
004D47  2  A6 2E                LDX     tgttile
004D49  2  BD 8B 1D             LDA     tile_prop,X
004D4C  2  29 01                AND     #P_PASS
004D4E  2  F0 26                BEQ     @done           ; blocked terrain
004D50  2               ; monsters do not occupy map-transition landmarks
004D50  2  BD 8B 1D             LDA     tile_prop,X
004D53  2  29 8C                AND     #(P_TOWN|P_DUNG|P_CASTLE)
004D55  2  D0 1F                BNE     @done
004D57  2               ; not onto the player?
004D57  2  A5 2C                LDA     tgtx
004D59  2  CD 7B 6D             CMP     px
004D5C  2  D0 07                BNE     @okcell
004D5E  2  A5 2D                LDA     tgty
004D60  2  CD 7C 6D             CMP     py
004D63  2  F0 11                BEQ     @done           ; would land on player (shouldn't: adjacency handled)
004D65  2               @okcell:
004D65  2               ; not onto another monster?
004D65  2  20 D2 48             JSR     mon_at
004D68  2  B0 0C                BCS     @done           ; occupied
004D6A  2               ; commit move
004D6A  2  A6 2F                LDX     monidx
004D6C  2  A5 2C                LDA     tgtx
004D6E  2  9D B5 6E             STA     mon_x,X
004D71  2  A5 2D                LDA     tgty
004D73  2  9D C1 6E             STA     mon_y,X
004D76  2               @done:
004D76  2  60                   RTS
004D77  2               
004D77  2               ; mon_step_away - move the monster in monidx one cell away from the
004D77  2               ; player along the larger distance axis.
004D77  2               mon_step_away:
004D77  2  A6 2F                LDX     monidx
004D79  2  38                   SEC
004D7A  2  BD B5 6E             LDA     mon_x,X
004D7D  2  ED 7B 6D             SBC     px
004D80  2  85 20                STA     tmp0
004D82  2  38                   SEC
004D83  2  BD C1 6E             LDA     mon_y,X
004D86  2  ED 7C 6D             SBC     py
004D89  2  85 21                STA     tmp1
004D8B  2  A5 20                LDA     tmp0
004D8D  2  20 E9 4D             JSR     abs_a
004D90  2  85 22                STA     tmp2
004D92  2  A5 21                LDA     tmp1
004D94  2  20 E9 4D             JSR     abs_a
004D97  2  85 23                STA     tmp3
004D99  2  A6 2F                LDX     monidx
004D9B  2  BD B5 6E             LDA     mon_x,X
004D9E  2  85 2C                STA     tgtx
004DA0  2  BD C1 6E             LDA     mon_y,X
004DA3  2  85 2D                STA     tgty
004DA5  2  A5 22                LDA     tmp2
004DA7  2  C5 23                CMP     tmp3
004DA9  2  90 0E                BCC     @vert
004DAB  2  A5 20                LDA     tmp0
004DAD  2  30 05                BMI     @left
004DAF  2  E6 2C                INC     tgtx
004DB1  2  4C C4 4D             JMP     @try
004DB4  2               @left:
004DB4  2  C6 2C                DEC     tgtx
004DB6  2  4C C4 4D             JMP     @try
004DB9  2               @vert:
004DB9  2  A5 21                LDA     tmp1
004DBB  2  30 05                BMI     @up
004DBD  2  E6 2D                INC     tgty
004DBF  2  4C C4 4D             JMP     @try
004DC2  2               @up:
004DC2  2  C6 2D                DEC     tgty
004DC4  2               @try:
004DC4  2  20 F4 1E             JSR     tileat
004DC7  2  A6 2E                LDX     tgttile
004DC9  2  BD 8B 1D             LDA     tile_prop,X
004DCC  2  29 01                AND     #P_PASS
004DCE  2  F0 18                BEQ     @done
004DD0  2  BD 8B 1D             LDA     tile_prop,X
004DD3  2  29 8C                AND     #(P_TOWN|P_DUNG|P_CASTLE)
004DD5  2  D0 11                BNE     @done
004DD7  2  20 D2 48             JSR     mon_at
004DDA  2  B0 0C                BCS     @done
004DDC  2  A6 2F                LDX     monidx
004DDE  2  A5 2C                LDA     tgtx
004DE0  2  9D B5 6E             STA     mon_x,X
004DE3  2  A5 2D                LDA     tgty
004DE5  2  9D C1 6E             STA     mon_y,X
004DE8  2               @done:
004DE8  2  60                   RTS
004DE9  2               
004DE9  2               ;----------------------------------------------------------------
004DE9  2               ; abs_a - A = |A| treating A as signed 8-bit.
004DE9  2               ;----------------------------------------------------------------
004DE9  2               abs_a:
004DE9  2  C9 80                CMP     #$80
004DEB  2  90 05                BCC     @pos
004DED  2  49 FF                EOR     #$FF
004DEF  2  18                   CLC
004DF0  2  69 01                ADC     #1
004DF2  2               @pos:
004DF2  2  60                   RTS
004DF3  2               
004DF3  1                       .INCLUDE "player.asm"
004DF3  2               ;______________________________________________________________________________
004DF3  2               ;  player.asm - player movement, map transitions, treasure
004DF3  2               ;______________________________________________________________________________
004DF3  2               
004DF3  2               ;----------------------------------------------------------------
004DF3  2               ; Player starting state on the overworld.
004DF3  2               ;----------------------------------------------------------------
004DF3  2               PLAYER_START_X  = 20
004DF3  2               PLAYER_START_Y  = 9
004DF3  2               
004DF3  2               player_init:
004DF3  2  A9 14                LDA     #PLAYER_START_X
004DF5  2  8D 7B 6D             STA     px
004DF8  2  A9 09                LDA     #PLAYER_START_Y
004DFA  2  8D 7C 6D             STA     py
004DFD  2  A9 1E                LDA     #30
004DFF  2  8D 7D 6D             STA     phealth
004E02  2  8D 7E 6D             STA     pmaxhp
004E05  2  A9 01                LDA     #1
004E07  2  8D 7F 6D             STA     plevel
004E0A  2  A9 00                LDA     #0
004E0C  2  8D 80 6D             STA     pxp
004E0F  2  8D 81 6D             STA     pxp+1
004E12  2  A9 32                LDA     #50
004E14  2  8D 82 6D             STA     pgold
004E17  2  A9 00                LDA     #0
004E19  2  8D 83 6D             STA     pgold+1
004E1C  2  A9 FA 8D 84          SETW16  pfood, 250
004E20  2  6D A9 00 8D  
004E24  2  85 6D        
004E26  2  A9 00                LDA     #0
004E28  2  8D 86 6D             STA     ppotions
004E2B  2  A9 01                LDA     #1
004E2D  2  8D 87 6D             STA     pweapon         ; dagger
004E30  2  A9 00                LDA     #0
004E32  2  8D 88 6D             STA     parmor          ; clothes
004E35  2  A9 00                LDA     #LOC_WORLD
004E37  2  8D 89 6D             STA     loc
004E3A  2  A9 00                LDA     #0
004E3C  2  8D 8A 6D             STA     town_id
004E3F  2  8D 8B 6D             STA     discovery_flags
004E42  2  8D 90 6D             STA     bosskilled
004E45  2  8D 91 6D             STA     queststate
004E48  2  8D 92 6D             STA     boss_breath_dir
004E4B  2  8D 93 6D             STA     poison_turns
004E4E  2  8D 94 6D             STA     turn_phase
004E51  2  8D 95 6D             STA     guard_active
004E54  2  8D 96 6D             STA     attack_flags
004E57  2  60                   RTS
004E58  2               
004E58  2               ;----------------------------------------------------------------
004E58  2               ; try_move - attempt to move the player by (dx,dy).
004E58  2               ;   IN: dx, dy = signed -1/0/+1 deltas
004E58  2               ;   Effects: combat on bump, terrain block, town/dungeon entry,
004E58  2               ;   treasure pickup, exit interiors, food cost.  Monsters act after
004E58  2               ;   a successful step (handled by caller via did_move flag).
004E58  2               ;   OUT: did_move (game var) = 1 if a turn was consumed.
004E58  2               ;----------------------------------------------------------------
004E58  2               try_move:
004E58  2  A9 00                LDA     #0
004E5A  2  8D 97 6D             STA     did_move
004E5D  2               ; target = (px+dx, py+dy)
004E5D  2  18                   CLC
004E5E  2  AD 7B 6D             LDA     px
004E61  2  65 2A                ADC     dx
004E63  2  85 2C                STA     tgtx
004E65  2  18                   CLC
004E66  2  AD 7C 6D             LDA     py
004E69  2  65 2B                ADC     dy
004E6B  2  85 2D                STA     tgty
004E6D  2               
004E6D  2               ; monster there? -> attack (consumes the turn)
004E6D  2  20 D2 48             JSR     mon_at
004E70  2  90 09                BCC     @noenemy
004E72  2               ; X = monster slot ; resolve combat
004E72  2  20 2C 54             JSR     player_attacks_monster
004E75  2  A9 01                LDA     #1
004E77  2  8D 97 6D             STA     did_move
004E7A  2  60                   RTS
004E7B  2               @noenemy:
004E7B  2               ; look at the terrain
004E7B  2  20 F4 1E             JSR     tileat          ; -> tgttile
004E7E  2  A6 2E                LDX     tgttile
004E80  2  BD 8B 1D             LDA     tile_prop,X
004E83  2  85 20                STA     tmp0            ; property bits
004E85  2  29 01                AND     #P_PASS
004E87  2  D0 0B                BNE     @passable
004E89  2               ; blocked
004E89  2  20 FB 10             JSR     sfx_blocked
004E8C  2  A9 08 A0 58          PRINTMSG_MSG m_blocked
004E90  2  20 CA 40     
004E93  2  60                   RTS                     ; no turn consumed on a wall bump
004E94  2               @passable:
004E94  2               ; check special tiles
004E94  2  A5 20                LDA     tmp0
004E96  2  29 04                AND     #P_TOWN
004E98  2  F0 06                BEQ     @ck_castle
004E9A  2  20 FB 48             JSR     save_overworld_monsters
004E9D  2  4C 60 52             JMP     enter_town
004EA0  2               @ck_castle:
004EA0  2  A5 20                LDA     tmp0
004EA2  2  29 80                AND     #P_CASTLE
004EA4  2  F0 06                BEQ     @ck_dung
004EA6  2  20 FB 48             JSR     save_overworld_monsters
004EA9  2  4C B5 52             JMP     enter_castle
004EAC  2               @ck_dung:
004EAC  2  A5 20                LDA     tmp0
004EAE  2  29 08                AND     #P_DUNG
004EB0  2  F0 06                BEQ     @ck_exit
004EB2  2  20 FB 48             JSR     save_overworld_monsters
004EB5  2  4C F0 52             JMP     enter_dungeon
004EB8  2               @ck_exit:
004EB8  2  A5 20                LDA     tmp0
004EBA  2  29 10                AND     #P_EXIT
004EBC  2  F0 03                BEQ     @ck_treas
004EBE  2  4C 74 53             JMP     leave_interior
004EC1  2               @ck_treas:
004EC1  2               ; commit the move first
004EC1  2  A5 2C                LDA     tgtx
004EC3  2  8D 7B 6D             STA     px
004EC6  2  A5 2D                LDA     tgty
004EC8  2  8D 7C 6D             STA     py
004ECB  2  A9 01                LDA     #1
004ECD  2  8D 97 6D             STA     did_move
004ED0  2               ; treasure?
004ED0  2  A5 20                LDA     tmp0
004ED2  2  29 20                AND     #P_TREAS
004ED4  2  F0 03                BEQ     @food
004ED6  2  20 29 51             JSR     collect_treasure
004ED9  2               @food:
004ED9  2               ; terrain sets the base travel cost: roads and bridges are free,
004ED9  2               ; ordinary ground costs one ration, and marshes cost two.
004ED9  2  A9 01                LDA     #1
004EDB  2  85 22                STA     tmp2
004EDD  2  AD 89 6D             LDA     loc
004EE0  2  D0 19                BNE     @armor_cost
004EE2  2  A5 2E                LDA     tgttile
004EE4  2  C9 07                CMP     #T_ROAD
004EE6  2  F0 0F                BEQ     @easy_travel
004EE8  2  C9 08                CMP     #T_BRIDGE
004EEA  2  F0 0B                BEQ     @easy_travel
004EEC  2  C9 10                CMP     #T_MARSH
004EEE  2  D0 0B                BNE     @armor_cost
004EF0  2  A9 02                LDA     #2
004EF2  2  85 22                STA     tmp2
004EF4  2  4C FB 4E             JMP     @armor_cost
004EF7  2               @easy_travel:
004EF7  2  A9 00                LDA     #0
004EF9  2  85 22                STA     tmp2
004EFB  2               @armor_cost:
004EFB  2               ; plate armor adds one ration to any successful step
004EFB  2  AE 88 6D             LDX     parmor
004EFE  2  E0 03                CPX     #3
004F00  2  D0 02                BNE     @consume_food
004F02  2  E6 22                INC     tmp2
004F04  2               @consume_food:
004F04  2  A5 22                LDA     tmp2
004F06  2  F0 08                BEQ     @terrain_effect
004F08  2  20 22 4F             JSR     consume_food_unit
004F0B  2  C6 22                DEC     tmp2
004F0D  2  4C 04 4F             JMP     @consume_food
004F10  2               @terrain_effect:
004F10  2               ; marshes may poison the traveler after movement is committed
004F10  2  AD 89 6D             LDA     loc
004F13  2  D0 09                BNE     @discoveries
004F15  2  A5 2E                LDA     tgttile
004F17  2  C9 10                CMP     #T_MARSH
004F19  2  D0 03                BNE     @discoveries
004F1B  2  20 3C 4F             JSR     marsh_hazard
004F1E  2               @discoveries:
004F1E  2  20 6D 4F             JSR     check_overworld_discovery
004F21  2  60                   RTS
004F22  2               
004F22  2               ;----------------------------------------------------------------
004F22  2               ; consume_food_unit - consume one provision if any remain.
004F22  2               ;----------------------------------------------------------------
004F22  2               consume_food_unit:
004F22  2  AD 84 6D             LDA     pfood
004F25  2  0D 85 6D             ORA     pfood+1
004F28  2  F0 11                BEQ     @done
004F2A  2  38                   SEC
004F2B  2  AD 84 6D             LDA     pfood
004F2E  2  E9 01                SBC     #1
004F30  2  8D 84 6D             STA     pfood
004F33  2  AD 85 6D             LDA     pfood+1
004F36  2  E9 00                SBC     #0
004F38  2  8D 85 6D             STA     pfood+1
004F3B  2               @done:
004F3B  2  60                   RTS
004F3C  2               
004F3C  2               ;----------------------------------------------------------------
004F3C  2               ; marsh_hazard - marsh travel can inflict poison. Leather armor
004F3C  2               ; reduces the chance from one-in-eight to one-in-sixteen.
004F3C  2               ;----------------------------------------------------------------
004F3C  2               marsh_hazard:
004F3C  2  AE 88 6D             LDX     parmor
004F3F  2  E0 01                CPX     #1
004F41  2  D0 04                BNE     @normal_risk
004F43  2  A9 10                LDA     #16
004F45  2  D0 02                BNE     @roll
004F47  2               @normal_risk:
004F47  2  A9 08                LDA     #8
004F49  2               @roll:
004F49  2  20 9A 0E             JSR     rng_d
004F4C  2  C9 01                CMP     #1
004F4E  2  D0 1C                BNE     @safe
004F50  2  AD 93 6D             LDA     poison_turns
004F53  2  D0 08                BNE     @refresh
004F55  2  A9 84                LDA     #$84            ; skip the immediate status tick
004F57  2  8D 93 6D             STA     poison_turns
004F5A  2  4C 62 4F             JMP     @poisoned
004F5D  2               @refresh:
004F5D  2  A9 04                LDA     #4
004F5F  2  8D 93 6D             STA     poison_turns
004F62  2               @poisoned:
004F62  2  20 9B 11             JSR     sfx_poison
004F65  2  A9 6A A0 5B          PRINTMSG_MSG m_marsh_poison
004F69  2  20 CA 40     
004F6C  2               @safe:
004F6C  2  60                   RTS
004F6D  2               
004F6D  2               ;----------------------------------------------------------------
004F6D  2               ; check_overworld_discovery - award one-time authored discoveries
004F6D  2               ; when the player reaches their overworld coordinates.
004F6D  2               ;----------------------------------------------------------------
004F6D  2               check_overworld_discovery:
004F6D  2  AD 89 6D             LDA     loc
004F70  2  F0 01                BEQ     :+
004F72  2  60                   RTS
004F73  2               :
004F73  2  AD 8B 6D             LDA     discovery_flags
004F76  2  29 01                AND     #DISC_CACHE
004F78  2  D0 11                BNE     @cairn_check
004F7A  2  AD 7B 6D             LDA     px
004F7D  2  C9 1E                CMP     #CACHE_X
004F7F  2  D0 0A                BNE     @cairn_check
004F81  2  AD 7C 6D             LDA     py
004F84  2  C9 04                CMP     #CACHE_Y
004F86  2  D0 03                BNE     @cairn_check
004F88  2  4C BC 4F             JMP     discover_cache
004F8B  2               @cairn_check:
004F8B  2  AD 8B 6D             LDA     discovery_flags
004F8E  2  29 02                AND     #DISC_CAIRN
004F90  2  D0 11                BNE     @waystone_check
004F92  2  AD 7B 6D             LDA     px
004F95  2  C9 1F                CMP     #CAIRN_X
004F97  2  D0 0A                BNE     @waystone_check
004F99  2  AD 7C 6D             LDA     py
004F9C  2  C9 1A                CMP     #CAIRN_Y
004F9E  2  D0 03                BNE     @waystone_check
004FA0  2  4C F1 4F             JMP     discover_cairn
004FA3  2               @waystone_check:
004FA3  2  AD 8B 6D             LDA     discovery_flags
004FA6  2  29 04                AND     #DISC_WAYSTONE
004FA8  2  D0 11                BNE     @done
004FAA  2  AD 7B 6D             LDA     px
004FAD  2  C9 1D                CMP     #WAYSTONE_X
004FAF  2  D0 0A                BNE     @done
004FB1  2  AD 7C 6D             LDA     py
004FB4  2  C9 28                CMP     #WAYSTONE_Y
004FB6  2  D0 03                BNE     @done
004FB8  2  4C 15 50             JMP     discover_waystone
004FBB  2               @done:
004FBB  2  60                   RTS
004FBC  2               
004FBC  2               ; A hunter's hidden cache provides both money and travel supplies.
004FBC  2               discover_cache:
004FBC  2  AD 8B 6D             LDA     discovery_flags
004FBF  2  09 01                ORA     #DISC_CACHE
004FC1  2  8D 8B 6D             STA     discovery_flags
004FC4  2  18                   CLC
004FC5  2  AD 82 6D             LDA     pgold
004FC8  2  69 28                ADC     #40
004FCA  2  8D 82 6D             STA     pgold
004FCD  2  AD 83 6D             LDA     pgold+1
004FD0  2  69 00                ADC     #0
004FD2  2  8D 83 6D             STA     pgold+1
004FD5  2  18                   CLC
004FD6  2  AD 84 6D             LDA     pfood
004FD9  2  69 4B                ADC     #75
004FDB  2  8D 84 6D             STA     pfood
004FDE  2  AD 85 6D             LDA     pfood+1
004FE1  2  69 00                ADC     #0
004FE3  2  8D 85 6D             STA     pfood+1
004FE6  2  20 3C 12             JSR     sfx_treasure
004FE9  2  A9 89 A0 5C          PRINTMSG_MSG m_discover_cache
004FED  2  20 CA 40     
004FF0  2  60                   RTS
004FF1  2               
004FF1  2               ; The hilltop cairn grants a permanent vitality blessing.
004FF1  2               discover_cairn:
004FF1  2  AD 8B 6D             LDA     discovery_flags
004FF4  2  09 02                ORA     #DISC_CAIRN
004FF6  2  8D 8B 6D             STA     discovery_flags
004FF9  2  18                   CLC
004FFA  2  AD 7E 6D             LDA     pmaxhp
004FFD  2  69 05                ADC     #5
004FFF  2  8D 7E 6D             STA     pmaxhp
005002  2  8D 7D 6D             STA     phealth
005005  2  A9 00                LDA     #0
005007  2  8D 93 6D             STA     poison_turns
00500A  2  20 73 12             JSR     sfx_levelup
00500D  2  A9 BE A0 5C          PRINTMSG_MSG m_discover_cairn
005011  2  20 CA 40     
005014  2  60                   RTS
005015  2               
005015  2               ; The old waystone gives a concise route clue.
005015  2               discover_waystone:
005015  2  AD 8B 6D             LDA     discovery_flags
005018  2  09 04                ORA     #DISC_WAYSTONE
00501A  2  8D 8B 6D             STA     discovery_flags
00501D  2  20 3C 12             JSR     sfx_treasure
005020  2  A9 F3 A0 5C          PRINTMSG_MSG m_discover_waystone
005024  2  20 CA 40     
005027  2  60                   RTS
005028  2               
005028  2               ;----------------------------------------------------------------
005028  2               ; overworld_use - contextual overworld interaction. The discovered
005028  2               ; waystone can be read again with T so its route clue is not lost.
005028  2               ;----------------------------------------------------------------
005028  2               overworld_use:
005028  2  AD 7B 6D             LDA     px
00502B  2  C9 1D                CMP     #WAYSTONE_X
00502D  2  D0 12                BNE     @shortcut_a
00502F  2  AD 7C 6D             LDA     py
005032  2  C9 28                CMP     #WAYSTONE_Y
005034  2  D0 0B                BNE     @shortcut_a
005036  2  20 EA 0F             JSR     sfx_talk
005039  2  A9 F3 A0 5C          PRINTMSG_MSG m_discover_waystone
00503D  2  20 CA 40     
005040  2  60                   RTS
005041  2               @shortcut_a:
005041  2  AD 7B 6D             LDA     px
005044  2  C9 14                CMP     #SHORTCUT_A_X
005046  2  D0 12                BNE     @shortcut_b
005048  2  AD 7C 6D             LDA     py
00504B  2  C9 39                CMP     #SHORTCUT_A_Y
00504D  2  D0 0B                BNE     @shortcut_b
00504F  2  A9 20                LDA     #SHORTCUT_B_X
005051  2  85 2C                STA     tgtx
005053  2  A9 3B                LDA     #SHORTCUT_B_Y
005055  2  85 2D                STA     tgty
005057  2  4C 7E 50             JMP     shortcut_cross
00505A  2               @shortcut_b:
00505A  2  AD 7B 6D             LDA     px
00505D  2  C9 20                CMP     #SHORTCUT_B_X
00505F  2  D0 12                BNE     @nothing
005061  2  AD 7C 6D             LDA     py
005064  2  C9 3B                CMP     #SHORTCUT_B_Y
005066  2  D0 0B                BNE     @nothing
005068  2  A9 14                LDA     #SHORTCUT_A_X
00506A  2  85 2C                STA     tgtx
00506C  2  A9 39                LDA     #SHORTCUT_A_Y
00506E  2  85 2D                STA     tgty
005070  2  4C 7E 50             JMP     shortcut_cross
005073  2               @nothing:
005073  2  20 FB 10             JSR     sfx_blocked
005076  2  A9 B9 A0 66          PRINTMSG_MSG t_nothing
00507A  2  20 CA 40     
00507D  2  60                   RTS
00507E  2               
00507E  2               ; The reed ford is a deliberate shortcut through the Sunken March:
00507E  2               ; useful, but costly enough that using it wounded is a bad idea.
00507E  2               shortcut_cross:
00507E  2  AD 7D 6D             LDA     phealth
005081  2  C9 07                CMP     #SHORTCUT_HP_COST+1
005083  2  B0 0B                BCS     @can_cross
005085  2  20 FB 10             JSR     sfx_blocked
005088  2  A9 67 A0 5D          PRINTMSG_MSG m_shortcut_weak
00508C  2  20 CA 40     
00508F  2  60                   RTS
005090  2               @can_cross:
005090  2  20 D2 48             JSR     mon_at
005093  2  90 0B                BCC     @destination_clear
005095  2  20 FB 10             JSR     sfx_blocked
005098  2  A9 98 A0 5D          PRINTMSG_MSG m_shortcut_blocked
00509C  2  20 CA 40     
00509F  2  60                   RTS
0050A0  2               @destination_clear:
0050A0  2  38                   SEC
0050A1  2  AD 7D 6D             LDA     phealth
0050A4  2  E9 06                SBC     #SHORTCUT_HP_COST
0050A6  2  8D 7D 6D             STA     phealth
0050A9  2               
0050A9  2  A2 14                LDX     #SHORTCUT_FOOD_COST
0050AB  2               @food:
0050AB  2  AD 84 6D             LDA     pfood
0050AE  2  0D 85 6D             ORA     pfood+1
0050B1  2  F0 06                BEQ     @move
0050B3  2  20 22 4F             JSR     consume_food_unit
0050B6  2  CA                   DEX
0050B7  2  D0 F2                BNE     @food
0050B9  2               @move:
0050B9  2  A5 2C                LDA     tgtx
0050BB  2  8D 7B 6D             STA     px
0050BE  2  A5 2D                LDA     tgty
0050C0  2  8D 7C 6D             STA     py
0050C3  2  A9 01                LDA     #1
0050C5  2  8D 97 6D             STA     did_move
0050C8  2  20 15 10             JSR     sfx_ford
0050CB  2  A9 30 A0 5D          PRINTMSG_MSG m_shortcut_cross
0050CF  2  20 CA 40     
0050D2  2  60                   RTS
0050D3  2               
0050D3  2               ;----------------------------------------------------------------
0050D3  2               ; drink_potion - consume one stored potion to heal and cure poison.
0050D3  2               ; A successful drink consumes a turn; failed attempts do not.
0050D3  2               ;----------------------------------------------------------------
0050D3  2               drink_potion:
0050D3  2  A9 00                LDA     #0
0050D5  2  8D 97 6D             STA     did_move
0050D8  2  AD 86 6D             LDA     ppotions
0050DB  2  D0 0B                BNE     @has_potion
0050DD  2  20 FB 10             JSR     sfx_blocked
0050E0  2  A9 05 A0 5C          PRINTMSG_MSG m_no_potion
0050E4  2  20 CA 40     
0050E7  2  60                   RTS
0050E8  2               @has_potion:
0050E8  2  AD 7D 6D             LDA     phealth
0050EB  2  CD 7E 6D             CMP     pmaxhp
0050EE  2  90 10                BCC     @drink
0050F0  2  AD 93 6D             LDA     poison_turns
0050F3  2  D0 0B                BNE     @drink
0050F5  2  20 FB 10             JSR     sfx_blocked
0050F8  2  A9 22 A0 5C          PRINTMSG_MSG m_potion_unused
0050FC  2  20 CA 40     
0050FF  2  60                   RTS
005100  2               @drink:
005100  2  CE 86 6D             DEC     ppotions
005103  2  A9 00                LDA     #0
005105  2  8D 93 6D             STA     poison_turns
005108  2  18                   CLC
005109  2  AD 7D 6D             LDA     phealth
00510C  2  69 14                ADC     #POTION_HEAL
00510E  2  CD 7E 6D             CMP     pmaxhp
005111  2  90 03                BCC     :+
005113  2  AD 7E 6D             LDA     pmaxhp
005116  2               :
005116  2  8D 7D 6D             STA     phealth
005119  2  20 3C 12             JSR     sfx_treasure
00511C  2  A9 41 A0 5C          PRINTMSG_MSG m_potion_drink
005120  2  20 CA 40     
005123  2  A9 01                LDA     #1
005125  2  8D 97 6D             STA     did_move
005128  2  60                   RTS
005129  2               
005129  2               ;----------------------------------------------------------------
005129  2               ; collect_treasure - pick up a chest at (tgtx,tgty): table-driven
005129  2               ; reward, then clear the tile to floor.
005129  2               ;----------------------------------------------------------------
005129  2               collect_treasure:
005129  2               ; clear the chest tile -> floor
005129  2  A9 09                LDA     #T_FLOOR
00512B  2  20 9B 1F             JSR     settile
00512E  2  20 3C 12             JSR     sfx_treasure
005131  2               
005131  2  A9 09                LDA     #REWARD_TABLE_SIZE
005133  2  20 8A 0E             JSR     rng_mod
005136  2  AA                   TAX
005137  2  BD 57 52             LDA     reward_amount,X
00513A  2  85 21                STA     tmp1
00513C  2  BD 4E 52             LDA     reward_type,X
00513F  2  C9 00                CMP     #REWARD_GOLD
005141  2  D0 03                BNE     :+
005143  2  4C 6C 51             JMP     @gold
005146  2               :
