005DC8  2               
005DC8  1                       .INCLUDE "town.asm"
005DC8  2               ;______________________________________________________________________________
005DC8  2               ;  town.asm - shop interaction inside towns
005DC8  2               ;
005DC8  2               ;  When the player presses USE ('T') in a town while adjacent to a
005DC8  2               ;  shop counter ('S' tile), the shop menu opens.  The menu is drawn
005DC8  2               ;  over the message rows; the player picks an option, gold is spent,
005DC8  2               ;  and the menu returns to the map.
005DC8  2               ;______________________________________________________________________________
005DC8  2               
005DC8  2               ; Eastmere's outfitter favors equipment; Valehaven's market favors
005DC8  2               ; healing and provisions. All services remain available in both.
005DC8  2               shop_heal_price:
005DC8  2  0F 05                .BYTE   15, 5
005DCA  2               shop_food_price:
005DCA  2  19 0F                .BYTE   25, 15
005DCC  2               shop_food_amount:
005DCC  2  4B 96                .BYTE   75, 150
005DCE  2               shop_weapon_price:
005DCE  2  2D 4B                .BYTE   45, 75
005DD0  2               shop_armor_price:
005DD0  2  23 41                .BYTE   35, 65
005DD2  2               shop_potion_price:
005DD2  2  1E 0C                .BYTE   30, 12
005DD4  2               
005DD4  2               ;----------------------------------------------------------------
005DD4  2               ; use_action - bound to the USE key ('T'). Dispatch contextual
005DD4  2               ; interactions for the active location.
005DD4  2               ;----------------------------------------------------------------
005DD4  2               use_action:
005DD4  2  AD 89 6D             LDA     loc
005DD7  2  C9 00                CMP     #LOC_WORLD
005DD9  2  F0 13                BEQ     @inworld
005DDB  2  C9 03                CMP     #LOC_CASTLE
005DDD  2  F0 12                BEQ     @incastle
005DDF  2  C9 01                CMP     #LOC_TOWN
005DE1  2  F0 11                BEQ     @intown
005DE3  2  20 FB 10             JSR     sfx_blocked
005DE6  2  A9 B9 A0 66          PRINTMSG_MSG t_nothing
005DEA  2  20 CA 40     
005DED  2  60                   RTS
005DEE  2               @inworld:
005DEE  2  4C 28 50             JMP     overworld_use
005DF1  2               @incastle:
005DF1  2  4C 25 68             JMP     castle_use
005DF4  2               @intown:
005DF4  2               ; is a shop tile adjacent (4-neighbour) or under us?
005DF4  2  20 FF 5D             JSR     shop_adjacent
005DF7  2  B0 03                BCS     @open
005DF9  2  4C 69 5E             JMP     town_talk
005DFC  2               @open:
005DFC  2  4C 86 5E             JMP     shop_menu
005DFF  2               
005DFF  2               ;----------------------------------------------------------------
005DFF  2               ; shop_adjacent - C=1 if a T_SHOP tile is at or next to the player.
005DFF  2               ;----------------------------------------------------------------
005DFF  2               shop_adjacent:
005DFF  2               ; center
005DFF  2  AD 7B 6D             LDA     px
005E02  2  85 2C                STA     tgtx
005E04  2  AD 7C 6D             LDA     py
005E07  2  85 2D                STA     tgty
005E09  2  20 F4 1E             JSR     tileat
005E0C  2  A5 2E                LDA     tgttile
005E0E  2  C9 0E                CMP     #T_SHOP
005E10  2  F0 55                BEQ     @yes
005E12  2               ; up
005E12  2  AD 7B 6D             LDA     px
005E15  2  85 2C                STA     tgtx
005E17  2  AD 7C 6D             LDA     py
005E1A  2  38                   SEC
005E1B  2  E9 01                SBC     #1
005E1D  2  85 2D                STA     tgty
005E1F  2  20 F4 1E             JSR     tileat
005E22  2  A5 2E                LDA     tgttile
005E24  2  C9 0E                CMP     #T_SHOP
005E26  2  F0 3F                BEQ     @yes
005E28  2               ; down
005E28  2  AD 7C 6D             LDA     py
005E2B  2  18                   CLC
005E2C  2  69 01                ADC     #1
005E2E  2  85 2D                STA     tgty
005E30  2  AD 7B 6D             LDA     px
005E33  2  85 2C                STA     tgtx
005E35  2  20 F4 1E             JSR     tileat
005E38  2  A5 2E                LDA     tgttile
005E3A  2  C9 0E                CMP     #T_SHOP
005E3C  2  F0 29                BEQ     @yes
005E3E  2               ; left
005E3E  2  AD 7C 6D             LDA     py
005E41  2  85 2D                STA     tgty
005E43  2  AD 7B 6D             LDA     px
005E46  2  38                   SEC
005E47  2  E9 01                SBC     #1
005E49  2  85 2C                STA     tgtx
005E4B  2  20 F4 1E             JSR     tileat
005E4E  2  A5 2E                LDA     tgttile
005E50  2  C9 0E                CMP     #T_SHOP
005E52  2  F0 13                BEQ     @yes
005E54  2               ; right
005E54  2  AD 7B 6D             LDA     px
005E57  2  18                   CLC
005E58  2  69 01                ADC     #1
005E5A  2  85 2C                STA     tgtx
005E5C  2  20 F4 1E             JSR     tileat
005E5F  2  A5 2E                LDA     tgttile
005E61  2  C9 0E                CMP     #T_SHOP
005E63  2  F0 02                BEQ     @yes
005E65  2  18                   CLC
005E66  2  60                   RTS
005E67  2               @yes:
005E67  2  38                   SEC
005E68  2  60                   RTS
005E69  2               
005E69  2               ;----------------------------------------------------------------
005E69  2               ; town_talk - contextual town rumor/dialog.  Non-shop T use gives
005E69  2               ; short guidance based on the active town and current quest state.
005E69  2               ;----------------------------------------------------------------
005E69  2               town_talk:
005E69  2  AD 8A 6D             LDA     town_id
005E6C  2  0A                   ASL     A               ; town_id * 2
005E6D  2  85 20                STA     tmp0
005E6F  2  0A                   ASL     A               ; town_id * 4
005E70  2  18                   CLC
005E71  2  65 20                ADC     tmp0            ; town_id * 6
005E73  2  18                   CLC
005E74  2  6D 91 6D             ADC     queststate
005E77  2  0A                   ASL     A
005E78  2  AA                   TAX
005E79  2  BD A1 63             LDA     town_rumors,X
005E7C  2  BC A2 63             LDY     town_rumors+1,X
005E7F  2  20 EA 0F             JSR     sfx_talk
005E82  2  20 CA 40             JSR     msg_print
005E85  2  60                   RTS
005E86  2               
005E86  2               ;----------------------------------------------------------------
005E86  2               ; shop_menu - draw the shop menu over the message area and loop
005E86  2               ; processing purchases until the player presses X.
005E86  2               ;----------------------------------------------------------------
005E86  2               shop_menu:
005E86  2  20 AA 12             JSR     sfx_door
005E89  2               ; start with the greeting as the status line
005E89  2  20 1E 60             JSR     shop_set_greeting
005E8C  2               @redraw:
005E8C  2  20 45 60             JSR     shop_draw
005E8F  2               @key:
005E8F  2  20 D6 44             JSR     getkey_block
005E92  2  C9 31                CMP     #'1'
005E94  2  D0 03                BNE     :+
005E96  2  4C D6 5E             JMP     @heal
005E99  2               :
005E99  2  C9 32                CMP     #'2'
005E9B  2  D0 03                BNE     :+
005E9D  2  4C FF 5E             JMP     @food
005EA0  2               :
005EA0  2  C9 33                CMP     #'3'
005EA2  2  D0 03                BNE     :+
005EA4  2  4C 32 5F             JMP     @weapon
005EA7  2               :
005EA7  2  C9 34                CMP     #'4'
005EA9  2  D0 03                BNE     :+
005EAB  2  4C 6A 5F             JMP     @armor
005EAE  2               :
005EAE  2  C9 35                CMP     #'5'
005EB0  2  D0 03                BNE     :+
005EB2  2  4C A2 5F             JMP     @potion
005EB5  2               :
005EB5  2  C9 58                CMP     #'X'
005EB7  2  D0 03                BNE     :+
005EB9  2  4C D3 5E             JMP     @goleave
005EBC  2               :
005EBC  2  C9 78                CMP     #'x'
005EBE  2  D0 03                BNE     :+
005EC0  2  4C D3 5E             JMP     @goleave
005EC3  2               :
005EC3  2  20 FB 10             JSR     sfx_blocked
005EC6  2  A9 EF 8D A1          SETSTAT t_badkey
005ECA  2  6D A9 67 8D  
005ECE  2  A2 6D        
005ED0  2  4C 8C 5E             JMP     @redraw
005ED3  2               @goleave:
005ED3  2  4C EA 5F             JMP     @leave
005ED6  2               @heal:
005ED6  2  AE 8A 6D             LDX     town_id
005ED9  2  BD C8 5D             LDA     shop_heal_price,X
005EDC  2  20 FB 5F             JSR     spend_gold
005EDF  2  B0 03                BCS     :+
005EE1  2  4C DA 5F             JMP     @poor
005EE4  2               :
005EE4  2  AD 7E 6D             LDA     pmaxhp
005EE7  2  8D 7D 6D             STA     phealth
005EEA  2  A9 00                LDA     #0
005EEC  2  8D 93 6D             STA     poison_turns
005EEF  2  20 3C 12             JSR     sfx_treasure
005EF2  2  A9 F7 8D A1          SETSTAT t_healed
005EF6  2  6D A9 66 8D  
005EFA  2  A2 6D        
005EFC  2  4C 8C 5E             JMP     @redraw
005EFF  2               @food:
005EFF  2  AE 8A 6D             LDX     town_id
005F02  2  BD CA 5D             LDA     shop_food_price,X
005F05  2  20 FB 5F             JSR     spend_gold
005F08  2  B0 03                BCS     :+
005F0A  2  4C DA 5F             JMP     @poor
005F0D  2               :
005F0D  2  AE 8A 6D             LDX     town_id
005F10  2  18                   CLC
005F11  2  AD 84 6D             LDA     pfood
005F14  2  7D CC 5D             ADC     shop_food_amount,X
005F17  2  8D 84 6D             STA     pfood
005F1A  2  AD 85 6D             LDA     pfood+1
005F1D  2  69 00                ADC     #0
005F1F  2  8D 85 6D             STA     pfood+1
005F22  2  20 3C 12             JSR     sfx_treasure
005F25  2  A9 16 8D A1          SETSTAT t_fed
005F29  2  6D A9 67 8D  
005F2D  2  A2 6D        
005F2F  2  4C 8C 5E             JMP     @redraw
005F32  2               @weapon:
005F32  2  AD 87 6D             LDA     pweapon
005F35  2  C9 03                CMP     #3
005F37  2  B0 21                BCS     @maxwpn
005F39  2  AE 8A 6D             LDX     town_id
005F3C  2  BD CE 5D             LDA     shop_weapon_price,X
005F3F  2  20 FB 5F             JSR     spend_gold
005F42  2  B0 03                BCS     :+
005F44  2  4C DA 5F             JMP     @poor
005F47  2               :
005F47  2  EE 87 6D             INC     pweapon
005F4A  2  20 3C 12             JSR     sfx_treasure
005F4D  2  A9 35 8D A1          SETSTAT t_boughtw
005F51  2  6D A9 67 8D  
005F55  2  A2 6D        
005F57  2  4C 8C 5E             JMP     @redraw
005F5A  2               @maxwpn:
005F5A  2  20 FB 10             JSR     sfx_blocked
005F5D  2  A9 92 8D A1          SETSTAT t_maxed
005F61  2  6D A9 67 8D  
005F65  2  A2 6D        
005F67  2  4C 8C 5E             JMP     @redraw
005F6A  2               @armor:
005F6A  2  AD 88 6D             LDA     parmor
005F6D  2  C9 03                CMP     #3
005F6F  2  B0 21                BCS     @maxarm
005F71  2  AE 8A 6D             LDX     town_id
005F74  2  BD D0 5D             LDA     shop_armor_price,X
005F77  2  20 FB 5F             JSR     spend_gold
005F7A  2  B0 03                BCS     :+
005F7C  2  4C DA 5F             JMP     @poor
005F7F  2               :
005F7F  2  EE 88 6D             INC     parmor
005F82  2  20 3C 12             JSR     sfx_treasure
005F85  2  A9 54 8D A1          SETSTAT t_boughta
005F89  2  6D A9 67 8D  
005F8D  2  A2 6D        
005F8F  2  4C 8C 5E             JMP     @redraw
005F92  2               @maxarm:
005F92  2  20 FB 10             JSR     sfx_blocked
005F95  2  A9 92 8D A1          SETSTAT t_maxed
005F99  2  6D A9 67 8D  
005F9D  2  A2 6D        
005F9F  2  4C 8C 5E             JMP     @redraw
005FA2  2               @potion:
005FA2  2  AD 86 6D             LDA     ppotions
005FA5  2  C9 09                CMP     #POTION_MAX
005FA7  2  B0 21                BCS     @maxpot
005FA9  2  AE 8A 6D             LDX     town_id
005FAC  2  BD D2 5D             LDA     shop_potion_price,X
005FAF  2  20 FB 5F             JSR     spend_gold
005FB2  2  B0 03                BCS     :+
005FB4  2  4C DA 5F             JMP     @poor
005FB7  2               :
005FB7  2  EE 86 6D             INC     ppotions
005FBA  2  20 3C 12             JSR     sfx_treasure
005FBD  2  A9 73 8D A1          SETSTAT t_boughtp
005FC1  2  6D A9 67 8D  
005FC5  2  A2 6D        
005FC7  2  4C 8C 5E             JMP     @redraw
005FCA  2               @maxpot:
005FCA  2  20 FB 10             JSR     sfx_blocked
005FCD  2  A9 B1 8D A1          SETSTAT t_potion_max
005FD1  2  6D A9 67 8D  
005FD5  2  A2 6D        
005FD7  2  4C 8C 5E             JMP     @redraw
005FDA  2               @poor:
005FDA  2  20 FB 10             JSR     sfx_blocked
005FDD  2  A9 D0 8D A1          SETSTAT t_poor
005FE1  2  6D A9 67 8D  
005FE5  2  A2 6D        
005FE7  2  4C 8C 5E             JMP     @redraw
005FEA  2               @leave:
005FEA  2               ; fully restore the game screen, then report leaving
005FEA  2  20 AA 12             JSR     sfx_door
005FED  2  20 70 08             JSR     full_redraw
005FF0  2  20 F9 40             JSR     msg_redraw
005FF3  2  A9 0D A0 68          PRINTMSG_MSG t_bye
005FF7  2  20 CA 40     
005FFA  2  60                   RTS
005FFB  2               
005FFB  2               ;----------------------------------------------------------------
005FFB  2               ; spend_gold - try to spend A gold.  C=1 success (gold deducted),
005FFB  2               ;              C=0 if not enough.
005FFB  2               ;----------------------------------------------------------------
005FFB  2               spend_gold:
005FFB  2  85 20                STA     tmp0
005FFD  2               ; gold >= tmp0 ?  (16-bit gold, 8-bit cost)
005FFD  2  AD 83 6D             LDA     pgold+1
006000  2  D0 07                BNE     @ok             ; high byte nonzero -> plenty
006002  2  AD 82 6D             LDA     pgold
006005  2  C5 20                CMP     tmp0
006007  2  90 13                BCC     @no
006009  2               @ok:
006009  2  38                   SEC
00600A  2  AD 82 6D             LDA     pgold
00600D  2  E5 20                SBC     tmp0
00600F  2  8D 82 6D             STA     pgold
006012  2  AD 83 6D             LDA     pgold+1
006015  2  E9 00                SBC     #0
006017  2  8D 83 6D             STA     pgold+1
00601A  2  38                   SEC
00601B  2  60                   RTS
00601C  2               @no:
00601C  2  18                   CLC
00601D  2  60                   RTS
00601E  2               
00601E  2               ;----------------------------------------------------------------
00601E  2               ; shop_set_greeting - select a greeting for the active town.
00601E  2               ;----------------------------------------------------------------
00601E  2               shop_set_greeting:
00601E  2  AD 8A 6D             LDA     town_id
006021  2  0A                   ASL     A
006022  2  AA                   TAX
006023  2  BD 7F 66             LDA     shop_greetings,X
006026  2  8D A1 6D             STA     shopstat
006029  2  BD 80 66             LDA     shop_greetings+1,X
00602C  2  8D A2 6D             STA     shopstat+1
00602F  2  60                   RTS
006030  2               
006030  2               ;----------------------------------------------------------------
006030  2               ; shop_print_line - print a town-specific shop line.
006030  2               ;   IN: A = line index (SHOPTXT_*)
006030  2               ;----------------------------------------------------------------
006030  2               SHOPTXT_HEADER  = 0
006030  2               SHOPTXT_HEAL    = 1
006030  2               SHOPTXT_FOOD    = 2
006030  2               SHOPTXT_WEAPON  = 3
006030  2               SHOPTXT_ARMOR   = 4
006030  2               SHOPTXT_POTION  = 5
006030  2               
006030  2               shop_print_line:
006030  2  0A                   ASL     A
006031  2  0A                   ASL     A               ; two town pointers per line
006032  2  85 20                STA     tmp0
006034  2  AD 8A 6D             LDA     town_id
006037  2  0A                   ASL     A
006038  2  18                   CLC
006039  2  65 20                ADC     tmp0
00603B  2  AA                   TAX
00603C  2  BD 87 61             LDA     shop_text_table,X
00603F  2  BC 88 61             LDY     shop_text_table+1,X
006042  2  4C A2 3E             JMP     prmsg
006045  2               
006045  2               ;----------------------------------------------------------------
006045  2               ; Shop box geometry - a clean panel drawn inside the viewport,
006045  2               ; well clear of the bottom-right auto-scroll cell.
006045  2               ;----------------------------------------------------------------
006045  2               SHOP_X0         = 3             ; left column of box
006045  2               SHOP_X1         = 42            ; right column of box
006045  2               SHOP_Y0         = 4             ; top row of box
006045  2               SHOP_Y1         = 17            ; bottom row of box
006045  2               SHOP_W          = SHOP_X1-SHOP_X0+1
006045  2               
006045  2               ;----------------------------------------------------------------
006045  2               ; shop_draw - render the shop as a self-contained bordered panel.
006045  2               ; The whole box is repainted each call (background + border via
006045  2               ; direct VRAM, then text via firmware) so it is always clean.
006045  2               ;----------------------------------------------------------------
006045  2               shop_draw:
006045  2               ; --- paint box background + border directly to VRAM ---
006045  2  20 42 3D             JSR     vid_enter
006048  2  A9 04                LDA     #SHOP_Y0
00604A  2  85 27                STA     rowidx
00604C  2               @bgrow:
00604C  2  A5 27                LDA     rowidx
00604E  2  20 57 3D             JSR     rowbase
006051  2  A0 03                LDY     #SHOP_X0
006053  2               @bgcol:
006053  2               ; border on edges, blank interior
006053  2  C0 03                CPY     #SHOP_X0
006055  2  F0 19                BEQ     @edge
006057  2  C0 2A                CPY     #SHOP_X1
006059  2  F0 15                BEQ     @edge
00605B  2  A5 27                LDA     rowidx
00605D  2  C9 04                CMP     #SHOP_Y0
00605F  2  F0 0F                BEQ     @edge
006061  2  C9 11                CMP     #SHOP_Y1
006063  2  F0 0B                BEQ     @edge
006065  2               ; interior cell
006065  2  A9 20                LDA     #space
006067  2  91 14                STA     (vptr),Y
006069  2  A9 1F                LDA     #C_SHOPBG
00606B  2  91 16                STA     (cptr),Y
00606D  2  4C 78 60             JMP     @bgnext
006070  2               @edge:
006070  2  A9 20                LDA     #' '
006072  2  91 14                STA     (vptr),Y
006074  2  A9 1B                LDA     #C_SHOPBRD
006076  2  91 16                STA     (cptr),Y
006078  2               @bgnext:
006078  2  C8                   INY
006079  2  C0 2B                CPY     #SHOP_X1+1
00607B  2  D0 D6                BNE     @bgcol
00607D  2  E6 27                INC     rowidx
00607F  2  A5 27                LDA     rowidx
006081  2  C9 12                CMP     #SHOP_Y1+1
006083  2  D0 C7                BNE     @bgrow
006085  2  20 51 3D             JSR     vid_exit
006088  2               
006088  2               ; --- text lines via firmware (interior color C_SHOPBG) ---
006088  2  A9 1E                LDA     #C_SHOPTTL
00608A  2  8D 4A 06             STA     CURCOLOR
00608D  2  A2 0B                LDX     #SHOP_X0+8
00608F  2  A0 04                LDY     #SHOP_Y0
006091  2  20 90 3E             JSR     locate
006094  2  A9 00                LDA     #SHOPTXT_HEADER
006096  2  20 30 60             JSR     shop_print_line
006099  2               
006099  2  A9 1F                LDA     #C_SHOPTXT
00609B  2  8D 4A 06             STA     CURCOLOR
00609E  2  A2 06                LDX     #SHOP_X0+3
0060A0  2  A0 06                LDY     #SHOP_Y0+2
0060A2  2  20 90 3E             JSR     locate
0060A5  2  A9 01                LDA     #SHOPTXT_HEAL
0060A7  2  20 30 60             JSR     shop_print_line
0060AA  2  A2 06                LDX     #SHOP_X0+3
0060AC  2  A0 07                LDY     #SHOP_Y0+3
0060AE  2  20 90 3E             JSR     locate
0060B1  2  A9 02                LDA     #SHOPTXT_FOOD
0060B3  2  20 30 60             JSR     shop_print_line
0060B6  2  A2 06                LDX     #SHOP_X0+3
0060B8  2  A0 08                LDY     #SHOP_Y0+4
0060BA  2  20 90 3E             JSR     locate
0060BD  2  A9 03                LDA     #SHOPTXT_WEAPON
0060BF  2  20 30 60             JSR     shop_print_line
0060C2  2  A2 06                LDX     #SHOP_X0+3
0060C4  2  A0 09                LDY     #SHOP_Y0+5
0060C6  2  20 90 3E             JSR     locate
0060C9  2  A9 04                LDA     #SHOPTXT_ARMOR
0060CB  2  20 30 60             JSR     shop_print_line
0060CE  2  A2 06                LDX     #SHOP_X0+3
0060D0  2  A0 0A                LDY     #SHOP_Y0+6
0060D2  2  20 90 3E             JSR     locate
0060D5  2  A9 05                LDA     #SHOPTXT_POTION
0060D7  2  20 30 60             JSR     shop_print_line
0060DA  2  A2 06                LDX     #SHOP_X0+3
0060DC  2  A0 0B                LDY     #SHOP_Y0+7
0060DE  2  20 90 3E             JSR     locate
0060E1  2  A9 E3 A0 62          PRINTMSG t_optx
0060E5  2  20 A2 3E     
0060E8  2  A2 06                LDX     #SHOP_X0+3
0060EA  2  A0 0C                LDY     #SHOP_Y0+8
0060EC  2  20 90 3E             JSR     locate
0060EF  2  20 35 61             JSR     shop_print_weapon_status
0060F2  2               
0060F2  2               ; gold line
0060F2  2  A2 06                LDX     #SHOP_X0+3
0060F4  2  A0 0D                LDY     #SHOP_Y0+9
0060F6  2  20 90 3E             JSR     locate
0060F9  2  A9 1F                LDA     #C_SHOPTXT
0060FB  2  8D 4A 06             STA     CURCOLOR
0060FE  2  A9 02 A0 63          PRINTMSG t_gold
006102  2  20 A2 3E     
006105  2  AD 82 6D 85          COPY16  pgold, numarg
006109  2  1E AD 83 6D  
00610D  2  85 1F        
00610F  2  20 6E 40             JSR     displaynum
006112  2  A2 06                LDX     #SHOP_X0+3
006114  2  A0 0E                LDY     #SHOP_Y0+10
006116  2  20 90 3E             JSR     locate
006119  2  20 5E 61             JSR     shop_print_armor_status
00611C  2               
00611C  2               ; status line (last action / greeting)
00611C  2  A2 06                LDX     #SHOP_X0+3
00611E  2  A0 10                LDY     #SHOP_Y1-1
006120  2  20 90 3E             JSR     locate
006123  2  A9 1A                LDA     #C_SHOPST
006125  2  8D 4A 06             STA     CURCOLOR
006128  2  AD A1 6D             LDA     shopstat
00612B  2  AC A2 6D             LDY     shopstat+1
00612E  2  20 A2 3E             JSR     prmsg
006131  2  20 3B 41             JSR     draw_panel
006134  2  60                   RTS
