0044B0  2               
0044B0  2               ;----------------------------------------------------------------
0044B0  2               ; yorn - wait for a Y/N keypress.  Returns Z=1 if Yes (A='Y').
0044B0  2               ;----------------------------------------------------------------
0044B0  2               yorn:
0044B0  2               @wait:
0044B0  2  20 D6 44             JSR     getkey_block
0044B3  2  C9 59                CMP     #'Y'
0044B5  2  F0 19                BEQ     @yes
0044B7  2  C9 79                CMP     #'y'
0044B9  2  F0 15                BEQ     @yes
0044BB  2  C9 4E                CMP     #'N'
0044BD  2  F0 14                BEQ     @no
0044BF  2  C9 6E                CMP     #'n'
0044C1  2  F0 10                BEQ     @no
0044C3  2  20 FB 10             JSR     sfx_blocked
0044C6  2  A9 1E A0 48          PRINTMSG_MSG yorn_badkey
0044CA  2  20 CA 40     
0044CD  2  4C B0 44             JMP     @wait
0044D0  2               @yes:
0044D0  2  A9 00                LDA     #0              ; Z=1
0044D2  2  60                   RTS
0044D3  2               @no:
0044D3  2  A9 01                LDA     #1              ; Z=0
0044D5  2  60                   RTS
0044D6  2               
0044D6  2               ;----------------------------------------------------------------
0044D6  2               ; getkey_block - block until a key is pressed; return it in A.
0044D6  2               ;----------------------------------------------------------------
0044D6  2               getkey_block:
0044D6  2               @gk:
0044D6  2  A9 14 85 32          FARCALL FC_CHRIN
0044DA  2  20 F0 FF     
0044DD  2  C9 FF                CMP     #$FF
0044DF  2  F0 F5                BEQ     @gk
0044E1  2  60                   RTS
0044E2  2               
0044E2  2               ;----------------------------------------------------------------
0044E2  2               ; getkey - non-blocking read; A=key or 0 if none.
0044E2  2               ;----------------------------------------------------------------
0044E2  2               getkey:
0044E2  2  A9 14 85 32          FARCALL FC_CHRIN
0044E6  2  20 F0 FF     
0044E9  2  C9 FF                CMP     #$FF
0044EB  2  D0 02                BNE     @got
0044ED  2  A9 00                LDA     #0
0044EF  2               @got:
0044EF  2  60                   RTS
0044F0  2               
0044F0  2               ;----------------------------------------------------------------
0044F0  2               ; drainkeys - consume and discard all buffered keystrokes.
0044F0  2               ;----------------------------------------------------------------
0044F0  2               drainkeys:
0044F0  2               @dk:
0044F0  2  A9 14 85 32          FARCALL FC_CHRIN
0044F4  2  20 F0 FF     
0044F7  2  C9 FF                CMP     #$FF
0044F9  2  D0 F5                BNE     @dk             ; got a key - keep draining
0044FB  2  60                   RTS
