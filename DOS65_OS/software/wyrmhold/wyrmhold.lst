005546  2  A0 57                LDY     #>c_the
005548  2  20 A6 53             JSR     mb_str
00554B  2  A5 21                LDA     tmp1
00554D  2  20 12 54             JSR     mb_mname
005550  2  A9 A2                LDA     #<c_dies
005552  2  A0 57                LDY     #>c_dies
005554  2  20 A6 53             JSR     mb_str
005557  2  20 1D 54             JSR     mb_flush
00555A  2  20 1F 12             JSR     sfx_killed
00555D  2               ; remove monster
00555D  2  A6 2F                LDX     monidx
00555F  2  20 F2 48             JSR     mon_kill
005562  2               ; quest miniboss?
