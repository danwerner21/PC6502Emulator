004454  2  A0 0B                LDY     #HELP_Y0+8
004456  2  20 90 3E             JSR     locate
004459  2  A9 AD A0 47          PRINTMSG help_status
00445D  2  20 A2 3E     
004460  2  A2 05                LDX     #HELP_X0+2
004462  2  A0 0C                LDY     #HELP_Y0+9
004464  2  20 90 3E             JSR     locate
004467  2  A9 CC A0 47          PRINTMSG help_objective
