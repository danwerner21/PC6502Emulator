005589  2               ;----------------------------------------------------------------
005589  2               ; check_levelup - if xp >= level*20, level up (raise maxhp, heal).
005589  2               ;----------------------------------------------------------------
005589  2               check_levelup:
005589  2               ; threshold = plevel * 20  (8-bit is enough up to lvl 12)
005589  2  AD 7F 6D             LDA     plevel
00558C  2  85 20                STA     tmp0
00558E  2  A9 00                LDA     #0
005590  2  85 21                STA     tmp1
005592  2               ; tmp = level*20 = level*16 + level*4
005592  2  AD 7F 6D             LDA     plevel
005595  2  0A                   ASL     A
005596  2  0A                   ASL     A               ; *4
005597  2  85 22                STA     tmp2
005599  2  AD 7F 6D             LDA     plevel
00559C  2  0A                   ASL     A
00559D  2  0A                   ASL     A
00559E  2  0A                   ASL     A
00559F  2  0A                   ASL     A               ; *16
0055A0  2  18                   CLC
0055A1  2  65 22                ADC     tmp2
0055A3  2  85 22                STA     tmp2            ; level*20 (low); ignore >255 (caps fine)
0055A5  2               ; compare xp (16-bit) >= tmp2
0055A5  2  AD 81 6D             LDA     pxp+1
0055A8  2  D0 07                BNE     @levelup        ; xp >= 256 definitely past early thresholds
0055AA  2  AD 80 6D             LDA     pxp
0055AD  2  C5 22                CMP     tmp2
0055AF  2  90 31                BCC     @done
0055B1  2               @levelup:
0055B1  2  EE 7F 6D             INC     plevel
0055B4  2               ; maxhp += 8, full heal
0055B4  2  AD 7E 6D             LDA     pmaxhp
0055B7  2  18                   CLC
0055B8  2  69 08                ADC     #8
0055BA  2  8D 7E 6D             STA     pmaxhp
0055BD  2  8D 7D 6D             STA     phealth
0055C0  2  A9 00                LDA     #0
0055C2  2  8D 93 6D             STA     poison_turns
0055C5  2  20 73 12             JSR     sfx_levelup
0055C8  2  20 A0 53             JSR     mb_reset
0055CB  2  A9 F6                LDA     #<c_levelup
0055CD  2  A0 57                LDY     #>c_levelup
0055CF  2  20 A6 53             JSR     mb_str
0055D2  2  AD 7F 6D             LDA     plevel
0055D5  2  20 BD 53             JSR     mb_num
0055D8  2  A9 9B                LDA     #<c_bang
0055DA  2  A0 57                LDY     #>c_bang
0055DC  2  20 A6 53             JSR     mb_str
0055DF  2  20 1D 54             JSR     mb_flush
0055E2  2               @done:
0055E2  2  60                   RTS
