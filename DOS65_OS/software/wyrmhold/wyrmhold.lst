003D42  2               
003D42  1                       .INCLUDE "video.asm"
003D42  2               ;______________________________________________________________________________
003D42  2               ;  video.asm - memory-mapped video: paging, framing, viewport, UI text
003D42  2               ;
003D42  2               ;  Direct VRAM access (the fast path used by SpeedScript): map video
003D42  2               ;  sub-page $F9 into CPU bank $A.  Then:
003D42  2               ;     text  char at  $A000 + row*80 + col
003D42  2               ;     color cell at  $A800 + row*80 + col
003D42  2               ;  Color byte = (bg<<4)|fg.
003D42  2               ;
003D42  2               ;  All direct-write routines must be bracketed by vid_enter / vid_exit.
003D42  2               ;  UI text via the firmware (prmsg / putxy) does NOT page; it uses
003D42  2               ;  FARCALL chrout/locate and must be used while in task 0.
003D42  2               ;______________________________________________________________________________
003D42  2               
003D42  2               ;----------------------------------------------------------------
003D42  2               ; vid_enter - map video text/color page into $A000-$AFFF (task 1)
003D42  2               ;             trashes A,X ; preserves Y
003D42  2               ;----------------------------------------------------------------
003D42  2               vid_enter:
003D42  2  A9 01                LDA     #$01            ; configure task 01
003D44  2  A2 0A                LDX     #$0A            ; CPU bank $A ($A000-$AFFF)
003D46  2  A0 F9                LDY     #VIDTEXT_PAGE   ; physical video page $F9
003D48  2  20 F6 FF             JSR     SETPAGE
003D4B  2  A9 01                LDA     #$01
003D4D  2  8D E0 EF             STA     PC6502_ACT_TASK ; activate task 01
003D50  2  60                   RTS
003D51  2               
003D51  2               ;----------------------------------------------------------------
003D51  2               ; vid_exit - restore normal memory at $A000 (task 0)
003D51  2               ;----------------------------------------------------------------
003D51  2               vid_exit:
003D51  2  A9 00                LDA     #$00
003D53  2  8D E0 EF             STA     PC6502_ACT_TASK
003D56  2  60                   RTS
003D57  2               
003D57  2               ;----------------------------------------------------------------
003D57  2               ; rowbase - compute VRAM pointers for the start of a screen row.
003D57  2               ;   IN : A = row (0..23)
003D57  2               ;   OUT: vptr -> $A000 + row*80   (text)
003D57  2               ;        cptr -> $A800 + row*80   (color)
003D57  2               ;   row*80 = row*64 + row*16 = (row<<6)+(row<<4)
003D57  2               ;----------------------------------------------------------------
003D57  2               rowbase:
003D57  2  85 20                STA     tmp0            ; row
003D59  2               ; row*16 -> ptr2
003D59  2  A9 00                LDA     #0
003D5B  2  85 13                STA     ptr2+1
003D5D  2  A5 20                LDA     tmp0
003D5F  2  0A                   ASL     A               ; *2
003D60  2  0A                   ASL     A               ; *4
003D61  2  0A                   ASL     A               ; *8
003D62  2  0A                   ASL     A               ; *16 (row<=23 so <=368, may set carry)
003D63  2  85 12                STA     ptr2
003D65  2  A9 00                LDA     #0
003D67  2  2A                   ROL     A
003D68  2  85 13                STA     ptr2+1          ; high bits of row*16
003D6A  2               ; row*64 -> ptr
003D6A  2  A5 20                LDA     tmp0
003D6C  2  85 10                STA     ptr
003D6E  2  A9 00                LDA     #0
003D70  2  85 11                STA     ptr+1
003D72  2  06 10                ASL     ptr
003D74  2  26 11                ROL     ptr+1           ; *2
003D76  2  06 10                ASL     ptr
003D78  2  26 11                ROL     ptr+1           ; *4
003D7A  2  06 10                ASL     ptr
003D7C  2  26 11                ROL     ptr+1           ; *8
003D7E  2  06 10                ASL     ptr
003D80  2  26 11                ROL     ptr+1           ; *16
003D82  2  06 10                ASL     ptr
003D84  2  26 11                ROL     ptr+1           ; *32
003D86  2  06 10                ASL     ptr
003D88  2  26 11                ROL     ptr+1           ; *64
003D8A  2               ; ptr = ptr + ptr2 = row*80
003D8A  2  18                   CLC
003D8B  2  A5 10                LDA     ptr
003D8D  2  65 12                ADC     ptr2
003D8F  2  85 10                STA     ptr
003D91  2  A5 11                LDA     ptr+1
003D93  2  65 13                ADC     ptr2+1
003D95  2  85 11                STA     ptr+1
003D97  2               ; vptr = $A000 + ptr
003D97  2  18                   CLC
003D98  2  A5 10                LDA     ptr
003D9A  2  85 14                STA     vptr
003D9C  2  A5 11                LDA     ptr+1
003D9E  2  69 A0                ADC     #>VRAM_TEXT
003DA0  2  85 15                STA     vptr+1
003DA2  2               ; cptr = $A800 + ptr
003DA2  2  18                   CLC
003DA3  2  A5 10                LDA     ptr
003DA5  2  85 16                STA     cptr
003DA7  2  A5 11                LDA     ptr+1
003DA9  2  69 A8                ADC     #>VRAM_COLOR
003DAB  2  85 17                STA     cptr+1
003DAD  2  60                   RTS
003DAE  2               
003DAE  2               ;----------------------------------------------------------------
003DAE  2               ; putcell - write one char+color cell directly to VRAM.
003DAE  2               ;   MUST be called between vid_enter / vid_exit.
003DAE  2               ;   IN : tmp1 = row, tmp2 = col, tmp3 = char, colidx = color
003DAE  2               ;   trashes A,Y
003DAE  2               ;----------------------------------------------------------------
003DAE  2               putcell:
003DAE  2  A5 21                LDA     tmp1
003DB0  2  20 57 3D             JSR     rowbase
003DB3  2  A4 22                LDY     tmp2
003DB5  2  A5 23                LDA     tmp3
003DB7  2  91 14                STA     (vptr),Y
003DB9  2  A5 26                LDA     colidx
003DBB  2  91 16                STA     (cptr),Y
003DBD  2  60                   RTS
003DBE  2               
003DBE  2               ;----------------------------------------------------------------
003DBE  2               ; cls_vram - fill the whole screen with spaces in C_BLANK.
003DBE  2               ;----------------------------------------------------------------
003DBE  2               cls_vram:
003DBE  2  20 42 3D             JSR     vid_enter
003DC1  2  A9 00                LDA     #0
003DC3  2  85 27                STA     rowidx
003DC5  2               @row:
003DC5  2  A5 27                LDA     rowidx
003DC7  2  20 57 3D             JSR     rowbase
003DCA  2  A0 00                LDY     #0
003DCC  2               @col:
003DCC  2  A9 20                LDA     #space
003DCE  2  91 14                STA     (vptr),Y
003DD0  2  A9 08                LDA     #C_BLANK
003DD2  2  91 16                STA     (cptr),Y
003DD4  2  C8                   INY
003DD5  2  C0 50                CPY     #SCRW
003DD7  2  D0 F3                BNE     @col
003DD9  2  E6 27                INC     rowidx
003DDB  2  A5 27                LDA     rowidx
003DDD  2  C9 18                CMP     #SCRH
003DDF  2  D0 E4                BNE     @row
003DE1  2  4C 51 3D             JMP     vid_exit
003DE4  2               
003DE4  2               ;----------------------------------------------------------------
003DE4  2               ; fillrow_vram - fill one row [colA..colB) with char/color.
003DE4  2               ;   IN: tmp1=row, tmp2=start col, tmp3=char, colidx=color, cnt0=count
003DE4  2               ;   MUST be inside vid_enter/vid_exit.
003DE4  2               ;----------------------------------------------------------------
003DE4  2               fillrow_vram:
003DE4  2  A5 21                LDA     tmp1
003DE6  2  20 57 3D             JSR     rowbase
003DE9  2  A4 22                LDY     tmp2
003DEB  2  A6 24                LDX     cnt0
003DED  2               @fl:
003DED  2  A5 23                LDA     tmp3
003DEF  2  91 14                STA     (vptr),Y
003DF1  2  A5 26                LDA     colidx
003DF3  2  91 16                STA     (cptr),Y
003DF5  2  C8                   INY
003DF6  2  CA                   DEX
003DF7  2  D0 F4                BNE     @fl
003DF9  2  60                   RTS
003DFA  2               
003DFA  2               ;----------------------------------------------------------------
003DFA  2               ; draw_frame - draw the static game UI: title bar, viewport frame,
003DFA  2               ;              stat panel frame, and message area divider.
003DFA  2               ;              Done once at game start (and after returning from
003DFA  2               ;              full-screen menus).
003DFA  2               ;----------------------------------------------------------------
003DFA  2               draw_frame:
003DFA  2  20 BE 3D             JSR     cls_vram
003DFD  2  20 42 3D             JSR     vid_enter
003E00  2               
003E00  2               ; --- top title bar (row 0) ---
003E00  2  A9 00                LDA     #0
003E02  2  85 21                STA     tmp1
003E04  2  A9 00                LDA     #0
003E06  2  85 22                STA     tmp2
003E08  2  A9 20                LDA     #space
003E0A  2  85 23                STA     tmp3
003E0C  2  A9 0E                LDA     #C_TITLE
003E0E  2  85 26                STA     colidx
003E10  2  A9 50                LDA     #SCRW
003E12  2  85 24                STA     cnt0
003E14  2  20 E4 3D             JSR     fillrow_vram
003E17  2               ; centered title text written below via vid_exit path
003E17  2               
003E17  2               ; --- viewport top/bottom horizontal borders ---
003E17  2               ; top border at row 0 already part of title; we frame the
003E17  2               ; viewport with vertical bars and a bottom rule at VPY0+VPH.
003E17  2               ; vertical left/right bars for viewport rows
003E17  2  A2 01                LDX     #VPY0
003E19  2               @vbar:
003E19  2  8A                   TXA
003E1A  2  85 21                STA     tmp1
003E1C  2  20 57 3D             JSR     rowbase
003E1F  2  A0 00                LDY     #0              ; left edge col 0
003E21  2  A9 7C                LDA     #'|'
003E23  2  91 14                STA     (vptr),Y
003E25  2  A9 0B                LDA     #C_BORDER
003E27  2  91 16                STA     (cptr),Y
003E29  2  A0 2D                LDY     #(VPW+1)        ; right edge of viewport
003E2B  2  A9 7C                LDA     #'|'
003E2D  2  91 14                STA     (vptr),Y
003E2F  2  A9 0B                LDA     #C_BORDER
003E31  2  91 16                STA     (cptr),Y
003E33  2  E8                   INX
003E34  2  E0 15                CPX     #(VPY0+VPH)
003E36  2  D0 E1                BNE     @vbar
003E38  2               
003E38  2               ; viewport bottom rule + message divider share row VPY0+VPH
003E38  2               ; (= MSGY0-1).  Draw it full-width.
003E38  2  A9 15                LDA     #(VPY0+VPH)
003E3A  2  85 21                STA     tmp1
003E3C  2  A9 00                LDA     #0
003E3E  2  85 22                STA     tmp2
003E40  2  A9 3D                LDA     #'='
003E42  2  85 23                STA     tmp3
003E44  2  A9 0B                LDA     #C_BORDER
003E46  2  85 26                STA     colidx
003E48  2  A9 50                LDA     #SCRW
003E4A  2  85 24                STA     cnt0
003E4C  2  20 E4 3D             JSR     fillrow_vram
003E4F  2               
003E4F  2               ; panel header row (row 1) background highlight
003E4F  2  A9 01                LDA     #1
003E51  2  85 21                STA     tmp1
003E53  2  A9 2E                LDA     #(VPW+2)
003E55  2  85 22                STA     tmp2
003E57  2  A9 20                LDA     #space
003E59  2  85 23                STA     tmp3
003E5B  2  A9 1E                LDA     #C_PANELHDR
003E5D  2  85 26                STA     colidx
003E5F  2  A9 22                LDA     #(SCRW-(VPW+2))
003E61  2  85 24                STA     cnt0
003E63  2  20 E4 3D             JSR     fillrow_vram
003E66  2               
003E66  2  20 51 3D             JSR     vid_exit
003E69  2               
003E69  2               ; write the title bar + panel header text via firmware
003E69  2  A2 1E                LDX     #30
003E6B  2  A0 00                LDY     #0
003E6D  2  20 90 3E             JSR     locate
003E70  2  A9 0E                LDA     #C_TITLE
003E72  2  8D 4A 06             STA     CURCOLOR
003E75  2  A9 4F A0 40          PRINTMSG titlebar
003E79  2  20 A2 3E     
003E7C  2               
003E7C  2  A2 30                LDX     #(VPW+4)
003E7E  2  A0 01                LDY     #1
003E80  2  20 90 3E             JSR     locate
003E83  2  A9 1E                LDA     #C_PANELHDR
003E85  2  8D 4A 06             STA     CURCOLOR
003E88  2  A9 63 A0 40          PRINTMSG panelhdr
003E8C  2  20 A2 3E     
003E8F  2  60                   RTS
003E90  2               
003E90  2               ;----------------------------------------------------------------
003E90  2               ; locate - position the firmware text cursor.  X=col, Y=row.
003E90  2               ;----------------------------------------------------------------
003E90  2               locate:
003E90  2  A9 25 85 32          FARCALL FC_LOCATE
003E94  2  20 F0 FF     
003E97  2  60                   RTS
003E98  2               
003E98  2               ;----------------------------------------------------------------
003E98  2               ; putc - output one char via firmware (A=char), honoring CURCOLOR.
003E98  2               ;        (Cannot use the FARCALL macro - it would clobber the char
003E98  2               ;         in A.  Set farfunct, then restore A before the call.)
003E98  2               ;----------------------------------------------------------------
003E98  2               putc:
003E98  2  48                   PHA
003E99  2  A9 13                LDA     #FC_CHROUT
003E9B  2  85 32                STA     farfunct
003E9D  2  68                   PLA
003E9E  2  20 F0 FF             JSR     DO_FARCALL
003EA1  2  60                   RTS
003EA2  2               
003EA2  2               ;----------------------------------------------------------------
003EA2  2               ; prmsg - print a 0-terminated string via firmware chrout.
003EA2  2               ;   IN: A=lo, Y=hi of string address.  Uses CURCOLOR for color.
003EA2  2               ;----------------------------------------------------------------
003EA2  2               prmsg:
003EA2  2  85 1C                STA     strp
003EA4  2  84 1D                STY     strp+1
003EA6  2  A0 00                LDY     #0
003EA8  2               @pl:
003EA8  2  B1 1C                LDA     (strp),Y
003EAA  2  F0 08                BEQ     @done
003EAC  2  5A                   PHY
003EAD  2  20 98 3E             JSR     putc
003EB0  2  7A                   PLY
003EB1  2  C8                   INY
003EB2  2  D0 F4                BNE     @pl
003EB4  2               @done:
003EB4  2  60                   RTS
003EB5  2               
003EB5  2               ;----------------------------------------------------------------
003EB5  2               ; putxy - position cursor (X=col,Y=row), set color (A=color),
003EB5  2               ;         then print string at strp.  Helper for panel fields.
003EB5  2               ;   IN: tmp2=col, tmp1=row, colidx=color, strp=string ptr
003EB5  2               ;----------------------------------------------------------------
003EB5  2               putxy:
003EB5  2  A6 22                LDX     tmp2
003EB7  2  A4 21                LDY     tmp1
003EB9  2  20 90 3E             JSR     locate
003EBC  2  A5 26                LDA     colidx
003EBE  2  8D 4A 06             STA     CURCOLOR
003EC1  2  A5 1C                LDA     strp
003EC3  2  A4 1D                LDY     strp+1
003EC5  2  20 A2 3E             JSR     prmsg
003EC8  2  60                   RTS
003EC9  2               
003EC9  2               ;----------------------------------------------------------------
003EC9  2               ; clear_panel_value - blank a panel field area before redraw.
003EC9  2               ;   IN: X=col, Y=row, A=width
003EC9  2               ;----------------------------------------------------------------
003EC9  2               clear_panel_value:
003EC9  2  85 25                STA     cnt1            ; width
003ECB  2  20 90 3E             JSR     locate
003ECE  2  A9 0F                LDA     #C_PANEL
003ED0  2  8D 4A 06             STA     CURCOLOR
003ED3  2               @cpv:
003ED3  2  A9 20                LDA     #space
003ED5  2  20 98 3E             JSR     putc
003ED8  2  C6 25                DEC     cnt1
003EDA  2  D0 F7                BNE     @cpv
003EDC  2  60                   RTS
003EDD  2               
003EDD  2               ;----------------------------------------------------------------
003EDD  2               ; render_view - draw the scrolling map viewport centered on the
003EDD  2               ; player. Each world tile is a 2x2 character-cell metatile.
003EDD  2               ;
003EDD  2               ;   uses: px,py (player world coords), loc (active map)
003EDD  2               ;   The top-left WORLD cell shown is (px-VPCX, py-VPCY).
003EDD  2               ;----------------------------------------------------------------
003EDD  2               render_view:
003EDD  2  20 42 3D             JSR     vid_enter
003EE0  2               ; world-tile row = 0..VPTH-1
003EE0  2  A9 00                LDA     #0
003EE2  2  85 27                STA     rowidx
003EE4  2               @vrow:
003EE4  2               ; world y for this row = py - VPCY + rowidx
003EE4  2  38                   SEC
003EE5  2  AD 7C 6D             LDA     py
003EE8  2  E9 05                SBC     #VPCY
003EEA  2  18                   CLC
003EEB  2  65 27                ADC     rowidx
003EED  2  85 2D                STA     tgty
003EEF  2               ; world-tile column loop
003EEF  2  A9 00                LDA     #0
003EF1  2  85 26                STA     colidx
003EF3  2               @vcol:
003EF3  2               ; world x = px - VPCX + colidx
003EF3  2  38                   SEC
003EF4  2  AD 7B 6D             LDA     px
003EF7  2  E9 0B                SBC     #VPCX
003EF9  2  18                   CLC
003EFA  2  65 26                ADC     colidx
003EFC  2  85 2C                STA     tgtx
003EFE  2               ; fetch tile (returns tgttile)
003EFE  2  20 F4 1E             JSR     tileat
003F01  2               ; metatile base glyph = MG_TERRAIN_BASE + tile_code*4
003F01  2  A5 2E                LDA     tgttile
003F03  2  0A                   ASL     A
003F04  2  0A                   ASL     A
003F05  2  18                   CLC
003F06  2  69 80                ADC     #MG_TERRAIN_BASE
003F08  2  85 24                STA     cnt0
003F0A  2  A6 2E                LDX     tgttile
003F0C  2  20 67 3F             JSR     render_tile_color
003F0F  2  85 25                STA     cnt1
003F11  2  A6 2E                LDX     tgttile
003F13  2               ; pick an alternate art variant for some cells so large regions of
003F13  2               ; one terrain don't show an obvious repeating grid. Variants are
003F13  2               ; position-stable so the map does not crawl during movement.
003F13  2  BD 7A 1D             LDA     tile_variant,X
003F16  2  F0 0D                BEQ     @novar          ; this terrain has no variant
003F18  2  A5 2C                LDA     tgtx
003F1A  2  45 2D                EOR     tgty
003F1C  2  29 01                AND     #$01
003F1E  2  F0 05                BEQ     @novar          ; hash says keep the base art
003F20  2  BD 7A 1D             LDA     tile_variant,X  ; swap in the variant metatile base
003F23  2  85 24                STA     cnt0
003F25  2               @novar:
003F25  2               ; screen column = VPX0 + colidx*2
003F25  2  A5 26                LDA     colidx
003F27  2  0A                   ASL     A
003F28  2  18                   CLC
003F29  2  69 01                ADC     #VPX0
003F2B  2  85 22                STA     tmp2
003F2D  2               ; screen row = VPY0 + rowidx*2
003F2D  2  A5 27                LDA     rowidx
003F2F  2  0A                   ASL     A
003F30  2  18                   CLC
003F31  2  69 01                ADC     #VPY0
003F33  2  85 23                STA     tmp3
003F35  2  20 9C 3F             JSR     blit_metatile_vram
003F38  2               ; next column
003F38  2  E6 26                INC     colidx
003F3A  2  A5 26                LDA     colidx
003F3C  2  C9 16                CMP     #VPTW
003F3E  2  D0 B3                BNE     @vcol
003F40  2               ; next row
003F40  2  E6 27                INC     rowidx
003F42  2  A5 27                LDA     rowidx
003F44  2  C9 0A                CMP     #VPTH
003F46  2  D0 9C                BNE     @vrow
003F48  2               
003F48  2               ; --- overlay monsters that fall within the viewport ---
003F48  2  20 66 4A             JSR     draw_monsters_vram
003F4B  2               
003F4B  2               ; --- overlay the dragon's warned fire lane ---
003F4B  2  20 96 4A             JSR     draw_dragon_telegraph_vram
003F4E  2               
003F4E  2               ; --- overlay fixed location characters ---
003F4E  2  20 81 3F             JSR     draw_castle_ruler_vram
003F51  2               
003F51  2               ; --- overlay the player at the fixed center metatile ---
003F51  2  A9 C4                LDA     #MG_PLAYER
003F53  2  85 24                STA     cnt0
003F55  2  A9 0F                LDA     #C_PLAYER
003F57  2  85 25                STA     cnt1
003F59  2  A9 17                LDA     #(VPX0+(VPCX*2))
003F5B  2  85 22                STA     tmp2
003F5D  2  A9 0B                LDA     #(VPY0+(VPCY*2))
003F5F  2  85 23                STA     tmp3
003F61  2  20 D9 3F             JSR     blit_entity_vram
003F64  2               
003F64  2  4C 51 3D             JMP     vid_exit
003F67  2               
003F67  2               ;----------------------------------------------------------------
003F67  2               ; render_tile_color - choose the visible color for tile X.
003F67  2               ;   IN: X=tile code
003F67  2               ;  OUT: A=color byte
003F67  2               ;----------------------------------------------------------------
003F67  2               render_tile_color:
003F67  2  AD 89 6D             LDA     loc
003F6A  2  C9 01                CMP     #LOC_TOWN
003F6C  2  D0 0F                BNE     @base
003F6E  2  AD 8A 6D             LDA     town_id
003F71  2  C9 01                CMP     #TOWN_VALEHAVEN
003F73  2  F0 04                BEQ     @vale
003F75  2  BD 58 1D             LDA     eastmere_tile_color,X
003F78  2  60                   RTS
003F79  2               @vale:
003F79  2  BD 69 1D             LDA     valehaven_tile_color,X
003F7C  2  60                   RTS
003F7D  2               @base:
003F7D  2  BD 47 1D             LDA     tile_color,X
003F80  2  60                   RTS
003F81  2               
003F81  2               ;----------------------------------------------------------------
003F81  2               ; draw_castle_ruler_vram - draw the ruler over the audience-room
003F81  2               ; throne using the player silhouette in royal colors.
003F81  2               ;----------------------------------------------------------------
003F81  2               draw_castle_ruler_vram:
003F81  2  AD 89 6D             LDA     loc
003F84  2  C9 03                CMP     #LOC_CASTLE
003F86  2  D0 13                BNE     @done
003F88  2  A9 0F                LDA     #CASTLE_RULER_X
003F8A  2  85 2C                STA     tgtx
003F8C  2  A9 04                LDA     #CASTLE_RULER_Y
003F8E  2  85 2D                STA     tgty
003F90  2  A9 C4                LDA     #MG_PLAYER
003F92  2  85 24                STA     cnt0
003F94  2  A9 4E                LDA     #COLOR(CO_BRYELLOW,CO_RED)
003F96  2  85 25                STA     cnt1
003F98  2  4C 21 40             JMP     plot_view_cell
003F9B  2               @done:
003F9B  2  60                   RTS
003F9C  2               
003F9C  2               ;----------------------------------------------------------------
003F9C  2               ; blit_metatile_vram - draw a 2x2 terrain metatile with one color.
003F9C  2               ;   IN: cnt0=base glyph, cnt1=color, tmp2=screen col, tmp3=screen row
003F9C  2               ;   MUST be called inside vid_enter/vid_exit.
003F9C  2               ;----------------------------------------------------------------
003F9C  2               blit_metatile_vram:
003F9C  2  A5 23                LDA     tmp3
003F9E  2  20 57 3D             JSR     rowbase
003FA1  2  A4 22                LDY     tmp2
003FA3  2  A5 24                LDA     cnt0
003FA5  2  91 14                STA     (vptr),Y
003FA7  2  A5 25                LDA     cnt1
003FA9  2  91 16                STA     (cptr),Y
003FAB  2  C8                   INY
003FAC  2  A5 24                LDA     cnt0
003FAE  2  18                   CLC
003FAF  2  69 01                ADC     #1
003FB1  2  91 14                STA     (vptr),Y
003FB3  2  A5 25                LDA     cnt1
003FB5  2  91 16                STA     (cptr),Y
003FB7  2               
003FB7  2  A5 23                LDA     tmp3
003FB9  2  18                   CLC
003FBA  2  69 01                ADC     #1
003FBC  2  20 57 3D             JSR     rowbase
003FBF  2  A4 22                LDY     tmp2
003FC1  2  A5 24                LDA     cnt0
003FC3  2  18                   CLC
003FC4  2  69 02                ADC     #2
003FC6  2  91 14                STA     (vptr),Y
003FC8  2  A5 25                LDA     cnt1
003FCA  2  91 16                STA     (cptr),Y
003FCC  2  C8                   INY
003FCD  2  A5 24                LDA     cnt0
003FCF  2  18                   CLC
003FD0  2  69 03                ADC     #3
003FD2  2  91 14                STA     (vptr),Y
003FD4  2  A5 25                LDA     cnt1
003FD6  2  91 16                STA     (cptr),Y
003FD8  2  60                   RTS
003FD9  2               
003FD9  2               ;----------------------------------------------------------------
003FD9  2               ; blit_entity_vram - overlay a 2x2 entity metatile while preserving
003FD9  2               ; each terrain cell's background color.
003FD9  2               ;   IN: cnt0=base glyph, cnt1=entity color, tmp2=screen col,
003FD9  2               ;       tmp3=screen row
003FD9  2               ;   MUST be called inside vid_enter/vid_exit.
003FD9  2               ;----------------------------------------------------------------
003FD9  2               blit_entity_vram:
003FD9  2  A5 23                LDA     tmp3
003FDB  2  20 57 3D             JSR     rowbase
003FDE  2  A4 22                LDY     tmp2
003FE0  2  A5 24                LDA     cnt0
003FE2  2  91 14                STA     (vptr),Y
003FE4  2  20 12 40             JSR     entity_color_at_y
003FE7  2  C8                   INY
003FE8  2  A5 24                LDA     cnt0
003FEA  2  18                   CLC
003FEB  2  69 01                ADC     #1
003FED  2  91 14                STA     (vptr),Y
003FEF  2  20 12 40             JSR     entity_color_at_y
003FF2  2               
003FF2  2  A5 23                LDA     tmp3
003FF4  2  18                   CLC
003FF5  2  69 01                ADC     #1
003FF7  2  20 57 3D             JSR     rowbase
003FFA  2  A4 22                LDY     tmp2
003FFC  2  A5 24                LDA     cnt0
003FFE  2  18                   CLC
003FFF  2  69 02                ADC     #2
004001  2  91 14                STA     (vptr),Y
004003  2  20 12 40             JSR     entity_color_at_y
004006  2  C8                   INY
004007  2  A5 24                LDA     cnt0
004009  2  18                   CLC
00400A  2  69 03                ADC     #3
00400C  2  91 14                STA     (vptr),Y
00400E  2  20 12 40             JSR     entity_color_at_y
004011  2  60                   RTS
004012  2               
004012  2               ; preserve background nibble at the current cptr,Y; apply cnt1 foreground
004012  2               entity_color_at_y:
004012  2  B1 16                LDA     (cptr),Y
004014  2  29 F0                AND     #$F0
004016  2  85 20                STA     tmp0
004018  2  A5 25                LDA     cnt1
00401A  2  29 0F                AND     #$0F
00401C  2  05 20                ORA     tmp0
00401E  2  91 16                STA     (cptr),Y
004020  2  60                   RTS
004021  2               
004021  2               ;----------------------------------------------------------------
004021  2               ; plot_view_cell - overlay an entity metatile at WORLD coords
004021  2               ; (tgtx,tgty) if it is visible.
004021  2               ;   IN: tgtx,tgty=world coords, cnt0=base glyph, cnt1=color
004021  2               ;   MUST be called inside vid_enter/vid_exit.
004021  2               ;----------------------------------------------------------------
004021  2               plot_view_cell:
004021  2               ; viewport tile column = tgtx - px + VPCX
004021  2  38                   SEC
004022  2  A5 2C                LDA     tgtx
004024  2  ED 7B 6D             SBC     px
004027  2  18                   CLC
004028  2  69 0B                ADC     #VPCX
00402A  2               ; must be 0..VPTW-1
00402A  2  30 22                BMI     @no             ; (signed underflow check via N flag)
00402C  2  C9 16                CMP     #VPTW
00402E  2  B0 1E                BCS     @no
004030  2  0A                   ASL     A
004031  2  18                   CLC
004032  2  69 01                ADC     #VPX0
004034  2  85 22                STA     tmp2            ; screen column
004036  2               ; viewport tile row = tgty - py + VPCY
004036  2  38                   SEC
004037  2  A5 2D                LDA     tgty
004039  2  ED 7C 6D             SBC     py
00403C  2  18                   CLC
00403D  2  69 05                ADC     #VPCY
00403F  2  30 0D                BMI     @no
004041  2  C9 0A                CMP     #VPTH
004043  2  B0 09                BCS     @no
004045  2  0A                   ASL     A
004046  2  18                   CLC
004047  2  69 01                ADC     #VPY0
004049  2  85 23                STA     tmp3            ; screen row
00404B  2  4C D9 3F             JMP     blit_entity_vram
00404E  2               @no:
00404E  2  60                   RTS
00404F  2               
00404F  2               ;----------------------------------------------------------------
00404F  2               ; Static UI strings
00404F  2               ;----------------------------------------------------------------
00404F  2               titlebar:
00404F  2  3D 20 57 20          .BYTE   "= W Y R M H O L D =",0
004053  2  59 20 52 20  
004057  2  4D 20 48 20  
004063  2               panelhdr:
004063  2  41 44 56 45          .BYTE   "ADVENTURER",0
004067  2  4E 54 55 52  
00406B  2  45 52 00     
00406E  2               
00406E  1                       .INCLUDE "ui.asm"
00406E  2               ;______________________________________________________________________________
00406E  2               ;  ui.asm - message log, stat panel, prompts, decimal output
00406E  2               ;______________________________________________________________________________
00406E  2               
00406E  2               ;----------------------------------------------------------------
00406E  2               ; displaynum - print the 16-bit value in numarg as decimal using
00406E  2               ;              the firmware (honours CURCOLOR).  No leading spaces.
00406E  2               ;              (adapted from speedscript displaynum)
00406E  2               ;----------------------------------------------------------------
00406E  2               displaynum:
00406E  2  A0 08                LDY     #8              ; index into nums (5 entries x2 bytes)
004070  2               @find:
004070  2  A5 1F                LDA     numarg+1
004072  2  D9 B8 40             CMP     nums+1,Y
004075  2  90 09                BCC     @next
004077  2  D0 0B                BNE     @start
004079  2  A5 1E                LDA     numarg
00407B  2  D9 B7 40             CMP     nums,Y
00407E  2  B0 04                BCS     @start
004080  2               @next:
004080  2  88                   DEY
004081  2  88                   DEY
004082  2  D0 EC                BNE     @find
004084  2               @start:
004084  2  A9 30                LDA     #'0'
004086  2  85 28                STA     numspace
004088  2               @dig:
004088  2  A5 1F                LDA     numarg+1
00408A  2  D9 B8 40             CMP     nums+1,Y
00408D  2  90 1E                BCC     @out
00408F  2  D0 09                BNE     @nocmp
004091  2  A5 1E                LDA     numarg
004093  2  F9 B7 40             SBC     nums,Y          ; carry set
004096  2  90 15                BCC     @out
004098  2  B0 05                BCS     @sub
00409A  2               @nocmp:
00409A  2  A5 1E                LDA     numarg
00409C  2  F9 B7 40             SBC     nums,Y          ; carry set
00409F  2               @sub:
00409F  2  E6 28                INC     numspace
0040A1  2  85 1E                STA     numarg
0040A3  2  A5 1F                LDA     numarg+1
0040A5  2  F9 B8 40             SBC     nums+1,Y
0040A8  2  85 1F                STA     numarg+1
0040AA  2  4C 88 40             JMP     @dig
0040AD  2               @out:
0040AD  2  A5 28                LDA     numspace
0040AF  2  20 98 3E             JSR     putc
0040B2  2  88                   DEY
0040B3  2  88                   DEY
0040B4  2  10 CE                BPL     @start
0040B6  2  60                   RTS
0040B7  2               
0040B7  2               ; place value table (1,10,100,1000,10000) as 16-bit LE words
0040B7  2               nums:
0040B7  2  01 00                .WORD   1
0040B9  2  0A 00                .WORD   10
0040BB  2  64 00                .WORD   100
0040BD  2  E8 03                .WORD   1000
0040BF  2  10 27                .WORD   10000
0040C1  2               
0040C1  2               ;----------------------------------------------------------------
0040C1  2               ; print a single 8-bit value (in A) as decimal.
0040C1  2               ;----------------------------------------------------------------
0040C1  2               print_byte:
0040C1  2  85 1E                STA     numarg
0040C3  2  A9 00                LDA     #0
0040C5  2  85 1F                STA     numarg+1
0040C7  2  4C 6E 40             JMP     displaynum
0040CA  2               
0040CA  2               ;----------------------------------------------------------------
0040CA  2               ; Message log: two lines at rows MSGY0 and MSGY0+1.
0040CA  2               ; msg_print scrolls the bottom line up and prints a new line.
0040CA  2               ;
0040CA  2               ;   msg_print:  IN A=lo,Y=hi of 0-terminated string
0040CA  2               ;----------------------------------------------------------------
0040CA  2               msg_print:
0040CA  2  85 1C                STA     strp
0040CC  2  84 1D                STY     strp+1
0040CE  2               ; copy current bottom line (msgbuf1) up to (msgbuf0)
0040CE  2  A2 00                LDX     #0
0040D0  2               @up:
0040D0  2  BD F8 6D             LDA     msgbuf1,X
0040D3  2  9D A8 6D             STA     msgbuf0,X
0040D6  2  E8                   INX
0040D7  2  E0 50                CPX     #SCRW
0040D9  2  D0 F5                BNE     @up
0040DB  2               ; copy new string into msgbuf1 (truncate/pad to SCRW)
0040DB  2  A0 00                LDY     #0
0040DD  2               @cp:
0040DD  2  B1 1C                LDA     (strp),Y
0040DF  2  F0 0B                BEQ     @padb
0040E1  2  99 F8 6D             STA     msgbuf1,Y
0040E4  2  C8                   INY
0040E5  2  C0 50                CPY     #SCRW
0040E7  2  D0 F4                BNE     @cp
0040E9  2  4C F6 40             JMP     @draw
0040EC  2               @padb:
0040EC  2  A9 20                LDA     #space
0040EE  2               @pad:
0040EE  2  99 F8 6D             STA     msgbuf1,Y
0040F1  2  C8                   INY
0040F2  2  C0 50                CPY     #SCRW
0040F4  2  D0 F8                BNE     @pad
0040F6  2               @draw:
0040F6  2  4C F9 40             JMP     msg_redraw
0040F9  2               
0040F9  2               ;----------------------------------------------------------------
0040F9  2               ; msg_redraw - blit both message buffers to the message rows via
0040F9  2               ;              direct VRAM (so it does not disturb the text cursor).
0040F9  2               ;----------------------------------------------------------------
0040F9  2               msg_redraw:
0040F9  2  20 42 3D             JSR     vid_enter
0040FC  2               ; row MSGY0 <- msgbuf0
0040FC  2  A9 16                LDA     #MSGY0
0040FE  2  20 57 3D             JSR     rowbase
004101  2  A0 00                LDY     #0
004103  2               @r0:
004103  2  B9 A8 6D             LDA     msgbuf0,Y
004106  2  91 14                STA     (vptr),Y
004108  2  A9 0F                LDA     #C_MSG
00410A  2  91 16                STA     (cptr),Y
00410C  2  C8                   INY
00410D  2  C0 50                CPY     #SCRW
00410F  2  D0 F2                BNE     @r0
004111  2               ; row MSGY0+1 <- msgbuf1
004111  2  A9 17                LDA     #MSGY0+1
004113  2  20 57 3D             JSR     rowbase
004116  2  A0 00                LDY     #0
004118  2               @r1:
004118  2  B9 F8 6D             LDA     msgbuf1,Y
00411B  2  91 14                STA     (vptr),Y
00411D  2  A9 0F                LDA     #C_MSG
00411F  2  91 16                STA     (cptr),Y
004121  2  C8                   INY
004122  2  C0 50                CPY     #SCRW
004124  2  D0 F2                BNE     @r1
004126  2  4C 51 3D             JMP     vid_exit
004129  2               
004129  2               ;----------------------------------------------------------------
004129  2               ; msg_clear - blank both message buffers and redraw.
004129  2               ;----------------------------------------------------------------
004129  2               msg_clear:
004129  2  A2 00                LDX     #0
00412B  2  A9 20                LDA     #space
00412D  2               @mc:
00412D  2  9D A8 6D             STA     msgbuf0,X
004130  2  9D F8 6D             STA     msgbuf1,X
004133  2  E8                   INX
004134  2  E0 50                CPX     #SCRW
004136  2  D0 F5                BNE     @mc
004138  2  4C F9 40             JMP     msg_redraw
00413B  2               
00413B  2               ;----------------------------------------------------------------
00413B  2               ; Stat panel.  Drawn on the right side using firmware text output.
00413B  2               ; Labels are static; values are redrawn each turn.
00413B  2               ;----------------------------------------------------------------
00413B  2               draw_panel:
00413B  2               ; HP line:  "HP   : nn/nn"
00413B  2  A2 30                LDX     #PANX
00413D  2  A0 03                LDY     #3
00413F  2  20 90 3E             JSR     locate
004142  2  A9 0F                LDA     #C_PANEL
004144  2  8D 4A 06             STA     CURCOLOR
004147  2  A9 FC A0 44          PRINTMSG lbl_hp
00414B  2  20 A2 3E     
00414E  2  AD 7D 6D             LDA     phealth
004151  2  20 C1 40             JSR     print_byte
004154  2  A9 2F                LDA     #'/'
004156  2  20 98 3E             JSR     putc
004159  2  AD 7E 6D             LDA     pmaxhp
00415C  2  20 C1 40             JSR     print_byte
00415F  2  20 38 43             JSR     pad_clear       ; clear trailing junk
004162  2               
004162  2               ; Level / XP
004162  2  A2 30                LDX     #PANX
004164  2  A0 05                LDY     #5
004166  2  20 90 3E             JSR     locate
004169  2  A9 04 A0 45          PRINTMSG lbl_lvl
00416D  2  20 A2 3E     
004170  2  AD 7F 6D             LDA     plevel
004173  2  20 C1 40             JSR     print_byte
004176  2  A2 3C                LDX     #PANX+12
004178  2  A0 05                LDY     #5
00417A  2  20 90 3E             JSR     locate
00417D  2  A9 0A A0 45          PRINTMSG lbl_xp
004181  2  20 A2 3E     
004184  2  AD 80 6D 85          COPY16  pxp, numarg
004188  2  1E AD 81 6D  
00418C  2  85 1F        
00418E  2  20 6E 40             JSR     displaynum
004191  2  20 38 43             JSR     pad_clear
004194  2               
004194  2               ; Gold / Food
004194  2  A2 30                LDX     #PANX
004196  2  A0 07                LDY     #7
004198  2  20 90 3E             JSR     locate
00419B  2  A9 0F A0 45          PRINTMSG lbl_gold
00419F  2  20 A2 3E     
0041A2  2  AD 82 6D 85          COPY16  pgold, numarg
0041A6  2  1E AD 83 6D  
0041AA  2  85 1F        
0041AC  2  20 6E 40             JSR     displaynum
0041AF  2  A2 3C                LDX     #PANX+12
0041B1  2  A0 07                LDY     #7
0041B3  2  20 90 3E             JSR     locate
0041B6  2  A9 16 A0 45          PRINTMSG lbl_food
0041BA  2  20 A2 3E     
0041BD  2  AD 84 6D 85          COPY16  pfood, numarg
0041C1  2  1E AD 85 6D  
0041C5  2  85 1F        
0041C7  2  20 6E 40             JSR     displaynum
0041CA  2  20 38 43             JSR     pad_clear
0041CD  2               
0041CD  2               ; Potions
0041CD  2  A2 30                LDX     #PANX
0041CF  2  A0 08                LDY     #8
0041D1  2  20 90 3E             JSR     locate
0041D4  2  A9 1D A0 45          PRINTMSG lbl_potion
0041D8  2  20 A2 3E     
0041DB  2  AD 86 6D             LDA     ppotions
0041DE  2  20 C1 40             JSR     print_byte
0041E1  2  20 38 43             JSR     pad_clear
0041E4  2               
0041E4  2               ; Weapon
0041E4  2  A2 30                LDX     #PANX
0041E6  2  A0 09                LDY     #9
0041E8  2  20 90 3E             JSR     locate
0041EB  2  A9 27 A0 45          PRINTMSG lbl_wpn
0041EF  2  20 A2 3E     
0041F2  2  AD 87 6D             LDA     pweapon
0041F5  2  20 48 43             JSR     name_weapon     ; strp -> name
0041F8  2  A5 1C                LDA     strp
0041FA  2  A4 1D                LDY     strp+1
0041FC  2  20 A2 3E             JSR     prmsg
0041FF  2  20 38 43             JSR     pad_clear
004202  2               
004202  2               ; Armor
004202  2  A2 30                LDX     #PANX
004204  2  A0 0A                LDY     #10
004206  2  20 90 3E             JSR     locate
004209  2  A9 30 A0 45          PRINTMSG lbl_arm
00420D  2  20 A2 3E     
004210  2  AD 88 6D             LDA     parmor
004213  2  20 55 43             JSR     name_armor
004216  2  A5 1C                LDA     strp
004218  2  A4 1D                LDY     strp+1
00421A  2  20 A2 3E             JSR     prmsg
00421D  2  20 38 43             JSR     pad_clear
004220  2               
004220  2               ; Location
004220  2  A2 30                LDX     #PANX
004222  2  A0 0C                LDY     #12
004224  2  20 90 3E             JSR     locate
004227  2  A9 39 A0 45          PRINTMSG lbl_loc
00422B  2  20 A2 3E     
00422E  2  AD 89 6D             LDA     loc
004231  2  20 62 43             JSR     name_loc
004234  2  A5 1C                LDA     strp
004236  2  A4 1D                LDY     strp+1
004238  2  20 A2 3E             JSR     prmsg
00423B  2  20 38 43             JSR     pad_clear
00423E  2               
00423E  2               ; Current objective
00423E  2  A2 30                LDX     #PANX
004240  2  A0 0E                LDY     #14
004242  2  20 90 3E             JSR     locate
004245  2  A9 1E                LDA     #C_PANELHDR
004247  2  8D 4A 06             STA     CURCOLOR
00424A  2  A9 42 A0 45          PRINTMSG lbl_obj
00424E  2  20 A2 3E     
004251  2  20 38 43             JSR     pad_clear
004254  2  A2 30                LDX     #PANX
004256  2  A0 0F                LDY     #15
004258  2  20 90 3E             JSR     locate
00425B  2  A9 0F                LDA     #C_PANEL
00425D  2  8D 4A 06             STA     CURCOLOR
004260  2  AD 91 6D             LDA     queststate
004263  2  20 9A 43             JSR     name_objective
004266  2  A5 1C                LDA     strp
004268  2  A4 1D                LDY     strp+1
00426A  2  20 A2 3E             JSR     prmsg
00426D  2  20 38 43             JSR     pad_clear
004270  2               
004270  2               ; Current status
004270  2  A2 30                LDX     #PANX
004272  2  A0 11                LDY     #17
004274  2  20 90 3E             JSR     locate
004277  2  A9 1E                LDA     #C_PANELHDR
004279  2  8D 4A 06             STA     CURCOLOR
00427C  2  A9 4C A0 45          PRINTMSG lbl_status
004280  2  20 A2 3E     
004283  2  20 38 43             JSR     pad_clear
004286  2  A2 30                LDX     #PANX
004288  2  A0 12                LDY     #18
00428A  2  20 90 3E             JSR     locate
00428D  2  A9 0F                LDA     #C_PANEL
00428F  2  8D 4A 06             STA     CURCOLOR
004292  2  AD 93 6D             LDA     poison_turns
004295  2  F0 15                BEQ     @healthy
004297  2  A9 0E                LDA     #C_STATUSWARN
004299  2  8D 4A 06             STA     CURCOLOR
00429C  2  A9 5B A0 45          PRINTMSG status_poison
0042A0  2  20 A2 3E     
0042A3  2  AD 93 6D             LDA     poison_turns
0042A6  2  20 C1 40             JSR     print_byte
0042A9  2  4C 34 43             JMP     @status_done
0042AC  2               @healthy:
0042AC  2  AD 7D 6D             LDA     phealth
0042AF  2  C9 0B                CMP     #HP_LOW_THRESHOLD+1
0042B1  2  B0 0F                BCS     @food_status
0042B3  2  A9 0E                LDA     #C_STATUSWARN
0042B5  2  8D 4A 06             STA     CURCOLOR
0042B8  2  A9 6D A0 45          PRINTMSG status_hp_low
0042BC  2  20 A2 3E     
0042BF  2  4C 34 43             JMP     @status_done
0042C2  2               @food_status:
0042C2  2  AD 85 6D             LDA     pfood+1
0042C5  2  D0 16                BNE     @terrain_status
0042C7  2  AD 84 6D             LDA     pfood
0042CA  2  C9 1A                CMP     #FOOD_LOW_THRESHOLD+1
0042CC  2  B0 0F                BCS     @terrain_status
0042CE  2  A9 0E                LDA     #C_STATUSWARN
0042D0  2  8D 4A 06             STA     CURCOLOR
0042D3  2  A9 64 A0 45          PRINTMSG status_food_low
0042D7  2  20 A2 3E     
0042DA  2  4C 34 43             JMP     @status_done
0042DD  2               @terrain_status:
0042DD  2  AD 89 6D             LDA     loc
0042E0  2  D0 23                BNE     @plain_healthy
0042E2  2  AD 7B 6D             LDA     px
0042E5  2  85 2C                STA     tgtx
0042E7  2  AD 7C 6D             LDA     py
0042EA  2  85 2D                STA     tgty
0042EC  2  20 F4 1E             JSR     tileat
0042EF  2  A5 2E                LDA     tgttile
0042F1  2  C9 07                CMP     #T_ROAD
0042F3  2  F0 1A                BEQ     @road
0042F5  2  C9 08                CMP     #T_BRIDGE
0042F7  2  F0 16                BEQ     @road
0042F9  2  C9 01                CMP     #T_FOREST
0042FB  2  F0 1C                BEQ     @forest
0042FD  2  C9 0F                CMP     #T_HILLS
0042FF  2  F0 22                BEQ     @hills
004301  2  C9 10                CMP     #T_MARSH
004303  2  F0 28                BEQ     @marsh
004305  2               @plain_healthy:
004305  2  A9 53 A0 45          PRINTMSG status_healthy
004309  2  20 A2 3E     
00430C  2  4C 34 43             JMP     @status_done
00430F  2               @road:
00430F  2  A9 74 A0 45          PRINTMSG status_road
004313  2  20 A2 3E     
004316  2  4C 34 43             JMP     @status_done
004319  2               @forest:
004319  2  A9 87 A0 45          PRINTMSG status_forest
00431D  2  20 A2 3E     
004320  2  4C 34 43             JMP     @status_done
004323  2               @hills:
004323  2  A9 94 A0 45          PRINTMSG status_hills
004327  2  20 A2 3E     
00432A  2  4C 34 43             JMP     @status_done
00432D  2               @marsh:
00432D  2  A9 A3 A0 45          PRINTMSG status_marsh
004331  2  20 A2 3E     
004334  2               @status_done:
004334  2  20 38 43             JSR     pad_clear
004337  2  60                   RTS
004338  2               
004338  2               ; pad_clear - print spaces out to the right screen edge to erase
004338  2               ;             any leftover characters from a previous longer value.
004338  2               ;             Stops at the last column to avoid auto-scroll.
004338  2               pad_clear:
004338  2               @pc:
004338  2  AD 47 06             LDA     CURX
00433B  2  C9 4F                CMP     #SCRW-1
00433D  2  B0 08                BCS     @done
00433F  2  A9 20                LDA     #space
004341  2  20 98 3E             JSR     putc
004344  2  4C 38 43             JMP     @pc
004347  2               @done:
004347  2  60                   RTS
004348  2               
004348  2               ;----------------------------------------------------------------
004348  2               ; name_weapon / name_armor / name_loc - set strp to a name string
004348  2               ;   IN: A = index
004348  2               ;----------------------------------------------------------------
004348  2               name_weapon:
004348  2  0A                   ASL     A
004349  2  AA                   TAX
00434A  2  BD B1 45             LDA     wpn_names,X
00434D  2  85 1C                STA     strp
00434F  2  BD B2 45             LDA     wpn_names+1,X
004352  2  85 1D                STA     strp+1
004354  2  60                   RTS
004355  2               name_armor:
004355  2  0A                   ASL     A
004356  2  AA                   TAX
004357  2  BD D0 45             LDA     arm_names,X
00435A  2  85 1C                STA     strp
00435C  2  BD D1 45             LDA     arm_names+1,X
00435F  2  85 1D                STA     strp+1
004361  2  60                   RTS
004362  2               name_loc:
004362  2  C9 00                CMP     #LOC_WORLD
004364  2  D0 13                BNE     @not_world
004366  2  AD 7C 6D             LDA     py
004369  2  20 E3 1E             JSR     region_from_y
00436C  2  0A                   ASL     A
00436D  2  AA                   TAX
00436E  2  BD 32 46             LDA     region_names,X
004371  2  85 1C                STA     strp
004373  2  BD 33 46             LDA     region_names+1,X
004376  2  85 1D                STA     strp+1
004378  2  60                   RTS
004379  2               @not_world:
004379  2  C9 01                CMP     #LOC_TOWN
00437B  2  D0 10                BNE     @interior
00437D  2  AD 8A 6D             LDA     town_id
004380  2  0A                   ASL     A
004381  2  AA                   TAX
004382  2  BD 5E 46             LDA     town_names,X
004385  2  85 1C                STA     strp
004387  2  BD 5F 46             LDA     town_names+1,X
00438A  2  85 1D                STA     strp+1
00438C  2  60                   RTS
00438D  2               @interior:
00438D  2  0A                   ASL     A
00438E  2  AA                   TAX
00438F  2  BD F4 45             LDA     loc_names,X
004392  2  85 1C                STA     strp
004394  2  BD F5 45             LDA     loc_names+1,X
004397  2  85 1D                STA     strp+1
004399  2  60                   RTS
00439A  2               name_objective:
00439A  2  0A                   ASL     A
00439B  2  AA                   TAX
00439C  2  BD 75 46             LDA     objective_names,X
00439F  2  85 1C                STA     strp
0043A1  2  BD 76 46             LDA     objective_names+1,X
0043A4  2  85 1D                STA     strp+1
0043A6  2  60                   RTS
