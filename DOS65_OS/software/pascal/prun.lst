00169Dr 1               op_UNIMP:
00169Dr 1               ; X still holds the offending opcode at dispatch time
00169Dr 1  86 rr                STX     tmp0
00169Fr 1  A9 00                LDA     #0
0016A1r 1  85 rr                STA     tmp0+1
0016A3r 1  DA                   PHX                     ; preserve for after banner
0016A4r 1  A9 rr                LDA     #<err_rt_opcode
0016A6r 1  85 rr                STA     tmp0
0016A8r 1  A9 rr                LDA     #>err_rt_opcode
