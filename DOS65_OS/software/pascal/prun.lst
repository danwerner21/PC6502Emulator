001A04r 1  xx xx xx xx  
001A08r 1  xx xx xx xx  
001A24r 1               
001A24r 1               ; ---------------------------------------------------------------------------
001A24r 1               ; Include shared I/O library
001A24r 1               ; ---------------------------------------------------------------------------
001A24r 1               .include    "IOLIB.ASM"
001A24r 2               .pc02
001A24r 2               ; iolib.asm — console and file I/O wrappers for DOS/65
001A24r 2               ;
001A24r 2               ; Uses PEM function 2 (CONOUT) for character output.
001A24r 2               ; This routes through DFT_CONSOLE and works on all platforms
001A24r 2               ; (serial, ESP video, memory-mapped video) regardless of which
001A24r 2               ; console driver is active.
001A24r 2               
001A24r 2                       .segment        "CODE"
001A24r 2               
001A24r 2               ; ---------------------------------------------------------------------------
001A24r 2               ; console_putc — output character in A to console via PEM #2
001A24r 2               ; ---------------------------------------------------------------------------
001A24r 2               console_putc:
001A24r 2  48                   PHA
001A25r 2  A2 02                LDX     #PEM_CONOUT
001A27r 2  20 03 01             JSR     PEM_ENTRY
001A2Ar 2  68                   PLA
001A2Br 2  60                   RTS
001A2Cr 2               
001A2Cr 2               ; ---------------------------------------------------------------------------
001A2Cr 2               ; console_newline — emit CR+LF
001A2Cr 2               ; ---------------------------------------------------------------------------
001A2Cr 2               console_newline:
001A2Cr 2  A9 0D                LDA     #$0D
001A2Er 2  A2 02                LDX     #PEM_CONOUT
001A30r 2  20 03 01             JSR     PEM_ENTRY
001A33r 2  A9 0A                LDA     #$0A
001A35r 2  A2 02                LDX     #PEM_CONOUT
001A37r 2  20 03 01             JSR     PEM_ENTRY
001A3Ar 2  60                   RTS
001A3Br 2               
001A3Br 2               ; ---------------------------------------------------------------------------
001A3Br 2               ; console_print_sz — print null-terminated string at tmp0
001A3Br 2               ; ---------------------------------------------------------------------------
001A3Br 2               console_print_sz:
001A3Br 2  A0 00                LDY     #0
001A3Dr 2               @loop:
001A3Dr 2  B1 rr                LDA     (tmp0),y
001A3Fr 2  F0 08                BEQ     @done
001A41r 2  A2 02                LDX     #PEM_CONOUT
001A43r 2  20 03 01             JSR     PEM_ENTRY
001A46r 2  C8                   INY
001A47r 2  D0 F4                BNE     @loop
001A49r 2               @done:
001A49r 2  60                   RTS
001A4Ar 2               
001A4Ar 2               ; ---------------------------------------------------------------------------
001A4Ar 2               ; console_print_pstr — print length-prefixed Pascal string at tmp0
001A4Ar 2               ; ---------------------------------------------------------------------------
001A4Ar 2               console_print_pstr:
001A4Ar 2  A0 00                LDY     #0
001A4Cr 2  B1 rr                LDA     (tmp0),y        ; length byte
001A4Er 2  F0 10                BEQ     @done
001A50r 2  AA                   TAX                     ; X = remaining chars — but X used by PEM!
001A51r 2               ; save length, use tmp1 as counter
001A51r 2  85 rr                STA     tmp1
001A53r 2  C8                   INY
001A54r 2               @loop:
001A54r 2  B1 rr                LDA     (tmp0),y
001A56r 2  A2 02                LDX     #PEM_CONOUT
001A58r 2  20 03 01             JSR     PEM_ENTRY
001A5Br 2  C8                   INY
001A5Cr 2  C6 rr                DEC     tmp1
001A5Er 2  D0 F4                BNE     @loop
001A60r 2               @done:
001A60r 2  60                   RTS
001A61r 2               
001A61r 2               ; ---------------------------------------------------------------------------
001A61r 2               ; console_print_dec — print signed 16-bit integer in tmp0:tmp0+1
001A61r 2               ; ---------------------------------------------------------------------------
001A61r 2               console_print_dec:
001A61r 2  A5 rr                LDA     tmp0+1
001A63r 2  10 14                BPL     @positive
001A65r 2  A9 2D                LDA     #'-'
001A67r 2  A2 02                LDX     #PEM_CONOUT
001A69r 2  20 03 01             JSR     PEM_ENTRY
001A6Cr 2  A9 00                LDA     #0
001A6Er 2  38                   SEC
001A6Fr 2  E5 rr                SBC     tmp0
001A71r 2  85 rr                STA     tmp0
001A73r 2  A9 00                LDA     #0
001A75r 2  E5 rr                SBC     tmp0+1
001A77r 2  85 rr                STA     tmp0+1
001A79r 2               @positive:
001A79r 2  A9 00                LDA     #0
001A7Br 2  48                   PHA                     ; sentinel
001A7Cr 2               @div_loop:
001A7Cr 2  20 rr rr             JSR     div16_by10      ; quotient→tmp0, remainder→scratch
001A7Fr 2  A5 rr                LDA     scratch
001A81r 2  18                   CLC
001A82r 2  69 30                ADC     #'0'
001A84r 2  48                   PHA
001A85r 2  A5 rr                LDA     tmp0
001A87r 2  05 rr                ORA     tmp0+1
001A89r 2  D0 F1                BNE     @div_loop
001A8Br 2               @print_loop:
001A8Br 2  68                   PLA
001A8Cr 2  F0 07                BEQ     @done2          ; sentinel
001A8Er 2  A2 02                LDX     #PEM_CONOUT
001A90r 2  20 03 01             JSR     PEM_ENTRY
001A93r 2  80 F6                BRA     @print_loop
001A95r 2               @done2:
001A95r 2  60                   RTS
001A96r 2               
001A96r 2               ; ---------------------------------------------------------------------------
001A96r 2               ; div16_by10 — divide tmp0:tmp0+1 by 10
001A96r 2               ; Result: quotient in tmp0:tmp0+1, remainder in scratch
001A96r 2               ; ---------------------------------------------------------------------------
001A96r 2               div16_by10:
001A96r 2  A9 00                LDA     #0
001A98r 2  85 rr                STA     scratch
001A9Ar 2  A2 10                LDX     #16
001A9Cr 2               @bit:
001A9Cr 2  06 rr                ASL     tmp0
001A9Er 2  26 rr                ROL     tmp0+1
001AA0r 2  26 rr                ROL     scratch
001AA2r 2  A5 rr                LDA     scratch
001AA4r 2  C9 0A                CMP     #10
001AA6r 2  90 06                BCC     @no_sub
001AA8r 2  E9 0A                SBC     #10
001AAAr 2  85 rr                STA     scratch
001AACr 2  E6 rr                INC     tmp0
001AAEr 2               @no_sub:
001AAEr 2  CA                   DEX
001AAFr 2  D0 EB                BNE     @bit
001AB1r 2  60                   RTS
001AB2r 2               
001AB2r 2               ; ---------------------------------------------------------------------------
001AB2r 2               ; console_read_line — read a line into buffer at tmp0, max len in x_save
001AB2r 2               ; Returns: Y = length (not including CR)
001AB2r 2               ; ---------------------------------------------------------------------------
001AB2r 2               console_read_line:
001AB2r 2  8E rr rr             STX     x_save
001AB5r 2  A0 00                LDY     #0
001AB7r 2               @loop:
001AB7r 2  A2 01                LDX     #PEM_CONIN
001AB9r 2  20 03 01             JSR     PEM_ENTRY
001ABCr 2  C9 0D                CMP     #$0D
001ABEr 2  F0 28                BEQ     @done
001AC0r 2  C9 08                CMP     #$08            ; backspace
001AC2r 2  D0 1C                BNE     @store
001AC4r 2  C0 00                CPY     #0
001AC6r 2  F0 EF                BEQ     @loop
001AC8r 2  88                   DEY
001AC9r 2  A9 08                LDA     #$08
001ACBr 2  A2 02                LDX     #PEM_CONOUT
001ACDr 2  20 03 01             JSR     PEM_ENTRY
001AD0r 2  A9 20                LDA     #' '
001AD2r 2  A2 02                LDX     #PEM_CONOUT
001AD4r 2  20 03 01             JSR     PEM_ENTRY
001AD7r 2  A9 08                LDA     #$08
001AD9r 2  A2 02                LDX     #PEM_CONOUT
001ADBr 2  20 03 01             JSR     PEM_ENTRY
001ADEr 2  80 D7                BRA     @loop
001AE0r 2               @store:
001AE0r 2  91 rr                STA     (tmp0),y
001AE2r 2  C8                   INY
001AE3r 2  CC rr rr             CPY     x_save
001AE6r 2  90 CF                BCC     @loop
001AE8r 2               @done:
001AE8r 2  60                   RTS
001AE9r 2               x_save:
001AE9r 2  00                   .BYTE   0
001AEAr 2               
001AEAr 2               ; ---------------------------------------------------------------------------
001AEAr 2               ; file_open — open file via FCB at tmp1; returns A=0 success, $FF=not found
001AEAr 2               ; PEM calling convention: X=function, A=FCB addr lo, Y=FCB addr hi
001AEAr 2               ; ---------------------------------------------------------------------------
001AEAr 2               file_open:
001AEAr 2  A5 rr                LDA     tmp1
001AECr 2  A4 rr                LDY     tmp1+1
001AEEr 2  A2 0F                LDX     #PEM_OPEN
001AF0r 2  20 03 01             JSR     PEM_ENTRY
001AF3r 2  60                   RTS
001AF4r 2               
001AF4r 2               ; ---------------------------------------------------------------------------
001AF4r 2               ; file_make — create/truncate file via FCB at tmp1
001AF4r 2               ; ---------------------------------------------------------------------------
001AF4r 2               file_make:
001AF4r 2  A5 rr                LDA     tmp1
001AF6r 2  A4 rr                LDY     tmp1+1
001AF8r 2  A2 16                LDX     #PEM_MAKE
001AFAr 2  20 03 01             JSR     PEM_ENTRY
001AFDr 2  60                   RTS
001AFEr 2               
001AFEr 2               ; ---------------------------------------------------------------------------
001AFEr 2               ; file_read_sector — read 128 bytes into DMA_BUF; returns A=0 ok, A=1 EOF
001AFEr 2               ; ---------------------------------------------------------------------------
001AFEr 2               file_read_sector:
001AFEr 2  A5 rr                LDA     tmp1
001B00r 2  A4 rr                LDY     tmp1+1
001B02r 2  A2 14                LDX     #PEM_READ
001B04r 2  20 03 01             JSR     PEM_ENTRY
001B07r 2  60                   RTS
001B08r 2               
001B08r 2               ; ---------------------------------------------------------------------------
001B08r 2               ; file_write_sector — write 128 bytes from DMA_BUF
001B08r 2               ; ---------------------------------------------------------------------------
001B08r 2               file_write_sector:
001B08r 2  A5 rr                LDA     tmp1
001B0Ar 2  A4 rr                LDY     tmp1+1
001B0Cr 2  A2 15                LDX     #PEM_WRITE
001B0Er 2  20 03 01             JSR     PEM_ENTRY
001B11r 2  60                   RTS
001B12r 2               
001B12r 2               ; ---------------------------------------------------------------------------
001B12r 2               ; file_close — close FCB at tmp1
001B12r 2               ; ---------------------------------------------------------------------------
001B12r 2               file_close:
001B12r 2  A5 rr                LDA     tmp1
001B14r 2  A4 rr                LDY     tmp1+1
001B16r 2  A2 10                LDX     #PEM_CLOSE
001B18r 2  20 03 01             JSR     PEM_ENTRY
001B1Br 2  60                   RTS
001B1Cr 2               
001B1Cr 2               ; ---------------------------------------------------------------------------
001B1Cr 2               ; file_setdma — point PEM at the 128-byte buffer at (A:Y)
001B1Cr 2               ; A = lo, Y = hi.  Trashes X.
001B1Cr 2               ; ---------------------------------------------------------------------------
001B1Cr 2               file_setdma:
001B1Cr 2  A2 1A                LDX     #PEM_SETDMA
001B1Er 2  4C 03 01             JMP     PEM_ENTRY
001B21r 2               
001B21r 2               ; ---------------------------------------------------------------------------
001B21r 2               ; file_setdma_default — restore PEM DMA pointer to system DMA_BUF
001B21r 2               ; ---------------------------------------------------------------------------
001B21r 2               file_setdma_default:
001B21r 2  A9 28                LDA     #<DMA_BUF
001B23r 2  A0 01                LDY     #>DMA_BUF
001B25r 2  A2 1A                LDX     #PEM_SETDMA
001B27r 2  4C 03 01             JMP     PEM_ENTRY
001B2Ar 2               
001B2Ar 1               .include    "MESSAGES.ASM"
001B2Ar 2               ; messages.asm — compiler error and status strings (null-terminated)
001B2Ar 2               
001B2Ar 2                       .segment  "CODE"
001B2Ar 2               
001B2Ar 2               msg_banner:
001B2Ar 2  50 61 73 63          .BYTE   "Pascal/65 Compiler v0.1 for DOS/65",13,10,0
001B2Er 2  61 6C 2F 36  
001B32r 2  35 20 43 6F  
001B4Fr 2               msg_compiling:
001B4Fr 2  43 6F 6D 70          .BYTE   "Compiling...",13,10,0
001B53r 2  69 6C 69 6E  
001B57r 2  67 2E 2E 2E  
001B5Er 2               msg_ok:
001B5Er 2  4F 4B 0D 0A          .BYTE   "OK",13,10,0
001B62r 2  00           
001B63r 2               msg_errors:
001B63r 2  20 65 72 72          .BYTE   " error(s)",13,10,0
001B67r 2  6F 72 28 73  
001B6Br 2  29 0D 0A 00  
001B6Fr 2               msg_line:
001B6Fr 2  20 4C 69 6E          .BYTE   " Line ",0
001B73r 2  65 20 00     
001B76r 2               msg_col:
001B76r 2  20 43 6F 6C          .BYTE   " Col ",0
001B7Ar 2  20 00        
001B7Cr 2               
