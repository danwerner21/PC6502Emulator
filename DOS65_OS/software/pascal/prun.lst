000F6Fr 1  8D rr rr             STA     frch_char
000F72r 1  C8                   INY
000F73r 1  98                   TYA
000F74r 1  A0 A5                LDY     #F_POS
000F76r 1  91 rr                STA     (tmp1),y
000F78r 1  20 rr rr             JSR     file_check_eof_helper
000F7Br 1  AD rr rr             LDA     frch_char
000F7Er 1  60                   RTS
000F7Fr 1               
000F7Fr 1               ; Helper: peek buf[F_POS], refilling the sector first if F_POS == 128.
000F7Fr 1               ; Sets F_EOF if no more data is available or peeked byte is CTRL-Z.
000F7Fr 1               ; Does not advance F_POS.  Trashes tmp2, X, Y.  Preserves tmp1, tmp3.
000F7Fr 1               file_check_eof_helper:
000F7Fr 1  A0 A5                LDY     #F_POS
000F81r 1  B1 rr                LDA     (tmp1),y
000F83r 1  C9 80                CMP     #128
000F85r 1  90 29                BCC     @fce_peek
