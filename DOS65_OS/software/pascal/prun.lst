000000r 1               ; prun.asm — P-Code Runtime for DOS/65
000000r 1               ;
000000r 1               ; Usage: PRUN <filename>   (loads <filename>.PCD and executes it)
000000r 1               ;
000000r 1               ; Memory layout at runtime:
000000r 1               ;   $0800-$17FF  this interpreter (code, dispatch tables, FCB, iolib, msgs)
000000r 1               ;   $1800-$1FFF  p-code loaded from .PCD (2 KB)
000000r 1               ;   $2000-$7FFF  p-machine value stack (grows up)
000000r 1               ;   $8000-$AFFF  heap (grows down from $B000)
000000r 1               ;   $B000-$B7DF  globals + string pool
000000r 1               
000000r 1               .PC02                                   ; enable 65C02 (BRA/PHX/PHY) for string built-ins
000000r 1               
000000r 1                       .include        "DEFINITIONS.ASM"
000000r 2               ; definitions.asm — constants, token codes, p-code opcodes, macros
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; DOS/65 system entry points
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               PEM_ENTRY       = $0103         ; JSR here; function # in X
000000r 2               WARM_BOOT       = $0100
000000r 2               DEFAULT_FCB     = $0107         ; DOS/65 dflfcb (parsed argument FCB)
000000r 2               DMA_BUF         = $0128         ; DOS/65 dflbuf (default DMA buffer)
000000r 2               
000000r 2               ; PEM function numbers
000000r 2               PEM_CONIN       = 1             ; console input with echo (blocking)
000000r 2               PEM_CONOUT      = 2             ; console output (A=char)
000000r 2               PEM_DIRCON      = 6             ; direct console I/O (BLOCKING — use fn 11 first)
000000r 2               PEM_CONSTAT     = 11            ; console status (non-blocking)
000000r 2               PEM_OPEN        = 15
000000r 2               PEM_CLOSE       = 16
000000r 2               PEM_SEARCH      = 17
000000r 2               PEM_DELETE      = 19
000000r 2               PEM_READ        = 20
000000r 2               PEM_WRITE       = 21
000000r 2               PEM_MAKE        = 22
000000r 2               PEM_SETDMA      = 26            ; set DMA buffer address (A=lo, Y=hi)
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; P-code opcodes
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 2               ; --- Constants ---
000000r 2               OP_LDCI         = $00           ; push sign-extended byte constant
000000r 2               OP_LDCW         = $01           ; push word constant (lo, hi)
000000r 2               OP_LDCC         = $02           ; push char constant
000000r 2               OP_LDCB         = $03           ; push boolean constant (0/1)
000000r 2               OP_LDCS         = $04           ; push string constant (len + bytes)
000000r 2               OP_LDCN         = $05           ; push NIL
000000r 2               
000000r 2               ; --- Local variable access ---
000000r 2               OP_LDL          = $10           ; push 16-bit local (byte offset from MP+8)
000000r 2               OP_STL          = $11           ; pop into 16-bit local
000000r 2               OP_LDA_L        = $12           ; push address of local
000000r 2               OP_LDB_L        = $13           ; push byte/char/bool local
000000r 2               OP_STB_L        = $14           ; pop byte into local
000000r 2               
000000r 2               ; --- Global variable access ---
000000r 2               OP_LDG          = $18           ; push 16-bit global (word offset from BASE)
000000r 2               OP_STG          = $19           ; pop into 16-bit global
000000r 2               OP_LDA_G        = $1A           ; push address of global
000000r 2               OP_LDB_G        = $1B           ; push byte global
000000r 2               OP_STB_G        = $1C           ; pop byte into global
000000r 2               
000000r 2               ; --- Indirect / array ---
000000r 2               OP_LDIND        = $20           ; TOS=addr → push word at addr
000000r 2               OP_STIND        = $21           ; NOS=addr, TOS=val → store
000000r 2               OP_LDB_IND      = $22           ; TOS=addr → push byte at addr
000000r 2               OP_STB_IND      = $23           ; NOS=addr, TOS=val → store byte
000000r 2               OP_INDEX        = $24           ; array index: addr=NOS+TOS*elemsize (word follows)
000000r 2               
000000r 2               ; --- Integer arithmetic ---
000000r 2               OP_ADI          = $30
000000r 2               OP_SBI          = $31
000000r 2               OP_MPI          = $32
000000r 2               OP_DVI          = $33
000000r 2               OP_MOD          = $34
000000r 2               OP_NGI          = $35           ; negate
000000r 2               OP_ABI          = $36           ; absolute value
000000r 2               OP_SQI          = $37           ; square
000000r 2               
000000r 2               ; --- Logical / bitwise ---
000000r 2               OP_LAND         = $38
000000r 2               OP_LOR          = $39
000000r 2               OP_LNOT         = $3A           ; logical NOT ($0000 ↔ $FFFF)
000000r 2               OP_BNOT         = $3B           ; bitwise complement
000000r 2               
000000r 2               ; --- Comparison (push $FFFF=true, $0000=false) ---
000000r 2               OP_EQUI         = $40
000000r 2               OP_NEQI         = $41
000000r 2               OP_LESI         = $42
000000r 2               OP_LEQI         = $43
000000r 2               OP_GTRI         = $44
000000r 2               OP_GEQI         = $45
000000r 2               OP_EQUB         = $46           ; byte equality
000000r 2               OP_EQUS         = $47           ; string equality
000000r 2               
000000r 2               ; --- Control flow ---
000000r 2               OP_UJP          = $50           ; unconditional jump (signed word offset)
000000r 2               OP_FJP          = $51           ; jump if false (pop TOS)
000000r 2               OP_TJP          = $52           ; jump if true  (pop TOS)
000000r 2               OP_IXPJP        = $53           ; case jump table
000000r 2               
000000r 2               ; --- Procedure/function calls ---
000000r 2               OP_CALL         = $60           ; call (signed word offset from current IPC)
000000r 2               OP_CALI         = $61           ; call absolute address (word)
000000r 2               OP_RET          = $62           ; return from procedure
000000r 2               OP_RETF         = $63           ; return from function (leave result on stack)
000000r 2               OP_MRKSTK       = $64           ; set up activation record (byte: local size)
000000r 2               OP_DEPSTK       = $65           ; tear down activation record
000000r 2               OP_STR          = $66           ; pop word, store at MP+AR_RET_VAL (function result)
000000r 2               OP_MRKA         = $67           ; mark+gather: bytes pcount, lsize_extra.
000000r 2                                               ; pcount values on TOS become local slots 0..pcount-1
000000r 2                                               ; in the new frame; lsize_extra reserves body-local space.
000000r 2               
000000r 2               ; --- Heap ---
000000r 2               OP_NEW          = $70           ; allocate (word size follows); push pointer
000000r 2               OP_DISP         = $71           ; free pointer on TOS
000000r 2               
000000r 2               ; --- I/O ---
000000r 2               OP_WRITI        = $80           ; write integer
000000r 2               OP_WRITC        = $81           ; write character
000000r 2               OP_WRITB        = $82           ; write boolean
000000r 2               OP_WRITS        = $83           ; write string
000000r 2               OP_WRITLN       = $84           ; write newline
000000r 2               OP_READI        = $85           ; read integer
000000r 2               OP_READC        = $86           ; read character
000000r 2               OP_READS        = $87           ; read string
000000r 2               OP_WRITR        = $88           ; write real (signed fixed-point, scale 100)
000000r 2               OP_READR        = $89           ; read real  (signed fixed-point, scale 100)
000000r 2               
000000r 2               ; --- Stack manipulation ---
000000r 2               OP_DUP          = $90
000000r 2               OP_POP          = $91
000000r 2               OP_SWAP         = $92
000000r 2               OP_MOVS         = $93           ; copy n bytes (byte count follows)
000000r 2               
000000r 2               ; --- String built-ins ---
000000r 2               OP_LEN          = $A0           ; TOS=strptr -> TOS=length (int)
000000r 2               OP_POS          = $A1           ; NOS=substr, TOS=str -> TOS=1-based pos (0=not found)
000000r 2               OP_COPY         = $A2           ; NNOS=str, NOS=index, TOS=count -> TOS=result strptr
000000r 2               OP_CONCAT       = $A3           ; NOS=s1, TOS=s2 -> TOS=result strptr
000000r 2               OP_INSET        = $A4           ; NOS=elem, TOS=setmask -> TOS=membership bool
000000r 2               OP_MPR          = $A5           ; real multiply (signed fixed-point, scale 100)
000000r 2               OP_DVR          = $A6           ; real divide   (signed fixed-point, scale 100)
000000r 2               
000000r 2               ; --- TEXT file I/O ---
000000r 2               ; All file ops take a file-struct pointer (NOS / TOS).
000000r 2               OP_FASSGN       = $B0           ; NOS=fileptr, TOS=strptr (filename) -> set FCB
000000r 2               OP_FRESET       = $B1           ; TOS=fileptr -> open existing for reading
000000r 2               OP_FREWRT       = $B2           ; TOS=fileptr -> create/truncate for writing
000000r 2               OP_FCLOSE       = $B3           ; TOS=fileptr -> flush and close
000000r 2               OP_FWRC         = $B4           ; NOS=fileptr, TOS=char -> append char
000000r 2               OP_FWRS         = $B5           ; NOS=fileptr, TOS=strptr -> append string
000000r 2               OP_FWRI         = $B6           ; NOS=fileptr, TOS=int   -> append decimal
000000r 2               OP_FWLN         = $B7           ; TOS=fileptr -> append CR+LF
000000r 2               OP_FRDC         = $B8           ; NOS=fileptr, TOS=charvar addr -> read char
000000r 2               OP_FRDI         = $B9           ; NOS=fileptr, TOS=intvar  addr -> read decimal int
000000r 2               OP_FRDLN        = $BA           ; TOS=fileptr -> skip remaining chars to end-of-line
000000r 2               OP_FEOF         = $BB           ; TOS=fileptr -> push EOF flag (0=false, $FFFF=true)
000000r 2               OP_FAPPND       = $BC           ; TOS=fileptr -> open/create for append at EOF
000000r 2               OP_FRDS         = $BD           ; NOS=fileptr, TOS=strvar addr -> read string to EOL
000000r 2               OP_FWRB         = $BE           ; NOS=fileptr, TOS=bool -> append "TRUE"/"FALSE"
000000r 2               OP_FEOLN        = $BF           ; TOS=fileptr -> push EOLN flag (true if at CR/LF/EOF)
000000r 2               OP_FWRR         = $C0           ; NOS=fileptr, TOS=real -> append fixed-point decimal
000000r 2               OP_FRDR         = $C1           ; NOS=fileptr, TOS=realvar addr -> read fixed-point decimal
000000r 2               
000000r 2               ; TEXT-file struct layout (168 bytes per variable)
000000r 2               F_FCB           = 0             ; 36 bytes
000000r 2               F_BUF           = 36            ; 128 bytes
000000r 2               F_MODE          = 164           ; 0=closed, 1=read, 2=write
000000r 2               F_POS           = 165           ; 0..127 buffer position
000000r 2               F_EOF           = 166           ; 0=more data, 1=EOF reached
000000r 2               F_SPARE         = 167
000000r 2               FILE_STRUCT_SZ  = 168
000000r 2               
000000r 2               F_MODE_CLOSED   = 0
000000r 2               F_MODE_READ     = 1
000000r 2               F_MODE_WRITE    = 2
000000r 2               
000000r 2               CTRL_Z          = $1A           ; CP/M text-file end-of-data marker
000000r 2               
000000r 2               ; --- Halt ---
000000r 2               OP_HALT         = $FF
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; .PCD file magic / version
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               PCD_MAGIC_0     = $50           ; 'P'
000000r 2               PCD_MAGIC_1     = $43           ; 'C'
000000r 2               PCD_VERSION     = $01
000000r 2               
000000r 2               ; PCD header offsets
000000r 2               PCD_MAGIC       = 0
000000r 2               PCD_VER         = 2
000000r 2               PCD_CODESZ      = 4             ; word: code section size
000000r 2               PCD_GLOBSZ      = 6             ; word: global data size
000000r 2               PCD_STRSZ       = 8             ; word: string pool size
000000r 2               PCD_ENTRY       = 10            ; word: entry point offset into code
000000r 2               PCD_HEADER_SZ   = 12
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Token codes (used by compiler lexer/parser)
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               TOK_EOF         = 0
000000r 2               TOK_IDENT       = 1
000000r 2               TOK_INT         = 2
000000r 2               TOK_STRING      = 3
000000r 2               TOK_CHAR        = 4
000000r 2               TOK_REAL        = 5
000000r 2               
000000r 2               ; Operators / punctuation
000000r 2               TOK_PLUS        = $10           ; +
000000r 2               TOK_MINUS       = $11           ; -
000000r 2               TOK_STAR        = $12           ; *
000000r 2               TOK_SLASH       = $13           ; /
000000r 2               TOK_EQ          = $14           ; =
000000r 2               TOK_NEQ         = $15           ; <>
000000r 2               TOK_LT          = $16           ; <
000000r 2               TOK_GT          = $17           ; >
000000r 2               TOK_LEQ         = $18           ; <=
000000r 2               TOK_GEQ         = $19           ; >=
000000r 2               TOK_ASSIGN      = $1A           ; :=
000000r 2               TOK_LPAREN      = $1B           ; (
000000r 2               TOK_RPAREN      = $1C           ; )
000000r 2               TOK_LBRACK      = $1D           ; [
000000r 2               TOK_RBRACK      = $1E           ; ]
000000r 2               TOK_COMMA       = $1F           ; ,
000000r 2               TOK_SEMICOLON   = $20           ; ;
000000r 2               TOK_COLON       = $21           ; :
000000r 2               TOK_DOT         = $22           ; .
000000r 2               TOK_DOTDOT      = $23           ; ..
000000r 2               TOK_CARET       = $24           ; ^
000000r 2               
000000r 2               ; Keywords
000000r 2               TOK_AND         = $40
000000r 2               TOK_ARRAY       = $41
000000r 2               TOK_BEGIN       = $42
000000r 2               TOK_CASE        = $43
000000r 2               TOK_CONST       = $44
000000r 2               TOK_DIV         = $45
000000r 2               TOK_DO          = $46
000000r 2               TOK_DOWNTO      = $47
000000r 2               TOK_ELSE        = $48
000000r 2               TOK_END         = $49
000000r 2               TOK_FOR         = $4A
000000r 2               TOK_FUNCTION    = $4B
000000r 2               TOK_IF          = $4C
000000r 2               TOK_IN          = $4D
000000r 2               TOK_MOD_KW      = $4E
000000r 2               TOK_NIL         = $4F
000000r 2               TOK_NOT         = $50
000000r 2               TOK_OF          = $51
000000r 2               TOK_OR          = $52
000000r 2               TOK_PROCEDURE   = $53
000000r 2               TOK_PROGRAM     = $54
000000r 2               TOK_RECORD      = $55
000000r 2               TOK_REPEAT      = $56
000000r 2               TOK_SET         = $57
000000r 2               TOK_THEN        = $58
000000r 2               TOK_TO          = $59
000000r 2               TOK_TYPE        = $5A
000000r 2               TOK_UNTIL       = $5B
000000r 2               TOK_VAR         = $5C
000000r 2               TOK_WHILE       = $5D
000000r 2               TOK_WITH        = $5E
000000r 2               TOK_IMPLEMENTATION = $5F
000000r 2               TOK_INTERFACE   = $60
000000r 2               TOK_UNIT        = $61
000000r 2               TOK_USES        = $62
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Useful macros
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 2               ; Call PEM with function number in X
000000r 2               .macro PEM func
000000r 2                       ldx     #func
000000r 2                       jsr     PEM_ENTRY
000000r 2               .endmacro
000000r 2               
000000r 1                       .include        "ZEROPAGE.ASM"
000000r 2               ; zeropage.asm — zero-page variable layout for PASCAL.COM and PRUN.COM
000000r 2               ;
000000r 2               ; Avoid $00-$2F (DOS/65 system), $32 (FARFUNCT), $39-$3A (DOS/65).
000000r 2               ; Safe range: $50-$EF
000000r 2               
000000r 2                       .segment        "ZEROPAGE"
000000r 2               
000000r 2  xx xx xx xx          .RES    $50             ; skip $00-$4F (DOS/65 system zero page)
000004r 2  xx xx xx xx  
000008r 2  xx xx xx xx  
000050r 2               
000050r 2               ; ---------------------------------------------------------------------------
000050r 2               ; P-machine registers — start at $50 as noted in comments below
000050r 2               ; ---------------------------------------------------------------------------
000050r 2               
000050r 2               pm_ipc:
000050r 2  xx xx                .RES    2               ; $50-$51  interpreter program counter
000052r 2               pm_sp:
000052r 2  xx xx                .RES    2               ; $52-$53  p-machine stack pointer
000054r 2               pm_mp:
000054r 2  xx xx                .RES    2               ; $54-$55  mark/frame pointer
000056r 2               pm_base:
000056r 2  xx xx                .RES    2               ; $56-$57  global variable base
000058r 2               pm_np:
000058r 2  xx xx                .RES    2               ; $58-$59  heap top (grows downward)
00005Ar 2               
00005Ar 2               ; General-purpose temporaries
00005Ar 2               tmp0:
00005Ar 2  xx xx                .RES    2               ; $5A-$5B
00005Cr 2               tmp1:
00005Cr 2  xx xx                .RES    2               ; $5C-$5D
00005Er 2               tmp2:
00005Er 2  xx xx                .RES    2               ; $5E-$5F
000060r 2               tmp3:
000060r 2  xx xx                .RES    2               ; $60-$61
000062r 2               
000062r 2               ; Byte-width scratch (often used by macros)
000062r 2               scratch:
000062r 2  xx                   .RES    1               ; $62
000063r 2               
000063r 2               ; ---------------------------------------------------------------------------
000063r 2               ; Compiler-specific zero-page variables (only used by PASCAL.COM)
000063r 2               ; ---------------------------------------------------------------------------
000063r 2               
000063r 2               ; Lexer state
000063r 2               lex_line:
000063r 2  xx xx                .RES    2               ; $63-$64  current source line number
000065r 2               lex_col:
000065r 2  xx                   .RES    1               ; $65      current column
000066r 2               lex_char:
000066r 2  xx                   .RES    1               ; $66      lookahead character
000067r 2               tok_type:
000067r 2  xx                   .RES    1               ; $67      current token type
000068r 2               tok_ival_lo:
000068r 2  xx                   .RES    1               ; $68      integer token value (lo)
000069r 2               tok_ival_hi:
000069r 2  xx                   .RES    1               ; $69      integer token value (hi)
00006Ar 2               
00006Ar 2               ; Parser / code generator state
00006Ar 2               cg_pc:
00006Ar 2  xx xx                .RES    2               ; $6A-$6B  current emit offset into code buffer
00006Cr 2               cg_globals:
00006Cr 2  xx xx                .RES    2               ; $6C-$6D  next available global variable offset
00006Er 2               scope_depth:
00006Er 2  xx                   .RES    1               ; $6E      current lexical nesting depth (0=global)
00006Fr 2               sym_chain:
00006Fr 2  xx xx                .RES    2               ; $6F-$70  pointer into symbol table chain
000071r 2               
000071r 2               ; FCB pointers (compiler I/O)
000071r 2               src_fcb:
000071r 2  xx xx                .RES    2               ; $71-$72  pointer to source FCB
000073r 2               out_fcb:
000073r 2  xx xx                .RES    2               ; $73-$74  pointer to output FCB
000075r 2               src_buf_pos:
000075r 2  xx                   .RES    1               ; $75      position within 128-byte sector buffer
000076r 2               src_buf_end:
000076r 2  xx                   .RES    1               ; $76      bytes valid in sector buffer
000077r 2               
000077r 2               ; FOR-loop scratch (parse_for; not nestable)
000077r 2               for_loop_top:
000077r 2  xx xx                .RES    2               ; $77-$78  cg_pc of loop test (back-jump target)
000079r 2               for_patch:
000079r 2  xx xx                .RES    2               ; $79-$7A  FJP exit patch address
00007Br 2               
00007Br 2               ; Result type of the most recently parsed expression (TY_INT/TY_CHAR/
00007Br 2               ; TY_BOOL/TY_STRING/etc.).  Used by parse_write_args to dispatch the
00007Br 2               ; right WRIT* opcode.  Set by parse_factor / parse_simple_expr /
00007Br 2               ; parse_expression as each rule produces its result.
00007Br 2               expr_type:
00007Br 2  xx                   .RES    1               ; $7B
00007Cr 2               
00007Cr 1               
00007Cr 1               ; ---------------------------------------------------------------------------
00007Cr 1               ; Runtime memory layout constants
00007Cr 1               ; ---------------------------------------------------------------------------
00007Cr 1               ; PCODE_BASE must lie above the end of the CODE segment so that loading
00007Cr 1               ; a .PCD file does not overwrite iolib/messages or the dispatch table.
00007Cr 1               ; CODE now reaches past $24DD, so move PCODE_BASE to $3000 for comfortable
00007Cr 1               ; headroom; STACK_BASE at $5000 leaves 8 KB for p-code.
00007Cr 1               PCODE_BASE      = $3000         ; where p-code is loaded
00007Cr 1               STACK_BASE      = $5000         ; bottom of p-machine value stack
00007Cr 1               STACK_TOP       = $8000         ; top of stack (grows up)
00007Cr 1               HEAP_TOP        = $B000         ; heap grows down from here
00007Cr 1               GLOBALS_BASE    = $B000         ; global variable area (below heap top)
00007Cr 1               
00007Cr 1               ; Activation record offsets from MP
00007Cr 1               AR_DYN_LINK     = 0             ; 2 bytes: saved MP
00007Cr 1               AR_RET_ADDR     = 2             ; 2 bytes: saved IPC
00007Cr 1               AR_STAT_LINK    = 4             ; 2 bytes: static link
00007Cr 1               AR_RET_VAL      = 6             ; 2 bytes: function return value slot
00007Cr 1               AR_LOCALS       = 8             ; start of local variables
00007Cr 1               
00007Cr 1               ; ---------------------------------------------------------------------------
00007Cr 1               ; P-code load buffer (at PCODE_BASE, filled by loader)
00007Cr 1               ; Actual code lives at runtime in $1000 range.
00007Cr 1               ; FCB and other data live in CODE segment (placed by ld65 after dispatch
00007Cr 1               ; tables) — keeping them out of the $2000+ stack region.
00007Cr 1               ; ---------------------------------------------------------------------------
00007Cr 1               
00007Cr 1                       .segment        "TEA"
000000r 1               
000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; Entry point — DOS/65 loads .COM at $0800 and jumps here
000000r 1               ; ---------------------------------------------------------------------------
000000r 1  4C rr rr             JMP     prun_main
000003r 1               
000003r 1               ; ---------------------------------------------------------------------------
000003r 1               ; prun_main
000003r 1               ; ---------------------------------------------------------------------------
000003r 1                       .segment        "CODE"
000000r 1               prun_main:
000000r 1               ; print banner
000000r 1  A9 rr                LDA     #<msg_rt_banner
000002r 1  85 rr                STA     tmp0
000004r 1  A9 rr                LDA     #>msg_rt_banner
000006r 1  85 rr                STA     tmp0+1
000008r 1  20 rr rr             JSR     console_print_sz
00000Br 1               
00000Br 1               ; build FCB from DEFAULT_FCB (DOS/65 fills $0107 with first argument)
00000Br 1  20 rr rr             JSR     build_pcd_fcb   ; copy $0107 → pcd_fcb, append .PCD extension
00000Er 1  B0 30                BCS     @no_file
000010r 1               
000010r 1               ; open the .PCD file
000010r 1  A9 rr                LDA     #<pcd_fcb
000012r 1  85 rr                STA     tmp1
000014r 1  A9 rr                LDA     #>pcd_fcb
000016r 1  85 rr                STA     tmp1+1
000018r 1  20 rr rr             JSR     file_open
00001Br 1  C9 FF                CMP     #$FF            ; PEM open returns $FF=not found, 0-3=dir entry
00001Dr 1  F0 21                BEQ     @no_file
00001Fr 1               
00001Fr 1               ; load p-code into memory starting at PCODE_BASE
00001Fr 1  20 rr rr             JSR     load_pcd
000022r 1  B0 2A                BCS     @load_err
000024r 1               
000024r 1               ; execute
000024r 1  20 rr rr             JSR     prun_execute
000027r 1               
000027r 1               ; clean exit
000027r 1  A9 rr                LDA     #<pcd_fcb
000029r 1  85 rr                STA     tmp1
00002Br 1  A9 rr                LDA     #>pcd_fcb
00002Dr 1  85 rr                STA     tmp1+1
00002Fr 1  20 rr rr             JSR     file_close
000032r 1  A9 rr                LDA     #<msg_rt_done
000034r 1  85 rr                STA     tmp0
000036r 1  A9 rr                LDA     #>msg_rt_done
000038r 1  85 rr                STA     tmp0+1
00003Ar 1  20 rr rr             JSR     console_print_sz
00003Dr 1  4C 00 01             JMP     WARM_BOOT
000040r 1               
000040r 1               @no_file:
000040r 1  A9 rr                LDA     #<err_nofile
000042r 1  85 rr                STA     tmp0
000044r 1  A9 rr                LDA     #>err_nofile
000046r 1  85 rr                STA     tmp0+1
000048r 1  20 rr rr             JSR     console_print_sz
00004Br 1  4C 00 01             JMP     WARM_BOOT
00004Er 1               
00004Er 1               @load_err:
00004Er 1  A9 rr                LDA     #<err_rt_magic
000050r 1  85 rr                STA     tmp0
000052r 1  A9 rr                LDA     #>err_rt_magic
000054r 1  85 rr                STA     tmp0+1
000056r 1  20 rr rr             JSR     console_print_sz
000059r 1  4C 00 01             JMP     WARM_BOOT
00005Cr 1               
00005Cr 1               ; ---------------------------------------------------------------------------
00005Cr 1               ; build_pcd_fcb — copy DEFAULT_FCB ($0107) to pcd_fcb, force extension "PCD"
00005Cr 1               ; DOS/65 CCM copies the parsed argument FCB to dflfcb=$0107, not $005C.
00005Cr 1               ; Returns: carry clear = ok, carry set = no filename given
00005Cr 1               ; ---------------------------------------------------------------------------
00005Cr 1               build_pcd_fcb:
00005Cr 1  A2 00                LDX     #0
00005Er 1               @copy:
00005Er 1  BD 07 01             LDA     DEFAULT_FCB,x
000061r 1  9D rr rr             STA     pcd_fcb,x
000064r 1  E8                   INX
000065r 1  E0 0C                CPX     #12
000067r 1  90 F5                BCC     @copy
000069r 1               ; zero the rest of FCB
000069r 1  A9 00                LDA     #0
00006Br 1               @zero:
00006Br 1  9D rr rr             STA     pcd_fcb,x
00006Er 1  E8                   INX
00006Fr 1  E0 24                CPX     #36
000071r 1  90 F8                BCC     @zero
000073r 1               ; check filename is non-blank
000073r 1  AD rr rr             LDA     pcd_fcb+1       ; first char of filename field
000076r 1  C9 20                CMP     #' '
000078r 1  F0 11                BEQ     @noname
00007Ar 1               ; force extension bytes 9-11 to "PCD"
00007Ar 1  A9 50                LDA     #'P'
00007Cr 1  8D rr rr             STA     pcd_fcb+9
00007Fr 1  A9 43                LDA     #'C'
000081r 1  8D rr rr             STA     pcd_fcb+10
000084r 1  A9 44                LDA     #'D'
000086r 1  8D rr rr             STA     pcd_fcb+11
000089r 1  18                   CLC
00008Ar 1  60                   RTS
00008Br 1               @noname:
00008Br 1  38                   SEC
00008Cr 1  60                   RTS
00008Dr 1               
00008Dr 1               ; ---------------------------------------------------------------------------
00008Dr 1               ; load_pcd — read .PCD header, validate, load code + globals + strings
00008Dr 1               ; Returns: carry clear = ok, carry set = error
00008Dr 1               ; ---------------------------------------------------------------------------
00008Dr 1               load_pcd:
00008Dr 1               ; ensure tmp1 points to pcd_fcb for all file I/O calls
00008Dr 1  A9 rr                LDA     #<pcd_fcb
00008Fr 1  85 rr                STA     tmp1
000091r 1  A9 rr                LDA     #>pcd_fcb
000093r 1  85 rr                STA     tmp1+1
000095r 1               ; Read first sector (contains header + start of code)
000095r 1  20 rr rr             JSR     file_read_sector
000098r 1  C9 00                CMP     #0
00009Ar 1  D0 62                BNE     @err
00009Cr 1               
00009Cr 1               ; validate magic
00009Cr 1  AD 28 01             LDA     DMA_BUF+0
00009Fr 1  C9 50                CMP     #PCD_MAGIC_0
0000A1r 1  D0 5B                BNE     @err
0000A3r 1  AD 29 01             LDA     DMA_BUF+1
0000A6r 1  C9 43                CMP     #PCD_MAGIC_1
0000A8r 1  D0 54                BNE     @err
0000AAr 1               
0000AAr 1               ; entry point — preserved in tmp3 for prun_execute
0000AAr 1  AD 32 01             LDA     DMA_BUF+PCD_ENTRY
0000ADr 1  85 rr                STA     tmp3
0000AFr 1  AD 33 01             LDA     DMA_BUF+PCD_ENTRY+1
0000B2r 1  85 rr                STA     tmp3+1
0000B4r 1               
0000B4r 1               ; remaining bytes still to copy = code size
0000B4r 1  AD 2C 01             LDA     DMA_BUF+PCD_CODESZ
0000B7r 1  85 rr                STA     tmp2
0000B9r 1  AD 2D 01             LDA     DMA_BUF+PCD_CODESZ+1
0000BCr 1  85 rr                STA     tmp2+1
0000BEr 1               
0000BEr 1               ; dest = PCODE_BASE - PCD_HEADER_SZ so that for the first sector
0000BEr 1               ; (tmp0),Y with Y=12..127 lands at PCODE_BASE+0..115.
0000BEr 1  38                   SEC
0000BFr 1  A9 00                LDA     #<PCODE_BASE
0000C1r 1  E9 0C                SBC     #PCD_HEADER_SZ
0000C3r 1  85 rr                STA     tmp0
0000C5r 1  A9 30                LDA     #>PCODE_BASE
0000C7r 1  E9 00                SBC     #0
0000C9r 1  85 rr                STA     tmp0+1
0000CBr 1               
0000CBr 1  A0 0C                LDY     #PCD_HEADER_SZ
0000CDr 1               @cloop:
0000CDr 1  A5 rr                LDA     tmp2
0000CFr 1  05 rr                ORA     tmp2+1
0000D1r 1  F0 29                BEQ     @done_ok
0000D3r 1  C0 80                CPY     #128
0000D5r 1  90 14                BCC     @cbyte
0000D7r 1               ; sector exhausted — advance dest by 128 and read the next one
0000D7r 1  18                   CLC
0000D8r 1  A5 rr                LDA     tmp0
0000DAr 1  69 80                ADC     #128
0000DCr 1  85 rr                STA     tmp0
0000DEr 1  90 02                BCC     :+
0000E0r 1  E6 rr                INC     tmp0+1
0000E2r 1               :
0000E2r 1  20 rr rr             JSR     file_read_sector
0000E5r 1  C9 00                CMP     #0
0000E7r 1  D0 15                BNE     @err
0000E9r 1  A0 00                LDY     #0
0000EBr 1               @cbyte:
0000EBr 1  B9 28 01             LDA     DMA_BUF,y
0000EEr 1  91 rr                STA     (tmp0),y
0000F0r 1  C8                   INY
0000F1r 1  A5 rr                LDA     tmp2
0000F3r 1  D0 02                BNE     :+
0000F5r 1  C6 rr                DEC     tmp2+1
0000F7r 1               :
0000F7r 1  C6 rr                DEC     tmp2
0000F9r 1  4C rr rr             JMP     @cloop
0000FCr 1               
0000FCr 1               @done_ok:
0000FCr 1  18                   CLC
0000FDr 1  60                   RTS
0000FEr 1               @err:
0000FEr 1  38                   SEC
0000FFr 1  60                   RTS
000100r 1               
000100r 1               ; ---------------------------------------------------------------------------
000100r 1               ; prun_execute — main fetch-decode-execute loop
000100r 1               ; ---------------------------------------------------------------------------
000100r 1               prun_execute:
000100r 1               ; initialise p-machine registers
000100r 1  A9 00                LDA     #<PCODE_BASE
000102r 1  18                   CLC
000103r 1  65 rr                ADC     tmp3            ; entry offset lo
000105r 1  85 rr                STA     pm_ipc
000107r 1  A9 30                LDA     #>PCODE_BASE
000109r 1  65 rr                ADC     tmp3+1
00010Br 1  85 rr                STA     pm_ipc+1
00010Dr 1               
00010Dr 1  A9 00                LDA     #<STACK_BASE
00010Fr 1  85 rr                STA     pm_sp
000111r 1  A9 50                LDA     #>STACK_BASE
000113r 1  85 rr                STA     pm_sp+1
000115r 1               
000115r 1  A9 00                LDA     #<STACK_BASE    ; first frame at bottom of stack
000117r 1  85 rr                STA     pm_mp
000119r 1  A9 50                LDA     #>STACK_BASE
00011Br 1  85 rr                STA     pm_mp+1
00011Dr 1               
00011Dr 1  A9 00                LDA     #<GLOBALS_BASE
00011Fr 1  85 rr                STA     pm_base
000121r 1  A9 B0                LDA     #>GLOBALS_BASE
000123r 1  85 rr                STA     pm_base+1
000125r 1               
000125r 1  A9 00                LDA     #<HEAP_TOP
000127r 1  85 rr                STA     pm_np
000129r 1  A9 B0                LDA     #>HEAP_TOP
00012Br 1  85 rr                STA     pm_np+1
00012Dr 1               
00012Dr 1  A9 00                LDA     #0                      ; reset string work-buffer cursor
00012Fr 1  8D rr rr             STA     str_work_idx
000132r 1               
000132r 1               ; ---------------------------------------------------------------------------
000132r 1               ; Fetch-decode-execute inner loop
000132r 1               ; ---------------------------------------------------------------------------
000132r 1               prun_loop:
000132r 1               ; fetch opcode at pm_ipc
000132r 1  A0 00                LDY     #0
000134r 1  B1 rr                LDA     (pm_ipc),y
000136r 1               ; advance IPC
000136r 1  E6 rr                INC     pm_ipc
000138r 1  D0 02                BNE     :+
00013Ar 1  E6 rr                INC     pm_ipc+1
00013Cr 1               :
00013Cr 1               ; dispatch via jump table
00013Cr 1  AA                   TAX                     ; X = opcode
00013Dr 1  BD rr rr             LDA     dispatch_lo,x
000140r 1  85 rr                STA     tmp0
000142r 1  BD rr rr             LDA     dispatch_hi,x
000145r 1  85 rr                STA     tmp0+1
000147r 1  6C rr rr             JMP     (tmp0)
00014Ar 1               
00014Ar 1               ; ---------------------------------------------------------------------------
00014Ar 1               ; Stack helpers
00014Ar 1               ; push 16-bit value in A(lo) / scratch(hi) onto p-machine stack
00014Ar 1               ; ---------------------------------------------------------------------------
00014Ar 1               pm_push:
00014Ar 1  A0 00                LDY     #0
00014Cr 1  91 rr                STA     (pm_sp),y
00014Er 1  C8                   INY
00014Fr 1  A5 rr                LDA     scratch
000151r 1  91 rr                STA     (pm_sp),y
000153r 1  18                   CLC
000154r 1  A5 rr                LDA     pm_sp
000156r 1  69 02                ADC     #2
000158r 1  85 rr                STA     pm_sp
00015Ar 1  90 02                BCC     :+
00015Cr 1  E6 rr                INC     pm_sp+1
00015Er 1               :
00015Er 1  60                   RTS
00015Fr 1               
00015Fr 1               ; pop 16-bit value from p-machine stack → A(lo) / scratch(hi)
00015Fr 1               pm_pop:
00015Fr 1  38                   SEC
000160r 1  A5 rr                LDA     pm_sp
000162r 1  E9 02                SBC     #2
000164r 1  85 rr                STA     pm_sp
000166r 1  B0 02                BCS     :+
000168r 1  C6 rr                DEC     pm_sp+1
00016Ar 1               :
00016Ar 1  A0 00                LDY     #0
00016Cr 1  B1 rr                LDA     (pm_sp),y
00016Er 1  48                   PHA
00016Fr 1  C8                   INY
000170r 1  B1 rr                LDA     (pm_sp),y
000172r 1  85 rr                STA     scratch
000174r 1  68                   PLA
000175r 1  60                   RTS
000176r 1               
000176r 1               ; peek at TOS without popping → A(lo) / scratch(hi)
000176r 1               pm_peek:
000176r 1  A5 rr                LDA     pm_sp
000178r 1  38                   SEC
000179r 1  E9 02                SBC     #2
00017Br 1  85 rr                STA     tmp1
00017Dr 1  A5 rr                LDA     pm_sp+1
00017Fr 1  E9 00                SBC     #0
000181r 1  85 rr                STA     tmp1+1
000183r 1  A0 00                LDY     #0
000185r 1  B1 rr                LDA     (tmp1),y
000187r 1  48                   PHA
000188r 1  C8                   INY
000189r 1  B1 rr                LDA     (tmp1),y
00018Br 1  85 rr                STA     scratch
00018Dr 1  68                   PLA
00018Er 1  60                   RTS
00018Fr 1               
00018Fr 1               ; fetch inline byte at IPC (advances IPC), returns in A
00018Fr 1               pm_fetch_byte:
00018Fr 1  A0 00                LDY     #0
000191r 1  B1 rr                LDA     (pm_ipc),y
000193r 1  E6 rr                INC     pm_ipc
000195r 1  D0 02                BNE     :+
000197r 1  E6 rr                INC     pm_ipc+1
000199r 1               :
000199r 1  60                   RTS
00019Ar 1               
00019Ar 1               ; fetch inline word (lo then hi) at IPC, returns lo in A, hi in scratch
00019Ar 1               pm_fetch_word:
00019Ar 1  20 rr rr             JSR     pm_fetch_byte
00019Dr 1  48                   PHA
00019Er 1  20 rr rr             JSR     pm_fetch_byte
0001A1r 1  85 rr                STA     scratch
0001A3r 1  68                   PLA
0001A4r 1  60                   RTS
0001A5r 1               
0001A5r 1               ; ---------------------------------------------------------------------------
0001A5r 1               ; Runtime error handler
0001A5r 1               ; ---------------------------------------------------------------------------
0001A5r 1               rt_error:
0001A5r 1               ; tmp0 already points to error string (caller's responsibility)
0001A5r 1  20 rr rr             JSR     console_print_sz
0001A8r 1  4C 00 01             JMP     WARM_BOOT
0001ABr 1               
0001ABr 1               ; ---------------------------------------------------------------------------
0001ABr 1               ; Opcode handlers
0001ABr 1               ; ---------------------------------------------------------------------------
0001ABr 1               
0001ABr 1               ; OP_HALT ($FF) — stop execution
0001ABr 1               op_HALT:
0001ABr 1  60                   RTS                     ; return to prun_main
0001ACr 1               
0001ACr 1               ; OP_LDCI ($00) — push sign-extended byte constant
0001ACr 1               op_LDCI:
0001ACr 1  20 rr rr             JSR     pm_fetch_byte
0001AFr 1  48                   PHA
0001B0r 1               ; sign-extend: if bit 7 set, high byte = $FF else $00
0001B0r 1  29 80                AND     #$80
0001B2r 1  F0 04                BEQ     :+
0001B4r 1  A9 FF                LDA     #$FF
0001B6r 1  D0 02                BNE     :++
0001B8r 1               :
0001B8r 1  A9 00                LDA     #$00
0001BAr 1               :
0001BAr 1  85 rr                STA     scratch
0001BCr 1  68                   PLA
0001BDr 1  20 rr rr             JSR     pm_push
0001C0r 1  4C rr rr             JMP     prun_loop
0001C3r 1               
0001C3r 1               ; OP_LDCW ($01) — push word constant
0001C3r 1               op_LDCW:
0001C3r 1  20 rr rr             JSR     pm_fetch_word   ; A=lo, scratch=hi
0001C6r 1  20 rr rr             JSR     pm_push
0001C9r 1  4C rr rr             JMP     prun_loop
0001CCr 1               
0001CCr 1               ; OP_LDCC ($02) — push char constant (zero-extended)
0001CCr 1               op_LDCC:
0001CCr 1  20 rr rr             JSR     pm_fetch_byte
0001CFr 1  48                   PHA
0001D0r 1  A9 00                LDA     #0
0001D2r 1  85 rr                STA     scratch
0001D4r 1  68                   PLA
0001D5r 1  20 rr rr             JSR     pm_push
0001D8r 1  4C rr rr             JMP     prun_loop
0001DBr 1               
0001DBr 1               ; OP_LDCB ($03) — push boolean constant
0001DBr 1               op_LDCB:
0001DBr 1  20 rr rr             JSR     pm_fetch_byte
0001DEr 1  C9 00                CMP     #0              ; pm_fetch_byte's Z reflects pm_ipc INC, not A
0001E0r 1  F0 0C                BEQ     :+
0001E2r 1  A9 FF                LDA     #$FF            ; TRUE = $FFFF
0001E4r 1  85 rr                STA     scratch
0001E6r 1  A9 FF                LDA     #$FF
0001E8r 1  20 rr rr             JSR     pm_push
0001EBr 1  4C rr rr             JMP     prun_loop
0001EEr 1               :
0001EEr 1  A9 00                LDA     #0
0001F0r 1  85 rr                STA     scratch
0001F2r 1  20 rr rr             JSR     pm_push
0001F5r 1  4C rr rr             JMP     prun_loop
0001F8r 1               
0001F8r 1               ; OP_LDCN ($05) — push NIL ($0000)
0001F8r 1               op_LDCN:
0001F8r 1  A9 00                LDA     #0
0001FAr 1  85 rr                STA     scratch
0001FCr 1  20 rr rr             JSR     pm_push
0001FFr 1  4C rr rr             JMP     prun_loop
000202r 1               
000202r 1               ; OP_LDCS ($04) — inline string constant.  IPC currently points at the
000202r 1               ; length byte (after opcode fetch).  Push that address as a Pascal-style
000202r 1               ; string pointer, then advance IPC past length+chars.
000202r 1               op_LDCS:
000202r 1               ; save current IPC as the string pointer
000202r 1  A5 rr                LDA     pm_ipc
000204r 1  85 rr                STA     tmp1
000206r 1  A5 rr                LDA     pm_ipc+1
000208r 1  85 rr                STA     tmp1+1
00020Ar 1               ; advance IPC by (length + 1)
00020Ar 1  A0 00                LDY     #0
00020Cr 1  B1 rr                LDA     (pm_ipc),y      ; length
00020Er 1  38                   SEC                     ; +1 for the length byte
00020Fr 1  65 rr                ADC     pm_ipc
000211r 1  85 rr                STA     pm_ipc
000213r 1  90 02                BCC     :+
000215r 1  E6 rr                INC     pm_ipc+1
000217r 1               :       ; push the saved string pointer
000217r 1  A5 rr                LDA     tmp1+1
000219r 1  85 rr                STA     scratch
00021Br 1  A5 rr                LDA     tmp1
00021Dr 1  20 rr rr             JSR     pm_push
000220r 1  4C rr rr             JMP     prun_loop
000223r 1               
000223r 1               ; OP_LDL ($10) — push 16-bit local var
000223r 1               op_LDL:
000223r 1  20 rr rr             JSR     pm_fetch_byte   ; byte offset
000226r 1  18                   CLC
000227r 1  69 08                ADC     #AR_LOCALS      ; offset from MP
000229r 1  48                   PHA
00022Ar 1  A5 rr                LDA     pm_mp
00022Cr 1  18                   CLC
00022Dr 1  68                   PLA
00022Er 1  65 rr                ADC     pm_mp
000230r 1  85 rr                STA     tmp1
000232r 1  A5 rr                LDA     pm_mp+1
000234r 1  69 00                ADC     #0
000236r 1  85 rr                STA     tmp1+1
000238r 1  A0 00                LDY     #0
00023Ar 1  B1 rr                LDA     (tmp1),y
00023Cr 1  48                   PHA
00023Dr 1  C8                   INY
00023Er 1  B1 rr                LDA     (tmp1),y
000240r 1  85 rr                STA     scratch
000242r 1  68                   PLA
000243r 1  20 rr rr             JSR     pm_push
000246r 1  4C rr rr             JMP     prun_loop
000249r 1               
000249r 1               ; OP_STL ($11) — pop into 16-bit local var
000249r 1               op_STL:
000249r 1  20 rr rr             JSR     pm_fetch_byte   ; byte offset
00024Cr 1  18                   CLC
00024Dr 1  69 08                ADC     #AR_LOCALS
00024Fr 1  18                   CLC
000250r 1  65 rr                ADC     pm_mp
000252r 1  85 rr                STA     tmp1
000254r 1  A5 rr                LDA     pm_mp+1
000256r 1  69 00                ADC     #0
000258r 1  85 rr                STA     tmp1+1
00025Ar 1  20 rr rr             JSR     pm_pop          ; A=lo, scratch=hi
00025Dr 1  A0 00                LDY     #0
00025Fr 1  91 rr                STA     (tmp1),y
000261r 1  C8                   INY
000262r 1  A5 rr                LDA     scratch
000264r 1  91 rr                STA     (tmp1),y
000266r 1  4C rr rr             JMP     prun_loop
000269r 1               
000269r 1               ; OP_LDG ($18) — push 16-bit global var (word offset from pm_base)
000269r 1               op_LDG:
000269r 1  20 rr rr             JSR     pm_fetch_word   ; A=lo offset, scratch=hi offset
00026Cr 1  18                   CLC
00026Dr 1  65 rr                ADC     pm_base
00026Fr 1  85 rr                STA     tmp1
000271r 1  A5 rr                LDA     scratch
000273r 1  65 rr                ADC     pm_base+1
000275r 1  85 rr                STA     tmp1+1
000277r 1  A0 00                LDY     #0
000279r 1  B1 rr                LDA     (tmp1),y
00027Br 1  48                   PHA
00027Cr 1  C8                   INY
00027Dr 1  B1 rr                LDA     (tmp1),y
00027Fr 1  85 rr                STA     scratch
000281r 1  68                   PLA
000282r 1  20 rr rr             JSR     pm_push
000285r 1  4C rr rr             JMP     prun_loop
000288r 1               
000288r 1               ; OP_STG ($19) — pop into 16-bit global var
000288r 1               op_STG:
000288r 1  20 rr rr             JSR     pm_fetch_word   ; A=lo offset, scratch=hi offset
00028Br 1  18                   CLC
00028Cr 1  65 rr                ADC     pm_base
00028Er 1  85 rr                STA     tmp1
000290r 1  A5 rr                LDA     scratch
000292r 1  65 rr                ADC     pm_base+1
000294r 1  85 rr                STA     tmp1+1
000296r 1  20 rr rr             JSR     pm_pop          ; A=lo, scratch=hi
000299r 1  A0 00                LDY     #0
00029Br 1  91 rr                STA     (tmp1),y
00029Dr 1  C8                   INY
00029Er 1  A5 rr                LDA     scratch
0002A0r 1  91 rr                STA     (tmp1),y
0002A2r 1  4C rr rr             JMP     prun_loop
0002A5r 1               
0002A5r 1               ; OP_LDA_L ($12) — push effective address of local (pm_mp + AR_LOCALS + offset)
0002A5r 1               op_LDA_L:
0002A5r 1  20 rr rr             JSR     pm_fetch_byte   ; A = byte offset
0002A8r 1  18                   CLC
0002A9r 1  69 08                ADC     #AR_LOCALS
0002ABr 1  18                   CLC
0002ACr 1  65 rr                ADC     pm_mp           ; A = lo of pm_mp + (offset+AR_LOCALS)
0002AEr 1  48                   PHA
0002AFr 1  A5 rr                LDA     pm_mp+1
0002B1r 1  69 00                ADC     #0              ; +carry
0002B3r 1  85 rr                STA     scratch
0002B5r 1  68                   PLA
0002B6r 1  20 rr rr             JSR     pm_push
0002B9r 1  4C rr rr             JMP     prun_loop
0002BCr 1               
0002BCr 1               ; OP_LDA_G ($1A) — push effective address of global (pm_base + offset)
0002BCr 1               op_LDA_G:
0002BCr 1  20 rr rr             JSR     pm_fetch_word   ; A=lo offset, scratch=hi offset
0002BFr 1  18                   CLC
0002C0r 1  65 rr                ADC     pm_base
0002C2r 1  48                   PHA
0002C3r 1  A5 rr                LDA     scratch
0002C5r 1  65 rr                ADC     pm_base+1
0002C7r 1  85 rr                STA     scratch         ; hi of address
0002C9r 1  68                   PLA                     ; lo of address
0002CAr 1  20 rr rr             JSR     pm_push
0002CDr 1  4C rr rr             JMP     prun_loop
0002D0r 1               
0002D0r 1               ; OP_LDIND ($20) — TOS=addr → push word at addr
0002D0r 1               op_LDIND:
0002D0r 1  20 rr rr             JSR     pm_pop          ; A=lo addr, scratch=hi addr
0002D3r 1  85 rr                STA     tmp1
0002D5r 1  A5 rr                LDA     scratch
0002D7r 1  85 rr                STA     tmp1+1
0002D9r 1  A0 00                LDY     #0
0002DBr 1  B1 rr                LDA     (tmp1),y
0002DDr 1  48                   PHA
0002DEr 1  C8                   INY
0002DFr 1  B1 rr                LDA     (tmp1),y
0002E1r 1  85 rr                STA     scratch
0002E3r 1  68                   PLA
0002E4r 1  20 rr rr             JSR     pm_push
0002E7r 1  4C rr rr             JMP     prun_loop
0002EAr 1               
0002EAr 1               ; OP_STIND ($21) — NOS=addr, TOS=val → store word at addr
0002EAr 1               op_STIND:
0002EAr 1  20 rr rr             JSR     pm_pop          ; pop val: A=lo, scratch=hi
0002EDr 1  85 rr                STA     tmp2
0002EFr 1  A5 rr                LDA     scratch
0002F1r 1  85 rr                STA     tmp2+1
0002F3r 1  20 rr rr             JSR     pm_pop          ; pop addr: A=lo, scratch=hi
0002F6r 1  85 rr                STA     tmp1
0002F8r 1  A5 rr                LDA     scratch
0002FAr 1  85 rr                STA     tmp1+1
0002FCr 1  A0 00                LDY     #0
0002FEr 1  A5 rr                LDA     tmp2
000300r 1  91 rr                STA     (tmp1),y
000302r 1  C8                   INY
000303r 1  A5 rr                LDA     tmp2+1
000305r 1  91 rr                STA     (tmp1),y
000307r 1  4C rr rr             JMP     prun_loop
00030Ar 1               
00030Ar 1               ; OP_INDEX ($24) — array element address
00030Ar 1               ; Reads 2 operand bytes: element size (word, lo then hi)
00030Ar 1               ; Stack: NOS=base_addr, TOS=index → pushes base_addr + index*elemsize
00030Ar 1               op_INDEX:
00030Ar 1  20 rr rr             JSR     pm_fetch_byte   ; elemsize lo
00030Dr 1  85 rr                STA     tmp2
00030Fr 1  20 rr rr             JSR     pm_fetch_byte   ; elemsize hi (ignored — always 0 in practice)
