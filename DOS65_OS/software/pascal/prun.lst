000F29r 1  B1 rr                LDA     (tmp1),y
000F2Br 1  A8                   TAY
000F2Cr 1  AD rr rr             LDA     fwrc_char
000F2Fr 1  91 rr                STA     (tmp2),y
000F31r 1  C8                   INY
000F32r 1  98                   TYA
000F33r 1  A0 A5                LDY     #F_POS
000F35r 1  91 rr                STA     (tmp1),y
000F37r 1  C9 80                CMP     #128
000F39r 1  D0 16                BNE     @fwch_done
