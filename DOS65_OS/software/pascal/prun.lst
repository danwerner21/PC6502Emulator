001BF7r 2  27 54 48 45          .byte "'THEN' expected",0
001BFBr 2  4E 27 20 65  
001BFFr 2  78 70 65 63  
001C07r 2               err_expected_to:
001C07r 2  27 54 4F 27          .byte "'TO' or 'DOWNTO' expected",0
001C0Br 2  20 6F 72 20  
001C0Fr 2  27 44 4F 57  
001C21r 2               err_expected_un:
001C21r 2  27 55 4E 54          .byte "'UNTIL' expected",0
001C25r 2  49 4C 27 20  
