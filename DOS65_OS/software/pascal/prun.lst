00158Br 1  20 rr rr             JSR     pm_pop                  ; file ptr → tmp1
00158Er 1  85 rr                STA     tmp1
001590r 1  A5 rr                LDA     scratch
001592r 1  85 rr                STA     tmp1+1
001594r 1  A9 00                LDA     #0
001596r 1  8D rr rr             STA     frs_idx
001599r 1               @frs_loop:
001599r 1  A0 A6                LDY     #F_EOF
00159Br 1  B1 rr                LDA     (tmp1),y
00159Dr 1  D0 37                BNE     @frs_done
00159Fr 1               ; peek char at buf[F_POS] without consuming
00159Fr 1  18                   CLC
0015A0r 1  A5 rr                LDA     tmp1
0015A2r 1  69 24                ADC     #F_BUF
0015A4r 1  85 rr                STA     tmp2
0015A6r 1  A5 rr                LDA     tmp1+1
0015A8r 1  69 00                ADC     #0
0015AAr 1  85 rr                STA     tmp2+1
0015ACr 1  A0 A5                LDY     #F_POS
0015AEr 1  B1 rr                LDA     (tmp1),y
0015B0r 1  A8                   TAY
0015B1r 1  B1 rr                LDA     (tmp2),y
0015B3r 1  C9 0D                CMP     #$0D
0015B5r 1  F0 1F                BEQ     @frs_done               ; leave CR for READLN
0015B7r 1  C9 0A                CMP     #$0A
0015B9r 1  F0 1B                BEQ     @frs_done               ; leave LF for READLN
0015BBr 1               ; not at EOL — consume and append
0015BBr 1  20 rr rr             JSR     file_read_char_helper
0015BEr 1  8D rr rr             STA     frs_char
0015C1r 1  AD rr rr             LDA     frs_idx
0015C4r 1  C9 FF                CMP     #255
0015C6r 1  B0 D1                BCS     @frs_loop               ; clamp (drop char)
0015C8r 1  EE rr rr             INC     frs_idx
0015CBr 1  AC rr rr             LDY     frs_idx
0015CEr 1  AD rr rr             LDA     frs_char
0015D1r 1  99 00 AC             STA     FRDS_BUF,y
0015D4r 1  80 C3                BRA     @frs_loop
0015D6r 1               @frs_done:
0015D6r 1  AD rr rr             LDA     frs_idx
0015D9r 1  8D 00 AC             STA     FRDS_BUF                ; length byte at offset 0
0015DCr 1               ; store buffer ptr ($AC00) into strvar at tmp3
0015DCr 1  A9 00                LDA     #<FRDS_BUF
0015DEr 1  A0 00                LDY     #0
0015E0r 1  91 rr                STA     (tmp3),y
0015E2r 1  C8                   INY
0015E3r 1  A9 AC                LDA     #>FRDS_BUF
0015E5r 1  91 rr                STA     (tmp3),y
0015E7r 1  4C rr rr             JMP     prun_loop
0015EAr 1               
0015EAr 1               ; OP_FWRB ($BE) — NOS=fileptr, TOS=bool → append "TRUE"/"FALSE"
0015EAr 1               op_FWRB:
0015EAr 1  20 rr rr             JSR     pm_pop                  ; bool value
0015EDr 1  85 rr                STA     tmp2
0015EFr 1  A5 rr                LDA     scratch
0015F1r 1  05 rr                ORA     tmp2
0015F3r 1  85 rr                STA     tmp2                    ; tmp2 = nonzero if true
0015F5r 1  20 rr rr             JSR     pm_pop                  ; file ptr
0015F8r 1  85 rr                STA     tmp1
0015FAr 1  A5 rr                LDA     scratch
0015FCr 1  85 rr                STA     tmp1+1
0015FEr 1  A5 rr                LDA     tmp2
001600r 1  F0 17                BEQ     @fwb_false
001602r 1               ; "TRUE"
001602r 1  A9 54                LDA     #'T'
001604r 1  20 rr rr             JSR     file_write_char_helper
001607r 1  A9 52                LDA     #'R'
001609r 1  20 rr rr             JSR     file_write_char_helper
00160Cr 1  A9 55                LDA     #'U'
00160Er 1  20 rr rr             JSR     file_write_char_helper
001611r 1  A9 45                LDA     #'E'
001613r 1  20 rr rr             JSR     file_write_char_helper
001616r 1  4C rr rr             JMP     prun_loop
001619r 1               @fwb_false:
001619r 1  A9 46                LDA     #'F'
00161Br 1  20 rr rr             JSR     file_write_char_helper
00161Er 1  A9 41                LDA     #'A'
001620r 1  20 rr rr             JSR     file_write_char_helper
001623r 1  A9 4C                LDA     #'L'
001625r 1  20 rr rr             JSR     file_write_char_helper
001628r 1  A9 53                LDA     #'S'
00162Ar 1  20 rr rr             JSR     file_write_char_helper
00162Dr 1  A9 45                LDA     #'E'
00162Fr 1  20 rr rr             JSR     file_write_char_helper
001632r 1  4C rr rr             JMP     prun_loop
001635r 1               
001635r 1               ; OP_FEOLN ($BF) — TOS=fileptr → push BOOL: true if EOF, CR, or LF is next
001635r 1               op_FEOLN:
001635r 1  20 rr rr             JSR     pm_pop
001638r 1  85 rr                STA     tmp1
00163Ar 1  A5 rr                LDA     scratch
00163Cr 1  85 rr                STA     tmp1+1
00163Er 1  A0 A6                LDY     #F_EOF
001640r 1  B1 rr                LDA     (tmp1),y
001642r 1  D0 26                BNE     @feol_true
001644r 1               ; peek current char without consuming
001644r 1  18                   CLC
001645r 1  A5 rr                LDA     tmp1
001647r 1  69 24                ADC     #F_BUF
001649r 1  85 rr                STA     tmp2
00164Br 1  A5 rr                LDA     tmp1+1
00164Dr 1  69 00                ADC     #0
00164Fr 1  85 rr                STA     tmp2+1
001651r 1  A0 A5                LDY     #F_POS
001653r 1  B1 rr                LDA     (tmp1),y
001655r 1  A8                   TAY
001656r 1  B1 rr                LDA     (tmp2),y
001658r 1  C9 0D                CMP     #$0D
00165Ar 1  F0 0E                BEQ     @feol_true
00165Cr 1  C9 0A                CMP     #$0A
00165Er 1  F0 0A                BEQ     @feol_true
001660r 1  A9 00                LDA     #0
001662r 1  85 rr                STA     scratch
001664r 1  20 rr rr             JSR     pm_push
001667r 1  4C rr rr             JMP     prun_loop
00166Ar 1               @feol_true:
00166Ar 1  A9 FF                LDA     #$FF
00166Cr 1  85 rr                STA     scratch
00166Er 1  A9 FF                LDA     #$FF
001670r 1  20 rr rr             JSR     pm_push
001673r 1  4C rr rr             JMP     prun_loop
