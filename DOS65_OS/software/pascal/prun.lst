000960r 1               ; OP_MRKA ($67) — mark stack and gather args.
000960r 1               ; Operands: pcount (1 byte), lsize_extra (1 byte).
000960r 1               ; The caller pushed pcount 16-bit args to the value stack BEFORE MRKA, so
000960r 1               ; their bytes occupy [pm_sp - 2*pcount .. pm_sp - 1].  MRKA shifts those
000960r 1               ; bytes UP by AR_LOCALS to make room for the AR header, sets up new MP
000960r 1               ; pointing at where the args used to start, and reserves AR_LOCALS +
000960r 1               ; 2*pcount + lsize_extra bytes of frame.  After MRKA, args occupy local
000960r 1               ; slots 0..pcount-1; LDL/STL with offsets 0,2,..,2*(pcount-1) reach them.
000960r 1               ; This lets the caller evaluate args under its OWN MP, fixing the bug
000960r 1               ; where MRKSTK changed MP before LDL could load caller-frame locals.
000960r 1               ; ---------------------------------------------------------------------------
000960r 1               op_MRKA:
000960r 1  20 rr rr             JSR     pm_fetch_byte           ; A = pcount
000963r 1  85 rr                STA     tmp2                    ; tmp2 = pcount (≤ 8)
000965r 1  20 rr rr             JSR     pm_fetch_byte           ; A = lsize_extra
000968r 1  85 rr                STA     tmp3                    ; tmp3 = lsize_extra
00096Ar 1               
00096Ar 1               ; new_mp = pm_sp - 2*pcount  (start of arg block, becomes new AR base)
00096Ar 1  A5 rr                LDA     pm_sp
00096Cr 1  38                   SEC
00096Dr 1  E5 rr                SBC     tmp2
00096Fr 1  E5 rr                SBC     tmp2
000971r 1  85 rr                STA     tmp0                    ; tmp0 = new_mp lo
000973r 1  A5 rr                LDA     pm_sp+1
000975r 1  E9 00                SBC     #0
000977r 1  E9 00                SBC     #0
000979r 1  85 rr                STA     tmp0+1                  ; tmp0+1 = new_mp hi
00097Br 1               
00097Br 1               ; Shift 2*pcount bytes UP by AR_LOCALS to make room for the AR header.
00097Br 1               ;   src = (tmp0)
00097Br 1               ;   dst = (tmp0)+AR_LOCALS  (alias tmp1)
00097Br 1  A5 rr                LDA     tmp0
00097Dr 1  18                   CLC
00097Er 1  69 08                ADC     #AR_LOCALS
000980r 1  85 rr                STA     tmp1
000982r 1  A5 rr                LDA     tmp0+1
000984r 1  69 00                ADC     #0
000986r 1  85 rr                STA     tmp1+1
000988r 1               
000988r 1  A5 rr                LDA     tmp2
00098Ar 1  0A                   ASL                             ; A = 2*pcount (bytes to copy)
00098Br 1  F0 09                BEQ     @mrka_no_copy
00098Dr 1  A8                   TAY                             ; Y = byte count (1..16)
00098Er 1               @mrka_copy:
00098Er 1  88                   DEY
00098Fr 1  B1 rr                LDA     (tmp0),y
000991r 1  91 rr                STA     (tmp1),y
000993r 1  98                   TYA
000994r 1  D0 F8                BNE     @mrka_copy
000996r 1               @mrka_no_copy:
000996r 1               
000996r 1               ; Initialize AR header: AR_DYN_LINK <- old MP.
000996r 1  A0 00                LDY     #AR_DYN_LINK
000998r 1  A5 rr                LDA     pm_mp
00099Ar 1  91 rr                STA     (tmp0),y
00099Cr 1  C8                   INY
00099Dr 1  A5 rr                LDA     pm_mp+1
00099Fr 1  91 rr                STA     (tmp0),y
0009A1r 1               
0009A1r 1               ; pm_mp = new_mp
0009A1r 1  A5 rr                LDA     tmp0
0009A3r 1  85 rr                STA     pm_mp
0009A5r 1  A5 rr                LDA     tmp0+1
0009A7r 1  85 rr                STA     pm_mp+1
0009A9r 1               
0009A9r 1               ; pm_sp = new_mp + AR_LOCALS + 2*pcount + lsize_extra
0009A9r 1  A5 rr                LDA     pm_mp
0009ABr 1  18                   CLC
0009ACr 1  69 08                ADC     #AR_LOCALS
0009AEr 1  85 rr                STA     pm_sp
0009B0r 1  A5 rr                LDA     pm_mp+1
0009B2r 1  69 00                ADC     #0
0009B4r 1  85 rr                STA     pm_sp+1
0009B6r 1               
0009B6r 1  A5 rr                LDA     pm_sp
0009B8r 1  18                   CLC
0009B9r 1  65 rr                ADC     tmp2
0009BBr 1  85 rr                STA     pm_sp
0009BDr 1  A5 rr                LDA     pm_sp+1
0009BFr 1  69 00                ADC     #0
0009C1r 1  85 rr                STA     pm_sp+1
0009C3r 1  A5 rr                LDA     pm_sp
0009C5r 1  18                   CLC
0009C6r 1  65 rr                ADC     tmp2
0009C8r 1  85 rr                STA     pm_sp
0009CAr 1  A5 rr                LDA     pm_sp+1
0009CCr 1  69 00                ADC     #0
0009CEr 1  85 rr                STA     pm_sp+1
0009D0r 1               
0009D0r 1  A5 rr                LDA     pm_sp
0009D2r 1  18                   CLC
0009D3r 1  65 rr                ADC     tmp3
0009D5r 1  85 rr                STA     pm_sp
0009D7r 1  A5 rr                LDA     pm_sp+1
0009D9r 1  69 00                ADC     #0
0009DBr 1  85 rr                STA     pm_sp+1
0009DDr 1               
0009DDr 1  4C rr rr             JMP     prun_loop
0009E0r 1               
0009E0r 1               ; OP_CALL ($60) — call procedure: signed 16-bit offset relative to IPC after operand
0009E0r 1               ; Saves return IPC into the new frame's AR_RET_ADDR slot, then jumps.
0009E0r 1               op_CALL:
0009E0r 1  20 rr rr             JSR     pm_fetch_word   ; A = offset lo, scratch = offset hi
0009E3r 1  48                   PHA                     ; save offset lo
0009E4r 1               ; save current IPC (= return address) into MP+AR_RET_ADDR
0009E4r 1  A0 02                LDY     #AR_RET_ADDR
0009E6r 1  A5 rr                LDA     pm_ipc
0009E8r 1  91 rr                STA     (pm_mp),y
0009EAr 1  C8                   INY
0009EBr 1  A5 rr                LDA     pm_ipc+1
0009EDr 1  91 rr                STA     (pm_mp),y
0009EFr 1               ; pm_ipc += offset (signed)
0009EFr 1  68                   PLA                     ; offset lo
0009F0r 1  18                   CLC
0009F1r 1  65 rr                ADC     pm_ipc
0009F3r 1  85 rr                STA     pm_ipc
0009F5r 1  A5 rr                LDA     scratch
0009F7r 1  65 rr                ADC     pm_ipc+1
0009F9r 1  85 rr                STA     pm_ipc+1
0009FBr 1  4C rr rr             JMP     prun_loop
0009FEr 1               
0009FEr 1               ; OP_RET ($62) — return from procedure
0009FEr 1               ;   pm_sp ← pm_mp           (collapse frame; discards locals + any junk above)
0009FEr 1               ;   pm_ipc ← MP+AR_RET_ADDR
0009FEr 1               ;   pm_mp  ← MP+AR_DYN_LINK  (saved old MP)
0009FEr 1               op_RET:
0009FEr 1               ; collapse stack first (preserves AR header — still readable via pm_mp)
0009FEr 1  A5 rr                LDA     pm_mp
000A00r 1  85 rr                STA     pm_sp
000A02r 1  A5 rr                LDA     pm_mp+1
000A04r 1  85 rr                STA     pm_sp+1
000A06r 1               ; restore IPC into tmp1 before clobbering MP
000A06r 1  A0 02                LDY     #AR_RET_ADDR
000A08r 1  B1 rr                LDA     (pm_mp),y
000A0Ar 1  85 rr                STA     tmp1
000A0Cr 1  C8                   INY
000A0Dr 1  B1 rr                LDA     (pm_mp),y
000A0Fr 1  85 rr                STA     tmp1+1
000A11r 1               ; restore old MP from AR_DYN_LINK
000A11r 1  A0 01                LDY     #AR_DYN_LINK+1
000A13r 1  B1 rr                LDA     (pm_mp),y
000A15r 1  48                   PHA                     ; old MP hi
000A16r 1  A0 00                LDY     #AR_DYN_LINK
000A18r 1  B1 rr                LDA     (pm_mp),y
000A1Ar 1  85 rr                STA     pm_mp
000A1Cr 1  68                   PLA
000A1Dr 1  85 rr                STA     pm_mp+1
000A1Fr 1               ; install IPC
000A1Fr 1  A5 rr                LDA     tmp1
000A21r 1  85 rr                STA     pm_ipc
000A23r 1  A5 rr                LDA     tmp1+1
000A25r 1  85 rr                STA     pm_ipc+1
000A27r 1  4C rr rr             JMP     prun_loop
000A2Ar 1               
000A2Ar 1               ; OP_RETF ($63) — return from function: capture AR_RET_VAL, collapse frame,
000A2Ar 1               ; restore IPC/MP, then push the captured value onto caller's stack.
000A2Ar 1               op_RETF:
000A2Ar 1               ; capture return value into tmp0 BEFORE collapsing
000A2Ar 1  A0 06                LDY     #AR_RET_VAL
000A2Cr 1  B1 rr                LDA     (pm_mp),y
000A2Er 1  85 rr                STA     tmp0
000A30r 1  C8                   INY
000A31r 1  B1 rr                LDA     (pm_mp),y
000A33r 1  85 rr                STA     tmp0+1
000A35r 1               ; collapse stack to MP
000A35r 1  A5 rr                LDA     pm_mp
000A37r 1  85 rr                STA     pm_sp
000A39r 1  A5 rr                LDA     pm_mp+1
000A3Br 1  85 rr                STA     pm_sp+1
000A3Dr 1               ; restore IPC into tmp1
000A3Dr 1  A0 02                LDY     #AR_RET_ADDR
000A3Fr 1  B1 rr                LDA     (pm_mp),y
000A41r 1  85 rr                STA     tmp1
000A43r 1  C8                   INY
000A44r 1  B1 rr                LDA     (pm_mp),y
000A46r 1  85 rr                STA     tmp1+1
000A48r 1               ; restore old MP from AR_DYN_LINK
000A48r 1  A0 01                LDY     #AR_DYN_LINK+1
000A4Ar 1  B1 rr                LDA     (pm_mp),y
000A4Cr 1  48                   PHA
000A4Dr 1  A0 00                LDY     #AR_DYN_LINK
000A4Fr 1  B1 rr                LDA     (pm_mp),y
000A51r 1  85 rr                STA     pm_mp
000A53r 1  68                   PLA
000A54r 1  85 rr                STA     pm_mp+1
000A56r 1               ; install IPC
000A56r 1  A5 rr                LDA     tmp1
000A58r 1  85 rr                STA     pm_ipc
000A5Ar 1  A5 rr                LDA     tmp1+1
000A5Cr 1  85 rr                STA     pm_ipc+1
000A5Er 1               ; push captured return value (lo in A, hi in scratch)
000A5Er 1  A5 rr                LDA     tmp0+1
000A60r 1  85 rr                STA     scratch
000A62r 1  A5 rr                LDA     tmp0
000A64r 1  20 rr rr             JSR     pm_push
000A67r 1  4C rr rr             JMP     prun_loop
000A6Ar 1               
000A6Ar 1               ; OP_STR ($66) — pop word, store at MP+AR_RET_VAL (function result slot)
000A6Ar 1               op_STR:
000A6Ar 1  20 rr rr             JSR     pm_pop          ; A=lo, scratch=hi
000A6Dr 1  A0 06                LDY     #AR_RET_VAL
000A6Fr 1  91 rr                STA     (pm_mp),y
000A71r 1  C8                   INY
000A72r 1  A5 rr                LDA     scratch
000A74r 1  91 rr                STA     (pm_mp),y
000A76r 1  4C rr rr             JMP     prun_loop
000A79r 1               
000A79r 1               ; OP_WRITI ($80) — pop integer, print decimal
000A79r 1               op_WRITI:
000A79r 1  20 rr rr             JSR     pm_pop          ; A=lo, scratch=hi
000A7Cr 1  85 rr                STA     tmp0
000A7Er 1  A5 rr                LDA     scratch
000A80r 1  85 rr                STA     tmp0+1
000A82r 1  20 rr rr             JSR     console_print_dec
000A85r 1  4C rr rr             JMP     prun_loop
000A88r 1               
000A88r 1               ; OP_WRITR ($88) — pop REAL, print fixed-point decimal with 2 digits
000A88r 1               op_WRITR:
000A88r 1  20 rr rr             JSR     pm_pop
000A8Br 1  85 rr                STA     tmp0
000A8Dr 1  A5 rr                LDA     scratch
000A8Fr 1  85 rr                STA     tmp0+1
000A91r 1  20 rr rr             JSR     real_print_console_helper
000A94r 1  4C rr rr             JMP     prun_loop
000A97r 1               
000A97r 1               ; OP_WRITC ($81) — pop char, print
000A97r 1               op_WRITC:
000A97r 1  20 rr rr             JSR     pm_pop
000A9Ar 1  20 rr rr             JSR     console_putc
000A9Dr 1  4C rr rr             JMP     prun_loop
000AA0r 1               
000AA0r 1               ; OP_WRITB ($82) — pop boolean, print TRUE/FALSE
000AA0r 1               op_WRITB:
000AA0r 1  20 rr rr             JSR     pm_pop
000AA3r 1  05 rr                ORA     scratch
000AA5r 1  F0 0E                BEQ     @false3
000AA7r 1  A9 rr                LDA     #<str_true
000AA9r 1  85 rr                STA     tmp0
000AABr 1  A9 rr                LDA     #>str_true
000AADr 1  85 rr                STA     tmp0+1
000AAFr 1  20 rr rr             JSR     console_print_sz
000AB2r 1  4C rr rr             JMP     prun_loop
000AB5r 1               @false3:
000AB5r 1  A9 rr                LDA     #<str_false
000AB7r 1  85 rr                STA     tmp0
000AB9r 1  A9 rr                LDA     #>str_false
000ABBr 1  85 rr                STA     tmp0+1
000ABDr 1  20 rr rr             JSR     console_print_sz
000AC0r 1  4C rr rr             JMP     prun_loop
000AC3r 1               
000AC3r 1               ; OP_WRITS ($83) — TOS = address of length-prefixed string, print it
000AC3r 1               op_WRITS:
000AC3r 1  20 rr rr             JSR     pm_pop
000AC6r 1  85 rr                STA     tmp0
000AC8r 1  A5 rr                LDA     scratch
000ACAr 1  85 rr                STA     tmp0+1
000ACCr 1  20 rr rr             JSR     console_print_pstr
000ACFr 1  4C rr rr             JMP     prun_loop
000AD2r 1               
000AD2r 1               ; OP_WRITLN ($84) — newline
000AD2r 1               op_WRITLN:
000AD2r 1  20 rr rr             JSR     console_newline
000AD5r 1  4C rr rr             JMP     prun_loop
000AD8r 1               
000AD8r 1               ; OP_READI ($85) — TOS = address of INTEGER variable.  Read a line from
000AD8r 1               ; the console, parse a signed decimal integer, store as a 16-bit word at
000AD8r 1               ; the popped address.
000AD8r 1               op_READI:
000AD8r 1  20 rr rr             JSR     pm_pop          ; A=lo addr, scratch=hi addr
000ADBr 1  85 rr                STA     tmp1            ; (zero-page) destination pointer
000ADDr 1  A5 rr                LDA     scratch
000ADFr 1  85 rr                STA     tmp1+1
000AE1r 1               ; read one line into read_line_buf
000AE1r 1  A9 rr                LDA     #<read_line_buf
000AE3r 1  85 rr                STA     tmp0
000AE5r 1  A9 rr                LDA     #>read_line_buf
000AE7r 1  85 rr                STA     tmp0+1
000AE9r 1  A2 1F                LDX     #31             ; max line length
000AEBr 1  20 rr rr             JSR     console_read_line; Y = length on return
000AEEr 1  8C rr rr             STY     read_len
000AF1r 1  20 rr rr             JSR     console_newline ; PEM CONIN echoes CR but no LF
000AF4r 1               ; parse signed decimal from read_line_buf into tmp2:tmp2+1
000AF4r 1  A9 00                LDA     #0
000AF6r 1  85 rr                STA     tmp2
000AF8r 1  85 rr                STA     tmp2+1
000AFAr 1  8D rr rr             STA     read_neg
000AFDr 1  A0 00                LDY     #0
000AFFr 1               @rd_skip:
000AFFr 1  CC rr rr             CPY     read_len
000B02r 1  B0 67                BCS     @rd_apply_sign  ; empty / all-space → 0
000B04r 1  B9 rr rr             LDA     read_line_buf,y
000B07r 1  C9 20                CMP     #' '
000B09r 1  D0 04                BNE     @rd_chk_sign
000B0Br 1  C8                   INY
000B0Cr 1  4C rr rr             JMP     @rd_skip
000B0Fr 1               @rd_chk_sign:
000B0Fr 1  C9 2D                CMP     #'-'
000B11r 1  D0 09                BNE     @rd_chk_plus
000B13r 1  A9 01                LDA     #1
000B15r 1  8D rr rr             STA     read_neg
000B18r 1  C8                   INY
000B19r 1  4C rr rr             JMP     @rd_digits
000B1Cr 1               @rd_chk_plus:
000B1Cr 1  C9 2B                CMP     #'+'
000B1Er 1  D0 01                BNE     @rd_digits
000B20r 1  C8                   INY
000B21r 1               @rd_digits:
000B21r 1  CC rr rr             CPY     read_len
000B24r 1  B0 45                BCS     @rd_apply_sign
000B26r 1  B9 rr rr             LDA     read_line_buf,y
000B29r 1  C9 30                CMP     #'0'
000B2Br 1  90 3E                BCC     @rd_apply_sign
000B2Dr 1  C9 3A                CMP     #'9'+1
000B2Fr 1  B0 3A                BCS     @rd_apply_sign
000B31r 1               ; tmp2 *= 10  (using temp = tmp2*2; tmp2 = (tmp2*2)*4 + temp)
000B31r 1  06 rr                ASL     tmp2
000B33r 1  26 rr                ROL     tmp2+1
000B35r 1  A5 rr                LDA     tmp2
000B37r 1  8D rr rr             STA     read_save2
000B3Ar 1  A5 rr                LDA     tmp2+1
000B3Cr 1  8D rr rr             STA     read_save2+1
000B3Fr 1  06 rr                ASL     tmp2
000B41r 1  26 rr                ROL     tmp2+1
000B43r 1  06 rr                ASL     tmp2
000B45r 1  26 rr                ROL     tmp2+1
000B47r 1  18                   CLC
000B48r 1  A5 rr                LDA     tmp2
000B4Ar 1  6D rr rr             ADC     read_save2
000B4Dr 1  85 rr                STA     tmp2
000B4Fr 1  A5 rr                LDA     tmp2+1
000B51r 1  6D rr rr             ADC     read_save2+1
000B54r 1  85 rr                STA     tmp2+1
000B56r 1               ; tmp2 += digit
000B56r 1  B9 rr rr             LDA     read_line_buf,y
000B59r 1  38                   SEC
000B5Ar 1  E9 30                SBC     #'0'
000B5Cr 1  18                   CLC
000B5Dr 1  65 rr                ADC     tmp2
000B5Fr 1  85 rr                STA     tmp2
000B61r 1  A9 00                LDA     #0
000B63r 1  65 rr                ADC     tmp2+1
000B65r 1  85 rr                STA     tmp2+1
000B67r 1  C8                   INY
000B68r 1  4C rr rr             JMP     @rd_digits
000B6Br 1               @rd_apply_sign:
000B6Br 1  AD rr rr             LDA     read_neg
000B6Er 1  F0 0D                BEQ     @rd_store
000B70r 1  38                   SEC
000B71r 1  A9 00                LDA     #0
000B73r 1  E5 rr                SBC     tmp2
000B75r 1  85 rr                STA     tmp2
000B77r 1  A9 00                LDA     #0
000B79r 1  E5 rr                SBC     tmp2+1
000B7Br 1  85 rr                STA     tmp2+1
000B7Dr 1               @rd_store:
000B7Dr 1  A0 00                LDY     #0
000B7Fr 1  A5 rr                LDA     tmp2
000B81r 1  91 rr                STA     (tmp1),y
000B83r 1  C8                   INY
000B84r 1  A5 rr                LDA     tmp2+1
000B86r 1  91 rr                STA     (tmp1),y
000B88r 1  4C rr rr             JMP     prun_loop
000B8Br 1               
000B8Br 1               ; OP_READR ($89) — read a console line, parse fixed-point REAL, push it.
000B8Br 1               op_READR:
000B8Br 1  A9 rr                LDA     #<read_line_buf
000B8Dr 1  85 rr                STA     tmp0
000B8Fr 1  A9 rr                LDA     #>read_line_buf
000B91r 1  85 rr                STA     tmp0+1
000B93r 1  A2 1F                LDX     #31
000B95r 1  20 rr rr             JSR     console_read_line
000B98r 1  8C rr rr             STY     read_len
000B9Br 1  20 rr rr             JSR     console_newline
000B9Er 1  A9 00                LDA     #0
000BA0r 1  85 rr                STA     tmp2
000BA2r 1  85 rr                STA     tmp2+1
000BA4r 1  8D rr rr             STA     read_neg
000BA7r 1  8D rr rr             STA     read_frac_count
000BAAr 1  8D rr rr             STA     read_seen_dot
000BADr 1  A0 00                LDY     #0
000BAFr 1               @rr_skip:
000BAFr 1  CC rr rr             CPY     read_len
000BB2r 1  B0 5F                BCS     @rr_scale
000BB4r 1  B9 rr rr             LDA     read_line_buf,y
000BB7r 1  C9 20                CMP     #' '
000BB9r 1  D0 03                BNE     @rr_chk_sign
000BBBr 1  C8                   INY
000BBCr 1  80 F1                BRA     @rr_skip
000BBEr 1               @rr_chk_sign:
000BBEr 1  C9 2D                CMP     #'-'
000BC0r 1  D0 08                BNE     @rr_chk_plus
000BC2r 1  A9 01                LDA     #1
000BC4r 1  8D rr rr             STA     read_neg
000BC7r 1  C8                   INY
000BC8r 1  80 05                BRA     @rr_loop
000BCAr 1               @rr_chk_plus:
000BCAr 1  C9 2B                CMP     #'+'
000BCCr 1  D0 01                BNE     @rr_loop
000BCEr 1  C8                   INY
000BCFr 1               @rr_loop:
000BCFr 1  CC rr rr             CPY     read_len
000BD2r 1  B0 3F                BCS     @rr_scale
000BD4r 1  B9 rr rr             LDA     read_line_buf,y
000BD7r 1  C9 2E                CMP     #'.'
000BD9r 1  D0 0D                BNE     @rr_digit
000BDBr 1  AD rr rr             LDA     read_seen_dot
000BDEr 1  D0 33                BNE     @rr_scale
000BE0r 1  A9 01                LDA     #1
000BE2r 1  8D rr rr             STA     read_seen_dot
000BE5r 1  C8                   INY
000BE6r 1  80 E7                BRA     @rr_loop
000BE8r 1               @rr_digit:
000BE8r 1  C9 30                CMP     #'0'
000BEAr 1  90 27                BCC     @rr_scale
000BECr 1  C9 3A                CMP     #'9'+1
000BEEr 1  B0 23                BCS     @rr_scale
000BF0r 1  AD rr rr             LDA     read_seen_dot
000BF3r 1  F0 07                BEQ     @rr_accum
000BF5r 1  AD rr rr             LDA     read_frac_count
000BF8r 1  C9 02                CMP     #2
000BFAr 1  B0 14                BCS     @rr_skip_digit
000BFCr 1               @rr_accum:
000BFCr 1  B9 rr rr             LDA     read_line_buf,y
000BFFr 1  38                   SEC
000C00r 1  E9 30                SBC     #'0'
000C02r 1  20 rr rr             JSR     accum_digit_tmp2
000C05r 1  AD rr rr             LDA     read_seen_dot
000C08r 1  F0 03                BEQ     @rr_after_digit
000C0Ar 1  EE rr rr             INC     read_frac_count
000C0Dr 1               @rr_after_digit:
000C0Dr 1  C8                   INY
000C0Er 1  80 BF                BRA     @rr_loop
000C10r 1               @rr_skip_digit:
000C10r 1  C8                   INY
000C11r 1  80 BC                BRA     @rr_loop
000C13r 1               @rr_scale:
000C13r 1  AD rr rr             LDA     read_frac_count
000C16r 1  D0 08                BNE     @rr_chk_frac1
000C18r 1  20 rr rr             JSR     mul_tmp2_by10
000C1Br 1  20 rr rr             JSR     mul_tmp2_by10
000C1Er 1  80 07                BRA     @rr_apply
000C20r 1               @rr_chk_frac1:
000C20r 1  C9 01                CMP     #1
000C22r 1  D0 03                BNE     @rr_apply
000C24r 1  20 rr rr             JSR     mul_tmp2_by10
000C27r 1               @rr_apply:
000C27r 1  AD rr rr             LDA     read_neg
000C2Ar 1  F0 03                BEQ     @rr_push
000C2Cr 1  20 rr rr             JSR     neg_tmp2
000C2Fr 1               @rr_push:
000C2Fr 1  A5 rr                LDA     tmp2
000C31r 1  A6 rr                LDX     tmp2+1
000C33r 1  86 rr                STX     scratch
000C35r 1  20 rr rr             JSR     pm_push
000C38r 1  4C rr rr             JMP     prun_loop
000C3Br 1               
000C3Br 1               read_line_buf:
000C3Br 1  xx xx xx xx          .RES    32
000C3Fr 1  xx xx xx xx  
000C43r 1  xx xx xx xx  
000C5Br 1               read_len:
000C5Br 1  xx                   .RES    1
000C5Cr 1               read_neg:
000C5Cr 1  xx                   .RES    1
000C5Dr 1               read_frac_count:
000C5Dr 1  xx                   .RES    1
000C5Er 1               read_seen_dot:
000C5Er 1  xx                   .RES    1
000C5Fr 1               read_save2:
000C5Fr 1  xx xx                .RES    2
000C61r 1               
000C61r 1               ; OP_READC ($86) — read char from console, push
000C61r 1               op_READC:
000C61r 1  A2 01 20 03          PEM     PEM_CONIN
000C65r 1  01           
000C66r 1  48                   PHA
000C67r 1  A9 00                LDA     #0
000C69r 1  85 rr                STA     scratch
000C6Br 1  68                   PLA
000C6Cr 1  20 rr rr             JSR     pm_push
000C6Fr 1  4C rr rr             JMP     prun_loop
000C72r 1               
000C72r 1               ; OP_DUP ($90) — duplicate TOS
000C72r 1               op_DUP:
000C72r 1  20 rr rr             JSR     pm_peek
000C75r 1  20 rr rr             JSR     pm_push
000C78r 1  4C rr rr             JMP     prun_loop
000C7Br 1               
000C7Br 1               ; OP_POP ($91) — discard TOS
000C7Br 1               op_POP:
000C7Br 1  20 rr rr             JSR     pm_pop
000C7Er 1  4C rr rr             JMP     prun_loop
000C81r 1               
000C81r 1               ; OP_SWAP ($92) — swap TOS and NOS
000C81r 1               op_SWAP:
000C81r 1  20 rr rr             JSR     pm_pop
000C84r 1  85 rr                STA     tmp2
000C86r 1  A5 rr                LDA     scratch
000C88r 1  85 rr                STA     tmp2+1
000C8Ar 1  20 rr rr             JSR     pm_pop
000C8Dr 1  85 rr                STA     tmp1
000C8Fr 1  A5 rr                LDA     scratch
000C91r 1  85 rr                STA     tmp1+1
000C93r 1  A5 rr                LDA     tmp2
000C95r 1  A6 rr                LDX     tmp2+1
000C97r 1  86 rr                STX     scratch
000C99r 1  20 rr rr             JSR     pm_push
000C9Cr 1  A5 rr                LDA     tmp1
000C9Er 1  A6 rr                LDX     tmp1+1
000CA0r 1  86 rr                STX     scratch
000CA2r 1  20 rr rr             JSR     pm_push
000CA5r 1  4C rr rr             JMP     prun_loop
000CA8r 1               
000CA8r 1               ; OP_NEW ($70) — allocate inline-size bytes from heap, push pointer
000CA8r 1               ; Bump allocator: pm_np grows down from HEAP_TOP. DISPOSE is a no-op.
000CA8r 1               op_NEW:
000CA8r 1  20 rr rr             JSR     pm_fetch_word   ; A=size lo, scratch=size hi
000CABr 1  85 rr                STA     tmp0
000CADr 1  A5 rr                LDA     scratch
000CAFr 1  85 rr                STA     tmp0+1
000CB1r 1  38                   SEC
000CB2r 1  A5 rr                LDA     pm_np
000CB4r 1  E5 rr                SBC     tmp0
000CB6r 1  85 rr                STA     pm_np
000CB8r 1  A5 rr                LDA     pm_np+1
000CBAr 1  E5 rr                SBC     tmp0+1
000CBCr 1  85 rr                STA     pm_np+1
000CBEr 1  A5 rr                LDA     pm_np+1
000CC0r 1  85 rr                STA     scratch
000CC2r 1  A5 rr                LDA     pm_np
000CC4r 1  20 rr rr             JSR     pm_push
000CC7r 1  4C rr rr             JMP     prun_loop
000CCAr 1               
000CCAr 1               ; OP_DISP ($71) — discard pointer (bump allocator cannot free)
000CCAr 1               op_DISP:
000CCAr 1  20 rr rr             JSR     pm_pop
000CCDr 1  4C rr rr             JMP     prun_loop
000CD0r 1               
000CD0r 1               ; ---------------------------------------------------------------------------
000CD0r 1               ; String built-in support
000CD0r 1               ;
000CD0r 1               ; Pascal-style strings: length byte at offset 0, characters at offsets 1..N.
000CD0r 1               ; COPY/CONCAT results live in one of three rotating 256-byte work buffers
000CD0r 1               ; placed in unused heap-area memory.  Round-robin allocation lets simple
000CD0r 1               ; nested expressions like CONCAT(COPY(s,1,3), 'x') work; deeper nesting
000CD0r 1               ; eventually recycles a buffer and corrupts an earlier result.
000CD0r 1               ; ---------------------------------------------------------------------------
000CD0r 1               STR_WORK_BASE   = $AD00
000CD0r 1               STR_WORK_COUNT  = 3
000CD0r 1               
000CD0r 1               str_work_idx:
000CD0r 1  xx                   .RES    1
000CD1r 1               
000CD1r 1               ; next_work_buf — return current work-buffer addr in tmp1, advance idx
000CD1r 1               next_work_buf:
000CD1r 1  AD rr rr             LDA     str_work_idx
000CD4r 1  18                   CLC
000CD5r 1  69 AD                ADC     #>STR_WORK_BASE
000CD7r 1  85 rr                STA     tmp1+1
000CD9r 1  A9 00                LDA     #0
000CDBr 1  85 rr                STA     tmp1
000CDDr 1  EE rr rr             INC     str_work_idx
000CE0r 1  AD rr rr             LDA     str_work_idx
000CE3r 1  C9 03                CMP     #STR_WORK_COUNT
000CE5r 1  90 05                BCC     :+
000CE7r 1  A9 00                LDA     #0
000CE9r 1  8D rr rr             STA     str_work_idx
000CECr 1  60           :       RTS
000CEDr 1               
000CEDr 1               ; OP_LEN ($A0) — TOS = string ptr → TOS = length (int)
000CEDr 1               op_LEN:
000CEDr 1  20 rr rr             JSR     pm_pop          ; A=lo, scratch=hi
000CF0r 1  85 rr                STA     tmp1
000CF2r 1  A5 rr                LDA     scratch
000CF4r 1  85 rr                STA     tmp1+1
000CF6r 1  A0 00                LDY     #0
000CF8r 1  B1 rr                LDA     (tmp1),y        ; length byte
000CFAr 1  48                   PHA
000CFBr 1  A9 00                LDA     #0
000CFDr 1  85 rr                STA     scratch
000CFFr 1  68                   PLA
000D00r 1  20 rr rr             JSR     pm_push
000D03r 1  4C rr rr             JMP     prun_loop
000D06r 1               
000D06r 1               ; OP_POS ($A1) — NOS=substr ptr, TOS=mainstr ptr → TOS=1-based position
000D06r 1               op_POS:
000D06r 1  20 rr rr             JSR     pm_pop          ; mainstr → tmp2
000D09r 1  85 rr                STA     tmp2
000D0Br 1  A5 rr                LDA     scratch
000D0Dr 1  85 rr                STA     tmp2+1
000D0Fr 1  20 rr rr             JSR     pm_pop          ; substr → tmp1
000D12r 1  85 rr                STA     tmp1
000D14r 1  A5 rr                LDA     scratch
000D16r 1  85 rr                STA     tmp1+1
000D18r 1               ; If substr length is 0, return 0
000D18r 1  A0 00                LDY     #0
000D1Ar 1  B1 rr                LDA     (tmp1),y
000D1Cr 1  D0 03                BNE     :+
000D1Er 1  4C rr rr             JMP     @pos_zero
000D21r 1               :
000D21r 1               ; sublen in pos_sublen, mainlen in pos_mainlen
000D21r 1  8D rr rr             STA     pos_sublen
000D24r 1  A0 00                LDY     #0
000D26r 1  B1 rr                LDA     (tmp2),y
000D28r 1  8D rr rr             STA     pos_mainlen
000D2Br 1               ; If sublen > mainlen, return 0
000D2Br 1  AD rr rr             LDA     pos_sublen
000D2Er 1  CD rr rr             CMP     pos_mainlen
000D31r 1  F0 02                BEQ     :+
000D33r 1  B0 4D                BCS     @pos_zero
000D35r 1               :
000D35r 1               ; pos_start = 1; loop while (pos_start + sublen - 1) <= mainlen
000D35r 1  A9 01                LDA     #1
000D37r 1  8D rr rr             STA     pos_start
000D3Ar 1               @pos_outer:
000D3Ar 1               ; max_start = mainlen - sublen + 1
000D3Ar 1  AD rr rr             LDA     pos_mainlen
000D3Dr 1  38                   SEC
000D3Er 1  ED rr rr             SBC     pos_sublen
000D41r 1  18                   CLC
000D42r 1  69 01                ADC     #1              ; A = max valid start
000D44r 1  CD rr rr             CMP     pos_start
000D47r 1  90 39                BCC     @pos_zero       ; pos_start > max_start → not found
000D49r 1               ; compare sublen bytes at main[pos_start..] vs sub[1..]
000D49r 1  A2 00                LDX     #0              ; substr offset (0..sublen-1, +1 to skip len byte)
000D4Br 1               @pos_cmp:
000D4Br 1  EC rr rr             CPX     pos_sublen
000D4Er 1  F0 1F                BEQ     @pos_found
000D50r 1  8A                   TXA
000D51r 1  18                   CLC
000D52r 1  6D rr rr             ADC     pos_start       ; main index = pos_start + X
000D55r 1  A8                   TAY
000D56r 1  B1 rr                LDA     (tmp2),y        ; main[pos_start+X]
000D58r 1  8D rr rr             STA     pos_save
000D5Br 1  8A                   TXA
000D5Cr 1  18                   CLC
000D5Dr 1  69 01                ADC     #1              ; sub index = X + 1
000D5Fr 1  A8                   TAY
000D60r 1  B1 rr                LDA     (tmp1),y        ; sub[X+1]
000D62r 1  CD rr rr             CMP     pos_save
000D65r 1  D0 03                BNE     @pos_next
000D67r 1  E8                   INX
000D68r 1  80 E1                BRA     @pos_cmp
000D6Ar 1               @pos_next:
000D6Ar 1  EE rr rr             INC     pos_start
000D6Dr 1  80 CB                BRA     @pos_outer
000D6Fr 1               @pos_found:
000D6Fr 1  AD rr rr             LDA     pos_start
000D72r 1  8D rr rr             STA     pos_save
000D75r 1  A9 00                LDA     #0
000D77r 1  85 rr                STA     scratch
000D79r 1  AD rr rr             LDA     pos_save
000D7Cr 1  20 rr rr             JSR     pm_push
000D7Fr 1  4C rr rr             JMP     prun_loop
000D82r 1               @pos_zero:
000D82r 1  A9 00                LDA     #0
000D84r 1  85 rr                STA     scratch
000D86r 1  20 rr rr             JSR     pm_push
000D89r 1  4C rr rr             JMP     prun_loop
000D8Cr 1               
000D8Cr 1  xx           pos_sublen:    .RES 1
000D8Dr 1  xx           pos_mainlen:   .RES 1
000D8Er 1  xx           pos_start:     .RES 1
000D8Fr 1  xx           pos_save:      .RES 1
000D90r 1               
000D90r 1               ; OP_COPY ($A2) — NNOS=str, NOS=index (1-based), TOS=count → TOS=result strptr
000D90r 1               op_COPY:
000D90r 1  20 rr rr             JSR     pm_pop          ; count
000D93r 1  8D rr rr             STA     copy_count
000D96r 1  20 rr rr             JSR     pm_pop          ; index
000D99r 1  8D rr rr             STA     copy_index
000D9Cr 1  20 rr rr             JSR     pm_pop          ; source ptr
000D9Fr 1  85 rr                STA     tmp2
000DA1r 1  A5 rr                LDA     scratch
000DA3r 1  85 rr                STA     tmp2+1
000DA5r 1  20 rr rr             JSR     next_work_buf   ; tmp1 = dest buffer
000DA8r 1               ; clamp index: if index < 1 or index > srclen, result is empty
000DA8r 1  A0 00                LDY     #0
000DAAr 1  B1 rr                LDA     (tmp2),y
000DACr 1  8D rr rr             STA     copy_srclen
000DAFr 1  AD rr rr             LDA     copy_index
000DB2r 1  F0 4A                BEQ     @copy_empty
000DB4r 1  CD rr rr             CMP     copy_srclen
000DB7r 1  F0 02                BEQ     :+
000DB9r 1  B0 43                BCS     @copy_empty
000DBBr 1               :
000DBBr 1               ; available = srclen - index + 1
000DBBr 1  AD rr rr             LDA     copy_srclen
000DBEr 1  38                   SEC
000DBFr 1  ED rr rr             SBC     copy_index
000DC2r 1  18                   CLC
000DC3r 1  69 01                ADC     #1
000DC5r 1  8D rr rr             STA     copy_avail
000DC8r 1               ; actual = min(count, available)
000DC8r 1  AD rr rr             LDA     copy_count
000DCBr 1  CD rr rr             CMP     copy_avail
000DCEr 1  90 03                BCC     :+
000DD0r 1  AD rr rr             LDA     copy_avail
000DD3r 1  8D rr rr     :       STA     copy_actual
000DD6r 1               ; copy actual bytes from src[index..] into dest[1..]
000DD6r 1  A2 00                LDX     #0
000DD8r 1               @copy_loop:
000DD8r 1  EC rr rr             CPX     copy_actual
000DDBr 1  F0 18                BEQ     @copy_done
000DDDr 1  8A                   TXA
000DDEr 1  18                   CLC
000DDFr 1  6D rr rr             ADC     copy_index      ; src offset = X + index
000DE2r 1  A8                   TAY
000DE3r 1  B1 rr                LDA     (tmp2),y
000DE5r 1  8D rr rr             STA     copy_save
000DE8r 1  8A                   TXA
000DE9r 1  18                   CLC
000DEAr 1  69 01                ADC     #1              ; dest offset = X + 1
000DECr 1  A8                   TAY
000DEDr 1  AD rr rr             LDA     copy_save
000DF0r 1  91 rr                STA     (tmp1),y
000DF2r 1  E8                   INX
000DF3r 1  80 E3                BRA     @copy_loop
000DF5r 1               @copy_done:
000DF5r 1  AD rr rr             LDA     copy_actual
000DF8r 1  A0 00                LDY     #0
000DFAr 1  91 rr                STA     (tmp1),y        ; write length byte
000DFCr 1  80 06                BRA     @copy_push
000DFEr 1               @copy_empty:
000DFEr 1  A9 00                LDA     #0
000E00r 1  A0 00                LDY     #0
000E02r 1  91 rr                STA     (tmp1),y
000E04r 1               @copy_push:
000E04r 1  A5 rr                LDA     tmp1+1
000E06r 1  85 rr                STA     scratch
000E08r 1  A5 rr                LDA     tmp1
000E0Ar 1  20 rr rr             JSR     pm_push
000E0Dr 1  4C rr rr             JMP     prun_loop
000E10r 1               
000E10r 1  xx           copy_count:    .RES 1
000E11r 1  xx           copy_index:    .RES 1
000E12r 1  xx           copy_srclen:   .RES 1
000E13r 1  xx           copy_avail:    .RES 1
000E14r 1  xx           copy_actual:   .RES 1
000E15r 1  xx           copy_save:     .RES 1
000E16r 1               
000E16r 1               ; OP_CONCAT ($A3) — NOS=s1, TOS=s2 → TOS=result strptr (s1 then s2)
000E16r 1               op_CONCAT:
000E16r 1  20 rr rr             JSR     pm_pop          ; s2 → tmp2
000E19r 1  85 rr                STA     tmp2
000E1Br 1  A5 rr                LDA     scratch
000E1Dr 1  85 rr                STA     tmp2+1
000E1Fr 1               ; stash s2 ptr in cat_s2 because next_work_buf and pm_pop touch tmp1
000E1Fr 1  A5 rr                LDA     tmp2
000E21r 1  8D rr rr             STA     cat_s2
000E24r 1  A5 rr                LDA     tmp2+1
000E26r 1  8D rr rr             STA     cat_s2+1
000E29r 1  20 rr rr             JSR     pm_pop          ; s1 → tmp2
000E2Cr 1  85 rr                STA     tmp2
000E2Er 1  A5 rr                LDA     scratch
000E30r 1  85 rr                STA     tmp2+1
000E32r 1  A5 rr                LDA     tmp2
000E34r 1  8D rr rr             STA     cat_s1
000E37r 1  A5 rr                LDA     tmp2+1
000E39r 1  8D rr rr             STA     cat_s1+1
000E3Cr 1  20 rr rr             JSR     next_work_buf   ; tmp1 = dest
000E3Fr 1               ; copy s1 chars
000E3Fr 1  AD rr rr             LDA     cat_s1
000E42r 1  85 rr                STA     tmp2
000E44r 1  AD rr rr             LDA     cat_s1+1
000E47r 1  85 rr                STA     tmp2+1
000E49r 1  A0 00                LDY     #0
000E4Br 1  B1 rr                LDA     (tmp2),y
000E4Dr 1  8D rr rr             STA     cat_s1len
000E50r 1  AA                   TAX                     ; X = remaining
000E51r 1  A0 01                LDY     #1              ; src offset
000E53r 1  A9 01                LDA     #1
000E55r 1  8D rr rr             STA     cat_dstoff
000E58r 1               @cat_s1_loop:
000E58r 1  E0 00                CPX     #0
000E5Ar 1  F0 18                BEQ     @cat_s2_start
000E5Cr 1  B1 rr                LDA     (tmp2),y
000E5Er 1  8D rr rr             STA     cat_save
000E61r 1  DA                   PHX
000E62r 1  5A                   PHY
000E63r 1  AC rr rr             LDY     cat_dstoff
000E66r 1  AD rr rr             LDA     cat_save
000E69r 1  91 rr                STA     (tmp1),y
000E6Br 1  EE rr rr             INC     cat_dstoff
000E6Er 1  7A                   PLY
000E6Fr 1  FA                   PLX
000E70r 1  C8                   INY
000E71r 1  CA                   DEX
000E72r 1  80 E4                BRA     @cat_s1_loop
000E74r 1               @cat_s2_start:
000E74r 1  AD rr rr             LDA     cat_s2
000E77r 1  85 rr                STA     tmp2
000E79r 1  AD rr rr             LDA     cat_s2+1
000E7Cr 1  85 rr                STA     tmp2+1
000E7Er 1  A0 00                LDY     #0
000E80r 1  B1 rr                LDA     (tmp2),y
000E82r 1  8D rr rr             STA     cat_s2len
000E85r 1  AA                   TAX
000E86r 1  A0 01                LDY     #1
000E88r 1               @cat_s2_loop:
000E88r 1  E0 00                CPX     #0
000E8Ar 1  F0 18                BEQ     @cat_done
000E8Cr 1  B1 rr                LDA     (tmp2),y
000E8Er 1  8D rr rr             STA     cat_save
000E91r 1  DA                   PHX
000E92r 1  5A                   PHY
000E93r 1  AC rr rr             LDY     cat_dstoff
000E96r 1  AD rr rr             LDA     cat_save
000E99r 1  91 rr                STA     (tmp1),y
000E9Br 1  EE rr rr             INC     cat_dstoff
000E9Er 1  7A                   PLY
000E9Fr 1  FA                   PLX
000EA0r 1  C8                   INY
000EA1r 1  CA                   DEX
000EA2r 1  80 E4                BRA     @cat_s2_loop
000EA4r 1               @cat_done:
000EA4r 1               ; total length = s1len + s2len (capped at 255)
000EA4r 1  18                   CLC
000EA5r 1  AD rr rr             LDA     cat_s1len
000EA8r 1  6D rr rr             ADC     cat_s2len
000EABr 1  90 02                BCC     :+
000EADr 1  A9 FF                LDA     #255
000EAFr 1  A0 00        :       LDY     #0
000EB1r 1  91 rr                STA     (tmp1),y
000EB3r 1  A5 rr                LDA     tmp1+1
000EB5r 1  85 rr                STA     scratch
000EB7r 1  A5 rr                LDA     tmp1
000EB9r 1  20 rr rr             JSR     pm_push
000EBCr 1  4C rr rr             JMP     prun_loop
000EBFr 1               
000EBFr 1  xx xx        cat_s1:        .RES 2
000EC1r 1  xx xx        cat_s2:        .RES 2
000EC3r 1  xx           cat_s1len:     .RES 1
000EC4r 1  xx           cat_s2len:     .RES 1
000EC5r 1  xx           cat_dstoff:    .RES 1
000EC6r 1  xx           cat_save:      .RES 1
000EC7r 1               
000EC7r 1               ; OP_INSET ($A4) — NOS=elem, TOS=setmask → TOS=membership bool
000EC7r 1               op_INSET:
000EC7r 1  20 rr rr             JSR     pm_pop          ; setmask
000ECAr 1  85 rr                STA     tmp2
000ECCr 1  A5 rr                LDA     scratch
000ECEr 1  85 rr                STA     tmp2+1
000ED0r 1  20 rr rr             JSR     pm_pop          ; elem
000ED3r 1  85 rr                STA     tmp1
000ED5r 1  A5 rr                LDA     scratch
000ED7r 1  D0 34                BNE     @inset_false
000ED9r 1  A5 rr                LDA     tmp1
000EDBr 1  C9 10                CMP     #16
000EDDr 1  B0 2E                BCS     @inset_false
000EDFr 1  AA                   TAX
000EE0r 1  A9 01                LDA     #1
000EE2r 1  85 rr                STA     tmp1
000EE4r 1  A9 00                LDA     #0
000EE6r 1  85 rr                STA     tmp1+1
000EE8r 1               @inset_shift:
000EE8r 1  E0 00                CPX     #0
000EEAr 1  F0 07                BEQ     @inset_check
000EECr 1  06 rr                ASL     tmp1
000EEEr 1  26 rr                ROL     tmp1+1
000EF0r 1  CA                   DEX
000EF1r 1  80 F5                BRA     @inset_shift
000EF3r 1               @inset_check:
000EF3r 1  A5 rr                LDA     tmp1
000EF5r 1  25 rr                AND     tmp2
000EF7r 1  85 rr                STA     tmp0
000EF9r 1  A5 rr                LDA     tmp1+1
000EFBr 1  25 rr                AND     tmp2+1
000EFDr 1  05 rr                ORA     tmp0
000EFFr 1  F0 0C                BEQ     @inset_false
000F01r 1  A9 FF                LDA     #$FF
000F03r 1  85 rr                STA     scratch
000F05r 1  A9 FF                LDA     #$FF
000F07r 1  20 rr rr             JSR     pm_push
000F0Ar 1  4C rr rr             JMP     prun_loop
000F0Dr 1               @inset_false:
000F0Dr 1  A9 00                LDA     #0
000F0Fr 1  85 rr                STA     scratch
000F11r 1  20 rr rr             JSR     pm_push
000F14r 1  4C rr rr             JMP     prun_loop
000F17r 1               
000F17r 1               ; ---------------------------------------------------------------------------
000F17r 1               ; TEXT file I/O handlers
000F17r 1               ;
000F17r 1               ; A TEXT variable is a 168-byte struct in globals:
000F17r 1               ;   F_FCB   (0..35)   FCB used by PEM
000F17r 1               ;   F_BUF   (36..163) 128-byte sector buffer
000F17r 1               ;   F_MODE  (164)     0=closed, 1=read, 2=write
000F17r 1               ;   F_POS   (165)     next byte index in F_BUF (0..128)
000F17r 1               ;   F_EOF   (166)     non-zero once EOF / CTRL-Z encountered
000F17r 1               ;
000F17r 1               ; The file ptr passed on the p-machine stack is the struct base address.
000F17r 1               ; The PEM DMA pointer is set to (struct + F_BUF) before each sector I/O,
000F17r 1               ; so multiple open files don't trample each other's buffers.
000F17r 1               ; ---------------------------------------------------------------------------
000F17r 1               
000F17r 1               ; Helper: write one char (in A) to file whose struct ptr is in tmp1.
000F17r 1               ; Trashes tmp2, X, Y. Preserves tmp1, tmp3, scratch.
000F17r 1               file_write_char_helper:
