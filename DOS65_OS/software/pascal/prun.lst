0016ACr 1  20 rr rr             JSR     console_print_sz
0016AFr 1  FA                   PLX
0016B0r 1  86 rr                STX     tmp0
0016B2r 1  A9 00                LDA     #0
0016B4r 1  85 rr                STA     tmp0+1
0016B6r 1  20 rr rr             JSR     console_print_dec
0016B9r 1  A9 0D                LDA     #13
0016BBr 1  A2 02                LDX     #PEM_CONOUT
0016BDr 1  20 03 01             JSR     PEM_ENTRY
0016C0r 1  A9 0A                LDA     #10
0016C2r 1  A2 02                LDX     #PEM_CONOUT
0016C4r 1  20 03 01             JSR     PEM_ENTRY
0016C7r 1  4C 00 01             JMP     WARM_BOOT
