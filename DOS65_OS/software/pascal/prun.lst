000F58r 1  A9 00                LDA     #0
000F5Ar 1  60                   RTS
000F5Br 1               :
000F5Br 1               ; Read current char at buf[F_POS] (RESET pre-loaded sector 0; this routine
000F5Br 1               ; is responsible for the post-read peek that triggers any future refill).
000F5Br 1  18                   CLC
000F5Cr 1  A5 rr                LDA     tmp1
000F5Er 1  69 24                ADC     #F_BUF
000F60r 1  85 rr                STA     tmp2
