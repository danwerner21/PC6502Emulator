UNIT T30U;
INTERFACE
CONST
  BASE = 41;
TYPE
  TBOX = RECORD X: INTEGER END;
VAR
  G: INTEGER;
PROCEDURE BUMP;
FUNCTION TWICE(A: INTEGER): INTEGER;
IMPLEMENTATION
VAR
  B: TBOX;

PROCEDURE BUMP;
BEGIN
  G := G + 1
END;

FUNCTION TWICE(A: INTEGER): INTEGER;
BEGIN
  TWICE := A + A
END;

BEGIN
  B.X := BASE;
  G := B.X;
  BUMP;
  WRITELN(TWICE(G))
END.
