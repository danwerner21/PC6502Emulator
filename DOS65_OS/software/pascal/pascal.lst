0025C9r 2  A5 rr                LDA     tmp3
0025CBr 2  AA                   TAX
0025CCr 2  BD rr rr             LDA     field_nested_first,x
0025CFr 2  8D rr rr             STA     field_chain_first
0025D2r 2  BD rr rr             LDA     field_nested_count,x
0025D5r 2  8D rr rr             STA     field_chain_count
