0023E4r 2  C9 4C                CMP     #'L'
0023E6r 2  D0 22                BNE     @bi4_no
0023E8r 2  AD rr rr             LDA     ident_buf+4
0023EBr 2  C9 4E                CMP     #'N'
0023EDr 2  D0 1B                BNE     @bi4_no
0023EFr 2  4C rr rr             JMP     parse_builtin_eoln
