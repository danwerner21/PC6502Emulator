0023F2r 2  AD rr rr             LDA     ident_buf+2
0023F5r 2  C9 52                CMP     #'R'
0023F7r 2  D0 11                BNE     @bi4_no
0023F9r 2  AD rr rr             LDA     ident_buf+3
0023FCr 2  C9 55                CMP     #'U'
0023FEr 2  D0 0A                BNE     @bi4_no
002400r 2  AD rr rr             LDA     ident_buf+4
002403r 2  C9 45                CMP     #'E'
002405r 2  D0 03                BNE     @bi4_no
002407r 2  4C rr rr             JMP     parse_builtin_true
00240Ar 2               @bi4_no:
00240Ar 2  4C rr rr             JMP     @do_lookup
00240Dr 2               @bi_chk5:
00240Dr 2               ; 5-letter built-ins: FALSE
