002DD4r 2               
002DD4r 2               emit_FASSGN:
002DD4r 2  A9 B0                LDA     #OP_FASSGN
002DD6r 2  4C rr rr             JMP     emit_byte
002DD9r 2               emit_FRESET:
002DD9r 2  A9 B1                LDA     #OP_FRESET
002DDBr 2  4C rr rr             JMP     emit_byte
002DDEr 2               emit_FREWRT:
002DDEr 2  A9 B2                LDA     #OP_FREWRT
002DE0r 2  4C rr rr             JMP     emit_byte
002DE3r 2               emit_FCLOSE:
002DE3r 2  A9 B3                LDA     #OP_FCLOSE
002DE5r 2  4C rr rr             JMP     emit_byte
002DE8r 2               emit_FWRC:
002DE8r 2  A9 B4                LDA     #OP_FWRC
002DEAr 2  4C rr rr             JMP     emit_byte
002DEDr 2               emit_FWRS:
002DEDr 2  A9 B5                LDA     #OP_FWRS
002DEFr 2  4C rr rr             JMP     emit_byte
002DF2r 2               emit_FWRI:
002DF2r 2  A9 B6                LDA     #OP_FWRI
002DF4r 2  4C rr rr             JMP     emit_byte
002DF7r 2               emit_FWRR:
002DF7r 2  A9 C0                LDA     #OP_FWRR
002DF9r 2  4C rr rr             JMP     emit_byte
002DFCr 2               emit_FWLN:
002DFCr 2  A9 B7                LDA     #OP_FWLN
002DFEr 2  4C rr rr             JMP     emit_byte
002E01r 2               emit_FRDC:
002E01r 2  A9 B8                LDA     #OP_FRDC
002E03r 2  4C rr rr             JMP     emit_byte
002E06r 2               emit_FRDI:
002E06r 2  A9 B9                LDA     #OP_FRDI
002E08r 2  4C rr rr             JMP     emit_byte
002E0Br 2               emit_FRDR:
002E0Br 2  A9 C1                LDA     #OP_FRDR
002E0Dr 2  4C rr rr             JMP     emit_byte
002E10r 2               emit_FRDLN:
002E10r 2  A9 BA                LDA     #OP_FRDLN
002E12r 2  4C rr rr             JMP     emit_byte
002E15r 2               emit_FEOF:
002E15r 2  A9 BB                LDA     #OP_FEOF
002E17r 2  4C rr rr             JMP     emit_byte
002E1Ar 2               emit_FAPPND:
002E1Ar 2  A9 BC                LDA     #OP_FAPPND
002E1Cr 2  4C rr rr             JMP     emit_byte
002E1Fr 2               emit_FRDS:
002E1Fr 2  A9 BD                LDA     #OP_FRDS
002E21r 2  4C rr rr             JMP     emit_byte
002E24r 2               emit_FWRB:
002E24r 2  A9 BE                LDA     #OP_FWRB
002E26r 2  4C rr rr             JMP     emit_byte
002E29r 2               emit_FEOLN:
