002DCCr 2  4C rr rr             JMP     emit_byte
002DCFr 2               
002DCFr 2               emit_CONCAT:
002DCFr 2  A9 A3                LDA     #OP_CONCAT
002DD1r 2  4C rr rr             JMP     emit_byte
002DD4r 2               
