0023A3r 2               @ident_or_call:
0023A3r 2               ; First check for built-ins (LENGTH/POS/COPY/CONCAT/EOF/EOLN/TRUE/FALSE)
0023A3r 2               ; by length+initial.  These take precedence over user identifiers
0023A3r 2               ; (matching WRITE/READ handling in parse_assign_or_call).  All dispatch
0023A3r 2               ; branches use JMPs because the target blocks are scattered too far for
0023A3r 2               ; ±127 byte BEQ range.
0023A3r 2  AD rr rr             LDA     ident_buf
0023A6r 2  C9 03                CMP     #3
0023A8r 2  D0 03                BNE     @bi_dn3
0023AAr 2  4C rr rr             JMP     @bi_chk3
0023ADr 2               @bi_dn3:
0023ADr 2  C9 04                CMP     #4
0023AFr 2  D0 03                BNE     @bi_dn4
0023B1r 2  4C rr rr             JMP     @bi_chk4
0023B4r 2               @bi_dn4:
0023B4r 2  C9 05                CMP     #5
