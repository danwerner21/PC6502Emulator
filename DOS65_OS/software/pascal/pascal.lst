001E98r 2               ; parse_repeat — REPEAT stmt { ; stmt } UNTIL expr
001E98r 2               ; ---------------------------------------------------------------------------
001E98r 2               parse_repeat:
001E98r 2  20 rr rr             JSR     next_token      ; consume REPEAT
001E9Br 2               ; save top
001E9Br 2  A5 rr                LDA     cg_pc
001E9Dr 2  48                   PHA
001E9Er 2  A5 rr                LDA     cg_pc+1
001EA0r 2  48                   PHA
001EA1r 2               @loop:
001EA1r 2  A5 rr                LDA     tok_type
001EA3r 2  C9 5B                CMP     #TOK_UNTIL
001EA5r 2  F0 12                BEQ     @until
001EA7r 2  C9 00                CMP     #TOK_EOF
001EA9r 2  F0 41                BEQ     @done
001EABr 2  20 rr rr             JSR     parse_statement
001EAEr 2  A5 rr                LDA     tok_type
001EB0r 2  C9 20                CMP     #TOK_SEMICOLON
001EB2r 2  D0 ED                BNE     @loop
001EB4r 2  20 rr rr             JSR     next_token
001EB7r 2  80 E8                BRA     @loop
001EB9r 2               @until:
001EB9r 2  20 rr rr             JSR     next_token      ; consume UNTIL
001EBCr 2  20 rr rr             JSR     parse_expression
001EBFr 2               ; FJP back to top
001EBFr 2  A9 51                LDA     #OP_FJP
001EC1r 2  20 rr rr             JSR     emit_byte
001EC4r 2  68                   PLA
001EC5r 2  85 rr                STA     tmp2+1
001EC7r 2  68                   PLA
001EC8r 2  85 rr                STA     tmp2
001ECAr 2  38                   SEC
001ECBr 2  A5 rr                LDA     tmp2
001ECDr 2  E5 rr                SBC     cg_pc
001ECFr 2  85 rr                STA     scratch
001ED1r 2  A5 rr                LDA     tmp2+1
001ED3r 2  E5 rr                SBC     cg_pc+1
001ED5r 2  85 rr                STA     scratch+1
001ED7r 2  A5 rr                LDA     scratch
001ED9r 2  38                   SEC
001EDAr 2  E9 02                SBC     #2
001EDCr 2  85 rr                STA     scratch
001EDEr 2  B0 02                BCS     :+
001EE0r 2  C6 rr                DEC     scratch+1
001EE2r 2               :
