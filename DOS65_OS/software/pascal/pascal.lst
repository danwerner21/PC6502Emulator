002153r 2  20 rr rr             JSR     emit_LAND
002156r 2  A9 03                LDA     #TY_BOOL
002158r 2  85 rr                STA     expr_type
00215Ar 2  4C rr rr             JMP     @mulop
00215Dr 2               
00215Dr 2               TOK_DIV_KW      = TOK_DIV       ; alias
00215Dr 2               
00215Dr 2               ; maybe_deref_loaded_ptr — a pointer value is already on the stack.
00215Dr 2               ; If the following token is '^', consume it and load the pointed-to word.
00215Dr 2               ; v1 pointer dereference still assumes pointer-to-INTEGER.
00215Dr 2               maybe_deref_loaded_ptr:
00215Dr 2  A5 rr                LDA     expr_type
00215Fr 2  C9 07                CMP     #TY_PTR
002161r 2  D0 10                BNE     @mdlp_done
002163r 2  A5 rr                LDA     tok_type
002165r 2  C9 24                CMP     #TOK_CARET
002167r 2  D0 0A                BNE     @mdlp_done
002169r 2  20 rr rr             JSR     next_token
00216Cr 2  20 rr rr             JSR     emit_LDIND
00216Fr 2  A9 01                LDA     #TY_INT
002171r 2  85 rr                STA     expr_type
002173r 2               @mdlp_done:
002173r 2  60                   RTS
002174r 2               
002174r 2               ; parse_with_field_load — current token is the field IDENT already matched by
002174r 2               ; with_lookup_field. Emits code for the field expression and leaves expr_type
002174r 2               ; set appropriately. Record-valued results stay as addresses on the stack.
002174r 2               parse_with_field_load:
002174r 2  20 rr rr             JSR     next_token              ; consume field name
002177r 2  20 rr rr             JSR     emit_with_field_base
00217Ar 2  AD rr rr             LDA     with_lookup_type
00217Dr 2  85 rr                STA     expr_type
00217Fr 2  C9 06                CMP     #TY_RECORD
002181r 2  F0 06                BEQ     @pwfl_record
002183r 2  20 rr rr             JSR     emit_LDIND
002186r 2  4C rr rr             JMP     maybe_deref_loaded_ptr
002189r 2               @pwfl_record:
002189r 2  A5 rr                LDA     tok_type
00218Br 2  C9 22                CMP     #TOK_DOT
00218Dr 2  F0 0D                BEQ     @pwfl_chain_prep
00218Fr 2  AD rr rr             LDA     with_lookup_first
002192r 2  8D rr rr             STA     expr_record_first
002195r 2  AD rr rr             LDA     with_lookup_count
002198r 2  8D rr rr             STA     expr_record_count
00219Br 2  60                   RTS
00219Cr 2               @pwfl_chain_prep:
00219Cr 2  AD rr rr             LDA     with_lookup_first
00219Fr 2  8D rr rr             STA     fcall_vmask
0021A2r 2  AD rr rr             LDA     with_lookup_count
0021A5r 2  8D rr rr             STA     fcall_lsize
