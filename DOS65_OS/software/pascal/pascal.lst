001F69r 2  C9 0A                CMP     #TY_REAL
001F6Br 2  F0 03                BEQ     @cbtr_done
001F6Dr 2  20 rr rr             JSR     emit_promote_tos_int_to_real
001F70r 2               @cbtr_done:
001F70r 2  A9 0A                LDA     #TY_REAL
001F72r 2  60                   RTS
001F73r 2               @cbtr_lhs_int_rhs_real:
001F73r 2  20 rr rr             JSR     emit_promote_nos_int_to_real
001F76r 2  A9 0A                LDA     #TY_REAL
001F78r 2  60                   RTS
001F79r 2               
001F79r 2               ; coerce_binary_to_int — A=lhs type, expr_type=rhs type.
001F79r 2               ; Truncates REAL operands to INTEGER and returns A=TY_INT.
001F79r 2               coerce_binary_to_int:
001F79r 2  C9 0A                CMP     #TY_REAL
001F7Br 2  F0 09                BEQ     @cbti_lhs_real
001F7Dr 2  A5 rr                LDA     expr_type
001F7Fr 2  C9 0A                CMP     #TY_REAL
001F81r 2  F0 12                BEQ     @cbti_rhs_real
001F83r 2  A9 01                LDA     #TY_INT
001F85r 2  60                   RTS
001F86r 2               @cbti_lhs_real:
001F86r 2  20 rr rr             JSR     emit_promote_nos_real_to_int
001F89r 2  A5 rr                LDA     expr_type
001F8Br 2  C9 0A                CMP     #TY_REAL
001F8Dr 2  D0 03                BNE     @cbti_done
001F8Fr 2  20 rr rr             JSR     emit_promote_tos_real_to_int
001F92r 2               @cbti_done:
001F92r 2  A9 01                LDA     #TY_INT
001F94r 2  60                   RTS
001F95r 2               @cbti_rhs_real:
