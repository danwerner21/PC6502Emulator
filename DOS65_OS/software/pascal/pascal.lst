002DC0r 2               
002DC0r 2               emit_LEN:
002DC0r 2  A9 A0                LDA     #OP_LEN
002DC2r 2  4C rr rr             JMP     emit_byte
002DC5r 2               
002DC5r 2               emit_POS:
002DC5r 2  A9 A1                LDA     #OP_POS
002DC7r 2  4C rr rr             JMP     emit_byte
002DCAr 2               
