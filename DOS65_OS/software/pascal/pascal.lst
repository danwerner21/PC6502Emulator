0023CFr 2               :
0023CFr 2  C9 45                CMP     #'E'
0023D1r 2  F0 07                BEQ     @bi_try_eoln
0023D3r 2  C9 54                CMP     #'T'
0023D5r 2  F0 1B                BEQ     @bi_try_true
0023D7r 2  4C rr rr             JMP     @do_lookup
0023DAr 2               @bi_try_eoln:
