002740r 2               ; ---------------------------------------------------------------------------
002740r 2               ; String built-in helpers — entered from parse_factor's @ident_or_call.
002740r 2               ; The identifier is still the current token on entry.
002740r 2               ; ---------------------------------------------------------------------------
002740r 2               
002740r 2               ; Skip current token if it matches A; otherwise just fall through.
002740r 2               ; Used to consume optional punctuation like '(' / ')' / ',' without aborting
002740r 2               ; on a missing token (compile_error elsewhere will catch malformed code).
002740r 2               parse_eat_token:
002740r 2  C5 rr                CMP     tok_type
002742r 2  D0 03                BNE     :+
002744r 2  4C rr rr             JMP     next_token
002747r 2  60           :       RTS
002748r 2               
002748r 2               parse_builtin_length:
002748r 2  20 rr rr             JSR     next_token              ; consume LENGTH
00274Br 2  A9 1B                LDA     #TOK_LPAREN
00274Dr 2  20 rr rr             JSR     parse_eat_token
002750r 2  20 rr rr             JSR     parse_expression        ; pushes string ptr
002753r 2  A9 1C                LDA     #TOK_RPAREN
002755r 2  20 rr rr             JSR     parse_eat_token
002758r 2  20 rr rr             JSR     emit_LEN
00275Br 2  A9 01                LDA     #TY_INT
00275Dr 2  85 rr                STA     expr_type
00275Fr 2  60                   RTS
002760r 2               
002760r 2               parse_builtin_pos:
002760r 2  20 rr rr             JSR     next_token              ; consume POS
002763r 2  A9 1B                LDA     #TOK_LPAREN
002765r 2  20 rr rr             JSR     parse_eat_token
002768r 2  20 rr rr             JSR     parse_expression        ; substr
00276Br 2  A9 1F                LDA     #TOK_COMMA
00276Dr 2  20 rr rr             JSR     parse_eat_token
002770r 2  20 rr rr             JSR     parse_expression        ; mainstr
002773r 2  A9 1C                LDA     #TOK_RPAREN
002775r 2  20 rr rr             JSR     parse_eat_token
002778r 2  20 rr rr             JSR     emit_POS
00277Br 2  A9 01                LDA     #TY_INT
00277Dr 2  85 rr                STA     expr_type
00277Fr 2  60                   RTS
002780r 2               
002780r 2               parse_builtin_copy:
002780r 2  20 rr rr             JSR     next_token              ; consume COPY
002783r 2  A9 1B                LDA     #TOK_LPAREN
002785r 2  20 rr rr             JSR     parse_eat_token
002788r 2  20 rr rr             JSR     parse_expression        ; src string
00278Br 2  A9 1F                LDA     #TOK_COMMA
00278Dr 2  20 rr rr             JSR     parse_eat_token
002790r 2  20 rr rr             JSR     parse_expression        ; index
002793r 2  A9 1F                LDA     #TOK_COMMA
002795r 2  20 rr rr             JSR     parse_eat_token
002798r 2  20 rr rr             JSR     parse_expression        ; count
00279Br 2  A9 1C                LDA     #TOK_RPAREN
00279Dr 2  20 rr rr             JSR     parse_eat_token
0027A0r 2  20 rr rr             JSR     emit_COPY
0027A3r 2  A9 04                LDA     #TY_STRING
0027A5r 2  85 rr                STA     expr_type
0027A7r 2  60                   RTS
0027A8r 2               
0027A8r 2               ; CONCAT(s1, s2 [, s3, ...]) — emit chained CONCAT2.  Each pair-merge writes
0027A8r 2               ; into the next round-robin work buffer, so 3+ args work as long as the
0027A8r 2               ; intermediate buffer isn't recycled before being consumed.
0027A8r 2               parse_builtin_concat:
0027A8r 2  20 rr rr             JSR     next_token              ; consume CONCAT
0027ABr 2  A9 1B                LDA     #TOK_LPAREN
0027ADr 2  20 rr rr             JSR     parse_eat_token
0027B0r 2  20 rr rr             JSR     parse_expression        ; first arg on stack
0027B3r 2  A5 rr                LDA     tok_type
0027B5r 2  C9 1F                CMP     #TOK_COMMA
0027B7r 2  F0 0A                BEQ     @cat_more
0027B9r 2               ; Single-arg CONCAT — just leave the string on the stack (rare/edge case).
0027B9r 2  A9 1C                LDA     #TOK_RPAREN
0027BBr 2  20 rr rr             JSR     parse_eat_token
0027BEr 2  A9 04                LDA     #TY_STRING
0027C0r 2  85 rr                STA     expr_type
0027C2r 2  60                   RTS
0027C3r 2               @cat_more:
0027C3r 2  20 rr rr             JSR     next_token              ; consume ','
0027C6r 2  20 rr rr             JSR     parse_expression        ; next arg
0027C9r 2  20 rr rr             JSR     emit_CONCAT             ; merge previous + next
0027CCr 2  A5 rr                LDA     tok_type
0027CEr 2  C9 1F                CMP     #TOK_COMMA
0027D0r 2  F0 F1                BEQ     @cat_more
0027D2r 2  A9 1C                LDA     #TOK_RPAREN
0027D4r 2  20 rr rr             JSR     parse_eat_token
0027D7r 2  A9 04                LDA     #TY_STRING
0027D9r 2  85 rr                STA     expr_type
0027DBr 2  60                   RTS
0027DCr 2               
0027DCr 2               ; ---------------------------------------------------------------------------
0027DCr 2               ; File built-in helpers — entered from parse_assign_or_call (statement form)
0027DCr 2               ; or parse_factor's @ident_or_call (EOF as expression).
0027DCr 2               ; ---------------------------------------------------------------------------
0027DCr 2               
0027DCr 2               ; ASSIGN(filevar, namestring)
0027DCr 2               parse_builtin_assign:
0027DCr 2  20 rr rr             JSR     next_token              ; consume ASSIGN
0027DFr 2  A9 1B                LDA     #TOK_LPAREN
0027E1r 2  20 rr rr             JSR     parse_eat_token
0027E4r 2  20 rr rr             JSR     parse_expression        ; file ptr (TY_TEXT)
0027E7r 2  A9 1F                LDA     #TOK_COMMA
0027E9r 2  20 rr rr             JSR     parse_eat_token
0027ECr 2  20 rr rr             JSR     parse_expression        ; filename string
0027EFr 2  A9 1C                LDA     #TOK_RPAREN
0027F1r 2  20 rr rr             JSR     parse_eat_token
0027F4r 2  4C rr rr             JMP     emit_FASSGN
0027F7r 2               
0027F7r 2               parse_builtin_reset:
0027F7r 2  20 rr rr             JSR     next_token              ; consume RESET
0027FAr 2  A9 1B                LDA     #TOK_LPAREN
0027FCr 2  20 rr rr             JSR     parse_eat_token
0027FFr 2  20 rr rr             JSR     parse_expression
002802r 2  A9 1C                LDA     #TOK_RPAREN
002804r 2  20 rr rr             JSR     parse_eat_token
002807r 2  4C rr rr             JMP     emit_FRESET
00280Ar 2               
00280Ar 2               parse_builtin_rewrite:
00280Ar 2  20 rr rr             JSR     next_token              ; consume REWRITE
00280Dr 2  A9 1B                LDA     #TOK_LPAREN
00280Fr 2  20 rr rr             JSR     parse_eat_token
002812r 2  20 rr rr             JSR     parse_expression
002815r 2  A9 1C                LDA     #TOK_RPAREN
002817r 2  20 rr rr             JSR     parse_eat_token
00281Ar 2  4C rr rr             JMP     emit_FREWRT
00281Dr 2               
00281Dr 2               parse_builtin_append:
00281Dr 2  20 rr rr             JSR     next_token              ; consume APPEND
002820r 2  A9 1B                LDA     #TOK_LPAREN
002822r 2  20 rr rr             JSR     parse_eat_token
002825r 2  20 rr rr             JSR     parse_expression
002828r 2  A9 1C                LDA     #TOK_RPAREN
00282Ar 2  20 rr rr             JSR     parse_eat_token
00282Dr 2  4C rr rr             JMP     emit_FAPPND
002830r 2               
002830r 2               parse_builtin_close:
002830r 2  20 rr rr             JSR     next_token              ; consume CLOSE
002833r 2  A9 1B                LDA     #TOK_LPAREN
002835r 2  20 rr rr             JSR     parse_eat_token
002838r 2  20 rr rr             JSR     parse_expression
00283Br 2  A9 1C                LDA     #TOK_RPAREN
00283Dr 2  20 rr rr             JSR     parse_eat_token
002840r 2  4C rr rr             JMP     emit_FCLOSE
002843r 2               
002843r 2               parse_builtin_eof:
002843r 2  20 rr rr             JSR     next_token              ; consume EOF
002846r 2  A9 1B                LDA     #TOK_LPAREN
002848r 2  20 rr rr             JSR     parse_eat_token
00284Br 2  20 rr rr             JSR     parse_expression        ; file ptr (TY_TEXT)
00284Er 2  A9 1C                LDA     #TOK_RPAREN
002850r 2  20 rr rr             JSR     parse_eat_token
002853r 2  20 rr rr             JSR     emit_FEOF
002856r 2  A9 03                LDA     #TY_BOOL
002858r 2  85 rr                STA     expr_type
00285Ar 2  60                   RTS
00285Br 2               
00285Br 2               parse_builtin_eoln:
00285Br 2  20 rr rr             JSR     next_token              ; consume EOLN
00285Er 2  A9 1B                LDA     #TOK_LPAREN
002860r 2  20 rr rr             JSR     parse_eat_token
002863r 2  20 rr rr             JSR     parse_expression        ; file ptr (TY_TEXT)
002866r 2  A9 1C                LDA     #TOK_RPAREN
002868r 2  20 rr rr             JSR     parse_eat_token
00286Br 2  20 rr rr             JSR     emit_FEOLN
00286Er 2  A9 03                LDA     #TY_BOOL
002870r 2  85 rr                STA     expr_type
002872r 2  60                   RTS
002873r 2               
002873r 2               ; NEW(p) — bump-allocate 2 bytes (pointer-to-INTEGER, v1) and store the
002873r 2               ; new heap address into pointer variable p.
002873r 2               ;   parse_arg_lvalue pushes &p; emit_NEW pushes the fresh pointer; STIND
002873r 2               ;   takes (NOS=addr, TOS=val) and writes val to addr.
002873r 2               parse_builtin_new:
002873r 2  20 rr rr             JSR     next_token              ; consume NEW
002876r 2  A9 1B                LDA     #TOK_LPAREN
002878r 2  20 rr rr             JSR     parse_eat_token
00287Br 2  20 rr rr             JSR     parse_arg_lvalue        ; push &p
00287Er 2  A9 1C                LDA     #TOK_RPAREN
002880r 2  20 rr rr             JSR     parse_eat_token
002883r 2  A9 00                LDA     #0
002885r 2  85 rr                STA     scratch                 ; size hi = 0
002887r 2  A9 02                LDA     #2                      ; v1: always allocate 2 bytes
002889r 2  20 rr rr             JSR     emit_NEW
00288Cr 2  4C rr rr             JMP     emit_STIND
00288Fr 2               
00288Fr 2               ; DISPOSE(p) — bump allocator can't free, so just discard the pointer.
00288Fr 2               parse_builtin_dispose:
00288Fr 2  20 rr rr             JSR     next_token              ; consume DISPOSE
002892r 2  A9 1B                LDA     #TOK_LPAREN
002894r 2  20 rr rr             JSR     parse_eat_token
002897r 2  20 rr rr             JSR     parse_expression        ; push p (value)
00289Ar 2  A9 1C                LDA     #TOK_RPAREN
00289Cr 2  20 rr rr             JSR     parse_eat_token
00289Fr 2  4C rr rr             JMP     emit_DISP
0028A2r 2               
0028A2r 2               ; TRUE / FALSE — predefined boolean constants.  Push 1/0 as TY_BOOL so
0028A2r 2               ; pw_emit_file routes to FWRB ("TRUE"/"FALSE") and pw_emit_console to WRITB.
0028A2r 2               parse_builtin_true:
0028A2r 2  20 rr rr             JSR     next_token              ; consume TRUE
0028A5r 2  A9 01                LDA     #1
0028A7r 2  20 rr rr             JSR     emit_LDCB
0028AAr 2  A9 03                LDA     #TY_BOOL
0028ACr 2  85 rr                STA     expr_type
0028AEr 2  60                   RTS
0028AFr 2               
0028AFr 2               parse_builtin_false:
0028AFr 2  20 rr rr             JSR     next_token              ; consume FALSE
0028B2r 2  A9 00                LDA     #0
0028B4r 2  20 rr rr             JSR     emit_LDCB
0028B7r 2  A9 03                LDA     #TY_BOOL
0028B9r 2  85 rr                STA     expr_type
0028BBr 2  60                   RTS
0028BCr 2               
0028BCr 1                       .include        "SYMTAB.ASM"
0028BCr 2               .PC02
0028BCr 2               ; symtab.asm — symbol table for Pascal/65 compiler
0028BCr 2               ;
0028BCr 2               ; Each entry occupies 16 bytes in the SYMTAB_BASE area:
0028BCr 2               ;   [0]    name length (1-15)
0028BCr 2               ;   [1-15] name chars (uppercase, padded with spaces)
0028BCr 2               ;   [16]   symbol kind: SYM_VAR, SYM_CONST, SYM_PROC, SYM_FUNC, SYM_TYPE, SYM_PARAM
0028BCr 2               ;   [17]   data type:   TY_INT, TY_CHAR, TY_BOOL, TY_STRING, TY_ARRAY, TY_RECORD, TY_PTR, TY_TEXT, TY_SET, TY_REAL
0028BCr 2               ;   [18-19] value/offset (word): variable offset from BASE/MP; const value; proc address
0028BCr 2               ;   [20]   scope depth (0=global)
0028BCr 2               ;   [21]   parameter count (for SYM_PROC/SYM_FUNC)
0028BCr 2               ;   [22-23] type info pointer (for array/record types)
0028BCr 2               ;   [24-31] formal parameter types 0..7 (for SYM_PROC/SYM_FUNC)
0028BCr 2               
0028BCr 2               SYM_ENTRY_SZ    = 32
0028BCr 2               
0028BCr 2               ; Symbol kinds
0028BCr 2               SYM_VAR         = 1
0028BCr 2               SYM_CONST       = 2
0028BCr 2               SYM_PROC        = 3
0028BCr 2               SYM_FUNC        = 4
0028BCr 2               SYM_TYPE        = 5
0028BCr 2               SYM_PARAM       = 6
0028BCr 2               SYM_RETVAL      = 7             ; binding for `funcname := expr` in fn body
0028BCr 2               SYM_VARREF      = 8             ; VAR (by-reference) parameter — local slot holds an address
0028BCr 2               
0028BCr 2               ; Data type codes
0028BCr 2               TY_INT          = 1
0028BCr 2               TY_CHAR         = 2
0028BCr 2               TY_BOOL         = 3
0028BCr 2               TY_STRING       = 4
0028BCr 2               TY_ARRAY        = 5
0028BCr 2               TY_RECORD       = 6
0028BCr 2               TY_PTR          = 7
0028BCr 2               TY_TEXT         = 8             ; TEXT file variable (168-byte struct)
0028BCr 2               TY_SET          = 9             ; 16-bit set mask over element values 0..15
0028BCr 2               TY_REAL         = 10            ; signed fixed-point REAL (scale 100, 2 decimal places)
0028BCr 2               TY_NONE         = 0             ; for procedures
0028BCr 2               
0028BCr 2                       .segment        "CODE"
0028BCr 2               
0028BCr 2               ; Number of entries currently in symbol table
0028BCr 2               symtab_count:
0028BCr 2  00 00                .WORD   0
0028BEr 2               
0028BEr 2               ; ---------------------------------------------------------------------------
0028BEr 2               ; symtab_init — clear symbol table
0028BEr 2               ; ---------------------------------------------------------------------------
0028BEr 2               symtab_init:
0028BEr 2  A9 00                LDA     #0
0028C0r 2  8D rr rr             STA     symtab_count
0028C3r 2  8D rr rr             STA     symtab_count+1
0028C6r 2  8D rr rr             STA     field_table_count
0028C9r 2  8D rr rr             STA     field_depth
0028CCr 2  8D rr rr             STA     ptr_meta_count
0028CFr 2  60                   RTS
0028D0r 2               
0028D0r 2               ; ---------------------------------------------------------------------------
0028D0r 2               ; field_table_add — append a record-field entry
0028D0r 2               ; Inputs:
0028D0r 2               ;   ident_buf = field name (length at [0], chars at [1..])
0028D0r 2               ;   A         = byte offset within the record
0028D0r 2               ;   X         = field data type (TY_*)
0028D0r 2               ; Returns: A = newly-assigned field index (current count - 1)
0028D0r 2               ;          carry set if field table is full (entry not added)
0028D0r 2               ; Clobbers: tmp2, tmp3, Y
0028D0r 2               ; ---------------------------------------------------------------------------
0028D0r 2               field_table_add:
0028D0r 2  48                   PHA                     ; save offset
0028D1r 2  8A                   TXA
0028D2r 2  48                   PHA                     ; save type
0028D3r 2               ; capacity check (max 32 entries)
0028D3r 2  AD rr rr             LDA     field_table_count
0028D6r 2  C9 20                CMP     #32
0028D8r 2  90 04                BCC     :+
0028DAr 2  68                   PLA                     ; discard type
0028DBr 2  68                   PLA                     ; discard offset
0028DCr 2  38                   SEC
0028DDr 2  60                   RTS
0028DEr 2               :
0028DEr 2               ; compute entry address: field_table + count*16
0028DEr 2  AD rr rr             LDA     field_table_count
0028E1r 2  0A                   ASL
0028E2r 2  0A                   ASL
0028E3r 2  0A                   ASL
0028E4r 2  0A                   ASL                     ; *16 (count<64 fits in 10 bits, but we land in low byte; high carry becomes part of address)
0028E5r 2  85 rr                STA     tmp2
0028E7r 2  A9 00                LDA     #0
0028E9r 2  2A                   ROL                     ; capture carry into hi
0028EAr 2  18                   CLC
0028EBr 2  69 rr                ADC     #>field_table
0028EDr 2  85 rr                STA     tmp2+1
0028EFr 2  A5 rr                LDA     tmp2
0028F1r 2  18                   CLC
0028F2r 2  69 rr                ADC     #<field_table
0028F4r 2  85 rr                STA     tmp2
0028F6r 2  90 02                BCC     :+
0028F8r 2  E6 rr                INC     tmp2+1
0028FAr 2               :
0028FAr 2               ; copy name length + chars
0028FAr 2  A0 00                LDY     #0
0028FCr 2  AD rr rr             LDA     ident_buf
0028FFr 2  91 rr                STA     (tmp2),y
002901r 2  AA                   TAX                     ; X = length
002902r 2  A0 01                LDY     #1
002904r 2               @nm:
002904r 2  C0 0D                CPY     #13
002906r 2  B0 0D                BCS     @padn
002908r 2  E0 00                CPX     #0
00290Ar 2  F0 09                BEQ     @padn
00290Cr 2  B9 rr rr             LDA     ident_buf,y
00290Fr 2  91 rr                STA     (tmp2),y
002911r 2  CA                   DEX
002912r 2  C8                   INY
002913r 2  80 EF                BRA     @nm
002915r 2               @padn:
002915r 2  C0 0D                CPY     #13
002917r 2  B0 07                BCS     @done_nm
002919r 2  A9 20                LDA     #' '
00291Br 2  91 rr                STA     (tmp2),y
00291Dr 2  C8                   INY
00291Er 2  80 F5                BRA     @padn
002920r 2               @done_nm:
002920r 2               ; offset (was on stack first → second pull)
002920r 2               ; type   (was on stack last  → first pull)
002920r 2  68                   PLA                     ; type
002921r 2  A0 0E                LDY     #14
002923r 2  91 rr                STA     (tmp2),y
002925r 2  68                   PLA                     ; offset
002926r 2  A0 0D                LDY     #13
002928r 2  91 rr                STA     (tmp2),y
00292Ar 2  AD rr rr             LDA     field_depth     ; nesting depth so scans can skip
00292Dr 2  A0 0F                LDY     #15             ; fields owned by deeper inline records
00292Fr 2  91 rr                STA     (tmp2),y
002931r 2               ; bump count, return new index
002931r 2  AD rr rr             LDA     field_table_count
002934r 2  EE rr rr             INC     field_table_count
002937r 2  18                   CLC
002938r 2  60                   RTS
002939r 2               
002939r 2               ; ---------------------------------------------------------------------------
002939r 2               ; field_lookup_in_record — find ident_buf among a contiguous range of fields
002939r 2               ; Inputs:
002939r 2               ;   ident_buf = field name to find
002939r 2               ;   A         = first field index in field_table
002939r 2               ;   X         = number of fields to scan
002939r 2               ; Returns: carry set = found
002939r 2               ;            A = byte offset within record
002939r 2               ;            X = field data type
002939r 2               ;          carry clear = not found
002939r 2               ; Clobbers: tmp2, tmp3, Y
002939r 2               ; ---------------------------------------------------------------------------
002939r 2               field_lookup_in_record:
002939r 2  85 rr                STA     tmp3            ; tmp3 = current field index
00293Br 2  86 rr                STX     tmp3+1          ; tmp3+1 = remaining count
00293Dr 2               ; Read the depth of field[tmp3] — the scan's "target depth". Slots
00293Dr 2               ; deeper than this belong to inline sub-records and are skipped so
00293Dr 2               ; the scan stays at the record's own nesting level.
00293Dr 2  A5 rr                LDA     tmp3
00293Fr 2  0A                   ASL
002940r 2  0A                   ASL
002941r 2  0A                   ASL
002942r 2  0A                   ASL
002943r 2  85 rr                STA     tmp2
002945r 2  A9 00                LDA     #0
002947r 2  2A                   ROL
002948r 2  18                   CLC
002949r 2  69 rr                ADC     #>field_table
00294Br 2  85 rr                STA     tmp2+1
00294Dr 2  A5 rr                LDA     tmp2
00294Fr 2  18                   CLC
002950r 2  69 rr                ADC     #<field_table
002952r 2  85 rr                STA     tmp2
002954r 2  90 02                BCC     :+
002956r 2  E6 rr                INC     tmp2+1
002958r 2               :
002958r 2  A0 0F                LDY     #15
00295Ar 2  B1 rr                LDA     (tmp2),y
00295Cr 2  8D rr rr             STA     field_lookup_depth
00295Fr 2               @scan:
00295Fr 2  A5 rr                LDA     tmp3+1
002961r 2  F0 4C                BEQ     @nf
002963r 2               ; compute entry addr: field_table + tmp3*16
002963r 2  A5 rr                LDA     tmp3
002965r 2  0A                   ASL
002966r 2  0A                   ASL
002967r 2  0A                   ASL
002968r 2  0A                   ASL                     ; *16 (low byte; carry → hi)
002969r 2  85 rr                STA     tmp2
00296Br 2  A9 00                LDA     #0
00296Dr 2  2A                   ROL
00296Er 2  18                   CLC
00296Fr 2  69 rr                ADC     #>field_table
002971r 2  85 rr                STA     tmp2+1
002973r 2  A5 rr                LDA     tmp2
002975r 2  18                   CLC
002976r 2  69 rr                ADC     #<field_table
002978r 2  85 rr                STA     tmp2
00297Ar 2  90 02                BCC     :+
00297Cr 2  E6 rr                INC     tmp2+1
00297Er 2               :
00297Er 2               ; skip slots whose depth differs from the scan's target depth
00297Er 2  A0 0F                LDY     #15
002980r 2  B1 rr                LDA     (tmp2),y
002982r 2  CD rr rr             CMP     field_lookup_depth
002985r 2  D0 22                BNE     @next
002987r 2               ; compare name length
002987r 2  A0 00                LDY     #0
002989r 2  B1 rr                LDA     (tmp2),y
00298Br 2  CD rr rr             CMP     ident_buf
00298Er 2  D0 19                BNE     @next
002990r 2  AA                   TAX                     ; X = length
002991r 2  A0 01                LDY     #1
002993r 2               @cmpn:
002993r 2  B1 rr                LDA     (tmp2),y
002995r 2  D9 rr rr             CMP     ident_buf,y
002998r 2  D0 0F                BNE     @next
00299Ar 2  C8                   INY
00299Br 2  CA                   DEX
00299Cr 2  D0 F5                BNE     @cmpn
00299Er 2               ; match — return offset and type
00299Er 2  A0 0E                LDY     #14
0029A0r 2  B1 rr                LDA     (tmp2),y        ; type
0029A2r 2  AA                   TAX
0029A3r 2  A0 0D                LDY     #13
0029A5r 2  B1 rr                LDA     (tmp2),y        ; offset
0029A7r 2  38                   SEC
0029A8r 2  60                   RTS
0029A9r 2               @next:
0029A9r 2  E6 rr                INC     tmp3
0029ABr 2  C6 rr                DEC     tmp3+1
0029ADr 2  80 B0                BRA     @scan
0029AFr 2               @nf:
0029AFr 2  18                   CLC
0029B0r 2  60                   RTS
0029B1r 2               
0029B1r 2               ; ---------------------------------------------------------------------------
0029B1r 2               ; symtab_find — look up ident_buf in symbol table
0029B1r 2               ; Returns: carry set = found (tmp3 = pointer to entry)
0029B1r 2               ;          carry clear = not found
0029B1r 2               ; Searches from newest (highest index) to oldest for proper scoping
0029B1r 2               ; ---------------------------------------------------------------------------
0029B1r 2               symtab_find:
0029B1r 2  AD rr rr             LDA     symtab_count
0029B4r 2  0D rr rr             ORA     symtab_count+1
0029B7r 2  D0 02                BNE     :+
0029B9r 2  18                   CLC
0029BAr 2  60                   RTS                     ; empty table
0029BBr 2               :
0029BBr 2               ; start from last entry
0029BBr 2  AD rr rr             LDA     symtab_count
0029BEr 2  85 rr                STA     tmp2
0029C0r 2  AD rr rr             LDA     symtab_count+1
0029C3r 2  85 rr                STA     tmp2+1
0029C5r 2               @loop:
0029C5r 2  A5 rr                LDA     tmp2
0029C7r 2  05 rr                ORA     tmp2+1
0029C9r 2  F0 34                BEQ     @not_found
0029CBr 2               ; decrement tmp2
0029CBr 2  A5 rr                LDA     tmp2
0029CDr 2  D0 02                BNE     :+
0029CFr 2  C6 rr                DEC     tmp2+1
0029D1r 2               :
0029D1r 2  C6 rr                DEC     tmp2
0029D3r 2               ; compute entry address: SYMTAB_BASE + tmp2 * SYM_ENTRY_SZ
0029D3r 2               ; tmp2 * 32 = tmp2 << 5
0029D3r 2  A5 rr                LDA     tmp2
0029D5r 2  0A                   ASL
0029D6r 2  0A                   ASL
0029D7r 2  0A                   ASL
0029D8r 2  0A                   ASL
0029D9r 2  0A                   ASL                     ; *32
0029DAr 2  18                   CLC
0029DBr 2  69 00                ADC     #<SYMTAB_BASE
0029DDr 2  85 rr                STA     tmp3
0029DFr 2  A5 rr                LDA     tmp2+1
0029E1r 2  2A                   ROL
0029E2r 2  69 80                ADC     #>SYMTAB_BASE
0029E4r 2  85 rr                STA     tmp3+1
0029E6r 2               ; compare name length
0029E6r 2  A0 00                LDY     #0
0029E8r 2  B1 rr                LDA     (tmp3),y
0029EAr 2  CD rr rr             CMP     ident_buf
0029EDr 2  D0 D6                BNE     @loop
0029EFr 2               ; compare name chars
0029EFr 2  AA                   TAX                     ; X = length
0029F0r 2  A0 00                LDY     #0
0029F2r 2               @cmp:
0029F2r 2  C8                   INY
0029F3r 2  B1 rr                LDA     (tmp3),y
0029F5r 2  D9 rr rr             CMP     ident_buf,y
0029F8r 2  D0 CB                BNE     @loop
0029FAr 2  CA                   DEX
0029FBr 2  D0 F5                BNE     @cmp
0029FDr 2  38                   SEC
0029FEr 2  60                   RTS
0029FFr 2               @not_found:
0029FFr 2  18                   CLC
002A00r 2  60                   RTS
002A01r 2               
002A01r 2               ; ---------------------------------------------------------------------------
002A01r 2               ; symtab_add — add entry to symbol table
002A01r 2               ; Inputs:
002A01r 2               ;   ident_buf = name
002A01r 2               ;   A = kind (SYM_*)
002A01r 2               ;   X = data type (TY_*)
002A01r 2               ;   tmp2 = value/offset word (lo in tmp2, hi in tmp2+1)
002A01r 2               ; Returns: tmp3 = pointer to new entry; carry set = table full
002A01r 2               ; ---------------------------------------------------------------------------
002A01r 2               symtab_add:
002A01r 2  48                   PHA                     ; save kind (A) — the rest of this routine clobbers A
002A02r 2  8A                   TXA
002A03r 2  48                   PHA                     ; save data type (X)
002A04r 2               ; check capacity
002A04r 2  AD rr rr             LDA     symtab_count+1
002A07r 2  C9 00                CMP     #(SYMTAB_MAXSZ / SYM_ENTRY_SZ) >> 8
002A09r 2  90 0B                BCC     :+
002A0Br 2  AD rr rr             LDA     symtab_count
002A0Er 2  C9 C0                CMP     #(SYMTAB_MAXSZ / SYM_ENTRY_SZ) & $FF
002A10r 2  90 04                BCC     :+
002A12r 2  68                   PLA                     ; discard saved type
002A13r 2  68                   PLA                     ; discard saved kind
002A14r 2  38                   SEC
002A15r 2  60                   RTS                     ; table full
002A16r 2               
002A16r 2               :       ; compute address of new entry
002A16r 2  AD rr rr             LDA     symtab_count
002A19r 2  0A                   ASL
002A1Ar 2  0A                   ASL
002A1Br 2  0A                   ASL
002A1Cr 2  0A                   ASL
002A1Dr 2  0A                   ASL                     ; *32
002A1Er 2  18                   CLC
002A1Fr 2  69 00                ADC     #<SYMTAB_BASE
002A21r 2  85 rr                STA     tmp3
002A23r 2  AD rr rr             LDA     symtab_count+1
002A26r 2  2A                   ROL
002A27r 2  69 80                ADC     #>SYMTAB_BASE
002A29r 2  85 rr                STA     tmp3+1
002A2Br 2               
002A2Br 2               ; copy name
002A2Br 2  A0 00                LDY     #0
002A2Dr 2  AD rr rr             LDA     ident_buf       ; length
002A30r 2  91 rr                STA     (tmp3),y
002A32r 2  AA                   TAX
002A33r 2               @name_copy:
002A33r 2  C8                   INY
002A34r 2  B9 rr rr             LDA     ident_buf,y
002A37r 2  91 rr                STA     (tmp3),y
002A39r 2  CA                   DEX
002A3Ar 2  D0 F7                BNE     @name_copy
002A3Cr 2               
002A3Cr 2               ; fill unused name bytes with space
002A3Cr 2  C8                   INY
002A3Dr 2               @pad:
002A3Dr 2  C0 10                CPY     #16
002A3Fr 2  B0 07                BCS     @done_pad
002A41r 2  A9 20                LDA     #' '
002A43r 2  91 rr                STA     (tmp3),y
002A45r 2  C8                   INY
002A46r 2  80 F5                BRA     @pad
002A48r 2               @done_pad:
002A48r 2               
002A48r 2               ; data type (was saved on stack first)
002A48r 2  68                   PLA
002A49r 2  A0 11                LDY     #17
002A4Br 2  91 rr                STA     (tmp3),y
002A4Dr 2               
002A4Dr 2               ; kind (was saved on stack second-to-last → on top first)
002A4Dr 2  68                   PLA
002A4Er 2  A0 10                LDY     #16
002A50r 2  91 rr                STA     (tmp3),y
002A52r 2               
002A52r 2               ; value/offset
002A52r 2  A5 rr                LDA     tmp2
002A54r 2  A0 12                LDY     #18
002A56r 2  91 rr                STA     (tmp3),y
002A58r 2  A5 rr                LDA     tmp2+1
002A5Ar 2  A0 13                LDY     #19
002A5Cr 2  91 rr                STA     (tmp3),y
002A5Er 2               
002A5Er 2               ; scope depth
002A5Er 2  A5 rr                LDA     scope_depth
002A60r 2  A0 14                LDY     #20
002A62r 2  91 rr                STA     (tmp3),y
002A64r 2               
002A64r 2               ; zero rest
002A64r 2  A9 00                LDA     #0
002A66r 2  A0 15                LDY     #21
002A68r 2               @zero:
002A68r 2  91 rr                STA     (tmp3),y
002A6Ar 2  C8                   INY
002A6Br 2  C0 20                CPY     #SYM_ENTRY_SZ
002A6Dr 2  90 F9                BCC     @zero
002A6Fr 2               
002A6Fr 2               ; increment count
002A6Fr 2  EE rr rr             INC     symtab_count
002A72r 2  D0 03                BNE     :+
002A74r 2  EE rr rr             INC     symtab_count+1
002A77r 2               :
002A77r 2  18                   CLC
002A78r 2  60                   RTS
002A79r 2               
002A79r 2               ; ---------------------------------------------------------------------------
002A79r 2               ; symtab_enter_scope — increment scope depth
002A79r 2               ; ---------------------------------------------------------------------------
002A79r 2               symtab_enter_scope:
002A79r 2  E6 rr                INC     scope_depth
002A7Br 2  60                   RTS
002A7Cr 2               
002A7Cr 2               ; ---------------------------------------------------------------------------
002A7Cr 2               ; symtab_leave_scope — remove all entries at current scope, decrement depth
002A7Cr 2               ; ---------------------------------------------------------------------------
002A7Cr 2               symtab_leave_scope:
002A7Cr 2               ; Remove all entries added at current scope depth, then decrement depth.
002A7Cr 2               ; Entries are appended in order, so trim from the end.
002A7Cr 2               @trim:
002A7Cr 2  AD rr rr             LDA     symtab_count
002A7Fr 2  0D rr rr             ORA     symtab_count+1
002A82r 2  F0 34                BEQ     @done           ; table empty
002A84r 2               ; compute address of last entry: SYMTAB_BASE + (count-1)*32
002A84r 2  AD rr rr             LDA     symtab_count
002A87r 2  38                   SEC
002A88r 2  E9 01                SBC     #1
002A8Ar 2  85 rr                STA     tmp2
002A8Cr 2  AD rr rr             LDA     symtab_count+1
002A8Fr 2  E9 00                SBC     #0
002A91r 2  85 rr                STA     tmp2+1
002A93r 2               ; tmp2 * 32 (shift left 5) → entry address
002A93r 2  A5 rr                LDA     tmp2
002A95r 2  0A                   ASL
002A96r 2  0A                   ASL
002A97r 2  0A                   ASL
002A98r 2  0A                   ASL
002A99r 2  0A                   ASL
002A9Ar 2  18                   CLC
002A9Br 2  69 00                ADC     #<SYMTAB_BASE
002A9Dr 2  85 rr                STA     tmp3
002A9Fr 2  A5 rr                LDA     tmp2+1
002AA1r 2  2A                   ROL
002AA2r 2  69 80                ADC     #>SYMTAB_BASE
002AA4r 2  85 rr                STA     tmp3+1
002AA6r 2               ; check scope depth field (offset 20 in entry)
002AA6r 2  A0 14                LDY     #20
002AA8r 2  B1 rr                LDA     (tmp3),y
002AAAr 2  C5 rr                CMP     scope_depth
002AACr 2  D0 0A                BNE     @done           ; entry belongs to an outer scope — stop
002AAEr 2               ; remove this entry
002AAEr 2  CE rr rr             DEC     symtab_count
002AB1r 2  D0 C9                BNE     @trim
002AB3r 2  CE rr rr             DEC     symtab_count+1
002AB6r 2  80 C4                BRA     @trim
002AB8r 2               @done:
002AB8r 2  C6 rr                DEC     scope_depth
002ABAr 2  60                   RTS
002ABBr 2               
002ABBr 1                       .include        "CODEGEN.ASM"
002ABBr 2               ; codegen.asm — p-code emitter for Pascal/65 compiler
002ABBr 2               ;
002ABBr 2               ; All generated p-code accumulates in CODEBUF_BASE.
002ABBr 2               ; cg_pc (zero page) tracks the next write offset.
002ABBr 2               
002ABBr 2                       .segment        "CODE"
002ABBr 2               
002ABBr 2               ; ---------------------------------------------------------------------------
002ABBr 2               ; emit_byte — append byte A to code buffer
002ABBr 2               ; ---------------------------------------------------------------------------
002ABBr 2               emit_byte:
002ABBr 2  48                   PHA                     ; save byte to emit
002ABCr 2               ; check buffer full
002ABCr 2  A5 rr                LDA     cg_pc+1
002ABEr 2  C9 80                CMP     #>CODEBUF_MAXSZ
002AC0r 2  90 13                BCC     :+
002AC2r 2  A5 rr                LDA     cg_pc
002AC4r 2  C9 00                CMP     #<CODEBUF_MAXSZ
002AC6r 2  90 0D                BCC     :+
002AC8r 2               ; error: p-code buffer full
002AC8r 2  68                   PLA
002AC9r 2  A9 rr                LDA     #<err_pcd_full
002ACBr 2  85 rr                STA     tmp0
002ACDr 2  A9 rr                LDA     #>err_pcd_full
002ACFr 2  85 rr                STA     tmp0+1
002AD1r 2  20 rr rr             JSR     compile_error
002AD4r 2  60                   RTS
002AD5r 2               :
002AD5r 2               ; store at CODEBUF_BASE + cg_pc
002AD5r 2  A5 rr                LDA     cg_pc
002AD7r 2  18                   CLC
002AD8r 2  69 00                ADC     #<CODEBUF_BASE
002ADAr 2  85 rr                STA     tmp2
002ADCr 2  A5 rr                LDA     cg_pc+1
002ADEr 2  69 49                ADC     #>CODEBUF_BASE
002AE0r 2  85 rr                STA     tmp2+1
002AE2r 2  68                   PLA
002AE3r 2  A0 00                LDY     #0
002AE5r 2  91 rr                STA     (tmp2),y
002AE7r 2               ; advance cg_pc
002AE7r 2  E6 rr                INC     cg_pc
002AE9r 2  D0 02                BNE     :+
002AEBr 2  E6 rr                INC     cg_pc+1
002AEDr 2               :
002AEDr 2  60                   RTS
002AEEr 2               
002AEEr 2               ; ---------------------------------------------------------------------------
002AEEr 2               ; emit_word — append word (lo then hi) from tmp2 to code buffer
002AEEr 2               ; ---------------------------------------------------------------------------
002AEEr 2               emit_word:
002AEEr 2  A5 rr                LDA     tmp2
002AF0r 2  20 rr rr             JSR     emit_byte
002AF3r 2  A5 rr                LDA     tmp2+1
002AF5r 2  20 rr rr             JSR     emit_byte
002AF8r 2  60                   RTS
002AF9r 2               
002AF9r 2               ; ---------------------------------------------------------------------------
002AF9r 2               ; emit_opcode — emit single opcode byte in A
002AF9r 2               ; ---------------------------------------------------------------------------
002AF9r 2               emit_opcode:
002AF9r 2  20 rr rr             JSR     emit_byte
002AFCr 2  60                   RTS
002AFDr 2               
002AFDr 2               ; --- Constant emitters ---
002AFDr 2               
002AFDr 2               emit_LDCI:                      ; push sign-extended byte in A
002AFDr 2  48                   PHA
002AFEr 2  A9 00                LDA     #OP_LDCI
002B00r 2  20 rr rr             JSR     emit_byte
002B03r 2  68                   PLA
002B04r 2  20 rr rr             JSR     emit_byte
002B07r 2  60                   RTS
002B08r 2               
002B08r 2               emit_LDCW:                      ; push word: lo in A, hi in scratch
002B08r 2  48                   PHA
002B09r 2  A9 01                LDA     #OP_LDCW
002B0Br 2  20 rr rr             JSR     emit_byte
002B0Er 2  68                   PLA
002B0Fr 2  20 rr rr             JSR     emit_byte
002B12r 2  A5 rr                LDA     scratch
002B14r 2  20 rr rr             JSR     emit_byte
002B17r 2  60                   RTS
002B18r 2               
002B18r 2               emit_LDCC:                      ; push char in A
002B18r 2  48                   PHA
002B19r 2  A9 02                LDA     #OP_LDCC
002B1Br 2  20 rr rr             JSR     emit_byte
002B1Er 2  68                   PLA
002B1Fr 2  20 rr rr             JSR     emit_byte
002B22r 2  60                   RTS
002B23r 2               
002B23r 2               emit_LDCB:                      ; push boolean in A (0=false, 1=true)
002B23r 2  48                   PHA
002B24r 2  A9 03                LDA     #OP_LDCB
002B26r 2  20 rr rr             JSR     emit_byte
002B29r 2  68                   PLA
002B2Ar 2  20 rr rr             JSR     emit_byte
002B2Dr 2  60                   RTS
002B2Er 2               
002B2Er 2               emit_LDCN:
002B2Er 2  A9 05                LDA     #OP_LDCN
002B30r 2  20 rr rr             JSR     emit_byte
002B33r 2  60                   RTS
002B34r 2               
002B34r 2               ; emit_LDCS — emit OP_LDCS followed by length byte and string bytes.
002B34r 2               ; Source string lives in ident_buf (length at [0], chars at [1..N]).
002B34r 2               ; The runtime will inline-fetch length+chars and push the address of
002B34r 2               ; the length byte as a Pascal-style string pointer.
002B34r 2               emit_LDCS:
002B34r 2  A9 04                LDA     #OP_LDCS
002B36r 2  20 rr rr             JSR     emit_byte
002B39r 2  AD rr rr             LDA     ident_buf       ; length
002B3Cr 2  85 rr                STA     scratch         ; counter / length cache
002B3Er 2  20 rr rr             JSR     emit_byte       ; emit length byte
002B41r 2  A2 00                LDX     #0
002B43r 2               @loop:
002B43r 2  E4 rr                CPX     scratch
002B45r 2  B0 0B                BCS     @done
002B47r 2  BD rr rr             LDA     ident_buf+1,x
002B4Ar 2  DA                   PHX
002B4Br 2  20 rr rr             JSR     emit_byte       ; clobbers tmp2 only
002B4Er 2  FA                   PLX
002B4Fr 2  E8                   INX
002B50r 2  80 F1                BRA     @loop
002B52r 2               @done:
002B52r 2  60                   RTS
002B53r 2               
002B53r 2               ; --- Local variable emitters ---
002B53r 2               
002B53r 2               emit_LDL:                       ; byte offset in A
002B53r 2  48                   PHA
002B54r 2  A9 10                LDA     #OP_LDL
002B56r 2  20 rr rr             JSR     emit_byte
002B59r 2  68                   PLA
002B5Ar 2  20 rr rr             JSR     emit_byte
002B5Dr 2  60                   RTS
002B5Er 2               
002B5Er 2               emit_STL:
002B5Er 2  48                   PHA
002B5Fr 2  A9 11                LDA     #OP_STL
002B61r 2  20 rr rr             JSR     emit_byte
002B64r 2  68                   PLA
002B65r 2  20 rr rr             JSR     emit_byte
002B68r 2  60                   RTS
002B69r 2               
002B69r 2               emit_LDA_L:
002B69r 2  48                   PHA
002B6Ar 2  A9 12                LDA     #OP_LDA_L
002B6Cr 2  20 rr rr             JSR     emit_byte
002B6Fr 2  68                   PLA
002B70r 2  20 rr rr             JSR     emit_byte
002B73r 2  60                   RTS
002B74r 2               
002B74r 2               ; --- Global variable emitters ---
002B74r 2               
002B74r 2               emit_LDG:                       ; word offset: lo in A, hi in scratch
002B74r 2  48                   PHA
002B75r 2  A9 18                LDA     #OP_LDG
002B77r 2  20 rr rr             JSR     emit_byte
002B7Ar 2  68                   PLA
002B7Br 2  20 rr rr             JSR     emit_byte
002B7Er 2  A5 rr                LDA     scratch
002B80r 2  20 rr rr             JSR     emit_byte
002B83r 2  60                   RTS
002B84r 2               
002B84r 2               emit_STG:
002B84r 2  48                   PHA
002B85r 2  A9 19                LDA     #OP_STG
002B87r 2  20 rr rr             JSR     emit_byte
002B8Ar 2  68                   PLA
002B8Br 2  20 rr rr             JSR     emit_byte
002B8Er 2  A5 rr                LDA     scratch
002B90r 2  20 rr rr             JSR     emit_byte
002B93r 2  60                   RTS
002B94r 2               
002B94r 2               emit_LDA_G:                     ; word offset: lo in A, hi in scratch
002B94r 2  48                   PHA
002B95r 2  A9 1A                LDA     #OP_LDA_G
002B97r 2  20 rr rr             JSR     emit_byte
002B9Ar 2  68                   PLA
002B9Br 2  20 rr rr             JSR     emit_byte
002B9Er 2  A5 rr                LDA     scratch
002BA0r 2  20 rr rr             JSR     emit_byte
002BA3r 2  60                   RTS
002BA4r 2               
002BA4r 2               ; --- Indirect (VAR-param) emitters ---
002BA4r 2               
002BA4r 2               emit_LDIND:
002BA4r 2  A9 20                LDA     #OP_LDIND
002BA6r 2  4C rr rr             JMP     emit_byte
002BA9r 2               
002BA9r 2               emit_STIND:
002BA9r 2  A9 21                LDA     #OP_STIND
002BABr 2  4C rr rr             JMP     emit_byte
002BAEr 2               
002BAEr 2               ; emit_INDEX — OP_INDEX + 2-byte element size word (lo in A, hi in scratch)
002BAEr 2               emit_INDEX:
002BAEr 2  48                   PHA
002BAFr 2  A9 24                LDA     #OP_INDEX
002BB1r 2  20 rr rr             JSR     emit_byte
002BB4r 2  68                   PLA
002BB5r 2  20 rr rr             JSR     emit_byte
002BB8r 2  A5 rr                LDA     scratch
002BBAr 2  20 rr rr             JSR     emit_byte
002BBDr 2  60                   RTS
002BBEr 2               
002BBEr 2               ; emit_NEW — OP_NEW + 2-byte allocation size (lo in A, hi in scratch)
002BBEr 2               emit_NEW:
002BBEr 2  48                   PHA
002BBFr 2  A9 70                LDA     #OP_NEW
002BC1r 2  20 rr rr             JSR     emit_byte
002BC4r 2  68                   PLA
002BC5r 2  20 rr rr             JSR     emit_byte
002BC8r 2  A5 rr                LDA     scratch
002BCAr 2  20 rr rr             JSR     emit_byte
002BCDr 2  60                   RTS
002BCEr 2               
002BCEr 2               ; emit_DISP — OP_DISP (no operand)
002BCEr 2               emit_DISP:
002BCEr 2  A9 71                LDA     #OP_DISP
002BD0r 2  4C rr rr             JMP     emit_byte
002BD3r 2               
002BD3r 2               ; ---------------------------------------------------------------------------
002BD3r 2               ; codegen_alloc_array_global — allocate ARRAY [array_lo..array_hi] in globals
002BD3r 2               ; Element size fixed at 2 (all scalars are word-sized).
002BD3r 2               ; Returns: tmp2 = adjusted_offset = raw_base - lo*2
002BD3r 2               ;          cg_globals advanced by (hi - lo + 1) * 2
002BD3r 2               ; Clobbers: tmp2, tmp3
002BD3r 2               ; ---------------------------------------------------------------------------
002BD3r 2               codegen_alloc_array_global:
002BD3r 2               ; count = hi - lo + 1  (16-bit)
002BD3r 2  AD rr rr             LDA     array_hi
002BD6r 2  38                   SEC
002BD7r 2  ED rr rr             SBC     array_lo
002BDAr 2  85 rr                STA     tmp2
002BDCr 2  AD rr rr             LDA     array_hi+1
002BDFr 2  ED rr rr             SBC     array_lo+1
002BE2r 2  85 rr                STA     tmp2+1
002BE4r 2  E6 rr                INC     tmp2
002BE6r 2  D0 02                BNE     :+
002BE8r 2  E6 rr                INC     tmp2+1
002BEAr 2               :
002BEAr 2               ; alloc_size = count * 2
002BEAr 2  06 rr                ASL     tmp2
002BECr 2  26 rr                ROL     tmp2+1
002BEEr 2               ; save raw_base = cg_globals before advancing
002BEEr 2  A5 rr                LDA     cg_globals
002BF0r 2  85 rr                STA     tmp3
002BF2r 2  A5 rr                LDA     cg_globals+1
002BF4r 2  85 rr                STA     tmp3+1
002BF6r 2               ; advance cg_globals by alloc_size (tmp2)
002BF6r 2  A5 rr                LDA     cg_globals
002BF8r 2  18                   CLC
002BF9r 2  65 rr                ADC     tmp2
002BFBr 2  85 rr                STA     cg_globals
002BFDr 2  A5 rr                LDA     cg_globals+1
002BFFr 2  65 rr                ADC     tmp2+1
002C01r 2  85 rr                STA     cg_globals+1
002C03r 2               ; adjusted_offset = raw_base (tmp3) - lo*2 (tmp2 reused)
002C03r 2  AD rr rr             LDA     array_lo
002C06r 2  0A                   ASL
002C07r 2  85 rr                STA     tmp2
002C09r 2  AD rr rr             LDA     array_lo+1
002C0Cr 2  2A                   ROL
002C0Dr 2  85 rr                STA     tmp2+1
002C0Fr 2  A5 rr                LDA     tmp3
002C11r 2  38                   SEC
002C12r 2  E5 rr                SBC     tmp2
002C14r 2  85 rr                STA     tmp2
002C16r 2  A5 rr                LDA     tmp3+1
002C18r 2  E5 rr                SBC     tmp2+1
002C1Ar 2  85 rr                STA     tmp2+1
002C1Cr 2  60                   RTS
002C1Dr 2               
002C1Dr 2               ; ---------------------------------------------------------------------------
002C1Dr 2               ; codegen_alloc_record_global — reserve record_size bytes in globals
002C1Dr 2               ; Returns: tmp2 = offset of record's first byte
002C1Dr 2               ;          cg_globals advanced by record_size
002C1Dr 2               ; ---------------------------------------------------------------------------
002C1Dr 2               codegen_alloc_record_global:
002C1Dr 2  A5 rr                LDA     cg_globals
002C1Fr 2  85 rr                STA     tmp2
002C21r 2  A5 rr                LDA     cg_globals+1
002C23r 2  85 rr                STA     tmp2+1
002C25r 2  18                   CLC
002C26r 2  A5 rr                LDA     cg_globals
002C28r 2  6D rr rr             ADC     record_size
002C2Br 2  85 rr                STA     cg_globals
002C2Dr 2  A5 rr                LDA     cg_globals+1
002C2Fr 2  6D rr rr             ADC     record_size+1
002C32r 2  85 rr                STA     cg_globals+1
002C34r 2  60                   RTS
002C35r 2               
002C35r 2               ; ---------------------------------------------------------------------------
002C35r 2               ; codegen_alloc_text_global — reserve FILE_STRUCT_SZ (168) bytes for a TEXT
002C35r 2               ; variable.  Returns tmp2 = offset of struct's first byte; cg_globals bumped.
002C35r 2               ; ---------------------------------------------------------------------------
002C35r 2               codegen_alloc_text_global:
002C35r 2  A5 rr                LDA     cg_globals
002C37r 2  85 rr                STA     tmp2
