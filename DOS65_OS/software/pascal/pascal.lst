0023C2r 2               @bi_dn6:
0023C2r 2  4C rr rr             JMP     @do_lookup
0023C5r 2               @bi_chk4:
0023C5r 2               ; 4-letter built-ins: COPY, EOLN, TRUE
0023C5r 2  AD rr rr             LDA     ident_buf+1
0023C8r 2  C9 43                CMP     #'C'
0023CAr 2  D0 03                BNE     :+
