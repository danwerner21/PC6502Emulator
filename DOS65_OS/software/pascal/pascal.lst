00225Ar 2               ; parse_set_literal — current token is '['. Supports [] and constant integer
00225Ar 2               ; items/ranges like [1,3,5] and [3..6]. Elements must be 0..15 in this build.
00225Ar 2               parse_set_literal:
00225Ar 2  A9 00                LDA     #0
