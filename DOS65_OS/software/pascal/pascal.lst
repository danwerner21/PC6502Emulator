001E6Cr 2               ; ---------------------------------------------------------------------------
001E6Cr 2               ; for_emit_load_var / for_emit_store_var — emit LDG/LDL or STG/STL based on
001E6Cr 2               ; sym_save_scope (0 = global) and sym_save_off (offset).
001E6Cr 2               ; ---------------------------------------------------------------------------
001E6Cr 2               for_emit_load_var:
001E6Cr 2  AD rr rr             LDA     sym_save_scope
001E6Fr 2  D0 0B                BNE     @local
001E71r 2  AD rr rr             LDA     sym_save_off+1
001E74r 2  85 rr                STA     scratch
001E76r 2  AD rr rr             LDA     sym_save_off
001E79r 2  4C rr rr             JMP     emit_LDG
001E7Cr 2               @local:
001E7Cr 2  AD rr rr             LDA     sym_save_off
001E7Fr 2  4C rr rr             JMP     emit_LDL
001E82r 2               
001E82r 2               for_emit_store_var:
001E82r 2  AD rr rr             LDA     sym_save_scope
001E85r 2  D0 0B                BNE     @local
001E87r 2  AD rr rr             LDA     sym_save_off+1
001E8Ar 2  85 rr                STA     scratch
001E8Cr 2  AD rr rr             LDA     sym_save_off
001E8Fr 2  4C rr rr             JMP     emit_STG
001E92r 2               @local:
001E92r 2  AD rr rr             LDA     sym_save_off
001E95r 2  4C rr rr             JMP     emit_STL
