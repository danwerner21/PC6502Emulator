0018E9r 2               :
0018E9r 2  C9 07                CMP     #SYM_RETVAL
0018EBr 2  F0 05                BEQ     @do_retval_assign
0018EDr 2  C9 08                CMP     #SYM_VARREF
0018EFr 2  F0 1A                BEQ     @do_varref_assign
0018F1r 2  60                   RTS
0018F2r 2               
0018F2r 2               @do_retval_assign:
0018F2r 2               ; `funcname := expr` inside function body — emit OP_STR which writes
0018F2r 2               ; the popped value to the current AR's AR_RET_VAL slot.
0018F2r 2  20 rr rr             JSR     next_token      ; consume function name
0018F5r 2  A5 rr                LDA     tok_type
0018F7r 2  C9 1A                CMP     #TOK_ASSIGN
0018F9r 2  D0 03                BNE     :+
0018FBr 2  20 rr rr             JSR     next_token      ; consume ':='
0018FEr 2               :
0018FEr 2  20 rr rr             JSR     parse_expression
001901r 2  AD rr rr             LDA     sym_save_type
001904r 2  20 rr rr             JSR     coerce_expr_to_target_type
001907r 2  20 rr rr             JSR     emit_STR
00190Ar 2  60                   RTS
00190Br 2               
00190Br 2               @do_varref_assign:
00190Br 2               ; VAR-by-reference param assignment: `paramname := expr` where the
00190Br 2               ; param's local slot holds an address.  Emit:
00190Br 2               ;   LDL <off>          ; push address (the value passed by caller)
00190Br 2               ;   <expr>             ; push value
00190Br 2               ;   STIND              ; pop val, pop addr, store
00190Br 2  20 rr rr             JSR     next_token      ; consume param name
00190Er 2  A5 rr                LDA     tok_type
001910r 2  C9 1A                CMP     #TOK_ASSIGN
001912r 2  D0 03                BNE     :+
001914r 2  20 rr rr             JSR     next_token      ; consume ':='
001917r 2               :
001917r 2  AD rr rr             LDA     sym_save_off
00191Ar 2  20 rr rr             JSR     emit_LDL        ; push address from local slot
00191Dr 2  20 rr rr             JSR     parse_expression
001920r 2  AD rr rr             LDA     sym_save_type
001923r 2  20 rr rr             JSR     coerce_expr_to_target_type
001926r 2  20 rr rr             JSR     emit_STIND
001929r 2  60                   RTS
00192Ar 2               
00192Ar 2               @do_assign:
00192Ar 2  20 rr rr             JSR     next_token      ; consume variable name identifier
00192Dr 2               ; check for compound-type access (array subscript or record field)
00192Dr 2  AD rr rr             LDA     sym_save_type
001930r 2  C9 05                CMP     #TY_ARRAY
001932r 2  F0 3E                BEQ     @array_assign
001934r 2  C9 06                CMP     #TY_RECORD
001936r 2  D0 03                BNE     :+
001938r 2  4C rr rr             JMP     @record_assign
00193Br 2               :
00193Br 2               ; ptr^ := expr — pointer dereference assignment
00193Br 2  C9 07                CMP     #TY_PTR
00193Dr 2  D0 09                BNE     :+
00193Fr 2  A5 rr                LDA     tok_type
001941r 2  C9 24                CMP     #TOK_CARET
001943r 2  D0 03                BNE     :+
001945r 2  4C rr rr             JMP     @ptr_deref_assign
001948r 2               :
001948r 2               ; scalar assignment — expect ':='
001948r 2  A5 rr                LDA     tok_type
00194Ar 2  C9 1A                CMP     #TOK_ASSIGN
00194Cr 2  D0 03                BNE     :+
00194Er 2  20 rr rr             JSR     next_token
001951r 2  20 rr rr     :       JSR     parse_expression
001954r 2  AD rr rr             LDA     sym_save_type
001957r 2  20 rr rr             JSR     coerce_expr_to_target_type
00195Ar 2  AD rr rr             LDA     sym_save_scope
00195Dr 2  D0 0C                BNE     @local_store
00195Fr 2  AD rr rr             LDA     sym_save_off+1
001962r 2  85 rr                STA     scratch
001964r 2  AD rr rr             LDA     sym_save_off
001967r 2  20 rr rr             JSR     emit_STG
00196Ar 2  60                   RTS
00196Br 2               @local_store:
00196Br 2  AD rr rr             LDA     sym_save_off
00196Er 2  20 rr rr             JSR     emit_STL
001971r 2  60                   RTS
001972r 2               
001972r 2               @array_assign:
001972r 2               ; a[i] := expr
001972r 2               ; emit base-address push
001972r 2  AD rr rr             LDA     sym_save_scope
001975r 2  D0 0D                BNE     @aarr_local
001977r 2  AD rr rr             LDA     sym_save_off+1
00197Ar 2  85 rr                STA     scratch
00197Cr 2  AD rr rr             LDA     sym_save_off
00197Fr 2  20 rr rr             JSR     emit_LDA_G
001982r 2  80 06                BRA     @aarr_idx
001984r 2               @aarr_local:
001984r 2  AD rr rr             LDA     sym_save_off
001987r 2  20 rr rr             JSR     emit_LDA_L
00198Ar 2               @aarr_idx:
00198Ar 2               ; consume '[', parse index expr, consume ']'
00198Ar 2  A5 rr                LDA     tok_type
00198Cr 2  C9 1D                CMP     #TOK_LBRACK
00198Er 2  D0 03                BNE     :+
001990r 2  20 rr rr             JSR     next_token
001993r 2  20 rr rr     :       JSR     parse_expression
001996r 2  A5 rr                LDA     tok_type
001998r 2  C9 1E                CMP     #TOK_RBRACK
00199Ar 2  D0 03                BNE     :+
00199Cr 2  20 rr rr             JSR     next_token
00199Fr 2               :
00199Fr 2               ; emit INDEX 2 0  (elemsize = 2 words)
00199Fr 2  A9 00                LDA     #0
0019A1r 2  85 rr                STA     scratch
0019A3r 2  A9 02                LDA     #2
0019A5r 2  20 rr rr             JSR     emit_INDEX
0019A8r 2               ; consume ':='
0019A8r 2  A5 rr                LDA     tok_type
0019AAr 2  C9 1A                CMP     #TOK_ASSIGN
0019ACr 2  D0 03                BNE     :+
0019AEr 2  20 rr rr             JSR     next_token
0019B1r 2               :
0019B1r 2               ; parse and emit RHS expression
0019B1r 2  AD rr rr             LDA     sym_save_vmask
0019B4r 2  48                   PHA
0019B5r 2  20 rr rr             JSR     parse_expression
0019B8r 2  68                   PLA
0019B9r 2  20 rr rr             JSR     coerce_expr_to_target_type
0019BCr 2               ; store: NOS=element_addr TOS=value → STIND
0019BCr 2  20 rr rr             JSR     emit_STIND
0019BFr 2  60                   RTS
0019C0r 2               
0019C0r 2               @record_assign:
0019C0r 2               ; v.field := expr
0019C0r 2               ; emit base-address push
0019C0r 2  AD rr rr             LDA     sym_save_scope
0019C3r 2  D0 0D                BNE     @rec_la_local
0019C5r 2  AD rr rr             LDA     sym_save_off+1
0019C8r 2  85 rr                STA     scratch
0019CAr 2  AD rr rr             LDA     sym_save_off
0019CDr 2  20 rr rr             JSR     emit_LDA_G
0019D0r 2  80 06                BRA     @rec_la_dot
0019D2r 2               @rec_la_local:
0019D2r 2  AD rr rr             LDA     sym_save_off
0019D5r 2  20 rr rr             JSR     emit_LDA_L
0019D8r 2               @rec_la_dot:
0019D8r 2               ; Chained LHS: TOS = &cur_record_base. Walk into nested records as long
0019D8r 2               ; as the field is RECORD-typed and another '.' follows; the final scalar
0019D8r 2               ; field becomes the STIND target.
0019D8r 2  AD rr rr             LDA     sym_save_vmask
0019DBr 2  8D rr rr             STA     fcall_vmask     ; cur first_field
0019DEr 2  AD rr rr             LDA     sym_save_lsize
0019E1r 2  8D rr rr             STA     fcall_lsize     ; cur field count
0019E4r 2               @rla_chain:
0019E4r 2               ; consume '.'
0019E4r 2  A5 rr                LDA     tok_type
0019E6r 2  C9 22                CMP     #TOK_DOT
0019E8r 2  D0 03                BNE     :+
0019EAr 2  20 rr rr             JSR     next_token
0019EDr 2               :
0019EDr 2               ; look up field name in current record
0019EDr 2  AD rr rr             LDA     fcall_vmask
0019F0r 2  AE rr rr             LDX     fcall_lsize
0019F3r 2  20 rr rr             JSR     field_lookup_in_record
0019F6r 2  B0 03                BCS     :+
0019F8r 2  4C rr rr             JMP     @rec_la_undef
0019FBr 2               :
0019FBr 2               ; A=offset, X=type, tmp3=matched index
0019FBr 2  48                   PHA
0019FCr 2  8A                   TXA
0019FDr 2  8D rr rr             STA     field_chain_type
001A00r 2  A5 rr                LDA     tmp3
001A02r 2  AA                   TAX
001A03r 2  BD rr rr             LDA     field_nested_first,x
001A06r 2  8D rr rr             STA     field_chain_first
001A09r 2  BD rr rr             LDA     field_nested_count,x
001A0Cr 2  8D rr rr             STA     field_chain_count
001A0Fr 2  68                   PLA
001A10r 2  F0 06                BEQ     @rla_no_off
001A12r 2  20 rr rr             JSR     emit_LDCI
001A15r 2  20 rr rr             JSR     emit_ADI
001A18r 2               @rla_no_off:
001A18r 2  20 rr rr             JSR     next_token      ; consume field name
001A1Br 2               ; If field is RECORD and next is '.', chain another level
001A1Br 2  AD rr rr             LDA     field_chain_type
001A1Er 2  C9 06                CMP     #TY_RECORD
001A20r 2  D0 14                BNE     @rla_leaf
001A22r 2  A5 rr                LDA     tok_type
001A24r 2  C9 22                CMP     #TOK_DOT
001A26r 2  D0 0E                BNE     @rla_leaf
001A28r 2  AD rr rr             LDA     field_chain_first
001A2Br 2  8D rr rr             STA     fcall_vmask
001A2Er 2  AD rr rr             LDA     field_chain_count
001A31r 2  8D rr rr             STA     fcall_lsize
001A34r 2  80 AE                BRA     @rla_chain
001A36r 2               @rla_leaf:
001A36r 2               ; expect ':='; TOS holds &leaf_field
001A36r 2  A5 rr                LDA     tok_type
001A38r 2  C9 1A                CMP     #TOK_ASSIGN
001A3Ar 2  D0 03                BNE     :+
001A3Cr 2  20 rr rr             JSR     next_token
001A3Fr 2               :
001A3Fr 2  AD rr rr             LDA     field_chain_type
001A42r 2  48                   PHA
001A43r 2  20 rr rr             JSR     parse_expression
001A46r 2  68                   PLA
001A47r 2  20 rr rr             JSR     coerce_expr_to_target_type
001A4Ar 2  20 rr rr             JSR     emit_STIND
001A4Dr 2  60                   RTS
001A4Er 2               @rec_la_undef:
001A4Er 2  A9 rr                LDA     #<err_undef
001A50r 2  85 rr                STA     tmp0
001A52r 2  A9 rr                LDA     #>err_undef
001A54r 2  85 rr                STA     tmp0+1
001A56r 2  20 rr rr             JSR     compile_error
001A59r 2  60                   RTS
001A5Ar 2               
001A5Ar 2               @ptr_deref_assign:
001A5Ar 2               ; p^ := expr  — push p's value (the heap address), parse RHS, then STIND.
001A5Ar 2               ; sym_save_scope/off identify the pointer variable.
001A5Ar 2  AD rr rr             LDA     sym_save_scope
001A5Dr 2  D0 0D                BNE     @pda_local
001A5Fr 2  AD rr rr             LDA     sym_save_off+1
001A62r 2  85 rr                STA     scratch
001A64r 2  AD rr rr             LDA     sym_save_off
001A67r 2  20 rr rr             JSR     emit_LDG                ; push pointer value (addr)
001A6Ar 2  80 06                BRA     @pda_after_load
001A6Cr 2               @pda_local:
001A6Cr 2  AD rr rr             LDA     sym_save_off
001A6Fr 2  20 rr rr             JSR     emit_LDL                ; push pointer value (addr)
001A72r 2               @pda_after_load:
001A72r 2  20 rr rr             JSR     next_token              ; consume '^'
001A75r 2  A5 rr                LDA     tok_type
001A77r 2  C9 1A                CMP     #TOK_ASSIGN
001A79r 2  D0 03                BNE     :+
001A7Br 2  20 rr rr             JSR     next_token              ; consume ':='
001A7Er 2  20 rr rr     :       JSR     parse_expression        ; push RHS value
001A81r 2  20 rr rr             JSR     emit_STIND              ; *(addr) := value
001A84r 2  60                   RTS
001A85r 2               
001A85r 2               @do_call:
001A85r 2               ; Phase B: value parameters (INTEGER words, 2 bytes each).
001A85r 2               ; sym_save_off       = proc's code address
001A85r 2               ; sym_save_pcount    = declared parameter count
001A85r 2               ;
001A85r 2               ; Calling sequence emitted:
001A85r 2               ;   for each arg i:
001A85r 2               ;       <expr>                   ; pushes value to TOS (uses CALLER's MP)
001A85r 2               ;   MRKA <pcount> <lsize_extra>  ; reframe + gather args into local slots
001A85r 2               ;   CALL <proc>                  ; jump (saves IPC into AR)
001A85r 2               ;
001A85r 2               ; Args are evaluated BEFORE MRKA so any LDL/LDA_L inside arg expressions
001A85r 2               ; reads the caller's frame.  MRKA then shifts the pcount values up by
001A85r 2               ; AR_LOCALS so they land at local slots 0..pcount-1 of the new frame.
001A85r 2               ; The procedure body reads params via LDL because they were added to the
001A85r 2               ; symbol table as SYM_VAR with scope=inner (proc) at offsets 0, 2, 4, ...
001A85r 2  20 rr rr             JSR     next_token      ; consume the proc-name identifier
001A88r 2               ; if no params, optionally consume "()" then emit MRKA + CALL
001A88r 2  AD rr rr             LDA     sym_save_pcount
001A8Br 2  F0 4F                BEQ     @no_args
001A8Dr 2               ; expect '(' for arg list
001A8Dr 2  A5 rr                LDA     tok_type
001A8Fr 2  C9 1B                CMP     #TOK_LPAREN
001A91r 2  D0 5B                BNE     @emit_call      ; missing '(' — caller mistake; emit anyway
001A93r 2  20 rr rr             JSR     next_token      ; consume '('
001A96r 2  A2 00                LDX     #0              ; X = current arg index
001A98r 2               @arg_loop:
001A98r 2               ; If sym_save_vmask bit X is set, this arg is VAR (push address).
001A98r 2               ; Otherwise parse_expression (push value).
001A98r 2  DA                   PHX
001A99r 2  A9 01                LDA     #1
001A9Br 2               @vbit:
001A9Br 2  E0 00                CPX     #0
001A9Dr 2  F0 04                BEQ     @vdone
001A9Fr 2  0A                   ASL
001AA0r 2  CA                   DEX
001AA1r 2  80 F8                BRA     @vbit
001AA3r 2               @vdone:
001AA3r 2  FA                   PLX                     ; restore loop counter
001AA4r 2  2D rr rr             AND     sym_save_vmask
001AA7r 2  F0 07                BEQ     @arg_value
001AA9r 2  DA                   PHX
001AAAr 2  20 rr rr             JSR     parse_arg_lvalue
001AADr 2  FA                   PLX
001AAEr 2  80 0F                BRA     @arg_stored
001AB0r 2               @arg_value:
001AB0r 2  DA                   PHX
001AB1r 2  20 rr rr             JSR     parse_expression
001AB4r 2  FA                   PLX
001AB5r 2  8A                   TXA
001AB6r 2  48                   PHA
001AB7r 2  BD rr rr             LDA     sym_param_types,x
001ABAr 2  20 rr rr             JSR     coerce_expr_to_target_type
001ABDr 2  68                   PLA
001ABEr 2  AA                   TAX
001ABFr 2               @arg_stored:
001ABFr 2               ; Value (or address for VAR) left on stack — MRKA gathers later.
001ABFr 2  E8                   INX
001AC0r 2  EC rr rr             CPX     sym_save_pcount
001AC3r 2  B0 0C                BCS     @done_args      ; X >= pcount — done
001AC5r 2               ; expect comma between args
001AC5r 2  A5 rr                LDA     tok_type
001AC7r 2  C9 1F                CMP     #TOK_COMMA
001AC9r 2  D0 06                BNE     @done_args
001ACBr 2  20 rr rr             JSR     next_token      ; consume ','
001ACEr 2  4C rr rr             JMP     @arg_loop       ; jmp — body grew past bra range
001AD1r 2               @done_args:
001AD1r 2  A5 rr                LDA     tok_type
001AD3r 2  C9 1C                CMP     #TOK_RPAREN
001AD5r 2  D0 17                BNE     @emit_call
001AD7r 2  20 rr rr             JSR     next_token      ; consume ')'
001ADAr 2  80 12                BRA     @emit_call
001ADCr 2               @no_args:
001ADCr 2               ; No declared params — accept and skip "()" if present.
001ADCr 2  A5 rr                LDA     tok_type
001ADEr 2  C9 1B                CMP     #TOK_LPAREN
001AE0r 2  D0 0C                BNE     @emit_call
001AE2r 2  20 rr rr             JSR     next_token      ; consume '('
001AE5r 2  A5 rr                LDA     tok_type
001AE7r 2  C9 1C                CMP     #TOK_RPAREN
001AE9r 2  D0 03                BNE     @emit_call
001AEBr 2  20 rr rr             JSR     next_token      ; consume ')'
001AEEr 2               @emit_call:
001AEEr 2               ; Emit MRKA <pcount> <lsize_extra>; lsize_extra = sym_save_lsize - 2*pcount.
001AEEr 2  AD rr rr             LDA     sym_save_lsize
001AF1r 2  38                   SEC
001AF2r 2  ED rr rr             SBC     sym_save_pcount
001AF5r 2  ED rr rr             SBC     sym_save_pcount
001AF8r 2  AA                   TAX                     ; X = lsize_extra (body locals only)
001AF9r 2  AD rr rr             LDA     sym_save_pcount ; A = pcount
001AFCr 2  20 rr rr             JSR     emit_MRKA
001AFFr 2               ; Emit CALL <delta>: A=target lo, scratch=target hi
001AFFr 2  AD rr rr             LDA     sym_save_off
001B02r 2  0D rr rr             ORA     sym_save_off+1
001B05r 2  D0 0B                BNE     :+
001B07r 2  A9 rr                LDA     #<err_undef
001B09r 2  85 rr                STA     tmp0
001B0Br 2  A9 rr                LDA     #>err_undef
001B0Dr 2  85 rr                STA     tmp0+1
001B0Fr 2  20 rr rr             JSR     compile_error
001B12r 2  AD rr rr     :       LDA     sym_save_off+1
001B15r 2  85 rr                STA     scratch
001B17r 2  AD rr rr             LDA     sym_save_off
001B1Ar 2  20 rr rr             JSR     emit_CALL
001B1Dr 2  60                   RTS
001B1Er 2               
001B1Er 2               ; ---------------------------------------------------------------------------
001B1Er 2               ; parse_write_args — WRITE/WRITELN argument list.
001B1Er 2               ;   Returns X=0 if console mode (caller emits WRITLN normally),
001B1Er 2               ;           X=1 if file mode (file ptr left on stack — caller emits FWLN
001B1Er 2               ;               or POP to consume it).
001B1Er 2               ; ---------------------------------------------------------------------------
001B1Er 2               parse_write_args:
001B1Er 2  A5 rr                LDA     tok_type
001B20r 2  C9 1B                CMP     #TOK_LPAREN
001B22r 2  D0 2F                BNE     @done_console
001B24r 2  20 rr rr             JSR     next_token              ; consume '('
001B27r 2  A5 rr                LDA     tok_type
001B29r 2  C9 1C                CMP     #TOK_RPAREN
001B2Br 2  F0 1D                BEQ     @close_console
001B2Dr 2  20 rr rr             JSR     parse_expression        ; parse first arg
001B30r 2               ; If first arg is TY_TEXT, switch to file mode (leave file ptr on stack).
001B30r 2  A5 rr                LDA     expr_type
001B32r 2  C9 08                CMP     #TY_TEXT
001B34r 2  F0 20                BEQ     @file_mode
001B36r 2               ; Console mode — emit appropriate WRIT* for first arg, then loop.
001B36r 2  20 rr rr             JSR     pw_emit_console
001B39r 2               @cons_loop:
001B39r 2  A5 rr                LDA     tok_type
001B3Br 2  C9 1F                CMP     #TOK_COMMA
001B3Dr 2  D0 0B                BNE     @close_console
001B3Fr 2  20 rr rr             JSR     next_token              ; consume ','
001B42r 2  20 rr rr             JSR     parse_expression
001B45r 2  20 rr rr             JSR     pw_emit_console
001B48r 2  80 EF                BRA     @cons_loop
001B4Ar 2               @close_console:
001B4Ar 2  A5 rr                LDA     tok_type
001B4Cr 2  C9 1C                CMP     #TOK_RPAREN
001B4Er 2  D0 03                BNE     :+
001B50r 2  20 rr rr             JSR     next_token              ; consume ')'
001B53r 2               :
001B53r 2               @done_console:
001B53r 2  A2 00                LDX     #0
001B55r 2  60                   RTS
001B56r 2               
001B56r 2               @file_mode:
001B56r 2               @file_loop:
001B56r 2  A5 rr                LDA     tok_type
001B58r 2  C9 1F                CMP     #TOK_COMMA
001B5Ar 2  D0 0E                BNE     @close_file
001B5Cr 2  20 rr rr             JSR     next_token              ; consume ','
001B5Fr 2  20 rr rr             JSR     emit_DUP                ; dup file ptr (consumed by FWRX)
001B62r 2  20 rr rr             JSR     parse_expression        ; arg on top of stack
001B65r 2  20 rr rr             JSR     pw_emit_file
001B68r 2  80 EC                BRA     @file_loop
001B6Ar 2               @close_file:
001B6Ar 2  A5 rr                LDA     tok_type
001B6Cr 2  C9 1C                CMP     #TOK_RPAREN
001B6Er 2  D0 03                BNE     :+
001B70r 2  20 rr rr             JSR     next_token              ; consume ')'
001B73r 2               :
001B73r 2  A2 01                LDX     #1
001B75r 2  60                   RTS
001B76r 2               
001B76r 2               ; pw_emit_console — emit WRITS/WRITC/WRITB/WRITI based on expr_type
001B76r 2               pw_emit_console:
001B76r 2  A5 rr                LDA     expr_type
001B78r 2  C9 04                CMP     #TY_STRING
001B7Ar 2  D0 03                BNE     :+
001B7Cr 2  4C rr rr             JMP     emit_WRITS
001B7Fr 2               :
001B7Fr 2  C9 02                CMP     #TY_CHAR
001B81r 2  D0 03                BNE     :+
001B83r 2  4C rr rr             JMP     emit_WRITC
001B86r 2               :
001B86r 2  C9 03                CMP     #TY_BOOL
001B88r 2  D0 03                BNE     :+
001B8Ar 2  4C rr rr             JMP     emit_WRITB
001B8Dr 2               :
001B8Dr 2  C9 0A                CMP     #TY_REAL
001B8Fr 2  D0 03                BNE     :+
001B91r 2  4C rr rr             JMP     emit_WRITR
001B94r 2               :
001B94r 2  4C rr rr             JMP     emit_WRITI
001B97r 2               
001B97r 2               ; pw_emit_file — emit FWRS/FWRC/FWRB/FWRI based on expr_type
001B97r 2               pw_emit_file:
001B97r 2  A5 rr                LDA     expr_type
001B99r 2  C9 04                CMP     #TY_STRING
001B9Br 2  D0 03                BNE     :+
001B9Dr 2  4C rr rr             JMP     emit_FWRS
001BA0r 2               :
001BA0r 2  C9 02                CMP     #TY_CHAR
001BA2r 2  D0 03                BNE     :+
001BA4r 2  4C rr rr             JMP     emit_FWRC
001BA7r 2               :
001BA7r 2  C9 03                CMP     #TY_BOOL
001BA9r 2  D0 03                BNE     :+
001BABr 2  4C rr rr             JMP     emit_FWRB
001BAEr 2               :
001BAEr 2  C9 0A                CMP     #TY_REAL
001BB0r 2  D0 03                BNE     :+
001BB2r 2  4C rr rr             JMP     emit_FWRR
001BB5r 2               :
001BB5r 2  4C rr rr             JMP     emit_FWRI
001BB8r 2               
001BB8r 2               ; emit_console_read_arg — current token must be an IDENT naming the target
001BB8r 2               ; variable. CHAR targets compile as:
001BB8r 2               ;   <addr> READC STIND
001BB8r 2               ; so the zero-extended character from OP_READC is stored into the variable's
001BB8r 2               ; 2-byte cell. Everything else currently uses READI.
001BB8r 2               emit_console_read_arg:
001BB8r 2  20 rr rr             JSR     symtab_find
001BBBr 2  90 1E                BCC     @cra_int
001BBDr 2  A0 11                LDY     #17
001BBFr 2  B1 rr                LDA     (tmp3),y
001BC1r 2  C9 0A                CMP     #TY_REAL
001BC3r 2  D0 09                BNE     :+
001BC5r 2  20 rr rr             JSR     parse_arg_lvalue
001BC8r 2  20 rr rr             JSR     emit_READR
001BCBr 2  4C rr rr             JMP     emit_STIND
001BCEr 2               :
001BCEr 2  C9 02                CMP     #TY_CHAR
001BD0r 2  D0 09                BNE     @cra_int
001BD2r 2  20 rr rr             JSR     parse_arg_lvalue
001BD5r 2  20 rr rr             JSR     emit_READC
001BD8r 2  4C rr rr             JMP     emit_STIND
001BDBr 2               @cra_int:
001BDBr 2  20 rr rr             JSR     parse_arg_lvalue
001BDEr 2  4C rr rr             JMP     emit_READI
001BE1r 2               
001BE1r 2               ; ---------------------------------------------------------------------------
001BE1r 2               ; parse_read_args — READ/READLN argument list.  Each argument must be a
001BE1r 2               ; variable identifier. Console mode dispatches by target type:
001BE1r 2               ;   CHAR    -> READC + STIND
001BE1r 2               ;   default -> READI
001BE1r 2               ; File mode still routes through FRDC / FRDS / FRDI based on target type.
001BE1r 2               ; ---------------------------------------------------------------------------
001BE1r 2               parse_read_args:
001BE1r 2  A5 rr                LDA     tok_type
001BE3r 2  C9 1B                CMP     #TOK_LPAREN
001BE5r 2  D0 3A                BNE     @rdone_console
001BE7r 2  20 rr rr             JSR     next_token              ; consume '('
001BEAr 2  A5 rr                LDA     tok_type
001BECr 2  C9 1C                CMP     #TOK_RPAREN
001BEEr 2  F0 28                BEQ     @rclose_console
001BF0r 2  C9 01                CMP     #TOK_IDENT
001BF2r 2  D0 24                BNE     @rclose_console
001BF4r 2               ; Peek: is the first ident a TY_TEXT variable?
001BF4r 2  20 rr rr             JSR     symtab_find
001BF7r 2  90 08                BCC     @cons_first
001BF9r 2  A0 11                LDY     #17
001BFBr 2  B1 rr                LDA     (tmp3),y
001BFDr 2  C9 08                CMP     #TY_TEXT
001BFFr 2  F0 23                BEQ     @file_first
001C01r 2               @cons_first:
001C01r 2  20 rr rr             JSR     emit_console_read_arg
001C04r 2               @cons_loop:
001C04r 2  A5 rr                LDA     tok_type
001C06r 2  C9 1F                CMP     #TOK_COMMA
001C08r 2  D0 0E                BNE     @rclose_console
001C0Ar 2  20 rr rr             JSR     next_token
001C0Dr 2  A5 rr                LDA     tok_type
001C0Fr 2  C9 01                CMP     #TOK_IDENT
001C11r 2  D0 05                BNE     @rclose_console
001C13r 2  20 rr rr             JSR     emit_console_read_arg
001C16r 2  80 EC                BRA     @cons_loop
001C18r 2               @rclose_console:
001C18r 2  A5 rr                LDA     tok_type
001C1Ar 2  C9 1C                CMP     #TOK_RPAREN
001C1Cr 2  D0 03                BNE     :+
001C1Er 2  20 rr rr             JSR     next_token              ; consume ')'
001C21r 2               :
001C21r 2               @rdone_console:
001C21r 2  A2 00                LDX     #0
001C23r 2  60                   RTS
001C24r 2               
001C24r 2               @file_first:
001C24r 2               ; Push the file ptr (struct address) by parsing the ident as an expression —
001C24r 2               ; for TY_TEXT this emits LDA_G/LDA_L which pushes the struct's address.
001C24r 2  20 rr rr             JSR     parse_expression
001C27r 2               @file_loop:
001C27r 2  A5 rr                LDA     tok_type
001C29r 2  C9 1F                CMP     #TOK_COMMA
001C2Br 2  D0 4A                BNE     @close_file
001C2Dr 2  20 rr rr             JSR     next_token              ; consume ','
001C30r 2  A5 rr                LDA     tok_type
001C32r 2  C9 01                CMP     #TOK_IDENT
001C34r 2  D0 41                BNE     @close_file
001C36r 2               ; Peek var type so we know whether to emit FRDC, FRDS, or FRDI.
001C36r 2  20 rr rr             JSR     symtab_find
001C39r 2  90 31                BCC     @file_int_default
001C3Br 2  A0 11                LDY     #17
001C3Dr 2  B1 rr                LDA     (tmp3),y
001C3Fr 2  C9 02                CMP     #TY_CHAR
001C41r 2  D0 0B                BNE     @file_chk_str
001C43r 2  20 rr rr             JSR     emit_DUP                ; dup file ptr
001C46r 2  20 rr rr             JSR     parse_arg_lvalue
001C49r 2  20 rr rr             JSR     emit_FRDC
001C4Cr 2  80 D9                BRA     @file_loop
001C4Er 2               @file_chk_str:
001C4Er 2  C9 04                CMP     #TY_STRING
001C50r 2  D0 0B                BNE     @file_chk_real
001C52r 2  20 rr rr             JSR     emit_DUP                ; dup file ptr
001C55r 2  20 rr rr             JSR     parse_arg_lvalue
001C58r 2  20 rr rr             JSR     emit_FRDS
001C5Br 2  80 CA                BRA     @file_loop
001C5Dr 2               @file_chk_real:
001C5Dr 2  C9 0A                CMP     #TY_REAL
001C5Fr 2  D0 0B                BNE     @file_int_default
001C61r 2  20 rr rr             JSR     emit_DUP                ; dup file ptr
001C64r 2  20 rr rr             JSR     parse_arg_lvalue
001C67r 2  20 rr rr             JSR     emit_FRDR
001C6Ar 2  80 BB                BRA     @file_loop
001C6Cr 2               @file_int_default:
001C6Cr 2  20 rr rr             JSR     emit_DUP                ; dup file ptr
001C6Fr 2  20 rr rr             JSR     parse_arg_lvalue
001C72r 2  20 rr rr             JSR     emit_FRDI
001C75r 2  80 B0                BRA     @file_loop
001C77r 2               @close_file:
001C77r 2  A5 rr                LDA     tok_type
001C79r 2  C9 1C                CMP     #TOK_RPAREN
001C7Br 2  D0 03                BNE     :+
001C7Dr 2  20 rr rr             JSR     next_token              ; consume ')'
001C80r 2               :
001C80r 2  A2 01                LDX     #1
001C82r 2  60                   RTS
001C83r 2               
001C83r 2               ; ---------------------------------------------------------------------------
001C83r 2               ; parse_if — IF expr THEN stmt [ ELSE stmt ]
001C83r 2               ; ---------------------------------------------------------------------------
001C83r 2               parse_if:
001C83r 2  20 rr rr             JSR     next_token      ; consume IF
001C86r 2  20 rr rr             JSR     parse_expression
001C89r 2               ; emit FJP with placeholder; save patch addr on 6502 stack
001C89r 2               ; (parse_statement will clobber tmp2 / scratch)
001C89r 2  20 rr rr             JSR     emit_FJP        ; A=patch_lo, scratch=patch_hi
001C8Cr 2  48                   PHA                     ; save FJP patch lo
001C8Dr 2  A5 rr                LDA     scratch
001C8Fr 2  48                   PHA                     ; save FJP patch hi
001C90r 2               ; THEN
001C90r 2  A5 rr                LDA     tok_type
001C92r 2  C9 58                CMP     #TOK_THEN
001C94r 2  D0 03                BNE     :+
001C96r 2  20 rr rr             JSR     next_token
001C99r 2               :
001C99r 2  20 rr rr             JSR     parse_statement
001C9Cr 2               ; check for ELSE
001C9Cr 2  A5 rr                LDA     tok_type
001C9Er 2  C9 48                CMP     #TOK_ELSE
001CA0r 2  D0 2C                BNE     @patch_then
001CA2r 2               ; emit UJP over else branch
001CA2r 2  20 rr rr             JSR     emit_UJP        ; A=patch_lo, scratch=patch_hi
001CA5r 2  48                   PHA                     ; save UJP patch lo
001CA6r 2  A5 rr                LDA     scratch
001CA8r 2  48                   PHA                     ; save UJP patch hi
001CA9r 2               ; restore FJP patch addr into tmp2 and patch it to here
001CA9r 2               ; (need to dig under the UJP entries on the stack)
001CA9r 2               ; stack top → bottom: UJP_hi, UJP_lo, FJP_hi, FJP_lo
001CA9r 2  68                   PLA                     ; UJP hi
001CAAr 2  85 rr                STA     tmp1+1
001CACr 2  68                   PLA                     ; UJP lo
001CADr 2  85 rr                STA     tmp1
001CAFr 2  68                   PLA                     ; FJP hi
001CB0r 2  85 rr                STA     tmp2+1
001CB2r 2  68                   PLA                     ; FJP lo
001CB3r 2  85 rr                STA     tmp2
001CB5r 2  20 rr rr             JSR     patch_jump      ; patch FJP → start of else branch
001CB8r 2               ; push UJP patch addr back for after-else patching
001CB8r 2  A5 rr                LDA     tmp1            ; UJP lo
001CBAr 2  48                   PHA
001CBBr 2  A5 rr                LDA     tmp1+1          ; UJP hi
001CBDr 2  48                   PHA
001CBEr 2  20 rr rr             JSR     next_token      ; consume ELSE
001CC1r 2  20 rr rr             JSR     parse_statement
001CC4r 2               ; patch UJP to here
001CC4r 2  68                   PLA                     ; UJP hi
001CC5r 2  85 rr                STA     tmp2+1
001CC7r 2  68                   PLA                     ; UJP lo
001CC8r 2  85 rr                STA     tmp2
001CCAr 2  20 rr rr             JSR     patch_jump
001CCDr 2  60                   RTS
001CCEr 2               @patch_then:
001CCEr 2               ; no ELSE — restore FJP patch addr and patch to here
001CCEr 2  68                   PLA                     ; FJP hi
001CCFr 2  85 rr                STA     tmp2+1
001CD1r 2  68                   PLA                     ; FJP lo
001CD2r 2  85 rr                STA     tmp2
001CD4r 2  20 rr rr             JSR     patch_jump
001CD7r 2  60                   RTS
001CD8r 2               
001CD8r 2               ; ---------------------------------------------------------------------------
001CD8r 2               ; parse_while — WHILE expr DO stmt
001CD8r 2               ; ---------------------------------------------------------------------------
001CD8r 2               parse_while:
001CD8r 2  20 rr rr             JSR     next_token      ; consume WHILE
001CDBr 2               ; save loop top
001CDBr 2  A5 rr                LDA     cg_pc
001CDDr 2  85 rr                STA     tmp2
001CDFr 2  A5 rr                LDA     cg_pc+1
001CE1r 2  85 rr                STA     tmp2+1
001CE3r 2               ; we'll need loop_top later; save on 6502 stack
001CE3r 2  A5 rr                LDA     tmp2+1
001CE5r 2  48                   PHA
001CE6r 2  A5 rr                LDA     tmp2
001CE8r 2  48                   PHA
001CE9r 2  20 rr rr             JSR     parse_expression
001CECr 2  20 rr rr             JSR     emit_FJP        ; exit if false
001CEFr 2  48                   PHA
001CF0r 2  A5 rr                LDA     scratch
001CF2r 2  48                   PHA
001CF3r 2               ; DO
001CF3r 2  A5 rr                LDA     tok_type
001CF5r 2  C9 46                CMP     #TOK_DO
001CF7r 2  D0 03                BNE     :+
001CF9r 2  20 rr rr             JSR     next_token
001CFCr 2               :
001CFCr 2  20 rr rr             JSR     parse_statement
001CFFr 2               ; emit UJP back to loop top
001CFFr 2  A9 50                LDA     #OP_UJP
001D01r 2  20 rr rr             JSR     emit_byte
001D04r 2               ; offset = loop_top - (cg_pc + 2)
001D04r 2  68                   PLA
001D05r 2  85 rr                STA     tmp3            ; FJP patch hi
001D07r 2  68                   PLA
001D08r 2  85 rr                STA     tmp3+1          ; FJP patch lo — note: reversed from earlier push
001D0Ar 2               ; compute back-edge offset
001D0Ar 2  68                   PLA                     ; loop_top lo
001D0Br 2  85 rr                STA     tmp2
001D0Dr 2  68                   PLA                     ; loop_top hi
001D0Er 2  85 rr                STA     tmp2+1
001D10r 2               ; delta = loop_top - (cg_pc + 2)
001D10r 2  38                   SEC
001D11r 2  A5 rr                LDA     tmp2
001D13r 2  E5 rr                SBC     cg_pc
001D15r 2  85 rr                STA     scratch
001D17r 2  A5 rr                LDA     tmp2+1
001D19r 2  E5 rr                SBC     cg_pc+1
001D1Br 2  85 rr                STA     scratch+1
001D1Dr 2  A5 rr                LDA     scratch
001D1Fr 2  38                   SEC
001D20r 2  E9 02                SBC     #2
001D22r 2  85 rr                STA     scratch
001D24r 2  B0 02                BCS     :+
001D26r 2  C6 rr                DEC     scratch+1
001D28r 2               :
001D28r 2  A5 rr                LDA     scratch
001D2Ar 2  20 rr rr             JSR     emit_byte
001D2Dr 2  A5 rr                LDA     scratch+1
001D2Fr 2  20 rr rr             JSR     emit_byte
001D32r 2               ; patch FJP exit
001D32r 2               ; tmp3+1:tmp3 holds FJP patch addr (note push order was lo,hi → pla gets hi first)
001D32r 2               ; Rebuild properly:
001D32r 2  A5 rr                LDA     tmp3+1
001D34r 2  85 rr                STA     tmp2
001D36r 2  A5 rr                LDA     tmp3
001D38r 2  85 rr                STA     tmp2+1
001D3Ar 2  20 rr rr             JSR     patch_jump
001D3Dr 2  60                   RTS
001D3Er 2               
001D3Er 2               ; ---------------------------------------------------------------------------
001D3Er 2               ; parse_for — FOR id := expr TO|DOWNTO expr DO stmt
001D3Er 2               ;
001D3Er 2               ; Codegen layout:
001D3Er 2               ;   <init>:   parse expr1; STG/STL var
001D3Er 2               ;             parse expr2; STG hidden_global   (limit, evaluated once)
001D3Er 2               ;   loop_top: LDG/LDL var; LDG hidden_global
001D3Er 2               ;             LEQI (TO) | GEQI (DOWNTO)
001D3Er 2               ;             FJP exit
001D3Er 2               ;             <body>
001D3Er 2               ;             LDG/LDL var; LDCI 1; ADI|SBI; STG/STL var
001D3Er 2               ;             UJP loop_top
001D3Er 2               ;   exit:
001D3Er 2               ;
001D3Er 2               ; State on 6502 stack across body:
001D3Er 2               ;   var_off_lo, var_off_hi, var_scope, dir, lim_off_hi, lim_off_lo
001D3Er 2               ; for_loop_top / for_patch live in zp (FOR is not nestable in this build).
001D3Er 2               ; ---------------------------------------------------------------------------
001D3Er 2               parse_for:
001D3Er 2  20 rr rr             JSR     next_token      ; consume FOR
001D41r 2               
001D41r 2  A5 rr                LDA     tok_type
001D43r 2  C9 01                CMP     #TOK_IDENT
001D45r 2  F0 01                BEQ     :+
001D47r 2  60                   RTS                     ; not an ident — silently bail
001D48r 2               :
001D48r 2  20 rr rr             JSR     symtab_find
001D4Br 2  B0 04                BCS     :+
001D4Dr 2  20 rr rr             JSR     next_token      ; consume the bad ident
001D50r 2  60                   RTS
001D51r 2               :
001D51r 2               ; snapshot var info into sym_save_*
001D51r 2  A0 14                LDY     #20
001D53r 2  B1 rr                LDA     (tmp3),y
001D55r 2  8D rr rr             STA     sym_save_scope
001D58r 2  A0 12                LDY     #18
001D5Ar 2  B1 rr                LDA     (tmp3),y
001D5Cr 2  8D rr rr             STA     sym_save_off
001D5Fr 2  A0 13                LDY     #19
001D61r 2  B1 rr                LDA     (tmp3),y
001D63r 2  8D rr rr             STA     sym_save_off+1
001D66r 2  20 rr rr             JSR     next_token      ; consume identifier
001D69r 2               
001D69r 2               ; push var info: scope, off_hi, off_lo (top)
001D69r 2  AD rr rr             LDA     sym_save_scope
001D6Cr 2  48                   PHA
001D6Dr 2  AD rr rr             LDA     sym_save_off+1
001D70r 2  48                   PHA
001D71r 2  AD rr rr             LDA     sym_save_off
001D74r 2  48                   PHA
001D75r 2               
001D75r 2               ; ':='
001D75r 2  A5 rr                LDA     tok_type
001D77r 2  C9 1A                CMP     #TOK_ASSIGN
001D79r 2  D0 03                BNE     :+
001D7Br 2  20 rr rr             JSR     next_token
001D7Er 2               :
001D7Er 2  20 rr rr             JSR     parse_expression; initial value on TOS
001D81r 2               
001D81r 2               ; restore sym_save_* (parse_expression may have clobbered them)
001D81r 2  68                   PLA
001D82r 2  8D rr rr             STA     sym_save_off
001D85r 2  68                   PLA
001D86r 2  8D rr rr             STA     sym_save_off+1
001D89r 2  68                   PLA
001D8Ar 2  8D rr rr             STA     sym_save_scope
001D8Dr 2  20 rr rr             JSR     for_emit_store_var
001D90r 2               
001D90r 2               ; re-push var info for use after loop
001D90r 2  AD rr rr             LDA     sym_save_scope
001D93r 2  48                   PHA
001D94r 2  AD rr rr             LDA     sym_save_off+1
001D97r 2  48                   PHA
001D98r 2  AD rr rr             LDA     sym_save_off
001D9Br 2  48                   PHA
001D9Cr 2               
001D9Cr 2               ; direction byte: 0 = TO, 1 = DOWNTO
001D9Cr 2  A9 00                LDA     #0
001D9Er 2  A6 rr                LDX     tok_type
001DA0r 2  E0 47                CPX     #TOK_DOWNTO
001DA2r 2  D0 02                BNE     :+
001DA4r 2  A9 01                LDA     #1
001DA6r 2               :
001DA6r 2  48                   PHA                     ; push dir
001DA7r 2  20 rr rr             JSR     next_token      ; consume TO / DOWNTO
001DAAr 2               
001DAAr 2               ; parse limit expression and store to a hidden global
001DAAr 2  20 rr rr             JSR     parse_expression
001DADr 2  20 rr rr             JSR     codegen_alloc_global; tmp2 = hidden offset
001DB0r 2               ; push the offset NOW — emit_STG will clobber tmp2
001DB0r 2  A5 rr                LDA     tmp2+1
001DB2r 2  48                   PHA                     ; lim_hi
001DB3r 2  A5 rr                LDA     tmp2
001DB5r 2  48                   PHA                     ; lim_lo (top)
001DB6r 2               ; reload from stack peek for emit_STG (A = lo, scratch = hi)
001DB6r 2  BA                   TSX
001DB7r 2  BD 02 01             LDA     $0102,x
001DBAr 2  85 rr                STA     scratch
001DBCr 2  BD 01 01             LDA     $0101,x
001DBFr 2  20 rr rr             JSR     emit_STG
001DC2r 2               
001DC2r 2               ; consume DO
001DC2r 2  A5 rr                LDA     tok_type
001DC4r 2  C9 46                CMP     #TOK_DO
001DC6r 2  D0 03                BNE     :+
001DC8r 2  20 rr rr             JSR     next_token
001DCBr 2               :
001DCBr 2               ; --- loop top ---
001DCBr 2  A5 rr                LDA     cg_pc
001DCDr 2  85 rr                STA     for_loop_top
001DCFr 2  A5 rr                LDA     cg_pc+1
001DD1r 2  85 rr                STA     for_loop_top+1
001DD3r 2               
001DD3r 2               ; emit LDG/LDL var — restore sym_save_* via TSX peek
001DD3r 2               ; stack from top: lim_lo, lim_hi, dir, var_lo, var_hi, var_scope
001DD3r 2  BA                   TSX
001DD4r 2  BD 04 01             LDA     $0104,x         ; var_lo
001DD7r 2  8D rr rr             STA     sym_save_off
001DDAr 2  BD 05 01             LDA     $0105,x         ; var_hi
001DDDr 2  8D rr rr             STA     sym_save_off+1
001DE0r 2  BD 06 01             LDA     $0106,x         ; var_scope
001DE3r 2  8D rr rr             STA     sym_save_scope
001DE6r 2  20 rr rr             JSR     for_emit_load_var
001DE9r 2               
001DE9r 2               ; emit LDG limit — limit hi at $0102,x, lo at $0101,x
001DE9r 2  BA                   TSX
001DEAr 2  BD 02 01             LDA     $0102,x
001DEDr 2  85 rr                STA     scratch
001DEFr 2  BD 01 01             LDA     $0101,x
001DF2r 2  20 rr rr             JSR     emit_LDG
001DF5r 2               
001DF5r 2               ; comparison: TO → LEQI (var <= limit), DOWNTO → GEQI
001DF5r 2  BA                   TSX
001DF6r 2  BD 03 01             LDA     $0103,x         ; dir
001DF9r 2  F0 05                BEQ     @cmp_to
001DFBr 2  20 rr rr             JSR     emit_GEQI
001DFEr 2  80 03                BRA     @cmp_done
001E00r 2               @cmp_to:
001E00r 2  20 rr rr             JSR     emit_LEQI
001E03r 2               @cmp_done:
001E03r 2               
001E03r 2               ; FJP exit placeholder
001E03r 2  20 rr rr             JSR     emit_FJP        ; A=patch_lo, scratch=patch_hi
001E06r 2  85 rr                STA     for_patch
001E08r 2  A5 rr                LDA     scratch
001E0Ar 2  85 rr                STA     for_patch+1
001E0Cr 2               
001E0Cr 2               ; --- body ---
001E0Cr 2  20 rr rr             JSR     parse_statement
001E0Fr 2               
001E0Fr 2               ; --- pop state in reverse push order ---
001E0Fr 2  68                   PLA                     ; lim_lo (discard)
001E10r 2  68                   PLA                     ; lim_hi (discard)
001E11r 2  68                   PLA                     ; direction
001E12r 2  8D rr rr             STA     sym_save_kind   ; reuse for direction storage
001E15r 2  68                   PLA                     ; var_lo
001E16r 2  8D rr rr             STA     sym_save_off
001E19r 2  68                   PLA                     ; var_hi
001E1Ar 2  8D rr rr             STA     sym_save_off+1
001E1Dr 2  68                   PLA                     ; var_scope
001E1Er 2  8D rr rr             STA     sym_save_scope
001E21r 2               
001E21r 2               ; emit increment / decrement: LDG var, LDCI 1, ADI|SBI, STG var
001E21r 2  20 rr rr             JSR     for_emit_load_var
001E24r 2  A9 01                LDA     #1
001E26r 2  20 rr rr             JSR     emit_LDCI
001E29r 2  AD rr rr             LDA     sym_save_kind   ; direction
001E2Cr 2  F0 05                BEQ     @inc
001E2Er 2  20 rr rr             JSR     emit_SBI
001E31r 2  80 03                BRA     @inc_done
001E33r 2               @inc:
001E33r 2  20 rr rr             JSR     emit_ADI
001E36r 2               @inc_done:
001E36r 2  20 rr rr             JSR     for_emit_store_var
001E39r 2               
001E39r 2               ; emit UJP back to loop_top
001E39r 2               ; offset = for_loop_top - (cg_pc_after_opcode + 2)
001E39r 2  A9 50                LDA     #OP_UJP
001E3Br 2  20 rr rr             JSR     emit_byte
001E3Er 2  38                   SEC
001E3Fr 2  A5 rr                LDA     for_loop_top
001E41r 2  E5 rr                SBC     cg_pc
001E43r 2  85 rr                STA     scratch
001E45r 2  A5 rr                LDA     for_loop_top+1
001E47r 2  E5 rr                SBC     cg_pc+1
001E49r 2  85 rr                STA     scratch+1
001E4Br 2  38                   SEC
001E4Cr 2  A5 rr                LDA     scratch
001E4Er 2  E9 02                SBC     #2
001E50r 2  85 rr                STA     scratch
001E52r 2  B0 02                BCS     :+
001E54r 2  C6 rr                DEC     scratch+1
001E56r 2               :
001E56r 2  A5 rr                LDA     scratch
001E58r 2  20 rr rr             JSR     emit_byte
001E5Br 2  A5 rr                LDA     scratch+1
001E5Dr 2  20 rr rr             JSR     emit_byte
001E60r 2               
001E60r 2               ; patch FJP exit
001E60r 2  A5 rr                LDA     for_patch
001E62r 2  85 rr                STA     tmp2
001E64r 2  A5 rr                LDA     for_patch+1
001E66r 2  85 rr                STA     tmp2+1
001E68r 2  20 rr rr             JSR     patch_jump
001E6Br 2  60                   RTS
