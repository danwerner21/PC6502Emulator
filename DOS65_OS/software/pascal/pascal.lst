002CA7r 2  4C rr rr             JMP     emit_byte
002CAAr 2               
002CAAr 2               ; --- Jump emitters ---
002CAAr 2               ; Returns: A/scratch = offset of the word operand in code buffer
002CAAr 2               ; (needed for backpatching)
002CAAr 2               
002CAAr 2               emit_UJP:                       ; emit UJP with placeholder offset
002CAAr 2  A9 50                LDA     #OP_UJP
002CACr 2  20 rr rr             JSR     emit_byte
002CAFr 2  A5 rr                LDA     cg_pc           ; save patch address
002CB1r 2  48                   PHA
002CB2r 2  A5 rr                LDA     cg_pc+1
002CB4r 2  48                   PHA
002CB5r 2  A9 00                LDA     #$00
002CB7r 2  20 rr rr             JSR     emit_byte       ; placeholder lo
002CBAr 2  A9 00                LDA     #$00
002CBCr 2  20 rr rr             JSR     emit_byte       ; placeholder hi
002CBFr 2  68                   PLA
002CC0r 2  85 rr                STA     scratch
002CC2r 2  68                   PLA                     ; lo of patch address
002CC3r 2  60                   RTS                     ; caller: save A/scratch as patch point
002CC4r 2               
002CC4r 2               emit_FJP:
002CC4r 2  A9 51                LDA     #OP_FJP
002CC6r 2  20 rr rr             JSR     emit_byte
002CC9r 2  A5 rr                LDA     cg_pc
002CCBr 2  48                   PHA
002CCCr 2  A5 rr                LDA     cg_pc+1
002CCEr 2  48                   PHA
002CCFr 2  A9 00                LDA     #$00
002CD1r 2  20 rr rr             JSR     emit_byte
002CD4r 2  A9 00                LDA     #$00
002CD6r 2  20 rr rr             JSR     emit_byte
002CD9r 2  68                   PLA
002CDAr 2  85 rr                STA     scratch
002CDCr 2  68                   PLA
002CDDr 2  60                   RTS
002CDEr 2               
002CDEr 2               emit_TJP:
002CDEr 2  A9 52                LDA     #OP_TJP
002CE0r 2  20 rr rr             JSR     emit_byte
002CE3r 2  A5 rr                LDA     cg_pc
002CE5r 2  48                   PHA
002CE6r 2  A5 rr                LDA     cg_pc+1
002CE8r 2  48                   PHA
002CE9r 2  A9 00                LDA     #$00
002CEBr 2  20 rr rr             JSR     emit_byte
002CEEr 2  A9 00                LDA     #$00
002CF0r 2  20 rr rr             JSR     emit_byte
002CF3r 2  68                   PLA
002CF4r 2  85 rr                STA     scratch
002CF6r 2  68                   PLA
002CF7r 2  60                   RTS
002CF8r 2               
002CF8r 2               ; ---------------------------------------------------------------------------
002CF8r 2               ; patch_jump — fill in jump offset at patch address stored in tmp2 (word)
002CF8r 2               ; The offset is computed as: (current cg_pc) - (patch_addr + 2)
002CF8r 2               ; i.e. relative to instruction after the operand word
002CF8r 2               ; ---------------------------------------------------------------------------
002CF8r 2               patch_jump:
002CF8r 2               ; delta = cg_pc - (patch_addr + 2)
002CF8r 2               ;   compute (cg_pc - 2) first, then subtract patch_addr
002CF8r 2  A5 rr                LDA     cg_pc
002CFAr 2  38                   SEC
002CFBr 2  E9 02                SBC     #2
002CFDr 2  85 rr                STA     scratch         ; lo of (cg_pc - 2)
002CFFr 2  A5 rr                LDA     cg_pc+1
002D01r 2  E9 00                SBC     #0
002D03r 2  85 rr                STA     scratch+1       ; hi of (cg_pc - 2)
002D05r 2  38                   SEC
002D06r 2  A5 rr                LDA     scratch
002D08r 2  E5 rr                SBC     tmp2
002D0Ar 2  48                   PHA
002D0Br 2  A5 rr                LDA     scratch+1
002D0Dr 2  E5 rr                SBC     tmp2+1
002D0Fr 2  85 rr                STA     scratch+1       ; high byte of delta
002D11r 2  68                   PLA
002D12r 2  85 rr                STA     scratch         ; low byte of delta
002D14r 2               ; write delta at patch address (CODEBUF_BASE + tmp2)
002D14r 2  A5 rr                LDA     tmp2
002D16r 2  18                   CLC
002D17r 2  69 00                ADC     #<CODEBUF_BASE
002D19r 2  85 rr                STA     tmp3
002D1Br 2  A5 rr                LDA     tmp2+1
002D1Dr 2  69 49                ADC     #>CODEBUF_BASE
002D1Fr 2  85 rr                STA     tmp3+1
002D21r 2  A0 00                LDY     #0
002D23r 2  A5 rr                LDA     scratch
002D25r 2  91 rr                STA     (tmp3),y
002D27r 2  C8                   INY
002D28r 2  A5 rr                LDA     scratch+1
002D2Ar 2  91 rr                STA     (tmp3),y
002D2Cr 2  60                   RTS
002D2Dr 2               
002D2Dr 2               ; --- I/O emitters ---
002D2Dr 2               
002D2Dr 2               emit_WRITI:
002D2Dr 2  A9 80                LDA     #OP_WRITI
002D2Fr 2  4C rr rr             JMP     emit_byte
002D32r 2               
002D32r 2               emit_WRITC:
002D32r 2  A9 81                LDA     #OP_WRITC
002D34r 2  4C rr rr             JMP     emit_byte
002D37r 2               
002D37r 2               emit_WRITB:
002D37r 2  A9 82                LDA     #OP_WRITB
002D39r 2  4C rr rr             JMP     emit_byte
002D3Cr 2               
002D3Cr 2               emit_WRITS:
002D3Cr 2  A9 83                LDA     #OP_WRITS
002D3Er 2  4C rr rr             JMP     emit_byte
002D41r 2               
002D41r 2               emit_WRITLN:
002D41r 2  A9 84                LDA     #OP_WRITLN
002D43r 2  4C rr rr             JMP     emit_byte
002D46r 2               
002D46r 2               emit_READI:
002D46r 2  A9 85                LDA     #OP_READI
002D48r 2  4C rr rr             JMP     emit_byte
002D4Br 2               
002D4Br 2               emit_WRITR:
002D4Br 2  A9 88                LDA     #OP_WRITR
002D4Dr 2  4C rr rr             JMP     emit_byte
002D50r 2               
002D50r 2               emit_READR:
002D50r 2  A9 89                LDA     #OP_READR
002D52r 2  4C rr rr             JMP     emit_byte
002D55r 2               
002D55r 2               emit_READC:
002D55r 2  A9 86                LDA     #OP_READC
002D57r 2  4C rr rr             JMP     emit_byte
002D5Ar 2               
002D5Ar 2               ; --- Stack ---
002D5Ar 2               
002D5Ar 2               emit_DUP:
002D5Ar 2  A9 90                LDA     #OP_DUP
002D5Cr 2  4C rr rr             JMP     emit_byte
002D5Fr 2               
002D5Fr 2               emit_POP:
002D5Fr 2  A9 91                LDA     #OP_POP
002D61r 2  4C rr rr             JMP     emit_byte
002D64r 2               
002D64r 2               emit_SWAP:
002D64r 2  A9 92                LDA     #OP_SWAP
002D66r 2  4C rr rr             JMP     emit_byte
002D69r 2               
002D69r 2               ; --- Calls ---
002D69r 2               
002D69r 2               emit_MRKSTK:                    ; local size in A
002D69r 2  48                   PHA
002D6Ar 2  A9 64                LDA     #OP_MRKSTK
002D6Cr 2  20 rr rr             JSR     emit_byte
002D6Fr 2  68                   PLA
002D70r 2  4C rr rr             JMP     emit_byte
002D73r 2               
002D73r 2               ; emit_MRKA — A=pcount, X=lsize_extra
002D73r 2               ; Emits OP_MRKA + pcount byte + lsize_extra byte.  See op_MRKA in prun.asm
002D73r 2               ; for runtime semantics.
002D73r 2               emit_MRKA:
002D73r 2  DA                   PHX                     ; save lsize_extra
002D74r 2  48                   PHA                     ; save pcount
002D75r 2  A9 67                LDA     #OP_MRKA
002D77r 2  20 rr rr             JSR     emit_byte
002D7Ar 2  68                   PLA                     ; pcount
002D7Br 2  20 rr rr             JSR     emit_byte
002D7Er 2  68                   PLA                     ; lsize_extra
002D7Fr 2  4C rr rr             JMP     emit_byte
002D82r 2               
002D82r 2               emit_RET:
002D82r 2  A9 62                LDA     #OP_RET
002D84r 2  4C rr rr             JMP     emit_byte
002D87r 2               
002D87r 2               emit_RETF:
002D87r 2  A9 63                LDA     #OP_RETF
002D89r 2  4C rr rr             JMP     emit_byte
002D8Cr 2               
002D8Cr 2               emit_STR:
002D8Cr 2  A9 66                LDA     #OP_STR
002D8Er 2  4C rr rr             JMP     emit_byte
002D91r 2               
002D91r 2               ; emit_CALL — A = target absolute code-buffer addr lo, scratch = hi
002D91r 2               ; Emits OP_CALL + signed 16-bit offset = target - (cg_pc_after_operand)
002D91r 2               emit_CALL:
002D91r 2  48                   PHA                     ; target lo
002D92r 2  A5 rr                LDA     scratch
002D94r 2  48                   PHA                     ; target hi
002D95r 2  A9 60                LDA     #OP_CALL
002D97r 2  20 rr rr             JSR     emit_byte       ; clobbers tmp2; preserves scratch & 6502 stack
002D9Ar 2               ; compute offset = target - cg_pc - 2 (16-bit)
002D9Ar 2  68                   PLA                     ; target hi
002D9Br 2  AA                   TAX
002D9Cr 2  68                   PLA                     ; target lo
002D9Dr 2  38                   SEC
002D9Er 2  E9 02                SBC     #2
002DA0r 2  48                   PHA                     ; partial lo
002DA1r 2  8A                   TXA                     ; target hi
002DA2r 2  E9 00                SBC     #0
002DA4r 2  85 rr                STA     scratch         ; partial hi
002DA6r 2  68                   PLA                     ; partial lo
002DA7r 2  38                   SEC
002DA8r 2  E5 rr                SBC     cg_pc
002DAAr 2  48                   PHA                     ; offset lo
002DABr 2  A5 rr                LDA     scratch
002DADr 2  E5 rr                SBC     cg_pc+1
002DAFr 2  85 rr                STA     scratch         ; offset hi
002DB1r 2  68                   PLA
002DB2r 2  20 rr rr             JSR     emit_byte       ; emit offset lo
002DB5r 2  A5 rr                LDA     scratch
002DB7r 2  20 rr rr             JSR     emit_byte       ; emit offset hi
002DBAr 2  60                   RTS
002DBBr 2               
002DBBr 2               emit_HALT:
002DBBr 2  A9 FF                LDA     #OP_HALT
002DBDr 2  4C rr rr             JMP     emit_byte
002DC0r 2               
