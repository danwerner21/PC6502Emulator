002234r 2  60                   RTS
002235r 2               
002235r 2               ; set_lit_add_value — A=value 0..15. ORs the matching bit into set_lit_mask.
002235r 2               set_lit_add_value:
002235r 2  AA                   TAX
002236r 2  A9 01                LDA     #1
002238r 2  85 rr                STA     tmp0
