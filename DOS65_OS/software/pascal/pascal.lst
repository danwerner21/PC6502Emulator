001EEDr 2               ; REAL / INTEGER coercion helpers
001EEDr 2               ; ---------------------------------------------------------------------------
001EEDr 2               
001EEDr 2               emit_promote_tos_int_to_real:
001EEDr 2  A9 64                LDA     #100
001EEFr 2  20 rr rr             JSR     emit_LDCI
001EF2r 2  4C rr rr             JMP     emit_MPI
001EF5r 2               
001EF5r 2               emit_promote_tos_real_to_int:
001EF5r 2  A9 64                LDA     #100
001EF7r 2  20 rr rr             JSR     emit_LDCI
001EFAr 2  4C rr rr             JMP     emit_DVI
001EFDr 2               
001EFDr 2               emit_promote_nos_int_to_real:
001EFDr 2  20 rr rr             JSR     emit_SWAP
001F00r 2  20 rr rr             JSR     emit_promote_tos_int_to_real
001F03r 2  4C rr rr             JMP     emit_SWAP
001F06r 2               
001F06r 2               emit_promote_nos_real_to_int:
001F06r 2  20 rr rr             JSR     emit_SWAP
001F09r 2  20 rr rr             JSR     emit_promote_tos_real_to_int
001F0Cr 2  4C rr rr             JMP     emit_SWAP
001F0Fr 2               
001F0Fr 2               ; coerce_expr_to_target_type — A=target TY_*, expr_type=current TOS type.
001F0Fr 2               ; Only INTEGER<->REAL coercions are performed; other combinations are left as-is.
001F0Fr 2               coerce_expr_to_target_type:
001F0Fr 2  AA                   TAX
001F10r 2  E0 0A                CPX     #TY_REAL
001F12r 2  F0 05                BEQ     @cett_real
001F14r 2  E0 01                CPX     #TY_INT
001F16r 2  F0 0F                BEQ     @cett_int
001F18r 2  60                   RTS
001F19r 2               @cett_real:
001F19r 2  A5 rr                LDA     expr_type
001F1Br 2  C9 01                CMP     #TY_INT
001F1Dr 2  D0 07                BNE     @cett_done
001F1Fr 2  20 rr rr             JSR     emit_promote_tos_int_to_real
001F22r 2  A9 0A                LDA     #TY_REAL
001F24r 2  85 rr                STA     expr_type
001F26r 2               @cett_done:
001F26r 2  60                   RTS
001F27r 2               @cett_int:
001F27r 2  A5 rr                LDA     expr_type
001F29r 2  C9 0A                CMP     #TY_REAL
001F2Br 2  D0 07                BNE     @cett_done2
001F2Dr 2  20 rr rr             JSR     emit_promote_tos_real_to_int
001F30r 2  A9 01                LDA     #TY_INT
001F32r 2  85 rr                STA     expr_type
001F34r 2               @cett_done2:
001F34r 2  60                   RTS
001F35r 2               
001F35r 2               ; coerce_binary_numeric_types — A=lhs type, expr_type=rhs type.
001F35r 2               ; Promotes one INTEGER operand to REAL when the other side is REAL.
001F35r 2               ; Returns A=result type (TY_INT or TY_REAL).
001F35r 2               coerce_binary_numeric_types:
001F35r 2  C9 0A                CMP     #TY_REAL
001F37r 2  F0 09                BEQ     @cbnt_lhs_real
001F39r 2  A5 rr                LDA     expr_type
001F3Br 2  C9 0A                CMP     #TY_REAL
001F3Dr 2  F0 0F                BEQ     @cbnt_lhs_int_rhs_real
001F3Fr 2  A9 01                LDA     #TY_INT
001F41r 2  60                   RTS
001F42r 2               @cbnt_lhs_real:
001F42r 2  A5 rr                LDA     expr_type
001F44r 2  C9 01                CMP     #TY_INT
001F46r 2  D0 03                BNE     @cbnt_real_done
001F48r 2  20 rr rr             JSR     emit_promote_tos_int_to_real
001F4Br 2               @cbnt_real_done:
001F4Br 2  A9 0A                LDA     #TY_REAL
001F4Dr 2  60                   RTS
001F4Er 2               @cbnt_lhs_int_rhs_real:
001F4Er 2  20 rr rr             JSR     emit_promote_nos_int_to_real
001F51r 2  A9 0A                LDA     #TY_REAL
001F53r 2  60                   RTS
001F54r 2               
001F54r 2               ; coerce_binary_to_real — A=lhs type, expr_type=rhs type.
001F54r 2               ; Ensures both operands are REAL and returns A=TY_REAL.
001F54r 2               coerce_binary_to_real:
001F54r 2  C9 0A                CMP     #TY_REAL
001F56r 2  F0 0F                BEQ     @cbtr_lhs_real
001F58r 2  A5 rr                LDA     expr_type
001F5Ar 2  C9 0A                CMP     #TY_REAL
001F5Cr 2  F0 15                BEQ     @cbtr_lhs_int_rhs_real
001F5Er 2  20 rr rr             JSR     emit_promote_tos_int_to_real
001F61r 2  20 rr rr             JSR     emit_promote_nos_int_to_real
001F64r 2  A9 0A                LDA     #TY_REAL
001F66r 2  60                   RTS
001F67r 2               @cbtr_lhs_real:
