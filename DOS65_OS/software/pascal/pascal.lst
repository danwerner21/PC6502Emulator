002C3Br 2  85 rr                STA     tmp2+1
002C3Dr 2  18                   CLC
002C3Er 2  A5 rr                LDA     cg_globals
002C40r 2  69 A8                ADC     #FILE_STRUCT_SZ
002C42r 2  85 rr                STA     cg_globals
002C44r 2  A5 rr                LDA     cg_globals+1
002C46r 2  69 00                ADC     #0
002C48r 2  85 rr                STA     cg_globals+1
002C4Ar 2  60                   RTS
002C4Br 2               
