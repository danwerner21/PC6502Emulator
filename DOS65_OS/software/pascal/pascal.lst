002420r 2  D0 11                BNE     @bi5_no
002422r 2  AD rr rr             LDA     ident_buf+4
002425r 2  C9 53                CMP     #'S'
002427r 2  D0 0A                BNE     @bi5_no
002429r 2  AD rr rr             LDA     ident_buf+5
00242Cr 2  C9 45                CMP     #'E'
00242Er 2  D0 03                BNE     @bi5_no
002430r 2  4C rr rr             JMP     parse_builtin_false
002433r 2               @bi5_no:
002433r 2  4C rr rr             JMP     @do_lookup
002436r 2               @bi_chk3:
