002446r 2  C9 4F                CMP     #'O'
002448r 2  D0 67                BNE     @do_lookup
00244Ar 2  AD rr rr             LDA     ident_buf+3
00244Dr 2  C9 46                CMP     #'F'
00244Fr 2  D0 60                BNE     @do_lookup
002451r 2  4C rr rr             JMP     parse_builtin_eof
002454r 2               @bi_chk_pos:
002454r 2  AD rr rr             LDA     ident_buf+2
002457r 2  C9 4F                CMP     #'O'
002459r 2  D0 56                BNE     @do_lookup
