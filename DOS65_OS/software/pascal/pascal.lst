0021E3r 2  A5 rr                LDA     tok_type
0021E5r 2  C9 22                CMP     #TOK_DOT
0021E7r 2  D0 0E                BNE     @pwfl_done_chain
0021E9r 2  AD rr rr             LDA     field_chain_first
0021ECr 2  8D rr rr             STA     fcall_vmask
