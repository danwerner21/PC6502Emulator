001624r 2               
001624r 2               ; ---------------------------------------------------------------------------
001624r 2               ; parse_with_stmt — WITH record_expr { , record_expr } DO statement
001624r 2               ; Each selector gets a hidden global word holding the runtime record base
001624r 2               ; address. The compile-time WITH context stack records the matching field
001624r 2               ; table span so unqualified identifiers can resolve as fields.
001624r 2               ; ---------------------------------------------------------------------------
001624r 2               parse_with_stmt:
001624r 2  AD rr rr             LDA     with_depth
001627r 2  48                   PHA                             ; restore point after the body
001628r 2  20 rr rr             JSR     next_token              ; consume WITH
00162Br 2               @pws_item:
00162Br 2  20 rr rr             JSR     parse_expression
00162Er 2  A5 rr                LDA     expr_type
001630r 2  C9 06                CMP     #TY_RECORD
001632r 2  F0 10                BEQ     @pws_record
001634r 2  A9 rr                LDA     #<err_type
001636r 2  85 rr                STA     tmp0
001638r 2  A9 rr                LDA     #>err_type
00163Ar 2  85 rr                STA     tmp0+1
00163Cr 2  20 rr rr             JSR     compile_error
00163Fr 2  20 rr rr             JSR     emit_POP                ; discard non-record expression result
001642r 2  80 43                BRA     @pws_after_item
001644r 2               @pws_record:
001644r 2  A9 02                LDA     #2
001646r 2  20 rr rr             JSR     codegen_alloc_global    ; tmp2 = hidden word for base addr
001649r 2  A5 rr                LDA     tmp2
00164Br 2  48                   PHA
00164Cr 2  A5 rr                LDA     tmp2+1
00164Er 2  48                   PHA
00164Fr 2  A5 rr                LDA     tmp2+1
001651r 2  85 rr                STA     scratch
001653r 2  A5 rr                LDA     tmp2
001655r 2  20 rr rr             JSR     emit_STG                ; save selector address
001658r 2  AE rr rr             LDX     with_depth
00165Br 2  E0 08                CPX     #WITH_DEPTHS
00165Dr 2  90 0D                BCC     @pws_push
00165Fr 2  A9 rr                LDA     #<err_too_many
001661r 2  85 rr                STA     tmp0
001663r 2  A9 rr                LDA     #>err_too_many
001665r 2  85 rr                STA     tmp0+1
001667r 2  20 rr rr             JSR     compile_error
00166Ar 2  80 19                BRA     @pws_discard_hidden
00166Cr 2               @pws_push:
00166Cr 2  68                   PLA
00166Dr 2  9D rr rr             STA     with_base_hi,x
001670r 2  68                   PLA
001671r 2  9D rr rr             STA     with_base_lo,x
001674r 2  AD rr rr             LDA     expr_record_first
001677r 2  9D rr rr             STA     with_first_field,x
00167Ar 2  AD rr rr             LDA     expr_record_count
00167Dr 2  9D rr rr             STA     with_field_count,x
001680r 2  EE rr rr             INC     with_depth
001683r 2  80 02                BRA     @pws_after_item
001685r 2               @pws_discard_hidden:
001685r 2  68                   PLA
001686r 2  68                   PLA
001687r 2               @pws_after_item:
001687r 2  A5 rr                LDA     tok_type
001689r 2  C9 1F                CMP     #TOK_COMMA
00168Br 2  D0 05                BNE     @pws_need_do
00168Dr 2  20 rr rr             JSR     next_token
001690r 2  80 99                BRA     @pws_item
001692r 2               @pws_need_do:
001692r 2  A5 rr                LDA     tok_type
001694r 2  C9 46                CMP     #TOK_DO
001696r 2  F0 0D                BEQ     @pws_do
001698r 2  A9 rr                LDA     #<err_expected_do
00169Ar 2  85 rr                STA     tmp0
00169Cr 2  A9 rr                LDA     #>err_expected_do
00169Er 2  85 rr                STA     tmp0+1
0016A0r 2  20 rr rr             JSR     compile_error
0016A3r 2  80 03                BRA     @pws_body
0016A5r 2               @pws_do:
0016A5r 2  20 rr rr             JSR     next_token              ; consume DO
0016A8r 2               @pws_body:
0016A8r 2  20 rr rr             JSR     parse_statement
0016ABr 2  68                   PLA
0016ACr 2  8D rr rr             STA     with_depth
0016AFr 2  60                   RTS
0016B0r 2               
0016B0r 2               ; ---------------------------------------------------------------------------
0016B0r 2               ; parse_with_field_assign — current token is the field IDENT already matched
0016B0r 2               ; by with_lookup_field. Handles scalar fields, pointer-field dereference, and
0016B0r 2               ; chained nested-record assignments such as `WITH R DO A.X := 1`.
0016B0r 2               ; ---------------------------------------------------------------------------
0016B0r 2               parse_with_field_assign:
0016B0r 2  20 rr rr             JSR     next_token              ; consume field name
0016B3r 2  20 rr rr             JSR     emit_with_field_base    ; push &field / &subrecord
0016B6r 2  AD rr rr             LDA     with_lookup_type
0016B9r 2  C9 06                CMP     #TY_RECORD
0016BBr 2  F0 30                BEQ     @pwfa_record
0016BDr 2  C9 07                CMP     #TY_PTR
0016BFr 2  D0 1C                BNE     @pwfa_scalar
0016C1r 2  A5 rr                LDA     tok_type
0016C3r 2  C9 24                CMP     #TOK_CARET
0016C5r 2  D0 16                BNE     @pwfa_scalar
0016C7r 2  20 rr rr             JSR     emit_LDIND              ; load pointer value from field cell
0016CAr 2  20 rr rr             JSR     next_token              ; consume '^'
0016CDr 2  A5 rr                LDA     tok_type
0016CFr 2  C9 1A                CMP     #TOK_ASSIGN
0016D1r 2  D0 03                BNE     :+
0016D3r 2  20 rr rr             JSR     next_token
0016D6r 2  20 rr rr     :       JSR     parse_expression
0016D9r 2  20 rr rr             JSR     emit_STIND
0016DCr 2  60                   RTS
0016DDr 2               @pwfa_scalar:
0016DDr 2  A5 rr                LDA     tok_type
0016DFr 2  C9 1A                CMP     #TOK_ASSIGN
0016E1r 2  D0 03                BNE     :+
0016E3r 2  20 rr rr             JSR     next_token
0016E6r 2  20 rr rr     :       JSR     parse_expression
0016E9r 2  20 rr rr             JSR     emit_STIND
0016ECr 2  60                   RTS
0016EDr 2               @pwfa_record:
0016EDr 2  A5 rr                LDA     tok_type
0016EFr 2  C9 22                CMP     #TOK_DOT
0016F1r 2  F0 0F                BEQ     @pwfa_chain_prep
0016F3r 2  A9 rr                LDA     #<err_type
0016F5r 2  85 rr                STA     tmp0
0016F7r 2  A9 rr                LDA     #>err_type
0016F9r 2  85 rr                STA     tmp0+1
0016FBr 2  20 rr rr             JSR     compile_error
0016FEr 2  20 rr rr             JSR     emit_POP                ; discard the subrecord address
001701r 2  60                   RTS
001702r 2               @pwfa_chain_prep:
001702r 2  AD rr rr             LDA     with_lookup_first
001705r 2  8D rr rr             STA     fcall_vmask
001708r 2  AD rr rr             LDA     with_lookup_count
00170Br 2  8D rr rr             STA     fcall_lsize
00170Er 2               @pwfa_chain:
00170Er 2  A5 rr                LDA     tok_type
001710r 2  C9 22                CMP     #TOK_DOT
001712r 2  D0 03                BNE     :+
001714r 2  20 rr rr             JSR     next_token
001717r 2               :
001717r 2  AD rr rr             LDA     fcall_vmask
00171Ar 2  AE rr rr             LDX     fcall_lsize
00171Dr 2  20 rr rr             JSR     field_lookup_in_record
001720r 2  90 4B                BCC     @pwfa_nf
001722r 2  48                   PHA
001723r 2  8A                   TXA
001724r 2  8D rr rr             STA     field_chain_type
001727r 2  A5 rr                LDA     tmp3
001729r 2  AA                   TAX
00172Ar 2  BD rr rr             LDA     field_nested_first,x
00172Dr 2  8D rr rr             STA     field_chain_first
001730r 2  BD rr rr             LDA     field_nested_count,x
001733r 2  8D rr rr             STA     field_chain_count
001736r 2  68                   PLA
001737r 2  F0 06                BEQ     @pwfa_no_off
001739r 2  20 rr rr             JSR     emit_LDCI
00173Cr 2  20 rr rr             JSR     emit_ADI
00173Fr 2               @pwfa_no_off:
00173Fr 2  20 rr rr             JSR     next_token              ; consume nested field name
001742r 2  AD rr rr             LDA     field_chain_type
001745r 2  C9 06                CMP     #TY_RECORD
001747r 2  D0 14                BNE     @pwfa_leaf
001749r 2  A5 rr                LDA     tok_type
00174Br 2  C9 22                CMP     #TOK_DOT
00174Dr 2  D0 0E                BNE     @pwfa_leaf
00174Fr 2  AD rr rr             LDA     field_chain_first
001752r 2  8D rr rr             STA     fcall_vmask
001755r 2  AD rr rr             LDA     field_chain_count
001758r 2  8D rr rr             STA     fcall_lsize
00175Br 2  80 B1                BRA     @pwfa_chain
00175Dr 2               @pwfa_leaf:
00175Dr 2  A5 rr                LDA     tok_type
00175Fr 2  C9 1A                CMP     #TOK_ASSIGN
001761r 2  D0 03                BNE     :+
001763r 2  20 rr rr             JSR     next_token
001766r 2  20 rr rr     :       JSR     parse_expression
001769r 2  20 rr rr             JSR     emit_STIND
00176Cr 2  60                   RTS
00176Dr 2               @pwfa_nf:
00176Dr 2  A9 rr                LDA     #<err_undef
00176Fr 2  85 rr                STA     tmp0
001771r 2  A9 rr                LDA     #>err_undef
001773r 2  85 rr                STA     tmp0+1
001775r 2  20 rr rr             JSR     compile_error
001778r 2  60                   RTS
001779r 2               
001779r 2               ; ---------------------------------------------------------------------------
001779r 2               ; parse_assign_or_call — identifier already consumed by caller (in ident_buf)
001779r 2               ; If next is ':=' → assignment
001779r 2               ; If next is '(' → procedure call
001779r 2               ; If identifier is WRITE/WRITELN → built-in I/O
001779r 2               ; ---------------------------------------------------------------------------
001779r 2               parse_assign_or_call:
001779r 2               ; Dispatch built-in I/O procedures by length+initial letter.  RECORD/REPEAT
001779r 2               ; are reserved keywords so they never reach this dispatch as identifiers.
001779r 2               ;   len 3 : NEW
001779r 2               ;   len 4 : READ
001779r 2               ;   len 5 : WRITE  | RESET  | CLOSE
001779r 2               ;   len 6 : READLN | ASSIGN | APPEND
001779r 2               ;   len 7 : WRITELN| REWRITE | DISPOSE
001779r 2  AD rr rr             LDA     ident_buf       ; length
00177Cr 2  C9 03                CMP     #3
00177Er 2  F0 16                BEQ     @chk_new
001780r 2  C9 04                CMP     #4
001782r 2  D0 03                bne     :+
001784r 2  4C rr rr             jmp     @chk_read
001787r 2               :
001787r 2  C9 05                CMP     #5
001789r 2  F0 2C                BEQ     @chk_len5
00178Br 2  C9 06                CMP     #6
00178Dr 2  F0 40                BEQ     @chk_len6
00178Fr 2  C9 07                CMP     #7
001791r 2  F0 5B                BEQ     @chk_len7
001793r 2  4C rr rr             JMP     @lookup_sym
001796r 2               
001796r 2               @chk_new:
001796r 2               ; "NEW" (3)
001796r 2  AD rr rr             LDA     ident_buf+1
001799r 2  C9 4E                CMP     #'N'
00179Br 2  F0 03                beq     :+
00179Dr 2  4C rr rr             JMP     @lookup_sym
0017A0r 2               :
0017A0r 2  AD rr rr             LDA     ident_buf+2
0017A3r 2  C9 45                CMP     #'E'
0017A5r 2  F0 03                beq     :+
0017A7r 2  4C rr rr             JMP     @lookup_sym
0017AAr 2               :
0017AAr 2  AD rr rr             LDA     ident_buf+3
0017ADr 2  C9 57                CMP     #'W'
0017AFr 2  F0 03                BEQ     :+
0017B1r 2  4C rr rr             JMP     @lookup_sym
0017B4r 2               :
0017B4r 2  4C rr rr             JMP     parse_builtin_new
0017B7r 2               
0017B7r 2               @chk_len5:
0017B7r 2  AD rr rr             LDA     ident_buf+1
0017BAr 2  C9 57                CMP     #'W'
0017BCr 2  F0 5A                BEQ     @chk_write
0017BEr 2  C9 52                CMP     #'R'
0017C0r 2  D0 03                BNE     :+
0017C2r 2  4C rr rr             JMP     @chk_reset
0017C5r 2               :
0017C5r 2  C9 43                CMP     #'C'
0017C7r 2  D0 03                BNE     :+
0017C9r 2  4C rr rr             JMP     @chk_close
0017CCr 2               :
0017CCr 2  4C rr rr             JMP     @lookup_sym
0017CFr 2               
0017CFr 2               @chk_len6:
0017CFr 2  AD rr rr             LDA     ident_buf+1
0017D2r 2  C9 52                CMP     #'R'
0017D4r 2  F0 7B                BEQ     @chk_readln
0017D6r 2  C9 41                CMP     #'A'
0017D8r 2  F0 03                BEQ     @chk_len6_a
0017DAr 2  4C rr rr             JMP     @lookup_sym
0017DDr 2               @chk_len6_a:
0017DDr 2  AD rr rr             LDA     ident_buf+2
0017E0r 2  C9 50                CMP     #'P'
0017E2r 2  D0 03                BNE     :+
0017E4r 2  4C rr rr             JMP     @chk_append
0017E7r 2               :
0017E7r 2  C9 53                CMP     #'S'
0017E9r 2  F0 7A                BEQ     @chk_assign
0017EBr 2  4C rr rr             JMP     @lookup_sym
0017EEr 2               
0017EEr 2               @chk_len7:
0017EEr 2  AD rr rr             LDA     ident_buf+1
0017F1r 2  C9 57                CMP     #'W'
0017F3r 2  F0 31                BEQ     @chk_writeln
0017F5r 2  C9 52                CMP     #'R'
0017F7r 2  F0 75                BEQ     @chk_rewrite
0017F9r 2  C9 44                CMP     #'D'
0017FBr 2  F0 03                BEQ     @chk_dispose
0017FDr 2  4C rr rr             JMP     @lookup_sym
001800r 2               
001800r 2               @chk_dispose:
001800r 2               ; "DISPOSE" (7) — verify I,S,P,O,S,E
001800r 2  AD rr rr             LDA     ident_buf+2
001803r 2  C9 49                CMP     #'I'
001805r 2  D0 6D                BNE     @lookup_sym_jmp
001807r 2  AD rr rr             LDA     ident_buf+3
00180Ar 2  C9 53                CMP     #'S'
00180Cr 2  D0 66                BNE     @lookup_sym_jmp
00180Er 2  AD rr rr             LDA     ident_buf+4
001811r 2  C9 50                CMP     #'P'
001813r 2  D0 5F                BNE     @lookup_sym_jmp
001815r 2  4C rr rr             JMP     parse_builtin_dispose
001818r 2               
001818r 2               @chk_write:
001818r 2               ; "WRITE" (5)
001818r 2  20 rr rr             JSR     next_token
00181Br 2  20 rr rr             JSR     parse_write_args        ; X=0 console, X=1 file (file ptr left)
00181Er 2  E0 00                CPX     #0
001820r 2  F0 03                BEQ     @w_done
001822r 2  20 rr rr             JSR     emit_POP                ; discard leftover file ptr
001825r 2               @w_done:
001825r 2  60                   RTS
001826r 2               
001826r 2               @chk_writeln:
001826r 2               ; "WRITELN" (7) — first ident_buf char already known 'W'
001826r 2  20 rr rr             JSR     next_token
001829r 2  A5 rr                LDA     tok_type
00182Br 2  C9 1B                CMP     #TOK_LPAREN
00182Dr 2  D0 0A                BNE     @just_nl
00182Fr 2  20 rr rr             JSR     parse_write_args
001832r 2  E0 00                CPX     #0
001834r 2  F0 03                BEQ     @just_nl
001836r 2  4C rr rr             JMP     emit_FWLN               ; file newline; consumes file ptr
001839r 2               @just_nl:
001839r 2  4C rr rr             JMP     emit_WRITLN
00183Cr 2               
00183Cr 2               @chk_read:
00183Cr 2               ; "READ" (4)
00183Cr 2  AD rr rr             LDA     ident_buf+1
00183Fr 2  C9 52                CMP     #'R'
001841r 2  D0 31                BNE     @lookup_sym_jmp
001843r 2  20 rr rr             JSR     next_token
001846r 2  20 rr rr             JSR     parse_read_args
001849r 2  E0 00                CPX     #0
00184Br 2  F0 03                BEQ     @r_done
00184Dr 2  20 rr rr             JSR     emit_POP                ; discard leftover file ptr
001850r 2               @r_done:
001850r 2  60                   RTS
001851r 2               
001851r 2               @chk_readln:
001851r 2               ; "READLN" (6).  Console: read each var.  File: read each var, then skip EOL.
001851r 2  20 rr rr             JSR     next_token
001854r 2  A5 rr                LDA     tok_type
001856r 2  C9 1B                CMP     #TOK_LPAREN
001858r 2  D0 0A                BNE     @rd_done
00185Ar 2  20 rr rr             JSR     parse_read_args
00185Dr 2  E0 00                CPX     #0
00185Fr 2  F0 03                BEQ     @rd_done
001861r 2  20 rr rr             JSR     emit_FRDLN              ; consumes file ptr, skips to EOL
001864r 2               @rd_done:
001864r 2  60                   RTS
001865r 2               
001865r 2               @chk_assign:
001865r 2               ; "ASSIGN" (6)
001865r 2  4C rr rr             JMP     parse_builtin_assign
001868r 2               @chk_append:
001868r 2               ; "APPEND" (6)
001868r 2  4C rr rr             JMP     parse_builtin_append
00186Br 2               @chk_reset:
00186Br 2               ; "RESET" (5)
00186Br 2  4C rr rr             JMP     parse_builtin_reset
00186Er 2               @chk_rewrite:
00186Er 2               ; "REWRITE" (7)
00186Er 2  4C rr rr             JMP     parse_builtin_rewrite
001871r 2               @chk_close:
001871r 2               ; "CLOSE" (5)
001871r 2  4C rr rr             JMP     parse_builtin_close
001874r 2               
001874r 2               @lookup_sym_jmp:
001874r 2  4C rr rr             JMP     @lookup_sym
001877r 2               
001877r 2               @lookup_sym:
001877r 2               ; WITH fields behave like an injected inner scope. Check them before the
001877r 2               ; real symbol table so `WITH R DO X := 1` binds `X` to the record field.
001877r 2  20 rr rr             JSR     with_lookup_field
00187Ar 2  90 04                BCC     @lookup_symtab
00187Cr 2  20 rr rr             JSR     parse_with_field_assign
00187Fr 2  60                   RTS
001880r 2               
001880r 2               @lookup_symtab:
001880r 2               ; look up identifier in symbol table
001880r 2  20 rr rr             JSR     symtab_find
001883r 2  B0 0F                BCS     @found_sym
001885r 2               ; undefined — error
001885r 2  A9 rr                LDA     #<err_undef
001887r 2  85 rr                STA     tmp0
001889r 2  A9 rr                LDA     #>err_undef
00188Br 2  85 rr                STA     tmp0+1
00188Dr 2  20 rr rr             JSR     compile_error
001890r 2               ; skip to semicolon / end
001890r 2  20 rr rr             JSR     next_token
001893r 2  60                   RTS
001894r 2               
001894r 2               @found_sym:
001894r 2               ; tmp3 = symbol entry pointer. Snapshot the fields we need
001894r 2               ; before any next_token / parse_expression call clobbers tmp3.
001894r 2  A0 10                LDY     #16
001896r 2  B1 rr                LDA     (tmp3),y
001898r 2  8D rr rr             STA     sym_save_kind
00189Br 2  A0 11                LDY     #17
00189Dr 2  B1 rr                LDA     (tmp3),y
00189Fr 2  8D rr rr             STA     sym_save_type
0018A2r 2  A0 14                LDY     #20
0018A4r 2  B1 rr                LDA     (tmp3),y
0018A6r 2  8D rr rr             STA     sym_save_scope
0018A9r 2  A0 12                LDY     #18
0018ABr 2  B1 rr                LDA     (tmp3),y
0018ADr 2  8D rr rr             STA     sym_save_off
0018B0r 2  A0 13                LDY     #19
0018B2r 2  B1 rr                LDA     (tmp3),y
0018B4r 2  8D rr rr             STA     sym_save_off+1
0018B7r 2  A0 15                LDY     #21
0018B9r 2  B1 rr                LDA     (tmp3),y
0018BBr 2  8D rr rr             STA     sym_save_pcount
0018BEr 2  A0 16                LDY     #22
0018C0r 2  B1 rr                LDA     (tmp3),y
0018C2r 2  8D rr rr             STA     sym_save_vmask
0018C5r 2  A0 17                LDY     #23
0018C7r 2  B1 rr                LDA     (tmp3),y
0018C9r 2  8D rr rr             STA     sym_save_lsize
0018CCr 2  A0 18                LDY     #24
0018CEr 2  A2 00                LDX     #0
0018D0r 2               @copy_ptypes:
0018D0r 2  B1 rr                LDA     (tmp3),y
0018D2r 2  9D rr rr             STA     sym_param_types,x
0018D5r 2  C8                   INY
0018D6r 2  E8                   INX
0018D7r 2  E0 08                CPX     #8
0018D9r 2  90 F5                BCC     @copy_ptypes
0018DBr 2  AD rr rr             LDA     sym_save_kind
0018DEr 2  C9 01                CMP     #SYM_VAR
0018E0r 2  F0 48                BEQ     @do_assign
0018E2r 2  C9 03                CMP     #SYM_PROC
0018E4r 2  D0 03                BNE     :+
