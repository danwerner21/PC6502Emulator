000000r 1               ; pascal.asm — Pascal/65 Compiler for DOS/65
000000r 1               ;
000000r 1               ; Usage: PASCAL <sourcename>
000000r 1               ;   Reads <sourcename>.PAS, writes <sourcename>.PCD
000000r 1               ;
000000r 1               ; Phase 1 entry point and top-level driver only.
000000r 1               ; Lexer, parser, symbol table, and code generator are in separate files
000000r 1               ; included at the bottom of this file.
000000r 1               
000000r 1               .PC02   ; enable 65C02 (bra/phx/plx) for write_pcd etc.
000000r 1                       ; lexer.asm also asserts this; included files
000000r 1                       ; pick it up after lexer.asm runs.
000000r 1               
000000r 1                       .include        "DEFINITIONS.ASM"
000000r 2               ; definitions.asm — constants, token codes, p-code opcodes, macros
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; DOS/65 system entry points
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               PEM_ENTRY       = $0103         ; JSR here; function # in X
000000r 2               WARM_BOOT       = $0100
000000r 2               DEFAULT_FCB     = $0107         ; DOS/65 dflfcb (parsed argument FCB)
000000r 2               DMA_BUF         = $0128         ; DOS/65 dflbuf (default DMA buffer)
000000r 2               
000000r 2               ; PEM function numbers
000000r 2               PEM_CONIN       = 1             ; console input with echo (blocking)
000000r 2               PEM_CONOUT      = 2             ; console output (A=char)
000000r 2               PEM_DIRCON      = 6             ; direct console I/O (BLOCKING — use fn 11 first)
000000r 2               PEM_CONSTAT     = 11            ; console status (non-blocking)
000000r 2               PEM_OPEN        = 15
000000r 2               PEM_CLOSE       = 16
000000r 2               PEM_SEARCH      = 17
000000r 2               PEM_DELETE      = 19
000000r 2               PEM_READ        = 20
000000r 2               PEM_WRITE       = 21
000000r 2               PEM_MAKE        = 22
000000r 2               PEM_SETDMA      = 26            ; set DMA buffer address (A=lo, Y=hi)
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; P-code opcodes
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 2               ; --- Constants ---
000000r 2               OP_LDCI         = $00           ; push sign-extended byte constant
000000r 2               OP_LDCW         = $01           ; push word constant (lo, hi)
000000r 2               OP_LDCC         = $02           ; push char constant
000000r 2               OP_LDCB         = $03           ; push boolean constant (0/1)
000000r 2               OP_LDCS         = $04           ; push string constant (len + bytes)
000000r 2               OP_LDCN         = $05           ; push NIL
000000r 2               
000000r 2               ; --- Local variable access ---
000000r 2               OP_LDL          = $10           ; push 16-bit local (byte offset from MP+8)
000000r 2               OP_STL          = $11           ; pop into 16-bit local
000000r 2               OP_LDA_L        = $12           ; push address of local
000000r 2               OP_LDB_L        = $13           ; push byte/char/bool local
000000r 2               OP_STB_L        = $14           ; pop byte into local
000000r 2               
000000r 2               ; --- Global variable access ---
000000r 2               OP_LDG          = $18           ; push 16-bit global (word offset from BASE)
000000r 2               OP_STG          = $19           ; pop into 16-bit global
000000r 2               OP_LDA_G        = $1A           ; push address of global
000000r 2               OP_LDB_G        = $1B           ; push byte global
000000r 2               OP_STB_G        = $1C           ; pop byte into global
000000r 2               
000000r 2               ; --- Indirect / array ---
000000r 2               OP_LDIND        = $20           ; TOS=addr → push word at addr
000000r 2               OP_STIND        = $21           ; NOS=addr, TOS=val → store
000000r 2               OP_LDB_IND      = $22           ; TOS=addr → push byte at addr
000000r 2               OP_STB_IND      = $23           ; NOS=addr, TOS=val → store byte
000000r 2               OP_INDEX        = $24           ; array index: addr=NOS+TOS*elemsize (word follows)
000000r 2               
000000r 2               ; --- Integer arithmetic ---
000000r 2               OP_ADI          = $30
000000r 2               OP_SBI          = $31
000000r 2               OP_MPI          = $32
000000r 2               OP_DVI          = $33
000000r 2               OP_MOD          = $34
000000r 2               OP_NGI          = $35           ; negate
000000r 2               OP_ABI          = $36           ; absolute value
000000r 2               OP_SQI          = $37           ; square
000000r 2               
000000r 2               ; --- Logical / bitwise ---
000000r 2               OP_LAND         = $38
000000r 2               OP_LOR          = $39
000000r 2               OP_LNOT         = $3A           ; logical NOT ($0000 ↔ $FFFF)
000000r 2               OP_BNOT         = $3B           ; bitwise complement
000000r 2               
000000r 2               ; --- Comparison (push $FFFF=true, $0000=false) ---
000000r 2               OP_EQUI         = $40
000000r 2               OP_NEQI         = $41
000000r 2               OP_LESI         = $42
000000r 2               OP_LEQI         = $43
000000r 2               OP_GTRI         = $44
000000r 2               OP_GEQI         = $45
000000r 2               OP_EQUB         = $46           ; byte equality
000000r 2               OP_EQUS         = $47           ; string equality
000000r 2               
000000r 2               ; --- Control flow ---
000000r 2               OP_UJP          = $50           ; unconditional jump (signed word offset)
000000r 2               OP_FJP          = $51           ; jump if false (pop TOS)
000000r 2               OP_TJP          = $52           ; jump if true  (pop TOS)
000000r 2               OP_IXPJP        = $53           ; case jump table
000000r 2               
000000r 2               ; --- Procedure/function calls ---
000000r 2               OP_CALL         = $60           ; call (signed word offset from current IPC)
000000r 2               OP_CALI         = $61           ; call absolute address (word)
000000r 2               OP_RET          = $62           ; return from procedure
000000r 2               OP_RETF         = $63           ; return from function (leave result on stack)
000000r 2               OP_MRKSTK       = $64           ; set up activation record (byte: local size)
000000r 2               OP_DEPSTK       = $65           ; tear down activation record
000000r 2               OP_STR          = $66           ; pop word, store at MP+AR_RET_VAL (function result)
000000r 2               OP_MRKA         = $67           ; mark+gather: bytes pcount, lsize_extra.
000000r 2                                               ; pcount values on TOS become local slots 0..pcount-1
000000r 2                                               ; in the new frame; lsize_extra reserves body-local space.
000000r 2               
000000r 2               ; --- Heap ---
000000r 2               OP_NEW          = $70           ; allocate (word size follows); push pointer
000000r 2               OP_DISP         = $71           ; free pointer on TOS
000000r 2               
000000r 2               ; --- I/O ---
000000r 2               OP_WRITI        = $80           ; write integer
000000r 2               OP_WRITC        = $81           ; write character
000000r 2               OP_WRITB        = $82           ; write boolean
000000r 2               OP_WRITS        = $83           ; write string
000000r 2               OP_WRITLN       = $84           ; write newline
000000r 2               OP_READI        = $85           ; read integer
000000r 2               OP_READC        = $86           ; read character
000000r 2               OP_READS        = $87           ; read string
000000r 2               OP_WRITR        = $88           ; write real (signed fixed-point, scale 100)
000000r 2               OP_READR        = $89           ; read real  (signed fixed-point, scale 100)
000000r 2               
000000r 2               ; --- Stack manipulation ---
000000r 2               OP_DUP          = $90
000000r 2               OP_POP          = $91
000000r 2               OP_SWAP         = $92
000000r 2               OP_MOVS         = $93           ; copy n bytes (byte count follows)
000000r 2               
000000r 2               ; --- String built-ins ---
000000r 2               OP_LEN          = $A0           ; TOS=strptr -> TOS=length (int)
000000r 2               OP_POS          = $A1           ; NOS=substr, TOS=str -> TOS=1-based pos (0=not found)
000000r 2               OP_COPY         = $A2           ; NNOS=str, NOS=index, TOS=count -> TOS=result strptr
000000r 2               OP_CONCAT       = $A3           ; NOS=s1, TOS=s2 -> TOS=result strptr
000000r 2               OP_INSET        = $A4           ; NOS=elem, TOS=setmask -> TOS=membership bool
000000r 2               OP_MPR          = $A5           ; real multiply (signed fixed-point, scale 100)
000000r 2               OP_DVR          = $A6           ; real divide   (signed fixed-point, scale 100)
000000r 2               
000000r 2               ; --- TEXT file I/O ---
000000r 2               ; All file ops take a file-struct pointer (NOS / TOS).
000000r 2               OP_FASSGN       = $B0           ; NOS=fileptr, TOS=strptr (filename) -> set FCB
000000r 2               OP_FRESET       = $B1           ; TOS=fileptr -> open existing for reading
000000r 2               OP_FREWRT       = $B2           ; TOS=fileptr -> create/truncate for writing
000000r 2               OP_FCLOSE       = $B3           ; TOS=fileptr -> flush and close
000000r 2               OP_FWRC         = $B4           ; NOS=fileptr, TOS=char -> append char
000000r 2               OP_FWRS         = $B5           ; NOS=fileptr, TOS=strptr -> append string
000000r 2               OP_FWRI         = $B6           ; NOS=fileptr, TOS=int   -> append decimal
000000r 2               OP_FWLN         = $B7           ; TOS=fileptr -> append CR+LF
000000r 2               OP_FRDC         = $B8           ; NOS=fileptr, TOS=charvar addr -> read char
000000r 2               OP_FRDI         = $B9           ; NOS=fileptr, TOS=intvar  addr -> read decimal int
000000r 2               OP_FRDLN        = $BA           ; TOS=fileptr -> skip remaining chars to end-of-line
000000r 2               OP_FEOF         = $BB           ; TOS=fileptr -> push EOF flag (0=false, $FFFF=true)
000000r 2               OP_FAPPND       = $BC           ; TOS=fileptr -> open/create for append at EOF
000000r 2               OP_FRDS         = $BD           ; NOS=fileptr, TOS=strvar addr -> read string to EOL
000000r 2               OP_FWRB         = $BE           ; NOS=fileptr, TOS=bool -> append "TRUE"/"FALSE"
000000r 2               OP_FEOLN        = $BF           ; TOS=fileptr -> push EOLN flag (true if at CR/LF/EOF)
000000r 2               OP_FWRR         = $C0           ; NOS=fileptr, TOS=real -> append fixed-point decimal
000000r 2               OP_FRDR         = $C1           ; NOS=fileptr, TOS=realvar addr -> read fixed-point decimal
000000r 2               
000000r 2               ; TEXT-file struct layout (168 bytes per variable)
000000r 2               F_FCB           = 0             ; 36 bytes
000000r 2               F_BUF           = 36            ; 128 bytes
000000r 2               F_MODE          = 164           ; 0=closed, 1=read, 2=write
000000r 2               F_POS           = 165           ; 0..127 buffer position
000000r 2               F_EOF           = 166           ; 0=more data, 1=EOF reached
000000r 2               F_SPARE         = 167
000000r 2               FILE_STRUCT_SZ  = 168
000000r 2               
000000r 2               F_MODE_CLOSED   = 0
000000r 2               F_MODE_READ     = 1
000000r 2               F_MODE_WRITE    = 2
000000r 2               
000000r 2               CTRL_Z          = $1A           ; CP/M text-file end-of-data marker
000000r 2               
000000r 2               ; --- Halt ---
000000r 2               OP_HALT         = $FF
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; .PCD file magic / version
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               PCD_MAGIC_0     = $50           ; 'P'
000000r 2               PCD_MAGIC_1     = $43           ; 'C'
000000r 2               PCD_VERSION     = $01
000000r 2               
000000r 2               ; PCD header offsets
000000r 2               PCD_MAGIC       = 0
000000r 2               PCD_VER         = 2
000000r 2               PCD_CODESZ      = 4             ; word: code section size
000000r 2               PCD_GLOBSZ      = 6             ; word: global data size
000000r 2               PCD_STRSZ       = 8             ; word: string pool size
000000r 2               PCD_ENTRY       = 10            ; word: entry point offset into code
000000r 2               PCD_HEADER_SZ   = 12
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Token codes (used by compiler lexer/parser)
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               TOK_EOF         = 0
000000r 2               TOK_IDENT       = 1
000000r 2               TOK_INT         = 2
000000r 2               TOK_STRING      = 3
000000r 2               TOK_CHAR        = 4
000000r 2               TOK_REAL        = 5
000000r 2               
000000r 2               ; Operators / punctuation
000000r 2               TOK_PLUS        = $10           ; +
000000r 2               TOK_MINUS       = $11           ; -
000000r 2               TOK_STAR        = $12           ; *
000000r 2               TOK_SLASH       = $13           ; /
000000r 2               TOK_EQ          = $14           ; =
000000r 2               TOK_NEQ         = $15           ; <>
000000r 2               TOK_LT          = $16           ; <
000000r 2               TOK_GT          = $17           ; >
000000r 2               TOK_LEQ         = $18           ; <=
000000r 2               TOK_GEQ         = $19           ; >=
000000r 2               TOK_ASSIGN      = $1A           ; :=
000000r 2               TOK_LPAREN      = $1B           ; (
000000r 2               TOK_RPAREN      = $1C           ; )
000000r 2               TOK_LBRACK      = $1D           ; [
000000r 2               TOK_RBRACK      = $1E           ; ]
000000r 2               TOK_COMMA       = $1F           ; ,
000000r 2               TOK_SEMICOLON   = $20           ; ;
000000r 2               TOK_COLON       = $21           ; :
000000r 2               TOK_DOT         = $22           ; .
000000r 2               TOK_DOTDOT      = $23           ; ..
000000r 2               TOK_CARET       = $24           ; ^
000000r 2               
000000r 2               ; Keywords
000000r 2               TOK_AND         = $40
000000r 2               TOK_ARRAY       = $41
000000r 2               TOK_BEGIN       = $42
000000r 2               TOK_CASE        = $43
000000r 2               TOK_CONST       = $44
000000r 2               TOK_DIV         = $45
000000r 2               TOK_DO          = $46
000000r 2               TOK_DOWNTO      = $47
000000r 2               TOK_ELSE        = $48
000000r 2               TOK_END         = $49
000000r 2               TOK_FOR         = $4A
000000r 2               TOK_FUNCTION    = $4B
000000r 2               TOK_IF          = $4C
000000r 2               TOK_IN          = $4D
000000r 2               TOK_MOD_KW      = $4E
000000r 2               TOK_NIL         = $4F
000000r 2               TOK_NOT         = $50
000000r 2               TOK_OF          = $51
000000r 2               TOK_OR          = $52
000000r 2               TOK_PROCEDURE   = $53
000000r 2               TOK_PROGRAM     = $54
000000r 2               TOK_RECORD      = $55
000000r 2               TOK_REPEAT      = $56
000000r 2               TOK_SET         = $57
000000r 2               TOK_THEN        = $58
000000r 2               TOK_TO          = $59
000000r 2               TOK_TYPE        = $5A
000000r 2               TOK_UNTIL       = $5B
000000r 2               TOK_VAR         = $5C
000000r 2               TOK_WHILE       = $5D
000000r 2               TOK_WITH        = $5E
000000r 2               TOK_IMPLEMENTATION = $5F
000000r 2               TOK_INTERFACE   = $60
000000r 2               TOK_UNIT        = $61
000000r 2               TOK_USES        = $62
000000r 2               
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; Useful macros
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 2               ; Call PEM with function number in X
000000r 2               .macro PEM func
000000r 2                       ldx     #func
000000r 2                       jsr     PEM_ENTRY
000000r 2               .endmacro
000000r 2               
000000r 1                       .include        "ZEROPAGE.ASM"
000000r 2               ; zeropage.asm — zero-page variable layout for PASCAL.COM and PRUN.COM
000000r 2               ;
000000r 2               ; Avoid $00-$2F (DOS/65 system), $32 (FARFUNCT), $39-$3A (DOS/65).
000000r 2               ; Safe range: $50-$EF
000000r 2               
000000r 2                       .segment        "ZEROPAGE"
000000r 2               
000000r 2  xx xx xx xx          .RES    $50             ; skip $00-$4F (DOS/65 system zero page)
000004r 2  xx xx xx xx  
000008r 2  xx xx xx xx  
000050r 2               
000050r 2               ; ---------------------------------------------------------------------------
000050r 2               ; P-machine registers — start at $50 as noted in comments below
000050r 2               ; ---------------------------------------------------------------------------
000050r 2               
000050r 2               pm_ipc:
000050r 2  xx xx                .RES    2               ; $50-$51  interpreter program counter
000052r 2               pm_sp:
000052r 2  xx xx                .RES    2               ; $52-$53  p-machine stack pointer
000054r 2               pm_mp:
000054r 2  xx xx                .RES    2               ; $54-$55  mark/frame pointer
000056r 2               pm_base:
000056r 2  xx xx                .RES    2               ; $56-$57  global variable base
000058r 2               pm_np:
000058r 2  xx xx                .RES    2               ; $58-$59  heap top (grows downward)
00005Ar 2               
00005Ar 2               ; General-purpose temporaries
00005Ar 2               tmp0:
00005Ar 2  xx xx                .RES    2               ; $5A-$5B
00005Cr 2               tmp1:
00005Cr 2  xx xx                .RES    2               ; $5C-$5D
00005Er 2               tmp2:
00005Er 2  xx xx                .RES    2               ; $5E-$5F
000060r 2               tmp3:
000060r 2  xx xx                .RES    2               ; $60-$61
000062r 2               
000062r 2               ; Byte-width scratch (often used by macros)
000062r 2               scratch:
000062r 2  xx                   .RES    1               ; $62
000063r 2               
000063r 2               ; ---------------------------------------------------------------------------
000063r 2               ; Compiler-specific zero-page variables (only used by PASCAL.COM)
000063r 2               ; ---------------------------------------------------------------------------
000063r 2               
000063r 2               ; Lexer state
000063r 2               lex_line:
000063r 2  xx xx                .RES    2               ; $63-$64  current source line number
000065r 2               lex_col:
000065r 2  xx                   .RES    1               ; $65      current column
000066r 2               lex_char:
000066r 2  xx                   .RES    1               ; $66      lookahead character
000067r 2               tok_type:
000067r 2  xx                   .RES    1               ; $67      current token type
000068r 2               tok_ival_lo:
000068r 2  xx                   .RES    1               ; $68      integer token value (lo)
000069r 2               tok_ival_hi:
000069r 2  xx                   .RES    1               ; $69      integer token value (hi)
00006Ar 2               
00006Ar 2               ; Parser / code generator state
00006Ar 2               cg_pc:
00006Ar 2  xx xx                .RES    2               ; $6A-$6B  current emit offset into code buffer
00006Cr 2               cg_globals:
00006Cr 2  xx xx                .RES    2               ; $6C-$6D  next available global variable offset
00006Er 2               scope_depth:
00006Er 2  xx                   .RES    1               ; $6E      current lexical nesting depth (0=global)
00006Fr 2               sym_chain:
00006Fr 2  xx xx                .RES    2               ; $6F-$70  pointer into symbol table chain
000071r 2               
000071r 2               ; FCB pointers (compiler I/O)
000071r 2               src_fcb:
000071r 2  xx xx                .RES    2               ; $71-$72  pointer to source FCB
000073r 2               out_fcb:
000073r 2  xx xx                .RES    2               ; $73-$74  pointer to output FCB
000075r 2               src_buf_pos:
000075r 2  xx                   .RES    1               ; $75      position within 128-byte sector buffer
000076r 2               src_buf_end:
000076r 2  xx                   .RES    1               ; $76      bytes valid in sector buffer
000077r 2               
000077r 2               ; FOR-loop scratch (parse_for; not nestable)
000077r 2               for_loop_top:
000077r 2  xx xx                .RES    2               ; $77-$78  cg_pc of loop test (back-jump target)
000079r 2               for_patch:
000079r 2  xx xx                .RES    2               ; $79-$7A  FJP exit patch address
00007Br 2               
00007Br 2               ; Result type of the most recently parsed expression (TY_INT/TY_CHAR/
00007Br 2               ; TY_BOOL/TY_STRING/etc.).  Used by parse_write_args to dispatch the
00007Br 2               ; right WRIT* opcode.  Set by parse_factor / parse_simple_expr /
00007Br 2               ; parse_expression as each rule produces its result.
00007Br 2               expr_type:
00007Br 2  xx                   .RES    1               ; $7B
00007Cr 2               
00007Cr 1               
00007Cr 1               ; ---------------------------------------------------------------------------
00007Cr 1               ; FCBs and file buffers
00007Cr 1               ; ---------------------------------------------------------------------------
00007Cr 1                       .segment        "CPMDATA"
000000r 1               
000000r 1               comp_src_fcb:
000000r 1  xx xx xx xx          .RES    36              ; source file FCB (.PAS)
000004r 1  xx xx xx xx  
000008r 1  xx xx xx xx  
000024r 1               comp_out_fcb:
000024r 1  xx xx xx xx          .RES    36              ; output file FCB (.PCD)
000028r 1  xx xx xx xx  
00002Cr 1  xx xx xx xx  
000048r 1               
000048r 1               ; 128-byte sector buffer for source reads
000048r 1               src_sector:
000048r 1  xx xx xx xx          .RES    128
00004Cr 1  xx xx xx xx  
000050r 1  xx xx xx xx  
0000C8r 1               
0000C8r 1               ; Comma-list buffer for parse_var_decls — collects names "A, B, C" before
0000C8r 1               ; the type is known so each can be added to the symbol table with the
0000C8r 1               ; same type code.  8 slots × 16 bytes; excess names are silently dropped.
0000C8r 1               var_name_count:
0000C8r 1  xx                   .RES    1
0000C9r 1               var_name_buf:
0000C9r 1  xx xx xx xx          .RES    128
0000CDr 1  xx xx xx xx  
0000D1r 1  xx xx xx xx  
000149r 1               
000149r 1               ; Field table for RECORD types.  32 entries × 16 bytes each:
000149r 1               ;   [0]    field name length (1-12)
000149r 1               ;   [1-12] field name chars (uppercase, padded with spaces)
000149r 1               ;   [13]   byte offset within the record
000149r 1               ;   [14]   field data type (TY_INT/TY_CHAR/TY_BOOL)
000149r 1               ;   [15]   reserved
000149r 1               field_table_count:
000149r 1  xx                   .RES    1
00014Ar 1               field_table:
00014Ar 1  xx xx xx xx          .RES    512             ; 32 entries × 16 bytes
00014Er 1  xx xx xx xx  
000152r 1  xx xx xx xx  
00034Ar 1               
00034Ar 1               ; Per-field "nested" metadata, parallel to field_table.  Only meaningful
00034Ar 1               ; when the field's type is TY_RECORD: holds the nested record's
00034Ar 1               ; first_field index and field count so chained access (`a.outer.inner`)
00034Ar 1               ; can traverse into the inner record.  Anonymous and named nested
00034Ar 1               ; records are both supported here.
00034Ar 1               field_nested_first:
00034Ar 1  xx xx xx xx          .RES    32
00034Er 1  xx xx xx xx  
000352r 1  xx xx xx xx  
00036Ar 1               field_nested_count:
00036Ar 1  xx xx xx xx          .RES    32
00036Er 1  xx xx xx xx  
000372r 1  xx xx xx xx  
00038Ar 1               field_ptr_meta:
00038Ar 1  xx xx xx xx          .RES    32
00038Er 1  xx xx xx xx  
000392r 1  xx xx xx xx  
0003AAr 1               
0003AAr 1               ; Separate buffer for collecting field names inside a RECORD declaration.
0003AAr 1               ; Distinct from var_name_buf so inline `VAR x: RECORD ... END` doesn't
0003AAr 1               ; lose the outer "x" while the field group is being parsed. Each active
0003AAr 1               ; RECORD nesting depth gets its own slice so an inner anonymous RECORD
0003AAr 1               ; doesn't overwrite the outer field names that still need to be added.
0003AAr 1               FIELD_NAME_DEPTHS = 8
0003AAr 1               field_name_count:
0003AAr 1  xx xx xx xx          .RES    FIELD_NAME_DEPTHS
0003AEr 1  xx xx xx xx  
0003B2r 1               field_name_buf:
0003B2r 1  xx xx xx xx          .RES    128 * FIELD_NAME_DEPTHS
0003B6r 1  xx xx xx xx  
0003BAr 1  xx xx xx xx  
0007B2r 1               
0007B2r 1               ; Scratch slots used by @rec_addf to remember the most recently-parsed
0007B2r 1               ; field's nested-record metadata.  Populated by the wrapper around the
0007B2r 1               ; recursive parse_type_spec call when the field type is TY_RECORD.
0007B2r 1               nest_save_first:
0007B2r 1  xx                   .RES    1
0007B3r 1               nest_save_count:
0007B3r 1  xx                   .RES    1
0007B4r 1               nest_save_size:
0007B4r 1  xx xx                .RES    2
0007B6r 1               
0007B6r 1               ; Nesting depth tracked by parse_type_spec @rec_loop. 0 = outside any
0007B6r 1               ; RECORD; bumped on entry, decremented on exit. Stored into byte 15 of
0007B6r 1               ; each field_table entry by field_table_add so field_lookup_in_record
0007B6r 1               ; can skip slots that belong to a deeper inline record. Without this
0007B6r 1               ; an outer record whose later fields follow an inline RECORD would
0007B6r 1               ; have an interleaved layout that count-based scan can't navigate.
0007B6r 1               field_depth:
0007B6r 1  xx                   .RES    1
0007B7r 1               field_lookup_depth:
0007B7r 1  xx                   .RES    1
0007B8r 1               
0007B8r 1               ; Pointer-type metadata table. Each pointer type remembers the pointee
0007B8r 1               ; type, its allocation size for NEW, and a few aux bytes that are
0007B8r 1               ; interpreted by pointee type:
0007B8r 1               ;   TY_RECORD -> aux0=first_field, aux1=field_count
0007B8r 1               ;   TY_ARRAY  -> aux0=elem_type,   aux1=elem_size (currently always 2)
0007B8r 1               ;   TY_PTR    -> aux0=child ptr-meta index
0007B8r 1               PTR_META_MAX = 32
0007B8r 1               ptr_meta_count:
0007B8r 1  xx                   .RES    1
0007B9r 1               ptr_meta_type:
0007B9r 1  xx xx xx xx          .RES    PTR_META_MAX
0007BDr 1  xx xx xx xx  
0007C1r 1  xx xx xx xx  
0007D9r 1               ptr_meta_size_lo:
0007D9r 1  xx xx xx xx          .RES    PTR_META_MAX
0007DDr 1  xx xx xx xx  
0007E1r 1  xx xx xx xx  
0007F9r 1               ptr_meta_size_hi:
0007F9r 1  xx xx xx xx          .RES    PTR_META_MAX
0007FDr 1  xx xx xx xx  
000801r 1  xx xx xx xx  
000819r 1               ptr_meta_aux0:
000819r 1  xx xx xx xx          .RES    PTR_META_MAX
00081Dr 1  xx xx xx xx  
000821r 1  xx xx xx xx  
000839r 1               ptr_meta_aux1:
000839r 1  xx xx xx xx          .RES    PTR_META_MAX
00083Dr 1  xx xx xx xx  
000841r 1  xx xx xx xx  
000859r 1               ptr_meta_aux2:
000859r 1  xx xx xx xx          .RES    PTR_META_MAX
00085Dr 1  xx xx xx xx  
000861r 1  xx xx xx xx  
000879r 1               
000879r 1               ; Active WITH contexts. Each entry stores a hidden global word that holds
000879r 1               ; the selected record's runtime base address, plus that record's first-field
000879r 1               ; index/count so unqualified identifiers can resolve as fields.
000879r 1               WITH_DEPTHS = 8
000879r 1               with_depth:
000879r 1  xx                   .RES    1
00087Ar 1               with_base_lo:
00087Ar 1  xx xx xx xx          .RES    WITH_DEPTHS
00087Er 1  xx xx xx xx  
000882r 1               with_base_hi:
000882r 1  xx xx xx xx          .RES    WITH_DEPTHS
000886r 1  xx xx xx xx  
00088Ar 1               with_first_field:
00088Ar 1  xx xx xx xx          .RES    WITH_DEPTHS
00088Er 1  xx xx xx xx  
000892r 1               with_field_count:
000892r 1  xx xx xx xx          .RES    WITH_DEPTHS
000896r 1  xx xx xx xx  
00089Ar 1               
00089Ar 1               ; Record-valued expressions leave an address on the stack and publish the
00089Ar 1               ; matching field-table span here so WITH selectors can reuse it.
00089Ar 1               expr_record_first:
00089Ar 1  xx                   .RES    1
00089Br 1               expr_record_count:
00089Br 1  xx                   .RES    1
00089Cr 1               expr_ptr_meta:
00089Cr 1  xx                   .RES    1
00089Dr 1               
00089Dr 1               ; Scratch filled by with_lookup_field before parse_with_field_{load,assign}.
00089Dr 1               with_lookup_off:
00089Dr 1  xx                   .RES    1
00089Er 1               with_lookup_type:
00089Er 1  xx                   .RES    1
00089Fr 1               with_lookup_base_lo:
00089Fr 1  xx                   .RES    1
0008A0r 1               with_lookup_base_hi:
0008A0r 1  xx                   .RES    1
0008A1r 1               with_lookup_first:
0008A1r 1  xx                   .RES    1
0008A2r 1               with_lookup_count:
0008A2r 1  xx                   .RES    1
0008A3r 1               with_lookup_ptrmeta:
0008A3r 1  xx                   .RES    1
0008A4r 1               
0008A4r 1               ; Top-level source mode: 0=plain program, 1=UNIT interface, 2=UNIT
0008A4r 1               ; implementation. Used so interface routine headings can be rebound to
0008A4r 1               ; their later implementation bodies without creating duplicate globals.
0008A4r 1               unit_section:
0008A4r 1  xx                   .RES    1
0008A5r 1               unit_import_mode:
0008A5r 1  xx                   .RES    1               ; 0=standalone source, nonzero=USES-import nesting depth
0008A6r 1               
0008A6r 1               ; Names collected from a single top-level USES clause. Separate from
0008A6r 1               ; var_name_buf because imported unit compilation reuses var_name_buf.
0008A6r 1               USES_NAME_SLOTS = 8
0008A6r 1               uses_name_count:
0008A6r 1  xx                   .RES    1
0008A7r 1               uses_name_buf:
0008A7r 1  xx xx xx xx          .RES    16 * USES_NAME_SLOTS
0008ABr 1  xx xx xx xx  
0008AFr 1  xx xx xx xx  
000927r 1               
000927r 1               ; Imported-unit de-duplication table. Names are stored in uppercase
000927r 1               ; ident_buf layout (length byte + 15 chars) so nested/repeated USES
000927r 1               ; clauses compile a unit at most once.
000927r 1               USED_UNIT_SLOTS = 8
000927r 1               used_unit_count:
000927r 1  xx                   .RES    1
000928r 1               used_unit_buf:
000928r 1  xx xx xx xx          .RES    16 * USED_UNIT_SLOTS
00092Cr 1  xx xx xx xx  
000930r 1  xx xx xx xx  
0009A8r 1               
0009A8r 1               ; Source-context stack for nested USES imports. Each entry saves the
0009A8r 1               ; current source FCB, buffered DMA sector, and lexer position so the
0009A8r 1               ; compiler can suspend one file, compile another, then resume cleanly.
0009A8r 1               SRC_CTX_DEPTHS = 4
0009A8r 1               src_ctx_depth:
0009A8r 1  xx                   .RES    1
0009A9r 1               src_ctx_buf_pos:
0009A9r 1  xx xx xx xx          .RES    SRC_CTX_DEPTHS
0009ADr 1               src_ctx_buf_end:
0009ADr 1  xx xx xx xx          .RES    SRC_CTX_DEPTHS
0009B1r 1               src_ctx_line_lo:
0009B1r 1  xx xx xx xx          .RES    SRC_CTX_DEPTHS
0009B5r 1               src_ctx_line_hi:
0009B5r 1  xx xx xx xx          .RES    SRC_CTX_DEPTHS
0009B9r 1               src_ctx_col:
0009B9r 1  xx xx xx xx          .RES    SRC_CTX_DEPTHS
0009BDr 1               src_ctx_char:
0009BDr 1  xx xx xx xx          .RES    SRC_CTX_DEPTHS
0009C1r 1               src_ctx_fcb:
0009C1r 1  xx xx xx xx          .RES    36 * SRC_CTX_DEPTHS
0009C5r 1  xx xx xx xx  
0009C9r 1  xx xx xx xx  
000A51r 1               src_ctx_dma:
000A51r 1  xx xx xx xx          .RES    128 * SRC_CTX_DEPTHS
000A55r 1  xx xx xx xx  
000A59r 1  xx xx xx xx  
000C51r 1               
000C51r 1               ; Code generation buffer — p-code accumulates here until file write.
000C51r 1               ; Keep this above the live CPMDATA working set used by the parser.
000C51r 1               ; This holds up to ~32KB of generated p-code.
000C51r 1               CODEBUF_BASE    = $4900
000C51r 1               CODEBUF_MAXSZ   = $8000         ; 32 KB
000C51r 1               
000C51r 1               ; Symbol table area
000C51r 1               SYMTAB_BASE     = $8000
000C51r 1               SYMTAB_MAXSZ    = $1800         ; 6 KB (≈200 entries at ~30 bytes each)
000C51r 1               
000C51r 1               ; String pool for identifier strings and string literals
000C51r 1               STRPOOL_BASE    = $9800
000C51r 1               STRPOOL_MAXSZ   = $0800         ; 2 KB
000C51r 1               
000C51r 1               ; ---------------------------------------------------------------------------
000C51r 1               ; Entry point
000C51r 1               ; ---------------------------------------------------------------------------
000C51r 1                       .segment        "TEA"
000000r 1               
000000r 1  4C rr rr             JMP     pascal_main
000003r 1               
000003r 1                       .segment        "CODE"
000000r 1               
000000r 1               pascal_main:
000000r 1               ; print banner
000000r 1  A9 rr                LDA     #<msg_banner
000002r 1  85 rr                STA     tmp0
000004r 1  A9 rr                LDA     #>msg_banner
000006r 1  85 rr                STA     tmp0+1
000008r 1  20 rr rr             JSR     console_print_sz
00000Br 1               
00000Br 1               ; build source FCB from DEFAULT_FCB ($0107) argument
00000Br 1  20 rr rr             JSR     build_src_fcb
00000Er 1  90 03                BCC     :+
000010r 1  4C rr rr             JMP     @no_file
000013r 1               :
000013r 1               ; print "Compiling: <name>"
000013r 1  A9 rr                LDA     #<msg_compiling
000015r 1  85 rr                STA     tmp0
000017r 1  A9 rr                LDA     #>msg_compiling
000019r 1  85 rr                STA     tmp0+1
00001Br 1  20 rr rr             JSR     console_print_sz
00001Er 1               
00001Er 1               ; open source file
00001Er 1  A9 rr                LDA     #<comp_src_fcb
000020r 1  85 rr                STA     src_fcb
000022r 1  A9 rr                LDA     #>comp_src_fcb
000024r 1  85 rr                STA     src_fcb+1
000026r 1  A9 rr                LDA     #<comp_src_fcb
000028r 1  85 rr                STA     tmp1
00002Ar 1  A9 rr                LDA     #>comp_src_fcb
00002Cr 1  85 rr                STA     tmp1+1
00002Er 1  20 rr rr             JSR     file_open
000031r 1  C9 FF                CMP     #$FF            ; PEM open: $FF=not found, 0-3=dir entry
000033r 1  D0 03                BNE     :+
000035r 1  4C rr rr             JMP     @no_file
000038r 1               :
000038r 1               
000038r 1               ; create output .PCD file
000038r 1  20 rr rr             JSR     build_out_fcb
00003Br 1  A9 rr                LDA     #<comp_out_fcb
00003Dr 1  85 rr                STA     tmp1
00003Fr 1  A9 rr                LDA     #>comp_out_fcb
000041r 1  85 rr                STA     tmp1+1
000043r 1  20 rr rr             JSR     file_make
000046r 1  C9 FF                CMP     #$FF            ; PEM make: $FF=dir full, 0-3=dir entry
000048r 1  D0 03                BNE     :+
00004Ar 1  4C rr rr             JMP     @out_err
00004Dr 1               :
00004Dr 1               
00004Dr 1               ; initialise compiler state
00004Dr 1  20 rr rr             JSR     compiler_init
000050r 1               
000050r 1               ; run compilation
000050r 1  20 rr rr             JSR     compile_program
000053r 1               
000053r 1               ; write .PCD file
000053r 1  20 rr rr             JSR     write_pcd
000056r 1               
000056r 1               ; close files
000056r 1  A9 rr                LDA     #<comp_src_fcb
000058r 1  85 rr                STA     tmp1
00005Ar 1  A9 rr                LDA     #>comp_src_fcb
00005Cr 1  85 rr                STA     tmp1+1
00005Er 1  20 rr rr             JSR     file_close
000061r 1  A9 rr                LDA     #<comp_out_fcb
000063r 1  85 rr                STA     tmp1
000065r 1  A9 rr                LDA     #>comp_out_fcb
000067r 1  85 rr                STA     tmp1+1
000069r 1  20 rr rr             JSR     file_close
00006Cr 1               
00006Cr 1               ; print result
00006Cr 1  AD rr rr             LDA     error_count
00006Fr 1  0D rr rr             ORA     error_count+1
000072r 1  D0 0E                BNE     @had_errors
000074r 1  A9 rr                LDA     #<msg_ok
000076r 1  85 rr                STA     tmp0
000078r 1  A9 rr                LDA     #>msg_ok
00007Ar 1  85 rr                STA     tmp0+1
00007Cr 1  20 rr rr             JSR     console_print_sz
00007Fr 1  4C 00 01             JMP     WARM_BOOT
000082r 1               
000082r 1               @had_errors:
000082r 1  AD rr rr             LDA     error_count
000085r 1  85 rr                STA     tmp0
000087r 1  AD rr rr             LDA     error_count+1
00008Ar 1  85 rr                STA     tmp0+1
00008Cr 1  20 rr rr             JSR     console_print_dec
00008Fr 1  A9 rr                LDA     #<msg_errors
000091r 1  85 rr                STA     tmp0
000093r 1  A9 rr                LDA     #>msg_errors
000095r 1  85 rr                STA     tmp0+1
000097r 1  20 rr rr             JSR     console_print_sz
00009Ar 1  4C 00 01             JMP     WARM_BOOT
00009Dr 1               
00009Dr 1               @no_file:
00009Dr 1  A9 rr                LDA     #<err_nofile
00009Fr 1  85 rr                STA     tmp0
0000A1r 1  A9 rr                LDA     #>err_nofile
0000A3r 1  85 rr                STA     tmp0+1
0000A5r 1  20 rr rr             JSR     console_print_sz
0000A8r 1  4C 00 01             JMP     WARM_BOOT
0000ABr 1               
0000ABr 1               @out_err:
0000ABr 1  A9 rr                LDA     #<err_outfile
0000ADr 1  85 rr                STA     tmp0
0000AFr 1  A9 rr                LDA     #>err_outfile
0000B1r 1  85 rr                STA     tmp0+1
0000B3r 1  20 rr rr             JSR     console_print_sz
0000B6r 1  4C 00 01             JMP     WARM_BOOT
0000B9r 1               
0000B9r 1               ; ---------------------------------------------------------------------------
0000B9r 1               ; build_src_fcb — populate comp_src_fcb from DEFAULT_FCB ($0107), force ".PAS"
0000B9r 1               ; DOS/65 CCM copies the parsed argument FCB to dflfcb=$0107, not $005C.
0000B9r 1               ; Returns: carry clear = ok, carry set = no filename
0000B9r 1               ; ---------------------------------------------------------------------------
0000B9r 1               build_src_fcb:
0000B9r 1  A2 00                LDX     #0
0000BBr 1               @copy:
0000BBr 1  BD 07 01             LDA     DEFAULT_FCB,x
0000BEr 1  9D rr rr             STA     comp_src_fcb,x
0000C1r 1  E8                   INX
0000C2r 1  E0 0C                CPX     #12
0000C4r 1  90 F5                BCC     @copy
0000C6r 1  A9 00                LDA     #0
0000C8r 1               @zero:
0000C8r 1  9D rr rr             STA     comp_src_fcb,x
0000CBr 1  E8                   INX
0000CCr 1  E0 24                CPX     #36
0000CEr 1  90 F8                BCC     @zero
0000D0r 1  AD rr rr             LDA     comp_src_fcb+1
0000D3r 1  C9 20                CMP     #' '
0000D5r 1  F0 11                BEQ     @noname
0000D7r 1  A9 50                LDA     #'P'
0000D9r 1  8D rr rr             STA     comp_src_fcb+9
0000DCr 1  A9 41                LDA     #'A'
0000DEr 1  8D rr rr             STA     comp_src_fcb+10
0000E1r 1  A9 53                LDA     #'S'
0000E3r 1  8D rr rr             STA     comp_src_fcb+11
0000E6r 1  18                   CLC
0000E7r 1  60                   RTS
0000E8r 1               @noname:
0000E8r 1  38                   SEC
0000E9r 1  60                   RTS
0000EAr 1               
0000EAr 1               ; ---------------------------------------------------------------------------
0000EAr 1               ; build_out_fcb — copy filename from comp_src_fcb, change extension to "PCD"
0000EAr 1               ; ---------------------------------------------------------------------------
0000EAr 1               build_out_fcb:
0000EAr 1  A2 00                LDX     #0
0000ECr 1               @copy:
0000ECr 1  BD rr rr             LDA     comp_src_fcb,x
0000EFr 1  9D rr rr             STA     comp_out_fcb,x
0000F2r 1  E8                   INX
0000F3r 1  E0 24                CPX     #36
0000F5r 1  90 F5                BCC     @copy
0000F7r 1  A9 50                LDA     #'P'
0000F9r 1  8D rr rr             STA     comp_out_fcb+9
0000FCr 1  A9 43                LDA     #'C'
0000FEr 1  8D rr rr             STA     comp_out_fcb+10
000101r 1  A9 44                LDA     #'D'
000103r 1  8D rr rr             STA     comp_out_fcb+11
000106r 1  60                   RTS
000107r 1               
000107r 1               ; ---------------------------------------------------------------------------
000107r 1               ; build_named_src_fcb — populate comp_src_fcb from ident_buf, force ".PAS"
000107r 1               ; The identifier is uppercased already by the lexer. Names longer than 8
000107r 1               ; chars are truncated to fit the FCB filename field.
000107r 1               ; Returns: carry clear = ok, carry set = empty name
000107r 1               ; ---------------------------------------------------------------------------
000107r 1               build_named_src_fcb:
000107r 1  AD rr rr             LDA     ident_buf
00010Ar 1  D0 02                BNE     :+
00010Cr 1  38                   SEC
00010Dr 1  60                   RTS
00010Er 1  A2 00        :       LDX     #0
000110r 1  A9 00                LDA     #0
000112r 1               @zero:
000112r 1  9D rr rr             STA     comp_src_fcb,x
000115r 1  E8                   INX
000116r 1  E0 24                CPX     #36
000118r 1  90 F8                BCC     @zero
00011Ar 1  A2 01                LDX     #1
00011Cr 1  A9 20                LDA     #' '
00011Er 1               @pad_name:
00011Er 1  9D rr rr             STA     comp_src_fcb,x
000121r 1  E8                   INX
000122r 1  E0 0C                CPX     #12
000124r 1  90 F8                BCC     @pad_name
000126r 1  A2 00                LDX     #0
000128r 1               @copy_name:
000128r 1  EC rr rr             CPX     ident_buf
00012Br 1  B0 0D                BCS     @set_ext
00012Dr 1  E0 08                CPX     #8
00012Fr 1  B0 09                BCS     @set_ext
000131r 1  BD rr rr             LDA     ident_buf+1,x
000134r 1  9D rr rr             STA     comp_src_fcb+1,x
000137r 1  E8                   INX
000138r 1  80 EE                BRA     @copy_name
00013Ar 1               @set_ext:
00013Ar 1  A9 50                LDA     #'P'
00013Cr 1  8D rr rr             STA     comp_src_fcb+9
00013Fr 1  A9 41                LDA     #'A'
000141r 1  8D rr rr             STA     comp_src_fcb+10
000144r 1  A9 53                LDA     #'S'
000146r 1  8D rr rr             STA     comp_src_fcb+11
000149r 1  18                   CLC
00014Ar 1  60                   RTS
00014Br 1               
00014Br 1               ; source_ctx_fcb_ptr — A=stack index, returns tmp0 -> saved FCB slot
00014Br 1               source_ctx_fcb_ptr:
00014Br 1  85 rr                STA     scratch
00014Dr 1  A9 rr                LDA     #<src_ctx_fcb
00014Fr 1  85 rr                STA     tmp0
000151r 1  A9 rr                LDA     #>src_ctx_fcb
000153r 1  85 rr                STA     tmp0+1
000155r 1               @scfp_loop:
000155r 1  A5 rr                LDA     scratch
000157r 1  F0 0F                BEQ     @scfp_done
000159r 1  18                   CLC
00015Ar 1  A5 rr                LDA     tmp0
00015Cr 1  69 24                ADC     #36
00015Er 1  85 rr                STA     tmp0
000160r 1  90 02                BCC     :+
000162r 1  E6 rr                INC     tmp0+1
000164r 1  C6 rr        :       DEC     scratch
000166r 1  80 ED                BRA     @scfp_loop
000168r 1               @scfp_done:
000168r 1  60                   RTS
000169r 1               
000169r 1               ; source_ctx_dma_ptr — A=stack index, returns tmp0 -> saved DMA slot
000169r 1               source_ctx_dma_ptr:
000169r 1  85 rr                STA     scratch
00016Br 1  A9 rr                LDA     #<src_ctx_dma
00016Dr 1  85 rr                STA     tmp0
00016Fr 1  A9 rr                LDA     #>src_ctx_dma
000171r 1  85 rr                STA     tmp0+1
000173r 1               @scdp_loop:
000173r 1  A5 rr                LDA     scratch
000175r 1  F0 0F                BEQ     @scdp_done
000177r 1  18                   CLC
000178r 1  A5 rr                LDA     tmp0
00017Ar 1  69 80                ADC     #$80
00017Cr 1  85 rr                STA     tmp0
00017Er 1  90 02                BCC     :+
000180r 1  E6 rr                INC     tmp0+1
000182r 1  C6 rr        :       DEC     scratch
000184r 1  80 ED                BRA     @scdp_loop
000186r 1               @scdp_done:
000186r 1  60                   RTS
000187r 1               
000187r 1               ; ---------------------------------------------------------------------------
000187r 1               ; source_push_current / source_pop_current — save and restore the active
000187r 1               ; source-file context around USES-imported unit compilation.
000187r 1               ; source_push_current returns carry set if the context stack is full.
000187r 1               ; ---------------------------------------------------------------------------
000187r 1               source_push_current:
000187r 1  AE rr rr             LDX     src_ctx_depth
00018Ar 1  E0 04                CPX     #SRC_CTX_DEPTHS
00018Cr 1  90 02                BCC     @spc_room
00018Er 1  38                   SEC
00018Fr 1  60                   RTS
000190r 1               @spc_room:
000190r 1  A5 rr                LDA     src_buf_pos
000192r 1  9D rr rr             STA     src_ctx_buf_pos,x
000195r 1  A5 rr                LDA     src_buf_end
000197r 1  9D rr rr             STA     src_ctx_buf_end,x
00019Ar 1  A5 rr                LDA     lex_line
00019Cr 1  9D rr rr             STA     src_ctx_line_lo,x
00019Fr 1  A5 rr                LDA     lex_line+1
0001A1r 1  9D rr rr             STA     src_ctx_line_hi,x
0001A4r 1  A5 rr                LDA     lex_col
0001A6r 1  9D rr rr             STA     src_ctx_col,x
0001A9r 1  A5 rr                LDA     lex_char
0001ABr 1  9D rr rr             STA     src_ctx_char,x
0001AEr 1  8A                   TXA
0001AFr 1  20 rr rr             JSR     source_ctx_fcb_ptr
0001B2r 1  A0 00                LDY     #0
0001B4r 1               @spc_fcb_copy:
0001B4r 1  B9 rr rr             LDA     comp_src_fcb,y
0001B7r 1  91 rr                STA     (tmp0),y
0001B9r 1  C8                   INY
0001BAr 1  C0 24                CPY     #36
0001BCr 1  90 F6                BCC     @spc_fcb_copy
0001BEr 1  8A                   TXA
0001BFr 1  20 rr rr             JSR     source_ctx_dma_ptr
0001C2r 1  A0 00                LDY     #0
0001C4r 1               @spc_dma_copy:
0001C4r 1  B9 28 01             LDA     DMA_BUF,y
0001C7r 1  91 rr                STA     (tmp0),y
0001C9r 1  C8                   INY
0001CAr 1  C0 80                CPY     #128
0001CCr 1  90 F6                BCC     @spc_dma_copy
0001CEr 1  EE rr rr             INC     src_ctx_depth
0001D1r 1  18                   CLC
0001D2r 1  60                   RTS
0001D3r 1               
0001D3r 1               source_pop_current:
0001D3r 1  AD rr rr             LDA     src_ctx_depth
0001D6r 1  F0 4C                BEQ     @spop_done
0001D8r 1  CE rr rr             DEC     src_ctx_depth
0001DBr 1  AE rr rr             LDX     src_ctx_depth
0001DEr 1  BD rr rr             LDA     src_ctx_buf_pos,x
0001E1r 1  85 rr                STA     src_buf_pos
0001E3r 1  BD rr rr             LDA     src_ctx_buf_end,x
0001E6r 1  85 rr                STA     src_buf_end
0001E8r 1  BD rr rr             LDA     src_ctx_line_lo,x
0001EBr 1  85 rr                STA     lex_line
0001EDr 1  BD rr rr             LDA     src_ctx_line_hi,x
0001F0r 1  85 rr                STA     lex_line+1
0001F2r 1  BD rr rr             LDA     src_ctx_col,x
0001F5r 1  85 rr                STA     lex_col
0001F7r 1  BD rr rr             LDA     src_ctx_char,x
0001FAr 1  85 rr                STA     lex_char
0001FCr 1  8A                   TXA
0001FDr 1  20 rr rr             JSR     source_ctx_fcb_ptr
000200r 1  A0 00                LDY     #0
000202r 1               @spop_fcb_copy:
000202r 1  B1 rr                LDA     (tmp0),y
000204r 1  99 rr rr             STA     comp_src_fcb,y
000207r 1  C8                   INY
000208r 1  C0 24                CPY     #36
00020Ar 1  90 F6                BCC     @spop_fcb_copy
00020Cr 1  8A                   TXA
00020Dr 1  20 rr rr             JSR     source_ctx_dma_ptr
000210r 1  A0 00                LDY     #0
000212r 1               @spop_dma_copy:
000212r 1  B1 rr                LDA     (tmp0),y
000214r 1  99 28 01             STA     DMA_BUF,y
000217r 1  C8                   INY
000218r 1  C0 80                CPY     #128
00021Ar 1  90 F6                BCC     @spop_dma_copy
00021Cr 1  A9 rr                LDA     #<comp_src_fcb
00021Er 1  85 rr                STA     src_fcb
000220r 1  A9 rr                LDA     #>comp_src_fcb
000222r 1  85 rr                STA     src_fcb+1
000224r 1               @spop_done:
000224r 1  60                   RTS
000225r 1               
000225r 1               ; ---------------------------------------------------------------------------
000225r 1               ; compiler_init — zero-out compiler state
000225r 1               ; ---------------------------------------------------------------------------
000225r 1               error_count:
000225r 1  00 00                .WORD   0
000227r 1               
000227r 1               compiler_init:
000227r 1  A9 00                LDA     #0
000229r 1  8D rr rr             STA     error_count
00022Cr 1  8D rr rr             STA     error_count+1
00022Fr 1               ; IPC starts at 0 (offset into code buffer)
00022Fr 1  85 rr                STA     cg_pc
000231r 1  85 rr                STA     cg_pc+1
000233r 1               ; globals start at 0
000233r 1  85 rr                STA     cg_globals
000235r 1  85 rr                STA     cg_globals+1
000237r 1               ; scope depth 0 = global
000237r 1  85 rr                STA     scope_depth
000239r 1  8D rr rr             STA     with_depth
00023Cr 1  8D rr rr             STA     expr_record_first
00023Fr 1  8D rr rr             STA     expr_record_count
000242r 1  8D rr rr             STA     unit_section
000245r 1  8D rr rr             STA     unit_import_mode
000248r 1  8D rr rr             STA     uses_name_count
00024Br 1  8D rr rr             STA     used_unit_count
00024Er 1  8D rr rr             STA     src_ctx_depth
000251r 1  A9 FF                LDA     #$FF
000253r 1  8D rr rr             STA     expr_ptr_meta
000256r 1               ; main entry-point patch slot — sentinel hi byte = $FF means "none/done"
000256r 1  8D rr rr             STA     main_jmp_patch+1
000259r 1  8D rr rr             STA     body_chain_patch+1
00025Cr 1               ; init lexer and prime first token
00025Cr 1  20 rr rr             JSR     lexer_init
00025Fr 1  20 rr rr             JSR     next_token
000262r 1  60                   RTS
000263r 1               
000263r 1               ; ---------------------------------------------------------------------------
000263r 1               ; compile_error — print error with line/col; increment error_count
000263r 1               ; tmp0 = pointer to error string
000263r 1               ; ---------------------------------------------------------------------------
000263r 1               compile_error:
000263r 1               ; save caller's message pointer (tmp0) into tmp3
000263r 1  A5 rr                LDA     tmp0
000265r 1  85 rr                STA     tmp3
000267r 1  A5 rr                LDA     tmp0+1
000269r 1  85 rr                STA     tmp3+1
00026Br 1               ; print "Line "
00026Br 1  A9 rr                LDA     #<msg_line
00026Dr 1  85 rr                STA     tmp0
00026Fr 1  A9 rr                LDA     #>msg_line
000271r 1  85 rr                STA     tmp0+1
000273r 1  20 rr rr             JSR     console_print_sz
000276r 1               ; print line number
000276r 1  A5 rr                LDA     lex_line
000278r 1  85 rr                STA     tmp0
00027Ar 1  A5 rr                LDA     lex_line+1
00027Cr 1  85 rr                STA     tmp0+1
00027Er 1  20 rr rr             JSR     console_print_dec
000281r 1               ; print ": "
000281r 1  A9 3A                LDA     #':'
000283r 1  A2 02                LDX     #PEM_CONOUT
000285r 1  20 03 01             JSR     PEM_ENTRY
000288r 1  A9 20                LDA     #' '
00028Ar 1  A2 02                LDX     #PEM_CONOUT
00028Cr 1  20 03 01             JSR     PEM_ENTRY
00028Fr 1               ; print the error message text
00028Fr 1  A5 rr                LDA     tmp3
000291r 1  85 rr                STA     tmp0
000293r 1  A5 rr                LDA     tmp3+1
000295r 1  85 rr                STA     tmp0+1
000297r 1  20 rr rr             JSR     console_print_sz
00029Ar 1  20 rr rr             JSR     console_newline
00029Dr 1               ; increment error count
00029Dr 1  EE rr rr             INC     error_count
0002A0r 1  D0 03                BNE     :+
0002A2r 1  EE rr rr             INC     error_count+1
0002A5r 1               :
0002A5r 1  60                   RTS
0002A6r 1               
0002A6r 1               ; ---------------------------------------------------------------------------
0002A6r 1               ; write_pcd — write .PCD header + entire code buffer to output file
0002A6r 1               ;   Sector 0:        12-byte header  + first 116 bytes of code  (padded)
0002A6r 1               ;   Sectors 1..N-1:  128 bytes of code each                     (last padded)
0002A6r 1               ;
0002A6r 1               ; Uses tmp0 = source pointer (into CODEBUF_BASE),
0002A6r 1               ;      tmp3 = bytes remaining to write,
0002A6r 1               ;      tmp1 = FCB pointer (re-loaded before each file_write_sector).
0002A6r 1               ; ---------------------------------------------------------------------------
0002A6r 1               write_pcd:
0002A6r 1               ; --- src_ptr = CODEBUF_BASE; remaining = cg_pc ---
0002A6r 1  A9 00                LDA     #<CODEBUF_BASE
0002A8r 1  85 rr                STA     tmp0
0002AAr 1  A9 49                LDA     #>CODEBUF_BASE
0002ACr 1  85 rr                STA     tmp0+1
0002AEr 1  A5 rr                LDA     cg_pc
0002B0r 1  85 rr                STA     tmp3
0002B2r 1  A5 rr                LDA     cg_pc+1
0002B4r 1  85 rr                STA     tmp3+1
0002B6r 1               
0002B6r 1               ; --- header bytes 0..11 directly into DMA_BUF ---
0002B6r 1  A9 50                LDA     #PCD_MAGIC_0
0002B8r 1  8D 28 01             STA     DMA_BUF+0
0002BBr 1  A9 43                LDA     #PCD_MAGIC_1
0002BDr 1  8D 29 01             STA     DMA_BUF+1
0002C0r 1  A9 01                LDA     #PCD_VERSION
0002C2r 1  8D 2A 01             STA     DMA_BUF+2
0002C5r 1  A9 00                LDA     #0
0002C7r 1  8D 2B 01             STA     DMA_BUF+3
0002CAr 1  A5 rr                LDA     cg_pc
0002CCr 1  8D 2C 01             STA     DMA_BUF+PCD_CODESZ
0002CFr 1  A5 rr                LDA     cg_pc+1
0002D1r 1  8D 2D 01             STA     DMA_BUF+PCD_CODESZ+1
0002D4r 1  A5 rr                LDA     cg_globals
0002D6r 1  8D 2E 01             STA     DMA_BUF+PCD_GLOBSZ
0002D9r 1  A5 rr                LDA     cg_globals+1
0002DBr 1  8D 2F 01             STA     DMA_BUF+PCD_GLOBSZ+1
0002DEr 1  A9 00                LDA     #0
0002E0r 1  8D 30 01             STA     DMA_BUF+PCD_STRSZ
0002E3r 1  8D 31 01             STA     DMA_BUF+PCD_STRSZ+1
0002E6r 1  8D 32 01             STA     DMA_BUF+PCD_ENTRY
0002E9r 1  8D 33 01             STA     DMA_BUF+PCD_ENTRY+1
0002ECr 1               
0002ECr 1               ; --- first sector: copy code into DMA_BUF[12..127] ---
0002ECr 1  A0 00                LDY     #0              ; src offset within this batch
0002EEr 1  A2 0C                LDX     #PCD_HEADER_SZ  ; dest offset in DMA
0002F0r 1               @fill1:
0002F0r 1  E0 80                CPX     #128
0002F2r 1  B0 23                BCS     @write1
0002F4r 1  A5 rr                LDA     tmp3
0002F6r 1  05 rr                ORA     tmp3+1
0002F8r 1  F0 11                BEQ     @pad1
0002FAr 1  B1 rr                LDA     (tmp0),y
0002FCr 1  9D 28 01             STA     DMA_BUF,x
0002FFr 1  E8                   INX
000300r 1  C8                   INY
000301r 1               ; remaining--
000301r 1  A5 rr                LDA     tmp3
000303r 1  D0 02                BNE     :+
000305r 1  C6 rr                DEC     tmp3+1
000307r 1               :
000307r 1  C6 rr                DEC     tmp3
000309r 1  80 E5                BRA     @fill1
00030Br 1               @pad1:
00030Br 1  E0 80                CPX     #128
00030Dr 1  B0 08                BCS     @write1
00030Fr 1  A9 00                LDA     #0
000311r 1  9D 28 01             STA     DMA_BUF,x
000314r 1  E8                   INX
000315r 1  80 F4                BRA     @pad1
000317r 1               @write1:
000317r 1               ; advance src by Y (bytes consumed from this batch)
000317r 1  84 rr                STY     scratch
000319r 1  18                   CLC
00031Ar 1  A5 rr                LDA     tmp0
00031Cr 1  65 rr                ADC     scratch
00031Er 1  85 rr                STA     tmp0
000320r 1  90 02                BCC     :+
000322r 1  E6 rr                INC     tmp0+1
000324r 1               :
000324r 1  A9 rr                LDA     #<comp_out_fcb
000326r 1  85 rr                STA     tmp1
000328r 1  A9 rr                LDA     #>comp_out_fcb
00032Ar 1  85 rr                STA     tmp1+1
00032Cr 1  20 rr rr             JSR     file_write_sector
00032Fr 1               
00032Fr 1               ; --- additional sectors (full 128 bytes each, last pad with 0) ---
00032Fr 1               @next_sec:
00032Fr 1  A5 rr                LDA     tmp3
000331r 1  05 rr                ORA     tmp3+1
000333r 1  F0 42                BEQ     @done
000335r 1  A0 00                LDY     #0
000337r 1               @fill2:
000337r 1  C0 80                CPY     #128
000339r 1  B0 22                BCS     @write2
00033Br 1  A5 rr                LDA     tmp3
00033Dr 1  05 rr                ORA     tmp3+1
00033Fr 1  F0 10                BEQ     @pad2
000341r 1  B1 rr                LDA     (tmp0),y
000343r 1  99 28 01             STA     DMA_BUF,y
000346r 1  C8                   INY
000347r 1  A5 rr                LDA     tmp3
000349r 1  D0 02                BNE     :+
00034Br 1  C6 rr                DEC     tmp3+1
00034Dr 1               :
00034Dr 1  C6 rr                DEC     tmp3
00034Fr 1  80 E6                BRA     @fill2
000351r 1               @pad2:
000351r 1  C0 80                CPY     #128
000353r 1  B0 08                BCS     @write2
000355r 1  A9 00                LDA     #0
000357r 1  99 28 01             STA     DMA_BUF,y
00035Ar 1  C8                   INY
00035Br 1  80 F4                BRA     @pad2
00035Dr 1               @write2:
00035Dr 1               ; advance src by 128 (Y is the count copied from src this sector;
00035Dr 1               ; padded bytes at the tail are not source bytes, but remaining is
00035Dr 1               ; already 0 in that case and the loop will exit).
00035Dr 1  84 rr                STY     scratch
00035Fr 1  18                   CLC
000360r 1  A5 rr                LDA     tmp0
000362r 1  65 rr                ADC     scratch
000364r 1  85 rr                STA     tmp0
000366r 1  90 02                BCC     :+
000368r 1  E6 rr                INC     tmp0+1
00036Ar 1               :
00036Ar 1  A9 rr                LDA     #<comp_out_fcb
00036Cr 1  85 rr                STA     tmp1
00036Er 1  A9 rr                LDA     #>comp_out_fcb
000370r 1  85 rr                STA     tmp1+1
000372r 1  20 rr rr             JSR     file_write_sector
000375r 1  80 B8                BRA     @next_sec
000377r 1               @done:
000377r 1  60                   RTS
000378r 1               
000378r 1               ; ---------------------------------------------------------------------------
000378r 1               ; Include sub-modules (compiler phases)
000378r 1               ; ---------------------------------------------------------------------------
000378r 1                       .include        "LEXER.ASM"
000378r 2               .PC02
000378r 2               ; lexer.asm — Pascal tokenizer
000378r 2               ;
000378r 2               ; Reads source file through 128-byte sector buffer.
000378r 2               ; Produces token stream via next_token (sets tok_type + value vars in ZP).
000378r 2               
000378r 2               ; ---------------------------------------------------------------------------
000378r 2               ; Keyword table — each entry: length byte, ASCII chars, token code
000378r 2               ; Searched linearly; 18 keywords.
000378r 2               ; ---------------------------------------------------------------------------
000378r 2                       .segment        "CODE"
000378r 2               
000378r 2               keyword_table:
000378r 2               ; length, chars..., token
000378r 2  03 41 4E 44          .BYTE   3, "AND",       TOK_AND
00037Cr 2  40           
00037Dr 2  05 41 52 52          .BYTE   5, "ARRAY",     TOK_ARRAY
000381r 2  41 59 41     
000384r 2  05 42 45 47          .BYTE   5, "BEGIN",     TOK_BEGIN
000388r 2  49 4E 42     
00038Br 2  04 43 41 53          .BYTE   4, "CASE",      TOK_CASE
00038Fr 2  45 43        
000391r 2  05 43 4F 4E          .BYTE   5, "CONST",     TOK_CONST
000395r 2  53 54 44     
000398r 2  03 44 49 56          .BYTE   3, "DIV",       TOK_DIV
00039Cr 2  45           
00039Dr 2  02 44 4F 46          .BYTE   2, "DO",        TOK_DO
0003A1r 2  06 44 4F 57          .BYTE   6, "DOWNTO",    TOK_DOWNTO
0003A5r 2  4E 54 4F 47  
0003A9r 2  04 45 4C 53          .BYTE   4, "ELSE",      TOK_ELSE
0003ADr 2  45 48        
0003AFr 2  03 45 4E 44          .BYTE   3, "END",       TOK_END
0003B3r 2  49           
0003B4r 2  03 46 4F 52          .BYTE   3, "FOR",       TOK_FOR
0003B8r 2  4A           
0003B9r 2  08 46 55 4E          .BYTE   8, "FUNCTION",  TOK_FUNCTION
0003BDr 2  43 54 49 4F  
0003C1r 2  4E 4B        
0003C3r 2  02 49 46 4C          .BYTE   2, "IF",        TOK_IF
0003C7r 2  0E 49 4D 50          .BYTE   14, "IMPLEMENTATION", TOK_IMPLEMENTATION
0003CBr 2  4C 45 4D 45  
0003CFr 2  4E 54 41 54  
0003D7r 2  02 49 4E 4D          .BYTE   2, "IN",        TOK_IN
0003DBr 2  09 49 4E 54          .BYTE   9, "INTERFACE", TOK_INTERFACE
0003DFr 2  45 52 46 41  
0003E3r 2  43 45 60     
0003E6r 2  03 4D 4F 44          .BYTE   3, "MOD",       TOK_MOD_KW
0003EAr 2  4E           
0003EBr 2  03 4E 49 4C          .BYTE   3, "NIL",       TOK_NIL
0003EFr 2  4F           
0003F0r 2  03 4E 4F 54          .BYTE   3, "NOT",       TOK_NOT
0003F4r 2  50           
0003F5r 2  02 4F 46 51          .BYTE   2, "OF",        TOK_OF
0003F9r 2  02 4F 52 52          .BYTE   2, "OR",        TOK_OR
0003FDr 2  09 50 52 4F          .BYTE   9, "PROCEDURE", TOK_PROCEDURE
000401r 2  43 45 44 55  
000405r 2  52 45 53     
000408r 2  07 50 52 4F          .BYTE   7, "PROGRAM",   TOK_PROGRAM
00040Cr 2  47 52 41 4D  
000410r 2  54           
000411r 2  06 52 45 43          .BYTE   6, "RECORD",    TOK_RECORD
000415r 2  4F 52 44 55  
000419r 2  06 52 45 50          .BYTE   6, "REPEAT",    TOK_REPEAT
00041Dr 2  45 41 54 56  
000421r 2  03 53 45 54          .BYTE   3, "SET",       TOK_SET
000425r 2  57           
000426r 2  04 54 48 45          .BYTE   4, "THEN",      TOK_THEN
00042Ar 2  4E 58        
00042Cr 2  02 54 4F 59          .BYTE   2, "TO",        TOK_TO
000430r 2  04 54 59 50          .BYTE   4, "TYPE",      TOK_TYPE
000434r 2  45 5A        
000436r 2  04 55 4E 49          .BYTE   4, "UNIT",      TOK_UNIT
00043Ar 2  54 61        
00043Cr 2  05 55 4E 54          .BYTE   5, "UNTIL",     TOK_UNTIL
000440r 2  49 4C 5B     
000443r 2  04 55 53 45          .BYTE   4, "USES",      TOK_USES
000447r 2  53 62        
000449r 2  03 56 41 52          .BYTE   3, "VAR",       TOK_VAR
00044Dr 2  5C           
00044Er 2  05 57 48 49          .BYTE   5, "WHILE",     TOK_WHILE
000452r 2  4C 45 5D     
000455r 2  04 57 49 54          .BYTE   4, "WITH",      TOK_WITH
000459r 2  48 5E        
00045Br 2  00                   .BYTE   0               ; sentinel
00045Cr 2               
00045Cr 2               ; Identifier buffer (max 63 chars + length byte at [0])
00045Cr 2               ident_buf:
00045Cr 2  xx xx xx xx          .RES    64
000460r 2  xx xx xx xx  
000464r 2  xx xx xx xx  
00049Cr 2               
00049Cr 2               ; Saved-name buffer for parser (e.g. var-decl name preservation across
00049Cr 2               ; parse_type_spec which clobbers ident_buf).
00049Cr 2               save_name_buf:
00049Cr 2  xx xx xx xx          .RES    16
0004A0r 2  xx xx xx xx  
0004A4r 2  xx xx xx xx  
0004ACr 2               
0004ACr 2               ; Saved symbol info — used by parse_assign_or_call to preserve symbol
0004ACr 2               ; entry fields across next_token + parse_expression, which clobber tmp3.
0004ACr 2               sym_save_kind:
0004ACr 2  xx                   .RES    1
0004ADr 2               sym_save_type:
0004ADr 2  xx                   .RES    1               ; SYM entry offset 17 (data type: TY_*)
0004AEr 2               sym_save_scope:
0004AEr 2  xx                   .RES    1
0004AFr 2               sym_save_off:
0004AFr 2  xx xx                .RES    2
0004B1r 2               sym_save_pcount:
0004B1r 2  xx                   .RES    1                       ; SYM_PROC param count (entry offset 21)
0004B2r 2               sym_save_vmask:
0004B2r 2  xx                   .RES    1               ; SYM_PROC/SYM_FUNC VAR-param bitmap (entry offset 22)
0004B3r 2               sym_save_lsize:
0004B3r 2  xx                   .RES    1               ; SYM_PROC/SYM_FUNC total local-area size (entry offset 23)
0004B4r 2               sym_param_types:
0004B4r 2  xx xx xx xx          .RES    8               ; formal parameter types 0..7 copied from entry bytes 24..31
0004B8r 2  xx xx xx xx  
0004BCr 2               
0004BCr 2               ; ARRAY type scratch — set by parse_type_spec when it parses an ARRAY type;
0004BCr 2               ; read by parse_var_decls to compute storage size and adjusted offset.
0004BCr 2               array_lo:
0004BCr 2  xx xx                .RES    2               ; lower bound (signed word)
0004BEr 2               array_hi:
0004BEr 2  xx xx                .RES    2               ; upper bound (signed word)
0004C0r 2               array_elem_ty:
0004C0r 2  xx                   .RES    1               ; element base type (TY_INT, TY_CHAR, TY_BOOL …)
0004C1r 2               
0004C1r 2               ; RECORD type scratch — set by parse_type_spec when it parses a RECORD type
0004C1r 2               ; (or resolves a TYPE alias of a RECORD).  Read by parse_var_decls and by
0004C1r 2               ; parse_type_decls to copy into the new SYM_VAR/SYM_TYPE entry.
0004C1r 2               record_size:
0004C1r 2  xx xx                .RES    2               ; total record size in bytes
0004C3r 2               record_first_field:
0004C3r 2  xx                   .RES    1               ; index of first field in field_table
0004C4r 2               record_field_count:
0004C4r 2  xx                   .RES    1               ; number of fields in this record
0004C5r 2               ptr_meta_cur:
0004C5r 2  xx                   .RES    1               ; current pointer-type metadata index
0004C6r 2               
0004C6r 2               ; Procedure-declaration scratch (parse_proc_decl; not nestable in this build).
0004C6r 2               proc_param_count:
0004C6r 2  xx                   .RES    1               ; running count while parsing param list
0004C7r 2               proc_entry_idx:
0004C7r 2  xx xx                .RES    2               ; symtab entry pointer (legacy name; for backpatch)
0004C9r 2               param_var_mask:
0004C9r 2  xx                   .RES    1               ; bitmap of which params are VAR (bit i ↔ param i, max 8)
0004CAr 2               group_is_var:
0004CAr 2  xx                   .RES    1               ; 1 while parsing the names of a VAR-prefixed group
0004CBr 2               local_alloc_off:
0004CBr 2  xx                   .RES    1               ; next free local-AR offset; init = pcount*2 at proc entry
0004CCr 2               uses_saved_tok:
0004CCr 2  xx                   .RES    1               ; saved top-level lookahead token while USES imports other source files
0004CDr 2               
0004CDr 2               ; Function-call scratch (parse_factor @sym_func_call; nested fn calls in args
0004CDr 2               ; not yet supported — see TODO).
0004CDr 2               fcall_pcount:
0004CDr 2  xx                   .RES    1
0004CEr 2               fcall_lo:
0004CEr 2  xx                   .RES    1
0004CFr 2               fcall_hi:
0004CFr 2  xx                   .RES    1
0004D0r 2               fcall_type:
0004D0r 2  xx                   .RES    1
0004D1r 2               fcall_vmask:
0004D1r 2  xx                   .RES    1               ; the called proc/func's VAR-param bitmap
0004D2r 2               fcall_lsize:
0004D2r 2  xx                   .RES    1               ; the called proc/func's total local-area size (params+locals)
0004D3r 2               fcall_param_types:
0004D3r 2  xx xx xx xx          .RES    8               ; formal parameter types 0..7 for the active function call
0004D7r 2  xx xx xx xx  
0004DBr 2               
0004DBr 2               ; Record-chain scratch (parse_statement / parse_factor). Used while walking
0004DBr 2               ; dotted field access through nested RECORD values.
0004DBr 2               field_chain_type:
0004DBr 2  xx                   .RES    1
0004DCr 2               field_chain_first:
0004DCr 2  xx                   .RES    1
0004DDr 2               field_chain_count:
0004DDr 2  xx                   .RES    1
0004DEr 2               field_chain_ptrmeta:
0004DEr 2  xx                   .RES    1
0004DFr 2               
0004DFr 2               ; SET literal scratch (compile-time only). SET values are 16-bit masks over
0004DFr 2               ; element values 0..15 in this build.
0004DFr 2               set_lit_mask:
0004DFr 2  xx xx                .RES    2
0004E1r 2               set_lit_lo:
0004E1r 2  xx                   .RES    1
0004E2r 2               set_lit_hi:
0004E2r 2  xx                   .RES    1
0004E3r 2               set_lit_cur:
0004E3r 2  xx                   .RES    1
0004E4r 2               real_frac_count:
0004E4r 2  xx                   .RES    1               ; lexer scratch while tokenising fixed-point REAL literals
0004E5r 2               
0004E5r 2               ; Main-program entry-point patch slot. compile_program emits a UJP at code
0004E5r 2               ; offset 0; top-level BEGIN/init blocks patch it to the first startup body
0004E5r 2               ; that should run. Hi byte = $FF means "already patched / none pending"
0004E5r 2               ; (sentinel — never a valid patch addr since cg_pc starts at 0).
0004E5r 2               main_jmp_patch:
0004E5r 2  xx xx                .RES    2
0004E7r 2               
0004E7r 2               ; Pending tail-jump patch for the most recently emitted top-level body.
0004E7r 2               ; Each startup body (unit init or main BEGIN) ends with a UJP placeholder so
0004E7r 2               ; later top-level bodies can be chained together without falling through into
0004E7r 2               ; intervening procedure/function code.
0004E7r 2               body_chain_patch:
0004E7r 2  xx xx                .RES    2
0004E9r 2               
0004E9r 2               ; ---------------------------------------------------------------------------
0004E9r 2               ; lexer_init — reset lexer state; call before compile_program
0004E9r 2               ; ---------------------------------------------------------------------------
0004E9r 2               lexer_init:
0004E9r 2  A9 01                LDA     #1
0004EBr 2  85 rr                STA     lex_line
0004EDr 2  A9 00                LDA     #0
0004EFr 2  85 rr                STA     lex_line+1
0004F1r 2  85 rr                STA     lex_col
0004F3r 2  85 rr                STA     src_buf_pos
0004F5r 2  85 rr                STA     src_buf_end
0004F7r 2               ; prime lex_char
0004F7r 2  20 rr rr             JSR     lexer_getc
0004FAr 2  60                   RTS
0004FBr 2               
0004FBr 2               ; ---------------------------------------------------------------------------
0004FBr 2               ; next_token — advance to next token, set tok_type
0004FBr 2               ; On return:
0004FBr 2               ;   tok_type  = token code
0004FBr 2               ;   tok_ival  = integer value (if TOK_INT)
0004FBr 2               ;   ident_buf = identifier string (if TOK_IDENT)
0004FBr 2               ; ---------------------------------------------------------------------------
0004FBr 2               next_token:
0004FBr 2               ; skip whitespace and comments
0004FBr 2               @skip:
0004FBr 2  A5 rr                LDA     lex_char
0004FDr 2  F0 3B                BEQ     @eof
0004FFr 2  C9 20                CMP     #' '
000501r 2  F0 13                BEQ     @ws
000503r 2  C9 09                CMP     #$09            ; TAB
000505r 2  F0 0F                BEQ     @ws
000507r 2  C9 0D                CMP     #$0D            ; CR — treat as whitespace, LF counts the line
000509r 2  F0 0B                BEQ     @ws
00050Br 2  C9 0A                CMP     #$0A            ; LF
00050Dr 2  F0 0C                BEQ     @nl
00050Fr 2  C9 7B                CMP     #'{'            ; Pascal comment start
000511r 2  F0 17                BEQ     @comment
000513r 2  4C rr rr             JMP     @not_ws
000516r 2               @ws:
000516r 2  20 rr rr             JSR     lexer_getc
000519r 2  80 E0                BRA     @skip
00051Br 2               @nl:
00051Br 2  E6 rr                INC     lex_line
00051Dr 2  D0 02                BNE     :+
00051Fr 2  E6 rr                INC     lex_line+1
000521r 2               :
000521r 2  A9 00                LDA     #0
000523r 2  85 rr                STA     lex_col
000525r 2  20 rr rr             JSR     lexer_getc
000528r 2  80 D1                BRA     @skip
00052Ar 2               @comment:
00052Ar 2               ; skip { ... }
00052Ar 2               @cloop:
00052Ar 2  20 rr rr             JSR     lexer_getc
00052Dr 2  A5 rr                LDA     lex_char        ; PLY inside lexer_getc clobbers Z; reload to test EOF
00052Fr 2  F0 09                BEQ     @eof
000531r 2  C9 7D                CMP     #'}'
000533r 2  D0 F5                BNE     @cloop
000535r 2  20 rr rr             JSR     lexer_getc
000538r 2  80 C1                BRA     @skip
00053Ar 2               @eof:
00053Ar 2  A9 00                LDA     #TOK_EOF
00053Cr 2  85 rr                STA     tok_type
00053Er 2  60                   RTS
00053Fr 2               
00053Fr 2               @not_ws:
00053Fr 2               ; letter → identifier or keyword
00053Fr 2  20 rr rr             JSR     is_letter
000542r 2  90 03                BCC     :+
000544r 2  4C rr rr             JMP     @ident
000547r 2               :
000547r 2               
000547r 2               ; digit → integer literal
000547r 2  20 rr rr             JSR     is_digit
00054Ar 2  90 03                BCC     :+
00054Cr 2  4C rr rr             JMP     @number
00054Fr 2               :
00054Fr 2               
00054Fr 2               ; string → string literal
00054Fr 2  C9 27                CMP     #$27            ; single quote
000551r 2  D0 03                BNE     :+
000553r 2  4C rr rr             JMP     @string
000556r 2               :
000556r 2               
000556r 2               ; operators and punctuation
000556r 2  4C rr rr             JMP     @punct
000559r 2               
000559r 2               ; --- Identifier ---
000559r 2               @ident:
000559r 2  A0 00                LDY     #0
00055Br 2               @id_loop:
00055Br 2  A5 rr                LDA     lex_char
00055Dr 2  20 rr rr             JSR     to_upper
000560r 2  99 rr rr             STA     ident_buf+1,y
000563r 2  C8                   INY
000564r 2  C0 3F                CPY     #63
000566r 2  F0 0F                BEQ     @id_done
000568r 2  20 rr rr             JSR     lexer_getc
00056Br 2  A5 rr                LDA     lex_char
00056Dr 2  20 rr rr             JSR     is_letter
000570r 2  B0 E9                BCS     @id_loop
000572r 2  20 rr rr             JSR     is_digit
000575r 2  B0 E4                BCS     @id_loop
000577r 2               @id_done:
000577r 2  98                   TYA
000578r 2  8D rr rr             STA     ident_buf       ; length
00057Br 2               ; check against keyword table
00057Br 2  20 rr rr             JSR     lookup_keyword
00057Er 2  85 rr                STA     tok_type
000580r 2  60                   RTS
000581r 2               
000581r 2               ; --- Numeric literal (integer or fixed-point REAL) ---
000581r 2               @number:
000581r 2  A9 00                LDA     #0
000583r 2  85 rr                STA     tok_ival_lo
000585r 2  85 rr                STA     tok_ival_hi
000587r 2               @num_loop:
000587r 2  A5 rr                LDA     lex_char
000589r 2  38                   SEC
00058Ar 2  E9 30                SBC     #'0'
00058Cr 2  20 rr rr             JSR     mul10_tokval    ; tokval = tokval*10 + digit
00058Fr 2  20 rr rr             JSR     lexer_getc
000592r 2  A5 rr                LDA     lex_char
000594r 2  20 rr rr             JSR     is_digit
000597r 2  B0 EE                BCS     @num_loop
000599r 2  A5 rr                LDA     lex_char
00059Br 2  C9 2E                CMP     #'.'
00059Dr 2  D0 5D                BNE     @num_int
00059Fr 2  A5 rr                LDA     src_buf_pos
0005A1r 2  C5 rr                CMP     src_buf_end
0005A3r 2  B0 57                BCS     @num_int               ; dot at sector boundary -> treat as integer
0005A5r 2  A8                   TAY
0005A6r 2  B9 28 01             LDA     DMA_BUF,y
0005A9r 2  C9 2E                CMP     #'.'
0005ABr 2  F0 4F                BEQ     @num_int               ; 1..10 range syntax
0005ADr 2  C9 30                CMP     #'0'
0005AFr 2  90 4B                BCC     @num_int
0005B1r 2  C9 3A                CMP     #'9'+1
0005B3r 2  B0 47                BCS     @num_int
0005B5r 2  A9 00                LDA     #0
0005B7r 2  8D rr rr             STA     real_frac_count
0005BAr 2  20 rr rr             JSR     lexer_getc             ; consume '.' -> first fractional digit
0005BDr 2               @real_loop:
0005BDr 2  A5 rr                LDA     lex_char
0005BFr 2  20 rr rr             JSR     is_digit
0005C2r 2  90 17                BCC     @real_done
0005C4r 2  AD rr rr             LDA     real_frac_count
0005C7r 2  C9 02                CMP     #2
0005C9r 2  B0 0B                BCS     @real_skip_digit
0005CBr 2  A5 rr                LDA     lex_char
0005CDr 2  38                   SEC
0005CEr 2  E9 30                SBC     #'0'
0005D0r 2  20 rr rr             JSR     mul10_tokval
0005D3r 2  EE rr rr             INC     real_frac_count
0005D6r 2               @real_skip_digit:
0005D6r 2  20 rr rr             JSR     lexer_getc
0005D9r 2  80 E2                BRA     @real_loop
0005DBr 2               @real_done:
0005DBr 2  AD rr rr             LDA     real_frac_count
0005DEr 2  C9 00                CMP     #0
0005E0r 2  D0 0C                BNE     :+
0005E2r 2  A9 00                LDA     #0
0005E4r 2  20 rr rr             JSR     mul10_tokval
0005E7r 2  A9 00                LDA     #0
0005E9r 2  20 rr rr             JSR     mul10_tokval
0005ECr 2  80 09                BRA     @num_real
0005EEr 2  C9 01        :       CMP     #1
0005F0r 2  D0 05                BNE     @num_real
0005F2r 2  A9 00                LDA     #0
0005F4r 2  20 rr rr             JSR     mul10_tokval
0005F7r 2               @num_real:
0005F7r 2  A9 05                LDA     #TOK_REAL
0005F9r 2  85 rr                STA     tok_type
0005FBr 2  60                   RTS
0005FCr 2               @num_int:
0005FCr 2  A9 02                LDA     #TOK_INT
0005FEr 2  85 rr                STA     tok_type
000600r 2  60                   RTS
000601r 2               
000601r 2               ; --- String literal ---
000601r 2               @string:
000601r 2  20 rr rr             JSR     lexer_getc      ; skip opening quote
000604r 2  A0 00                LDY     #0
000606r 2               @str_loop:
000606r 2  A5 rr                LDA     lex_char
000608r 2  F0 21                BEQ     @str_done       ; EOF
00060Ar 2  C9 27                CMP     #$27
00060Cr 2  F0 09                BEQ     @str_close
00060Er 2  99 rr rr             STA     ident_buf+1,y
000611r 2  C8                   INY
000612r 2  20 rr rr             JSR     lexer_getc
000615r 2  80 EF                BRA     @str_loop
000617r 2               @str_close:
000617r 2  20 rr rr             JSR     lexer_getc      ; skip closing quote
00061Ar 2               ; check for '' (escaped quote)
00061Ar 2  A5 rr                LDA     lex_char
00061Cr 2  C9 27                CMP     #$27
00061Er 2  D0 0B                BNE     @str_done
000620r 2  A9 27                LDA     #$27
000622r 2  99 rr rr             STA     ident_buf+1,y
000625r 2  C8                   INY
000626r 2  20 rr rr             JSR     lexer_getc
000629r 2  80 DB                BRA     @str_loop
00062Br 2               @str_done:
00062Br 2  98                   TYA
00062Cr 2  8D rr rr             STA     ident_buf
00062Fr 2  A9 03                LDA     #TOK_STRING
000631r 2  85 rr                STA     tok_type
000633r 2  60                   RTS
000634r 2               
000634r 2               ; --- Punctuation / operators ---
000634r 2               @punct:
000634r 2  A2 00                LDX     #0
000636r 2  A5 rr                LDA     lex_char
000638r 2  C9 2B                CMP     #'+'
00063Ar 2  D0 02                BNE     :+
00063Cr 2  A2 10                LDX     #TOK_PLUS
00063Er 2               :
00063Er 2  C9 2D                CMP     #'-'
000640r 2  D0 02                BNE     :+
000642r 2  A2 11                LDX     #TOK_MINUS
000644r 2               :
000644r 2  C9 2A                CMP     #'*'
000646r 2  D0 02                BNE     :+
000648r 2  A2 12                LDX     #TOK_STAR
00064Ar 2               :
00064Ar 2  C9 2F                CMP     #'/'
00064Cr 2  D0 02                BNE     :+
00064Er 2  A2 13                LDX     #TOK_SLASH
000650r 2               :
000650r 2  C9 3D                CMP     #'='
000652r 2  D0 02                BNE     :+
000654r 2  A2 14                LDX     #TOK_EQ
000656r 2               :
000656r 2  C9 28                CMP     #'('
000658r 2  D0 02                BNE     :+
00065Ar 2  A2 1B                LDX     #TOK_LPAREN
00065Cr 2               :
00065Cr 2  C9 29                CMP     #')'
00065Er 2  D0 02                BNE     :+
000660r 2  A2 1C                LDX     #TOK_RPAREN
000662r 2               :
000662r 2  C9 5B                CMP     #'['
000664r 2  D0 02                BNE     :+
000666r 2  A2 1D                LDX     #TOK_LBRACK
000668r 2               :
000668r 2  C9 5D                CMP     #']'
00066Ar 2  D0 02                BNE     :+
00066Cr 2  A2 1E                LDX     #TOK_RBRACK
00066Er 2               :
00066Er 2  C9 2C                CMP     #','
000670r 2  D0 02                BNE     :+
000672r 2  A2 1F                LDX     #TOK_COMMA
000674r 2               :
000674r 2  C9 3B                CMP     #';'
000676r 2  D0 02                BNE     :+
000678r 2  A2 20                LDX     #TOK_SEMICOLON
00067Ar 2               :
00067Ar 2  C9 5E                CMP     #'^'
00067Cr 2  D0 02                BNE     :+
00067Er 2  A2 24                LDX     #TOK_CARET
000680r 2               :
000680r 2  C9 3C                CMP     #'<'
000682r 2  D0 22                BNE     @not_lt
000684r 2  20 rr rr             JSR     lexer_getc
000687r 2  A5 rr                LDA     lex_char
000689r 2  C9 3D                CMP     #'='
00068Br 2  F0 09                BEQ     @leq
00068Dr 2  C9 3E                CMP     #'>'
00068Fr 2  F0 0D                BEQ     @neq
000691r 2  A9 16                LDA     #TOK_LT
000693r 2  85 rr                STA     tok_type
000695r 2  60                   RTS
000696r 2               @leq:
000696r 2  20 rr rr             JSR     lexer_getc
000699r 2  A9 18                LDA     #TOK_LEQ
00069Br 2  85 rr                STA     tok_type
00069Dr 2  60                   RTS
00069Er 2               @neq:
00069Er 2  20 rr rr             JSR     lexer_getc
0006A1r 2  A9 15                LDA     #TOK_NEQ
0006A3r 2  85 rr                STA     tok_type
0006A5r 2  60                   RTS
0006A6r 2               @not_lt:
0006A6r 2  C9 3E                CMP     #'>'
0006A8r 2  D0 16                BNE     @not_gt
0006AAr 2  20 rr rr             JSR     lexer_getc
0006ADr 2  A5 rr                LDA     lex_char
0006AFr 2  C9 3D                CMP     #'='
0006B1r 2  F0 05                BEQ     @geq
0006B3r 2  A9 17                LDA     #TOK_GT
0006B5r 2  85 rr                STA     tok_type
0006B7r 2  60                   RTS
0006B8r 2               @geq:
0006B8r 2  20 rr rr             JSR     lexer_getc
0006BBr 2  A9 19                LDA     #TOK_GEQ
0006BDr 2  85 rr                STA     tok_type
0006BFr 2  60                   RTS
0006C0r 2               @not_gt:
0006C0r 2  C9 3A                CMP     #':'
0006C2r 2  D0 16                BNE     @not_colon
0006C4r 2  20 rr rr             JSR     lexer_getc
0006C7r 2  A5 rr                LDA     lex_char
0006C9r 2  C9 3D                CMP     #'='
0006CBr 2  F0 05                BEQ     @assign
0006CDr 2  A9 21                LDA     #TOK_COLON
0006CFr 2  85 rr                STA     tok_type
0006D1r 2  60                   RTS
0006D2r 2               @assign:
0006D2r 2  20 rr rr             JSR     lexer_getc
0006D5r 2  A9 1A                LDA     #TOK_ASSIGN
0006D7r 2  85 rr                STA     tok_type
0006D9r 2  60                   RTS
0006DAr 2               @not_colon:
0006DAr 2  C9 2E                CMP     #'.'
0006DCr 2  D0 16                BNE     @not_dot
0006DEr 2  20 rr rr             JSR     lexer_getc
0006E1r 2  A5 rr                LDA     lex_char
0006E3r 2  C9 2E                CMP     #'.'
0006E5r 2  F0 05                BEQ     @dotdot
0006E7r 2  A9 22                LDA     #TOK_DOT
0006E9r 2  85 rr                STA     tok_type
0006EBr 2  60                   RTS
0006ECr 2               @dotdot:
0006ECr 2  20 rr rr             JSR     lexer_getc
0006EFr 2  A9 23                LDA     #TOK_DOTDOT
0006F1r 2  85 rr                STA     tok_type
0006F3r 2  60                   RTS
0006F4r 2               @not_dot:
0006F4r 2               ; If a single-byte operator matched above, X holds its TOK_* code.
0006F4r 2               ; Otherwise X=0 and the character is unknown — skip and retry.
0006F4r 2  E0 00                CPX     #0
0006F6r 2  F0 07                BEQ     @unknown
0006F8r 2  8A                   TXA
0006F9r 2  85 rr                STA     tok_type
0006FBr 2  20 rr rr             JSR     lexer_getc
0006FEr 2  60                   RTS
0006FFr 2               @unknown:
0006FFr 2  20 rr rr             JSR     lexer_getc
000702r 2  4C rr rr             JMP     next_token
000705r 2               
000705r 2               ; ---------------------------------------------------------------------------
000705r 2               ; lexer_getc — fetch next character into lex_char
000705r 2               ; Refills sector buffer via file_read_sector when empty
000705r 2               ; ---------------------------------------------------------------------------
000705r 2               lexer_getc:
000705r 2  5A                   PHY                     ; preserve caller's Y across refill + read
000706r 2  A5 rr                LDA     src_buf_pos
000708r 2  C5 rr                CMP     src_buf_end
00070Ar 2  90 17                BCC     @from_buf       ; still have data
00070Cr 2               ; refill buffer — set tmp1 to source FCB first
00070Cr 2               ; (other code paths leave tmp1 pointing at output FCB)
00070Cr 2  A5 rr                LDA     src_fcb
00070Er 2  85 rr                STA     tmp1
000710r 2  A5 rr                LDA     src_fcb+1
000712r 2  85 rr                STA     tmp1+1
000714r 2  20 rr rr             JSR     file_read_sector
000717r 2  C9 00                CMP     #0
000719r 2  D0 15                BNE     @eof_char
00071Br 2  A9 80                LDA     #128
00071Dr 2  85 rr                STA     src_buf_end
00071Fr 2  A9 00                LDA     #0
000721r 2  85 rr                STA     src_buf_pos
000723r 2               @from_buf:
000723r 2  A4 rr                LDY     src_buf_pos
000725r 2  B9 28 01             LDA     DMA_BUF,y
000728r 2  E6 rr                INC     src_buf_pos
00072Ar 2  85 rr                STA     lex_char
00072Cr 2  E6 rr                INC     lex_col
00072Er 2  7A                   PLY
00072Fr 2  60                   RTS
000730r 2               @eof_char:
000730r 2  A9 00                LDA     #0
000732r 2  85 rr                STA     lex_char
000734r 2  7A                   PLY
000735r 2  60                   RTS
000736r 2               
000736r 2               ; ---------------------------------------------------------------------------
000736r 2               ; lookup_keyword — check ident_buf against keyword_table
000736r 2               ; Returns: A = keyword token code, or TOK_IDENT if not found
000736r 2               ; ---------------------------------------------------------------------------
000736r 2               lookup_keyword:
000736r 2  A9 rr                LDA     #<keyword_table
000738r 2  85 rr                STA     tmp2
00073Ar 2  A9 rr                LDA     #>keyword_table
00073Cr 2  85 rr                STA     tmp2+1
00073Er 2               @next_kw:
00073Er 2  A0 00                LDY     #0
000740r 2  B1 rr                LDA     (tmp2),y        ; keyword length (0 = sentinel)
000742r 2  F0 2C                BEQ     @not_found
000744r 2  CD rr rr             CMP     ident_buf       ; compare lengths first
000747r 2  D0 15                BNE     @advance
000749r 2  AA                   TAX                     ; X = length
00074Ar 2  A0 01                LDY     #1
00074Cr 2               @cmp_loop:
00074Cr 2  B1 rr                LDA     (tmp2),y
00074Er 2  D9 rr rr             CMP     ident_buf,y
000751r 2  D0 0B                BNE     @advance
000753r 2  C8                   INY
000754r 2  CA                   DEX
000755r 2  D0 F5                BNE     @cmp_loop
000757r 2               ; match: token code is at offset length+1
000757r 2  AC rr rr             LDY     ident_buf
00075Ar 2  C8                   INY
00075Br 2  B1 rr                LDA     (tmp2),y
00075Dr 2  60                   RTS
00075Er 2               @advance:
00075Er 2               ; skip to next entry: advance tmp2 by (length+2)
00075Er 2               ; (Y may be >0 if we got here from @cmp_loop — reset to 0 first)
00075Er 2  A0 00                LDY     #0
000760r 2  B1 rr                LDA     (tmp2),y        ; length byte
000762r 2  18                   CLC
000763r 2  69 02                ADC     #2              ; +1 for length byte, +1 for token byte
000765r 2  18                   CLC
000766r 2  65 rr                ADC     tmp2
000768r 2  85 rr                STA     tmp2
00076Ar 2  90 02                BCC     :+
00076Cr 2  E6 rr                INC     tmp2+1
00076Er 2               :
00076Er 2  80 CE                BRA     @next_kw
000770r 2               @not_found:
000770r 2  A9 01                LDA     #TOK_IDENT
000772r 2  60                   RTS
000773r 2               
000773r 2               ; ---------------------------------------------------------------------------
000773r 2               ; is_letter — test lex_char; carry set if A-Z or a-z
000773r 2               ; ---------------------------------------------------------------------------
000773r 2               is_letter:
000773r 2  A5 rr                LDA     lex_char
000775r 2  C9 41                CMP     #'A'
000777r 2  90 10                BCC     @no
000779r 2  C9 5B                CMP     #'Z'+1
00077Br 2  90 0E                BCC     @yes
00077Dr 2  C9 61                CMP     #'a'
00077Fr 2  90 08                BCC     @no
000781r 2  C9 7B                CMP     #'z'+1
000783r 2  90 06                BCC     @yes
000785r 2  C9 5F                CMP     #'_'
000787r 2  F0 02                BEQ     @yes
000789r 2               @no:
000789r 2  18                   CLC
00078Ar 2  60                   RTS
00078Br 2               @yes:
00078Br 2  38                   SEC
00078Cr 2  60                   RTS
00078Dr 2               
00078Dr 2               ; ---------------------------------------------------------------------------
00078Dr 2               ; is_digit — test lex_char; carry set if 0-9
00078Dr 2               ; ---------------------------------------------------------------------------
00078Dr 2               is_digit:
00078Dr 2  A5 rr                LDA     lex_char
00078Fr 2  C9 30                CMP     #'0'
000791r 2  90 06                BCC     @no
000793r 2  C9 3A                CMP     #'9'+1
000795r 2  B0 02                BCS     @no
000797r 2  38                   SEC
000798r 2  60                   RTS
000799r 2               @no:
000799r 2  18                   CLC
00079Ar 2  60                   RTS
00079Br 2               
00079Br 2               ; ---------------------------------------------------------------------------
00079Br 2               ; to_upper — convert A to uppercase (A-Z,a-z only, others pass through)
00079Br 2               ; ---------------------------------------------------------------------------
00079Br 2               to_upper:
00079Br 2  C9 61                CMP     #'a'
00079Dr 2  90 06                BCC     @done
00079Fr 2  C9 7B                CMP     #'z'+1
0007A1r 2  B0 02                BCS     @done
0007A3r 2  29 DF                AND     #$DF
0007A5r 2               @done:
0007A5r 2  60                   RTS
0007A6r 2               
0007A6r 2               ; ---------------------------------------------------------------------------
0007A6r 2               ; mul10_tokval — tokval = tokval*10 + A  (A = digit 0-9)
0007A6r 2               ; ---------------------------------------------------------------------------
0007A6r 2               mul10_tokval:
0007A6r 2  48                   PHA
0007A7r 2               ; multiply tok_ival by 10: x10 = x*8 + x*2
0007A7r 2  A5 rr                LDA     tok_ival_lo
0007A9r 2  0A                   ASL                     ; *2
0007AAr 2  85 rr                STA     tmp2
0007ACr 2  A5 rr                LDA     tok_ival_hi
0007AEr 2  2A                   ROL
0007AFr 2  85 rr                STA     tmp2+1
0007B1r 2  A5 rr                LDA     tmp2            ; *4
0007B3r 2  0A                   ASL
0007B4r 2  85 rr                STA     tmp3
0007B6r 2  A5 rr                LDA     tmp2+1
0007B8r 2  2A                   ROL
0007B9r 2  85 rr                STA     tmp3+1
0007BBr 2  A5 rr                LDA     tmp3            ; *8
0007BDr 2  0A                   ASL
0007BEr 2  85 rr                STA     tmp3
0007C0r 2  A5 rr                LDA     tmp3+1
0007C2r 2  2A                   ROL
0007C3r 2  85 rr                STA     tmp3+1
0007C5r 2               ; *10 = *8 + *2
0007C5r 2  A5 rr                LDA     tmp3
0007C7r 2  18                   CLC
0007C8r 2  65 rr                ADC     tmp2
0007CAr 2  85 rr                STA     tok_ival_lo
0007CCr 2  A5 rr                LDA     tmp3+1
0007CEr 2  65 rr                ADC     tmp2+1
0007D0r 2  85 rr                STA     tok_ival_hi
0007D2r 2               ; add digit
0007D2r 2  68                   PLA
0007D3r 2  18                   CLC
0007D4r 2  65 rr                ADC     tok_ival_lo
0007D6r 2  85 rr                STA     tok_ival_lo
0007D8r 2  90 02                BCC     :+
0007DAr 2  E6 rr                INC     tok_ival_hi
0007DCr 2               :
0007DCr 2  60                   RTS
0007DDr 2               
0007DDr 1                       .include        "PARSER.ASM"
0007DDr 2               ; parser.asm — recursive-descent Pascal parser + single-pass code generator
0007DDr 2               ;
0007DDr 2               ; Entry point: compile_program (called from pascal_main)
0007DDr 2               ;
0007DDr 2               ; This is a skeleton. Each parse routine calls next_token and emits p-code
0007DDr 2               ; directly (no AST nodes). Phase 3 fleshes out the full grammar.
0007DDr 2               
0007DDr 2                       .segment        "CODE"
0007DDr 2               
0007DDr 2               ; ---------------------------------------------------------------------------
0007DDr 2               ; expect — verify current token is `expected_tok`, advance, error if not
0007DDr 2               ; expected_tok passed in X; error string pointer in tmp3 (lo) and A (hi)
0007DDr 2               ; ---------------------------------------------------------------------------
0007DDr 2               expect:
0007DDr 2  A5 rr                LDA     tok_type
0007DFr 2  E4 rr                CPX     tok_type
0007E1r 2  F0 18                BEQ     @ok
0007E3r 2               ; mismatch — report error using tmp3 as message pointer
0007E3r 2  A5 rr                LDA     tmp3
0007E5r 2  85 rr                STA     tmp0
0007E7r 2  A5 rr                LDA     tmp3+1
0007E9r 2  85 rr                STA     tmp0+1
0007EBr 2  20 rr rr             JSR     compile_error
0007EEr 2               ; attempt recovery: skip tokens until we see the expected one or EOF
0007EEr 2               @recover:
0007EEr 2  A5 rr                LDA     tok_type
0007F0r 2  F0 09                BEQ     @ok             ; EOF — stop recovery
0007F2r 2  E4 rr                CPX     tok_type
0007F4r 2  F0 05                BEQ     @ok
0007F6r 2  20 rr rr             JSR     next_token
0007F9r 2  80 F3                BRA     @recover
0007FBr 2               @ok:
0007FBr 2  20 rr rr             JSR     next_token
0007FEr 2  60                   RTS
0007FFr 2               
0007FFr 2               ; Helper macros — not ca65 .macros since they'd be complex; use inline calls.
0007FFr 2               
0007FFr 2               ; ---------------------------------------------------------------------------
0007FFr 2               ; compile_program — top-level dispatcher for PROGRAM or UNIT sources.
0007FFr 2               ; ---------------------------------------------------------------------------
0007FFr 2               compile_program:
0007FFr 2  20 rr rr             JSR     symtab_init
000802r 2  A9 00                LDA     #0
000804r 2  8D rr rr             STA     unit_section
000807r 2  A5 rr                LDA     tok_type
000809r 2  C9 61                CMP     #TOK_UNIT
00080Br 2  F0 03                BEQ     @unit_src
00080Dr 2  4C rr rr             JMP     @program_src
000810r 2               @unit_src:
000810r 2  4C rr rr             JMP     compile_unit
000813r 2               @program_src:
000813r 2               ; expect PROGRAM keyword
000813r 2  A5 rr                LDA     tok_type
000815r 2  C9 54                CMP     #TOK_PROGRAM
000817r 2  D0 0F                BNE     @no_hdr         ; allow missing PROGRAM header (lenient)
000819r 2  20 rr rr             JSR     next_token
00081Cr 2               ; program name (identifier)
00081Cr 2  20 rr rr             JSR     next_token
00081Fr 2               ; semicolon
00081Fr 2  A5 rr                LDA     tok_type
000821r 2  C9 20                CMP     #TOK_SEMICOLON
000823r 2  D0 03                BNE     :+
000825r 2  20 rr rr             JSR     next_token
000828r 2               :
000828r 2               @no_hdr:
000828r 2               ; Emit a forward UJP at code offset 0; parse_block patches it to point
000828r 2               ; to the main BEGIN block once all proc bodies have been emitted ahead
000828r 2               ; of it. The .PCD entry point stays at offset 0 (start of code = UJP).
000828r 2  20 rr rr             JSR     emit_UJP        ; A=patch_lo, scratch=patch_hi
00082Br 2  8D rr rr             STA     main_jmp_patch
00082Er 2  A5 rr                LDA     scratch
000830r 2  8D rr rr             STA     main_jmp_patch+1
000833r 2  20 rr rr             JSR     parse_block
000836r 2               ; Emit HALT at end of main program
000836r 2  20 rr rr             JSR     patch_startup_chain_if_needed
000839r 2  20 rr rr             JSR     emit_HALT
00083Cr 2  60                   RTS
00083Dr 2               
00083Dr 2               ; patch_startup_chain_if_needed — patch any pending top-level startup jumps
00083Dr 2               ; to the current cg_pc. This handles both the entry UJP (jump to the first
00083Dr 2               ; unit-init/main body) and the tail UJP emitted after each prior top-level
00083Dr 2               ; body (jump to the next one, or eventually HALT).
00083Dr 2               patch_startup_chain_if_needed:
00083Dr 2  AD rr rr             LDA     main_jmp_patch+1
000840r 2  C9 FF                CMP     #$FF
000842r 2  F0 12                BEQ     @pscii_tail
000844r 2  AD rr rr             LDA     main_jmp_patch
000847r 2  85 rr                STA     tmp2
000849r 2  AD rr rr             LDA     main_jmp_patch+1
00084Cr 2  85 rr                STA     tmp2+1
00084Er 2  20 rr rr             JSR     patch_jump
000851r 2  A9 FF                LDA     #$FF
000853r 2  8D rr rr             STA     main_jmp_patch+1
000856r 2               @pscii_tail:
000856r 2  AD rr rr             LDA     body_chain_patch+1
000859r 2  C9 FF                CMP     #$FF
00085Br 2  F0 12                BEQ     @pscii_done
00085Dr 2  AD rr rr             LDA     body_chain_patch
000860r 2  85 rr                STA     tmp2
000862r 2  AD rr rr             LDA     body_chain_patch+1
000865r 2  85 rr                STA     tmp2+1
000867r 2  20 rr rr             JSR     patch_jump
00086Ar 2  A9 FF                LDA     #$FF
00086Cr 2  8D rr rr             STA     body_chain_patch+1
00086Fr 2               @pscii_done:
00086Fr 2  60                   RTS
000870r 2               
000870r 2               ; ---------------------------------------------------------------------------
000870r 2               ; compile_unit — UNIT name ; INTERFACE ... IMPLEMENTATION ... [BEGIN ...] END.
000870r 2               ; UNIT sources may be standalone roots or USES-imported. The INTERFACE
000870r 2               ; section registers globals and routine headings; IMPLEMENTATION provides the
000870r 2               ; bodies plus an optional init block. Imported units compile inline into the
000870r 2               ; current .PCD while the startup jump chain preserves init order.
000870r 2               ; ---------------------------------------------------------------------------
000870r 2               compile_unit:
000870r 2  20 rr rr             JSR     next_token              ; consume UNIT
000873r 2  A5 rr                LDA     tok_type
000875r 2  C9 01                CMP     #TOK_IDENT
000877r 2  D0 21                BNE     :+
000879r 2  AD rr rr             LDA     unit_import_mode
00087Cr 2  D0 19                BNE     @cu_name_done
00087Er 2  AE rr rr             LDX     used_unit_count
000881r 2  E0 08                CPX     #USED_UNIT_SLOTS
000883r 2  B0 12                BCS     @cu_name_done
000885r 2  DA                   PHX
000886r 2  20 rr rr             JSR     used_unit_slot_ptr
000889r 2  A0 0F                LDY     #15
00088Br 2               @cu_root_name_copy:
00088Br 2  B9 rr rr             LDA     ident_buf,y
00088Er 2  91 rr                STA     (tmp2),y
000890r 2  88                   DEY
000891r 2  10 F8                BPL     @cu_root_name_copy
000893r 2  FA                   PLX
000894r 2  EE rr rr             INC     used_unit_count
000897r 2               @cu_name_done:
000897r 2  20 rr rr             JSR     next_token              ; consume unit name
00089Ar 2  A5 rr        :       LDA     tok_type
00089Cr 2  C9 20                CMP     #TOK_SEMICOLON
00089Er 2  D0 03                BNE     :+
0008A0r 2  20 rr rr             JSR     next_token
0008A3r 2  A5 rr        :       LDA     tok_type
0008A5r 2  C9 60                CMP     #TOK_INTERFACE
0008A7r 2  F0 0D                BEQ     @cu_have_iface
0008A9r 2  A9 rr                LDA     #<err_unexpected
0008ABr 2  85 rr                STA     tmp0
0008ADr 2  A9 rr                LDA     #>err_unexpected
0008AFr 2  85 rr                STA     tmp0+1
0008B1r 2  20 rr rr             JSR     compile_error
0008B4r 2  80 03                BRA     @cu_after_iface_kw
0008B6r 2               @cu_have_iface:
0008B6r 2  20 rr rr             JSR     next_token              ; consume INTERFACE
0008B9r 2               @cu_after_iface_kw:
0008B9r 2  AD rr rr             LDA     unit_import_mode
0008BCr 2  D0 0B                BNE     @cu_iface_ready
0008BEr 2  20 rr rr             JSR     emit_UJP
0008C1r 2  8D rr rr             STA     main_jmp_patch
0008C4r 2  A5 rr                LDA     scratch
0008C6r 2  8D rr rr             STA     main_jmp_patch+1
0008C9r 2               @cu_iface_ready:
0008C9r 2  A9 01                LDA     #1
0008CBr 2  8D rr rr             STA     unit_section
0008CEr 2  20 rr rr             JSR     parse_interface_block
0008D1r 2  A5 rr                LDA     tok_type
0008D3r 2  C9 5F                CMP     #TOK_IMPLEMENTATION
0008D5r 2  F0 0D                BEQ     @cu_have_impl
0008D7r 2  A9 rr                LDA     #<err_unexpected
0008D9r 2  85 rr                STA     tmp0
0008DBr 2  A9 rr                LDA     #>err_unexpected
0008DDr 2  85 rr                STA     tmp0+1
0008DFr 2  20 rr rr             JSR     compile_error
0008E2r 2  80 03                BRA     @cu_impl_start
0008E4r 2               @cu_have_impl:
0008E4r 2  20 rr rr             JSR     next_token              ; consume IMPLEMENTATION
0008E7r 2               @cu_impl_start:
0008E7r 2  A9 02                LDA     #2
0008E9r 2  8D rr rr             STA     unit_section
0008ECr 2  20 rr rr             JSR     parse_block
0008EFr 2  AD rr rr             LDA     unit_import_mode
0008F2r 2  D0 06                BNE     @cu_done
0008F4r 2  20 rr rr             JSR     patch_startup_chain_if_needed
0008F7r 2  20 rr rr             JSR     emit_HALT
0008FAr 2               @cu_done:
0008FAr 2  A9 00                LDA     #0
0008FCr 2  8D rr rr             STA     unit_section
0008FFr 2  60                   RTS
000900r 2               
000900r 2               ; ---------------------------------------------------------------------------
000900r 2               ; parse_interface_block — top-level INTERFACE declarations only.
000900r 2               ; Mirrors parse_block but PROCEDURE/FUNCTION consume headings without bodies.
000900r 2               ; Stops when IMPLEMENTATION (or anything unrecognised) is reached.
000900r 2               ; ---------------------------------------------------------------------------
000900r 2               parse_interface_block:
000900r 2               @pib_again:
000900r 2  A5 rr                LDA     tok_type
000902r 2  C9 62                CMP     #TOK_USES
000904r 2  F0 15                BEQ     @pib_uses
000906r 2  C9 44                CMP     #TOK_CONST
000908r 2  F0 16                BEQ     @pib_const
00090Ar 2  C9 5A                CMP     #TOK_TYPE
00090Cr 2  F0 1A                BEQ     @pib_type
00090Er 2  C9 5C                CMP     #TOK_VAR
000910r 2  F0 1E                BEQ     @pib_var
000912r 2  C9 53                CMP     #TOK_PROCEDURE
000914r 2  F0 22                BEQ     @pib_proc
000916r 2  C9 4B                CMP     #TOK_FUNCTION
000918r 2  F0 26                BEQ     @pib_func
00091Ar 2  60                   RTS
00091Br 2               @pib_uses:
00091Br 2  20 rr rr             JSR     parse_uses_clause
00091Er 2  80 E0                BRA     @pib_again
000920r 2               @pib_const:
000920r 2  20 rr rr             JSR     next_token
000923r 2  20 rr rr             JSR     parse_const_decls
000926r 2  80 D8                BRA     @pib_again
000928r 2               @pib_type:
000928r 2  20 rr rr             JSR     next_token
00092Br 2  20 rr rr             JSR     parse_type_decls
00092Er 2  80 D0                BRA     @pib_again
000930r 2               @pib_var:
000930r 2  20 rr rr             JSR     next_token
000933r 2  20 rr rr             JSR     parse_var_decls
000936r 2  80 C8                BRA     @pib_again
000938r 2               @pib_proc:
000938r 2  20 rr rr             JSR     next_token
00093Br 2  20 rr rr             JSR     parse_proc_iface_decl
00093Er 2  80 C0                BRA     @pib_again
000940r 2               @pib_func:
000940r 2  20 rr rr             JSR     next_token
000943r 2  20 rr rr             JSR     parse_func_iface_decl
000946r 2  80 B8                BRA     @pib_again
000948r 2               
000948r 2               ; ---------------------------------------------------------------------------
000948r 2               ; import_unit_by_name — ident_buf names a UNIT source file to compile into the
000948r 2               ; current output. Repeated/nested imports are de-duplicated globally.
000948r 2               ; ---------------------------------------------------------------------------
000948r 2               import_unit_by_name:
000948r 2  A2 00                LDX     #0
00094Ar 2               @iun_scan:
00094Ar 2  EC rr rr             CPX     used_unit_count
00094Dr 2  B0 25                BCS     @iun_add
00094Fr 2  DA                   PHX
000950r 2  20 rr rr             JSR     used_unit_slot_ptr
000953r 2  A0 00                LDY     #0
000955r 2  B1 rr                LDA     (tmp2),y
000957r 2  CD rr rr             CMP     ident_buf
00095Ar 2  D0 12                BNE     @iun_next
00095Cr 2  85 rr                STA     scratch
00095Er 2  A0 01                LDY     #1
000960r 2               @iun_cmp:
000960r 2  B1 rr                LDA     (tmp2),y
000962r 2  D9 rr rr             CMP     ident_buf,y
000965r 2  D0 07                BNE     @iun_next
000967r 2  C6 rr                DEC     scratch
000969r 2  F0 07                BEQ     @iun_found
00096Br 2  C8                   INY
00096Cr 2  80 F2                BRA     @iun_cmp
00096Er 2               @iun_next:
00096Er 2  FA                   PLX
00096Fr 2  E8                   INX
000970r 2  80 D8                BRA     @iun_scan
000972r 2               @iun_found:
000972r 2  FA                   PLX
000973r 2  60                   RTS
000974r 2               @iun_add:
000974r 2  E0 08                CPX     #USED_UNIT_SLOTS
000976r 2  90 0C                BCC     :+
000978r 2  A9 rr                LDA     #<err_too_many
00097Ar 2  85 rr                STA     tmp0
00097Cr 2  A9 rr                LDA     #>err_too_many
00097Er 2  85 rr                STA     tmp0+1
000980r 2  20 rr rr             JSR     compile_error
000983r 2  60                   RTS
000984r 2  DA           :       PHX
000985r 2  20 rr rr             JSR     used_unit_slot_ptr
000988r 2  A0 0F                LDY     #15
00098Ar 2               @iun_copy_name:
00098Ar 2  B9 rr rr             LDA     ident_buf,y
00098Dr 2  91 rr                STA     (tmp2),y
00098Fr 2  88                   DEY
000990r 2  10 F8                BPL     @iun_copy_name
000992r 2  FA                   PLX
000993r 2  EE rr rr             INC     used_unit_count
000996r 2  20 rr rr             JSR     source_push_current
000999r 2  90 0C                BCC     @iun_pushed
00099Br 2  A9 rr                LDA     #<err_too_many
00099Dr 2  85 rr                STA     tmp0
00099Fr 2  A9 rr                LDA     #>err_too_many
0009A1r 2  85 rr                STA     tmp0+1
0009A3r 2  20 rr rr             JSR     compile_error
0009A6r 2  60                   RTS
0009A7r 2               @iun_pushed:
0009A7r 2  20 rr rr             JSR     build_named_src_fcb
0009AAr 2  90 04                BCC     :+
0009ACr 2  20 rr rr             JSR     source_pop_current
0009AFr 2  60                   RTS
0009B0r 2  A9 rr        :       LDA     #<comp_src_fcb
0009B2r 2  85 rr                STA     src_fcb
0009B4r 2  85 rr                STA     tmp1
0009B6r 2  A9 rr                LDA     #>comp_src_fcb
0009B8r 2  85 rr                STA     src_fcb+1
0009BAr 2  85 rr                STA     tmp1+1
0009BCr 2  20 rr rr             JSR     file_open
0009BFr 2  C9 FF                CMP     #$FF
0009C1r 2  D0 0F                BNE     @iun_open_ok
0009C3r 2  A9 rr                LDA     #<err_nofile
0009C5r 2  85 rr                STA     tmp0
0009C7r 2  A9 rr                LDA     #>err_nofile
0009C9r 2  85 rr                STA     tmp0+1
0009CBr 2  20 rr rr             JSR     compile_error
0009CEr 2  20 rr rr             JSR     source_pop_current
0009D1r 2  60                   RTS
0009D2r 2               @iun_open_ok:
0009D2r 2  EE rr rr             INC     unit_import_mode
0009D5r 2  20 rr rr             JSR     lexer_init
0009D8r 2  20 rr rr             JSR     next_token
0009DBr 2  20 rr rr             JSR     compile_unit
0009DEr 2  CE rr rr             DEC     unit_import_mode
0009E1r 2  A9 rr                LDA     #<comp_src_fcb
0009E3r 2  85 rr                STA     tmp1
0009E5r 2  A9 rr                LDA     #>comp_src_fcb
0009E7r 2  85 rr                STA     tmp1+1
0009E9r 2  20 rr rr             JSR     file_close
0009ECr 2  20 rr rr             JSR     source_pop_current
0009EFr 2  60                   RTS
0009F0r 2               
0009F0r 2               ; ---------------------------------------------------------------------------
0009F0r 2               ; parse_uses_clause — top-level USES unit1, unit2, ... ;
0009F0r 2               ; Collects the unit names from the current source first, then compiles each
0009F0r 2               ; imported UNIT source while the current file context is suspended.
0009F0r 2               ; ---------------------------------------------------------------------------
0009F0r 2               parse_uses_clause:
0009F0r 2  20 rr rr             JSR     next_token              ; consume USES
0009F3r 2  A9 00                LDA     #0
0009F5r 2  8D rr rr             STA     uses_name_count
0009F8r 2               @puc_collect:
0009F8r 2  A5 rr                LDA     tok_type
0009FAr 2  C9 01                CMP     #TOK_IDENT
0009FCr 2  D0 34                BNE     @puc_done_collect
0009FEr 2  AE rr rr             LDX     uses_name_count
000A01r 2  E0 08                CPX     #USES_NAME_SLOTS
000A03r 2  B0 14                BCS     @puc_skip_store
000A05r 2  DA                   PHX
000A06r 2  20 rr rr             JSR     uses_name_slot_ptr
000A09r 2  A0 0F                LDY     #15
000A0Br 2               @puc_store:
000A0Br 2  B9 rr rr             LDA     ident_buf,y
000A0Er 2  91 rr                STA     (tmp2),y
000A10r 2  88                   DEY
000A11r 2  10 F8                BPL     @puc_store
000A13r 2  FA                   PLX
000A14r 2  EE rr rr             INC     uses_name_count
000A17r 2  80 0B                BRA     @puc_after_store
000A19r 2               @puc_skip_store:
000A19r 2  A9 rr                LDA     #<err_too_many
000A1Br 2  85 rr                STA     tmp0
000A1Dr 2  A9 rr                LDA     #>err_too_many
000A1Fr 2  85 rr                STA     tmp0+1
000A21r 2  20 rr rr             JSR     compile_error
000A24r 2               @puc_after_store:
000A24r 2  20 rr rr             JSR     next_token              ; consume unit name
000A27r 2  A5 rr                LDA     tok_type
000A29r 2  C9 1F                CMP     #TOK_COMMA
000A2Br 2  D0 05                BNE     @puc_done_collect
000A2Dr 2  20 rr rr             JSR     next_token
000A30r 2  80 C6                BRA     @puc_collect
000A32r 2               @puc_done_collect:
000A32r 2  A5 rr                LDA     tok_type
000A34r 2  48                   PHA
000A35r 2  A2 00                LDX     #0
000A37r 2               @puc_import_loop:
000A37r 2  EC rr rr             CPX     uses_name_count
000A3Ar 2  B0 16                BCS     @puc_resume
000A3Cr 2  DA                   PHX
000A3Dr 2  20 rr rr             JSR     uses_name_slot_ptr
000A40r 2  A0 0F                LDY     #15
000A42r 2               @puc_restore_name:
000A42r 2  B1 rr                LDA     (tmp2),y
000A44r 2  99 rr rr             STA     ident_buf,y
000A47r 2  88                   DEY
000A48r 2  10 F8                BPL     @puc_restore_name
000A4Ar 2  20 rr rr             JSR     import_unit_by_name
000A4Dr 2  FA                   PLX
000A4Er 2  E8                   INX
000A4Fr 2  4C rr rr             JMP     @puc_import_loop
000A52r 2               @puc_resume:
000A52r 2  68                   PLA
000A53r 2  C9 20                CMP     #TOK_SEMICOLON
000A55r 2  D0 04                BNE     @puc_no_semi
000A57r 2  20 rr rr             JSR     next_token
000A5Ar 2  60                   RTS
000A5Br 2               @puc_no_semi:
000A5Br 2  85 rr                STA     tok_type
000A5Dr 2  60                   RTS
000A5Er 2               
000A5Er 2               ; ---------------------------------------------------------------------------
000A5Er 2               ; parse_block — { const_part } { type_part } { var_part } { proc_part } statement_part
000A5Er 2               ; ---------------------------------------------------------------------------
000A5Er 2               parse_block:
000A5Er 2               @again:
000A5Er 2  A5 rr                LDA     tok_type
000A60r 2  C9 62                CMP     #TOK_USES
000A62r 2  D0 09                BNE     @blk_chk_const
000A64r 2  A5 rr                LDA     scope_depth
000A66r 2  D0 05                BNE     @blk_chk_const
000A68r 2  20 rr rr             JSR     parse_uses_clause
000A6Br 2  80 F1                BRA     @again
000A6Dr 2               @blk_chk_const:
000A6Dr 2  C9 44                CMP     #TOK_CONST
000A6Fr 2  F0 15                BEQ     @const
000A71r 2  C9 5A                CMP     #TOK_TYPE
000A73r 2  F0 19                BEQ     @type
000A75r 2  C9 5C                CMP     #TOK_VAR
000A77r 2  F0 1D                BEQ     @var
000A79r 2  C9 53                CMP     #TOK_PROCEDURE
000A7Br 2  F0 21                BEQ     @proc
000A7Dr 2  C9 4B                CMP     #TOK_FUNCTION
000A7Fr 2  F0 25                BEQ     @func
000A81r 2  C9 42                CMP     #TOK_BEGIN
000A83r 2  F0 29                BEQ     @body
000A85r 2  60                   RTS                     ; nothing recognisable
000A86r 2               
000A86r 2               @const:
000A86r 2  20 rr rr             JSR     next_token
000A89r 2  20 rr rr             JSR     parse_const_decls
000A8Cr 2  80 D0                BRA     @again
000A8Er 2               @type:
000A8Er 2  20 rr rr             JSR     next_token
000A91r 2  20 rr rr             JSR     parse_type_decls
000A94r 2  80 C8                BRA     @again
000A96r 2               @var:
000A96r 2  20 rr rr             JSR     next_token
000A99r 2  20 rr rr             JSR     parse_var_decls
000A9Cr 2  80 C0                BRA     @again
000A9Er 2               @proc:
000A9Er 2  20 rr rr             JSR     next_token
000AA1r 2  20 rr rr             JSR     parse_proc_decl
000AA4r 2  80 B8                BRA     @again
000AA6r 2               @func:
000AA6r 2  20 rr rr             JSR     next_token
000AA9r 2  20 rr rr             JSR     parse_func_decl
000AACr 2  80 B0                BRA     @again
000AAEr 2               @body:  ; If at global scope, patch the startup chain to this body's start
000AAEr 2                       ; before emitting any top-level init/main code.
000AAEr 2  A5 rr                LDA     scope_depth
000AB0r 2  D0 03                BNE     @body_emit
000AB2r 2  20 rr rr             JSR     patch_startup_chain_if_needed
000AB5r 2               @body_emit:
000AB5r 2  20 rr rr             JSR     parse_compound_stmt
000AB8r 2  A5 rr                LDA     scope_depth
000ABAr 2  D0 0B                BNE     @body_done
000ABCr 2  20 rr rr             JSR     emit_UJP
000ABFr 2  8D rr rr             STA     body_chain_patch
000AC2r 2  A5 rr                LDA     scratch
000AC4r 2  8D rr rr             STA     body_chain_patch+1
000AC7r 2               @body_done:
000AC7r 2  60                   RTS
000AC8r 2               
000AC8r 2               ; ---------------------------------------------------------------------------
000AC8r 2               ; parse_const_decls — name = [-]INT_LIT ;  { name = [-]INT_LIT ; }
000AC8r 2               ; Each constant goes into the symbol table as SYM_CONST with the literal
000AC8r 2               ; value stored at offsets 18-19; references emit LDCW with that value.
000AC8r 2               ; ---------------------------------------------------------------------------
000AC8r 2               parse_const_decls:
000AC8r 2               @loop:
000AC8r 2  A5 rr                LDA     tok_type
000ACAr 2  C9 01                CMP     #TOK_IDENT
000ACCr 2  F0 01                BEQ     @have_ident
000ACEr 2  60                   RTS                     ; done — no more constants
000ACFr 2               @have_ident:
000ACFr 2               ; save const name into save_name_buf
000ACFr 2  A0 0F                LDY     #15
000AD1r 2               @savename:
000AD1r 2  B9 rr rr             LDA     ident_buf,y
000AD4r 2  99 rr rr             STA     save_name_buf,y
000AD7r 2  88                   DEY
000AD8r 2  10 F7                BPL     @savename
000ADAr 2  20 rr rr             JSR     next_token      ; consume name
000ADDr 2               ; expect '='
000ADDr 2  A5 rr                LDA     tok_type
000ADFr 2  C9 14                CMP     #TOK_EQ
000AE1r 2  D0 03                BNE     :+
000AE3r 2  20 rr rr             JSR     next_token
000AE6r 2               :       ; optional unary minus — record in scratch (next_token preserves it)
000AE6r 2  A9 00                LDA     #0
000AE8r 2  85 rr                STA     scratch
000AEAr 2  A5 rr                LDA     tok_type
000AECr 2  C9 11                CMP     #TOK_MINUS
000AEEr 2  D0 07                BNE     @no_minus
000AF0r 2  A9 FF                LDA     #$FF
000AF2r 2  85 rr                STA     scratch
000AF4r 2  20 rr rr             JSR     next_token
000AF7r 2               @no_minus:
000AF7r 2  A9 01                LDA     #TY_INT
000AF9r 2  85 rr                STA     expr_type
000AFBr 2                       ; expect INT/REAL literal
000AFBr 2  A5 rr                LDA     tok_type
000AFDr 2  C9 02                CMP     #TOK_INT
000AFFr 2  F0 0C                BEQ     @have_int
000B01r 2  C9 05                CMP     #TOK_REAL
000B03r 2  F0 15                BEQ     @have_real
000B05r 2                       ; bad value — store 0 and try to recover
000B05r 2  A9 00                LDA     #0
000B07r 2  85 rr                STA     tmp2
000B09r 2  85 rr                STA     tmp2+1
000B0Br 2  80 1C                BRA     @add_const
000B0Dr 2               @have_int:
000B0Dr 2  A5 rr                LDA     tok_ival_lo
000B0Fr 2  85 rr                STA     tmp2
000B11r 2  A5 rr                LDA     tok_ival_hi
000B13r 2  85 rr                STA     tmp2+1
000B15r 2  20 rr rr             JSR     next_token      ; consume INT
000B18r 2  80 0F                BRA     @add_const
000B1Ar 2               @have_real:
000B1Ar 2  A5 rr                LDA     tok_ival_lo
000B1Cr 2  85 rr                STA     tmp2
000B1Er 2  A5 rr                LDA     tok_ival_hi
000B20r 2  85 rr                STA     tmp2+1
000B22r 2  A9 0A                LDA     #TY_REAL
000B24r 2  85 rr                STA     expr_type
000B26r 2  20 rr rr             JSR     next_token      ; consume REAL
000B29r 2               @add_const:
000B29r 2               ; apply negate flag if set
000B29r 2  A5 rr                LDA     scratch
000B2Br 2  F0 0D                BEQ     @no_neg
000B2Dr 2  38                   SEC
000B2Er 2  A9 00                LDA     #0
000B30r 2  E5 rr                SBC     tmp2
000B32r 2  85 rr                STA     tmp2
000B34r 2  A9 00                LDA     #0
000B36r 2  E5 rr                SBC     tmp2+1
000B38r 2  85 rr                STA     tmp2+1
000B3Ar 2               @no_neg:
000B3Ar 2               ; install in symbol table — value lives at offsets 18-19
000B3Ar 2  20 rr rr             JSR     swap_ident_save
000B3Dr 2  A9 02                LDA     #SYM_CONST
000B3Fr 2  A6 rr                LDX     expr_type
000B41r 2  20 rr rr             JSR     symtab_add
000B44r 2  20 rr rr             JSR     swap_ident_save
000B47r 2               ; expect ';'
000B47r 2  A5 rr                LDA     tok_type
000B49r 2  C9 20                CMP     #TOK_SEMICOLON
000B4Br 2  F0 03                BEQ     @pcd_semi
000B4Dr 2  4C rr rr             JMP     @loop
000B50r 2               @pcd_semi:
000B50r 2  20 rr rr             JSR     next_token
000B53r 2  4C rr rr             JMP     @loop
000B56r 2               
000B56r 2               ; ---------------------------------------------------------------------------
000B56r 2               ; parse_type_decls — name = type_spec ;  { ... }
000B56r 2               ; Each binding registers a SYM_TYPE entry whose offset-17 byte holds the
000B56r 2               ; base TY_* code.  parse_type_spec resolves later references back to this
000B56r 2               ; base type via symtab_find.
000B56r 2               ; ---------------------------------------------------------------------------
000B56r 2               parse_type_decls:
000B56r 2               @loop:
000B56r 2  A5 rr                LDA     tok_type
000B58r 2  C9 01                CMP     #TOK_IDENT
000B5Ar 2  F0 01                BEQ     :+
000B5Cr 2  60                   RTS                     ; done — no more type decls
000B5Dr 2               :       ; save type name into save_name_buf (parse_type_spec clobbers ident_buf)
000B5Dr 2  A0 0F                LDY     #15
000B5Fr 2               @savename:
000B5Fr 2  B9 rr rr             LDA     ident_buf,y
000B62r 2  99 rr rr             STA     save_name_buf,y
000B65r 2  88                   DEY
000B66r 2  10 F7                BPL     @savename
000B68r 2  20 rr rr             JSR     next_token      ; consume name
000B6Br 2               ; expect '='
000B6Br 2  A5 rr                LDA     tok_type
000B6Dr 2  C9 14                CMP     #TOK_EQ
000B6Fr 2  D0 03                BNE     :+
000B71r 2  20 rr rr             JSR     next_token
000B74r 2               :       ; parse the type definition; A = TY_* code
000B74r 2  20 rr rr             JSR     parse_type_spec
000B77r 2  85 rr                STA     scratch         ; save base type code
000B79r 2               ; bring the saved name back into ident_buf for symtab_add
000B79r 2  20 rr rr             JSR     swap_ident_save
000B7Cr 2               ; SYM_TYPE has no storage; offset bytes are unused (overwritten below
000B7Cr 2               ; for record types, which need to remember size + field-table location).
000B7Cr 2  A9 00                LDA     #0
000B7Er 2  85 rr                STA     tmp2
000B80r 2  85 rr                STA     tmp2+1
000B82r 2  A9 05                LDA     #SYM_TYPE
000B84r 2  A6 rr                LDX     scratch
000B86r 2  20 rr rr             JSR     symtab_add
000B89r 2               ; If this is a RECORD alias, stash record_size in bytes 18-19 and
000B89r 2               ; first_field/field_count in bytes 22-23 so later var-decls and field
000B89r 2               ; lookups can recover it.
000B89r 2  A5 rr                LDA     scratch
000B8Br 2  C9 06                CMP     #TY_RECORD
000B8Dr 2  D0 1C                BNE     @td_no_rec
000B8Fr 2  AD rr rr             LDA     record_size
000B92r 2  A0 12                LDY     #18
000B94r 2  91 rr                STA     (tmp3),y
000B96r 2  AD rr rr             LDA     record_size+1
000B99r 2  A0 13                LDY     #19
000B9Br 2  91 rr                STA     (tmp3),y
000B9Dr 2  AD rr rr             LDA     record_first_field
000BA0r 2  A0 16                LDY     #22
000BA2r 2  91 rr                STA     (tmp3),y
000BA4r 2  AD rr rr             LDA     record_field_count
000BA7r 2  A0 17                LDY     #23
000BA9r 2  91 rr                STA     (tmp3),y
000BABr 2               @td_no_rec:
000BABr 2               ; expect ';'
000BABr 2  A5 rr                LDA     tok_type
000BADr 2  C9 20                CMP     #TOK_SEMICOLON
000BAFr 2  F0 03                BEQ     @ptd_semi
000BB1r 2  4C rr rr             JMP     @loop
000BB4r 2               @ptd_semi:
000BB4r 2  20 rr rr             JSR     next_token
000BB7r 2  4C rr rr             JMP     @loop
000BBAr 2               
000BBAr 2               ; ---------------------------------------------------------------------------
000BBAr 2               ; parse_var_decls — name { , name } : type ;  { ... }
000BBAr 2               ; All names on one line share the same type, allocated in order.
000BBAr 2               ; ---------------------------------------------------------------------------
000BBAr 2               parse_var_decls:
000BBAr 2               @decl_loop:
000BBAr 2  A5 rr                LDA     tok_type
000BBCr 2  C9 01                CMP     #TOK_IDENT
000BBEr 2  F0 01                BEQ     :+
000BC0r 2  60                   RTS                     ; done — no more var decls
000BC1r 2               :       ; --- collect comma-separated names into var_name_buf ---
000BC1r 2  A9 00                LDA     #0
000BC3r 2  8D rr rr             STA     var_name_count
000BC6r 2               @collect:
000BC6r 2  A5 rr                LDA     tok_type
000BC8r 2  C9 01                CMP     #TOK_IDENT
000BCAr 2  D0 31                BNE     @end_collect
000BCCr 2  AD rr rr             LDA     var_name_count
000BCFr 2  C9 08                CMP     #8
000BD1r 2  B0 1C                BCS     @skip_save
000BD3r 2                       ; tmp2 = var_name_buf + count*16   (count<8 → fits without manual carry)
000BD3r 2  0A                   ASL
000BD4r 2  0A                   ASL
000BD5r 2  0A                   ASL
000BD6r 2  0A                   ASL                     ; *16
000BD7r 2  18                   CLC
000BD8r 2  69 rr                ADC     #<var_name_buf
000BDAr 2  85 rr                STA     tmp2
000BDCr 2  A9 00                LDA     #0
000BDEr 2  69 rr                ADC     #>var_name_buf
000BE0r 2  85 rr                STA     tmp2+1
000BE2r 2  A0 0F                LDY     #15
000BE4r 2               @cp_in:
000BE4r 2  B9 rr rr             LDA     ident_buf,y
000BE7r 2  91 rr                STA     (tmp2),y
000BE9r 2  88                   DEY
000BEAr 2  10 F8                BPL     @cp_in
000BECr 2  EE rr rr             INC     var_name_count
000BEFr 2               @skip_save:
000BEFr 2  20 rr rr             JSR     next_token      ; consume name
000BF2r 2  A5 rr                LDA     tok_type
000BF4r 2  C9 1F                CMP     #TOK_COMMA
000BF6r 2  D0 05                BNE     @end_collect
000BF8r 2  20 rr rr             JSR     next_token      ; consume ','
000BFBr 2  80 C9                BRA     @collect
000BFDr 2               @end_collect:
000BFDr 2               ; expect ':'
000BFDr 2  A5 rr                LDA     tok_type
000BFFr 2  C9 21                CMP     #TOK_COLON
000C01r 2  D0 03                BNE     :+
000C03r 2  20 rr rr             JSR     next_token
000C06r 2               :       ; parse type — A = TY_*
000C06r 2  20 rr rr             JSR     parse_type_spec
000C09r 2  85 rr                STA     scratch         ; stash type
000C0Br 2               ; --- add each collected name to symbol table ---
000C0Br 2               ; NOTE: consume ';' AFTER the add loop so next_token doesn't clobber
000C0Br 2               ; ident_buf before @cp_out restores the saved name.
000C0Br 2  A2 00                LDX     #0
000C0Dr 2               @add_loop:
000C0Dr 2  EC rr rr             CPX     var_name_count
000C10r 2  90 03                BCC     :+
000C12r 2  4C rr rr             JMP     @post_add       ; out-of-range branch — use jmp
000C15r 2               :
000C15r 2  DA                   PHX                     ; preserve loop counter across symtab_add
000C16r 2               ; tmp2 = var_name_buf + X*16
000C16r 2  8A                   TXA
000C17r 2  0A                   ASL
000C18r 2  0A                   ASL
000C19r 2  0A                   ASL
000C1Ar 2  0A                   ASL
000C1Br 2  18                   CLC
000C1Cr 2  69 rr                ADC     #<var_name_buf
000C1Er 2  85 rr                STA     tmp2
000C20r 2  A9 00                LDA     #0
000C22r 2  69 rr                ADC     #>var_name_buf
000C24r 2  85 rr                STA     tmp2+1
000C26r 2               ; copy slot → ident_buf so symtab_add sees the right name
000C26r 2  A0 0F                LDY     #15
000C28r 2               @cp_out:
000C28r 2  B1 rr                LDA     (tmp2),Y
000C2Ar 2  99 rr rr             STA     ident_buf,y
000C2Dr 2  88                   DEY
000C2Er 2  10 F8                BPL     @cp_out
000C30r 2               ; allocate storage — global if at top level, else from proc local AR
000C30r 2  A5 rr                LDA     scope_depth
000C32r 2  F0 2D                BEQ     @gv_alloc
000C34r 2               ; local: tmp2 = local_alloc_off; bump by per-type size
000C34r 2  AD rr rr             LDA     local_alloc_off
000C37r 2  85 rr                STA     tmp2
000C39r 2  A9 00                LDA     #0
000C3Br 2  85 rr                STA     tmp2+1
000C3Dr 2  A5 rr                LDA     scratch                 ; type code
000C3Fr 2  C9 06                CMP     #TY_RECORD
000C41r 2  F0 0B                BEQ     @lv_rec
000C43r 2               ; default scalar / pointer / etc — 2 bytes
000C43r 2  18                   CLC
000C44r 2  AD rr rr             LDA     local_alloc_off
000C47r 2  69 02                ADC     #2
000C49r 2  8D rr rr             STA     local_alloc_off
000C4Cr 2  80 33                BRA     @do_va_add
000C4Er 2               @lv_rec:
000C4Er 2  18                   CLC
000C4Fr 2  AD rr rr             LDA     local_alloc_off
000C52r 2  6D rr rr             ADC     record_size
000C55r 2  8D rr rr             STA     local_alloc_off
000C58r 2                       ; record_size+1 is normally 0 (records < 256 bytes) but
000C58r 2                       ; propagate the carry to be safe.
000C58r 2  A9 00                LDA     #0
000C5Ar 2  6D rr rr             ADC     record_size+1
000C5Dr 2  F0 22                BEQ     @do_va_add              ; no high-byte growth
000C5Fr 2                       ; would overflow byte counter; not handled — abort cleanly
000C5Fr 2  80 20                BRA     @do_va_add
000C61r 2               @gv_alloc:
000C61r 2  A5 rr                LDA     scratch
000C63r 2  C9 05                CMP     #TY_ARRAY
000C65r 2  F0 0D                BEQ     @gv_array
000C67r 2  C9 06                CMP     #TY_RECORD
000C69r 2  F0 0E                BEQ     @gv_record
000C6Br 2  C9 08                CMP     #TY_TEXT
000C6Dr 2  F0 0F                BEQ     @gv_text
000C6Fr 2  20 rr rr             JSR     codegen_alloc_global    ; scalar: 2 bytes, offset in tmp2
000C72r 2  80 0D                BRA     @do_va_add
000C74r 2               @gv_array:
000C74r 2  20 rr rr             JSR     codegen_alloc_array_global  ; array: right size, adj offset in tmp2
000C77r 2  80 08                BRA     @do_va_add
000C79r 2               @gv_record:
000C79r 2  20 rr rr             JSR     codegen_alloc_record_global ; record: record_size bytes, offset in tmp2
000C7Cr 2  80 03                BRA     @do_va_add
000C7Er 2               @gv_text:
000C7Er 2  20 rr rr             JSR     codegen_alloc_text_global   ; TEXT file: 168 bytes, offset in tmp2
000C81r 2               @do_va_add:
000C81r 2  A5 rr                LDA     scratch         ; type code
000C83r 2  AA                   TAX
000C84r 2  A9 01                LDA     #SYM_VAR
000C86r 2  20 rr rr             JSR     symtab_add      ; tmp3 = pointer to new entry
000C89r 2               ; type-specific metadata in entry bytes 22-23
000C89r 2  A5 rr                LDA     scratch
000C8Br 2  C9 05                CMP     #TY_ARRAY
000C8Dr 2  D0 0F                BNE     @va_chk_rec
000C8Fr 2  AD rr rr             LDA     array_elem_ty
000C92r 2  A0 16                LDY     #22
000C94r 2  91 rr                STA     (tmp3),y
000C96r 2  A9 02                LDA     #2              ; elemsize = 2 (word)
000C98r 2  A0 17                LDY     #23
000C9Ar 2  91 rr                STA     (tmp3),y
000C9Cr 2  80 12                BRA     @va_done
000C9Er 2               @va_chk_rec:
000C9Er 2  C9 06                CMP     #TY_RECORD
000CA0r 2  D0 0E                BNE     @va_done
000CA2r 2  AD rr rr             LDA     record_first_field
000CA5r 2  A0 16                LDY     #22
000CA7r 2  91 rr                STA     (tmp3),y
000CA9r 2  AD rr rr             LDA     record_field_count
000CACr 2  A0 17                LDY     #23
000CAEr 2  91 rr                STA     (tmp3),y
000CB0r 2               @va_done:
000CB0r 2  FA                   PLX
000CB1r 2  E8                   INX
000CB2r 2  4C rr rr             JMP     @add_loop       ; jmp — body grew past bra range
000CB5r 2               @post_add:
000CB5r 2               ; now safe to consume ';' — ident_buf already used
000CB5r 2  A5 rr                LDA     tok_type
000CB7r 2  C9 20                CMP     #TOK_SEMICOLON
000CB9r 2  D0 03                BNE     @pva_next
000CBBr 2  20 rr rr             JSR     next_token
000CBEr 2               @pva_next:
000CBEr 2  4C rr rr             JMP     @decl_loop
000CC1r 2               
000CC1r 2               ; swap 16 bytes between ident_buf and save_name_buf
000CC1r 2               swap_ident_save:
000CC1r 2  A0 0F                LDY     #15
000CC3r 2               @sw:
000CC3r 2  B9 rr rr             LDA     ident_buf,y
000CC6r 2  BE rr rr             LDX     save_name_buf,y
000CC9r 2  99 rr rr             STA     save_name_buf,y
000CCCr 2  8A                   TXA
000CCDr 2  99 rr rr             STA     ident_buf,y
000CD0r 2  88                   DEY
000CD1r 2  10 F0                BPL     @sw
000CD3r 2  60                   RTS
000CD4r 2               
000CD4r 2               ; field_name_slot_ptr â€” tmp2 = pointer to the current RECORD depth's
000CD4r 2               ; field-name slot. A = slot index (0..7).
000CD4r 2               field_name_slot_ptr:
000CD4r 2  0A                   ASL
000CD5r 2  0A                   ASL
000CD6r 2  0A                   ASL
000CD7r 2  0A                   ASL                             ; slot * 16
000CD8r 2  85 rr                STA     tmp2
000CDAr 2  A9 00                LDA     #0
000CDCr 2  85 rr                STA     tmp2+1
000CDEr 2  AE rr rr             LDX     field_depth
000CE1r 2  CA                   DEX                             ; 1-based depth -> 0-based slice index
000CE2r 2               @fnsp_depth:
000CE2r 2  E0 00                CPX     #0
000CE4r 2  F0 0E                BEQ     @fnsp_base
000CE6r 2  18                   CLC
000CE7r 2  A5 rr                LDA     tmp2
000CE9r 2  69 80                ADC     #$80
000CEBr 2  85 rr                STA     tmp2
000CEDr 2  90 02                BCC     :+
000CEFr 2  E6 rr                INC     tmp2+1
000CF1r 2  CA           :       DEX
000CF2r 2  80 EE                BRA     @fnsp_depth
000CF4r 2               @fnsp_base:
000CF4r 2  18                   CLC
000CF5r 2  A5 rr                LDA     tmp2
000CF7r 2  69 rr                ADC     #<field_name_buf
000CF9r 2  85 rr                STA     tmp2
000CFBr 2  A5 rr                LDA     tmp2+1
000CFDr 2  69 rr                ADC     #>field_name_buf
000CFFr 2  85 rr                STA     tmp2+1
000D01r 2  60                   RTS
000D02r 2               
000D02r 2               ; uses_name_slot_ptr — tmp2 = pointer to USES-name slot X (0..7)
000D02r 2               uses_name_slot_ptr:
000D02r 2  8A                   TXA
000D03r 2  0A                   ASL
000D04r 2  0A                   ASL
000D05r 2  0A                   ASL
000D06r 2  0A                   ASL
000D07r 2  18                   CLC
000D08r 2  69 rr                ADC     #<uses_name_buf
000D0Ar 2  85 rr                STA     tmp2
000D0Cr 2  A9 00                LDA     #0
000D0Er 2  69 rr                ADC     #>uses_name_buf
000D10r 2  85 rr                STA     tmp2+1
000D12r 2  60                   RTS
000D13r 2               
000D13r 2               ; used_unit_slot_ptr — tmp2 = pointer to imported-unit slot X (0..7)
000D13r 2               used_unit_slot_ptr:
000D13r 2  8A                   TXA
000D14r 2  0A                   ASL
000D15r 2  0A                   ASL
000D16r 2  0A                   ASL
000D17r 2  0A                   ASL
000D18r 2  18                   CLC
000D19r 2  69 rr                ADC     #<used_unit_buf
000D1Br 2  85 rr                STA     tmp2
000D1Dr 2  A9 00                LDA     #0
000D1Fr 2  69 rr                ADC     #>used_unit_buf
000D21r 2  85 rr                STA     tmp2+1
000D23r 2  60                   RTS
000D24r 2               
000D24r 2               ; ptr_meta_alloc — create one pointer-type metadata entry from the most
000D24r 2               ; recently parsed pointee type. Input A = pointee TY_*.
000D24r 2               ; For pointee TY_RECORD / TY_ARRAY, the current record_* / array_* globals
000D24r 2               ; are consulted for size and aux metadata.
000D24r 2               ; Returns: ptr_meta_cur = allocated metadata index, or $FF if full.
000D24r 2               ptr_meta_alloc:
000D24r 2  48                   PHA
000D25r 2  AE rr rr             LDX     ptr_meta_count
000D28r 2  E0 20                CPX     #PTR_META_MAX
000D2Ar 2  90 07                BCC     :+
000D2Cr 2  68                   PLA
000D2Dr 2  A9 FF                LDA     #$FF
000D2Fr 2  8D rr rr             STA     ptr_meta_cur
000D32r 2  60                   RTS
000D33r 2  68           :       PLA
000D34r 2  9D rr rr             STA     ptr_meta_type,x
000D37r 2  C9 07                CMP     #TY_PTR
000D39r 2  F0 38                BEQ     @pma_ptr
000D3Br 2  C9 06                CMP     #TY_RECORD
000D3Dr 2  F0 4F                BEQ     @pma_record
000D3Fr 2  C9 05                CMP     #TY_ARRAY
000D41r 2  F0 6B                BEQ     @pma_array
000D43r 2  C9 08                CMP     #TY_TEXT
000D45r 2  F0 16                BEQ     @pma_text
000D47r 2               @pma_scalar:
000D47r 2  A9 02                LDA     #2
000D49r 2  9D rr rr             STA     ptr_meta_size_lo,x
000D4Cr 2  A9 00                LDA     #0
000D4Er 2  9D rr rr             STA     ptr_meta_size_hi,x
000D51r 2  9D rr rr             STA     ptr_meta_aux0,x
000D54r 2  9D rr rr             STA     ptr_meta_aux1,x
000D57r 2  9D rr rr             STA     ptr_meta_aux2,x
000D5Ar 2  4C rr rr             JMP     @pma_done
000D5Dr 2               @pma_text:
000D5Dr 2  A9 A8                LDA     #168
000D5Fr 2  9D rr rr             STA     ptr_meta_size_lo,x
000D62r 2  A9 00                LDA     #0
000D64r 2  9D rr rr             STA     ptr_meta_size_hi,x
000D67r 2  9D rr rr             STA     ptr_meta_aux0,x
000D6Ar 2  9D rr rr             STA     ptr_meta_aux1,x
000D6Dr 2  9D rr rr             STA     ptr_meta_aux2,x
000D70r 2  4C rr rr             JMP     @pma_done
000D73r 2               @pma_ptr:
000D73r 2  A9 02                LDA     #2
000D75r 2  9D rr rr             STA     ptr_meta_size_lo,x
000D78r 2  A9 00                LDA     #0
000D7Ar 2  9D rr rr             STA     ptr_meta_size_hi,x
000D7Dr 2  AD rr rr             LDA     ptr_meta_cur
000D80r 2  9D rr rr             STA     ptr_meta_aux0,x
000D83r 2  A9 00                LDA     #0
000D85r 2  9D rr rr             STA     ptr_meta_aux1,x
000D88r 2  9D rr rr             STA     ptr_meta_aux2,x
000D8Br 2  4C rr rr             JMP     @pma_done
000D8Er 2               @pma_record:
000D8Er 2  AD rr rr             LDA     record_size
000D91r 2  9D rr rr             STA     ptr_meta_size_lo,x
000D94r 2  AD rr rr             LDA     record_size+1
000D97r 2  9D rr rr             STA     ptr_meta_size_hi,x
000D9Ar 2  AD rr rr             LDA     record_first_field
000D9Dr 2  9D rr rr             STA     ptr_meta_aux0,x
000DA0r 2  AD rr rr             LDA     record_field_count
000DA3r 2  9D rr rr             STA     ptr_meta_aux1,x
000DA6r 2  A9 00                LDA     #0
000DA8r 2  9D rr rr             STA     ptr_meta_aux2,x
000DABr 2  4C rr rr             JMP     @pma_done
000DAEr 2               @pma_array:
000DAEr 2               ; size = (hi - lo + 1) * 2  (all array elements are word-sized here)
000DAEr 2  AD rr rr             LDA     array_hi
000DB1r 2  38                   SEC
000DB2r 2  ED rr rr             SBC     array_lo
000DB5r 2  85 rr                STA     tmp0
000DB7r 2  AD rr rr             LDA     array_hi+1
000DBAr 2  ED rr rr             SBC     array_lo+1
000DBDr 2  85 rr                STA     tmp0+1
000DBFr 2  E6 rr                INC     tmp0
000DC1r 2  D0 02                BNE     :+
000DC3r 2  E6 rr                INC     tmp0+1
000DC5r 2  06 rr        :       ASL     tmp0
000DC7r 2  26 rr                ROL     tmp0+1
000DC9r 2  A5 rr                LDA     tmp0
000DCBr 2  9D rr rr             STA     ptr_meta_size_lo,x
000DCEr 2  A5 rr                LDA     tmp0+1
000DD0r 2  9D rr rr             STA     ptr_meta_size_hi,x
000DD3r 2  AD rr rr             LDA     array_elem_ty
000DD6r 2  9D rr rr             STA     ptr_meta_aux0,x
000DD9r 2  A9 02                LDA     #2
000DDBr 2  9D rr rr             STA     ptr_meta_aux1,x
000DDEr 2  A9 00                LDA     #0
000DE0r 2  9D rr rr             STA     ptr_meta_aux2,x
000DE3r 2               @pma_done:
000DE3r 2  8A                   TXA
000DE4r 2  8D rr rr             STA     ptr_meta_cur
000DE7r 2  EE rr rr             INC     ptr_meta_count
000DEAr 2  60                   RTS
000DEBr 2               
000DEBr 2               ; store_proc_param_type — record the current parameter's type code in the
000DEBr 2               ; owning proc/func entry at byte 24+proc_param_count (up to 8 params).
000DEBr 2               store_proc_param_type:
000DEBr 2  48                   PHA
000DECr 2  AC rr rr             LDY     proc_param_count
000DEFr 2  C0 08                CPY     #8
000DF1r 2  B0 13                BCS     @sppt_drop
000DF3r 2  AD rr rr             LDA     proc_entry_idx
000DF6r 2  85 rr                STA     tmp3
000DF8r 2  AD rr rr             LDA     proc_entry_idx+1
000DFBr 2  85 rr                STA     tmp3+1
000DFDr 2  98                   TYA
000DFEr 2  18                   CLC
000DFFr 2  69 18                ADC     #24
000E01r 2  A8                   TAY
000E02r 2  68                   PLA
000E03r 2  91 rr                STA     (tmp3),y
000E05r 2  60                   RTS
000E06r 2               @sppt_drop:
000E06r 2  68                   PLA
000E07r 2  60                   RTS
000E08r 2               
000E08r 2               ; ---------------------------------------------------------------------------
000E08r 2               ; parse_type_spec — consume type token(s), return TY_* code in A
000E08r 2               ; ---------------------------------------------------------------------------
000E08r 2               parse_type_spec:
000E08r 2  A5 rr                LDA     tok_type
000E0Ar 2  C9 01                CMP     #TOK_IDENT
000E0Cr 2  F0 03                BEQ     :+
000E0Er 2  4C rr rr             JMP     @not_ident
000E11r 2               :
000E11r 2               ; First check for a user-defined SYM_TYPE alias — built-ins like
000E11r 2               ; INTEGER/CHAR/BOOLEAN aren't in the symtab so this lookup falls
000E11r 2               ; through harmlessly when there's no user binding.
000E11r 2  20 rr rr             JSR     symtab_find
000E14r 2  90 34                BCC     @builtin
000E16r 2  A0 10                LDY     #16
000E18r 2  B1 rr                LDA     (tmp3),y
000E1Ar 2  C9 05                CMP     #SYM_TYPE
000E1Cr 2  D0 2C                BNE     @builtin
000E1Er 2  A0 11                LDY     #17
000E20r 2  B1 rr                LDA     (tmp3),y
000E22r 2  85 rr                STA     scratch         ; preserve across next_token
000E24r 2               ; If alias resolves to a RECORD, copy the record metadata back into the
000E24r 2               ; record_* globals so the caller (parse_var_decls) sees it.
000E24r 2  C9 06                CMP     #TY_RECORD
000E26r 2  D0 1C                BNE     @sty_no_rec
000E28r 2  A0 12                LDY     #18
000E2Ar 2  B1 rr                LDA     (tmp3),y
000E2Cr 2  8D rr rr             STA     record_size
000E2Fr 2  A0 13                LDY     #19
000E31r 2  B1 rr                LDA     (tmp3),y
000E33r 2  8D rr rr             STA     record_size+1
000E36r 2  A0 16                LDY     #22
000E38r 2  B1 rr                LDA     (tmp3),y
000E3Ar 2  8D rr rr             STA     record_first_field
000E3Dr 2  A0 17                LDY     #23
000E3Fr 2  B1 rr                LDA     (tmp3),y
000E41r 2  8D rr rr             STA     record_field_count
000E44r 2               @sty_no_rec:
000E44r 2  20 rr rr             JSR     next_token
000E47r 2  A5 rr                LDA     scratch
000E49r 2  60                   RTS
000E4Ar 2               @builtin:
000E4Ar 2               ; check for built-in type names
000E4Ar 2  AD rr rr             LDA     ident_buf       ; length
000E4Dr 2  C9 07                CMP     #7
000E4Fr 2  D0 20                BNE     @chk3
000E51r 2               ; "INTEGER" (7 chars)
000E51r 2  AD rr rr             LDA     ident_buf+1
000E54r 2  C9 49                CMP     #'I'
000E56r 2  D0 06                BNE     @chk_bool
000E58r 2  20 rr rr             JSR     next_token
000E5Br 2  A9 01                LDA     #TY_INT
000E5Dr 2  60                   RTS
000E5Er 2               @chk_bool:
000E5Er 2  AD rr rr             LDA     ident_buf+1
000E61r 2  C9 42                CMP     #'B'
000E63r 2  D0 06                BNE     @chk_str
000E65r 2  20 rr rr             JSR     next_token
000E68r 2  A9 03                LDA     #TY_BOOL
000E6Ar 2  60                   RTS
000E6Br 2               @chk_str:
000E6Br 2  20 rr rr             JSR     next_token
000E6Er 2  A9 01                LDA     #TY_INT         ; default
000E70r 2  60                   RTS
000E71r 2               @chk3:
000E71r 2  C9 04                CMP     #4
000E73r 2  D0 27                BNE     @chk6
000E75r 2               ; 4-char built-in types: "CHAR", "TEXT", or "REAL"
000E75r 2  AD rr rr             LDA     ident_buf+1
000E78r 2  C9 43                CMP     #'C'
000E7Ar 2  D0 06                BNE     @chk_text
000E7Cr 2  20 rr rr             JSR     next_token
000E7Fr 2  A9 02                LDA     #TY_CHAR
000E81r 2  60                   RTS
000E82r 2               @chk_text:
000E82r 2  C9 54                CMP     #'T'
000E84r 2  D0 06                BNE     @chk_real
000E86r 2  20 rr rr             JSR     next_token
000E89r 2  A9 08                LDA     #TY_TEXT
000E8Br 2  60                   RTS
000E8Cr 2               @chk_real:
000E8Cr 2  C9 52                CMP     #'R'
000E8Er 2  D0 06                BNE     @chk3b
000E90r 2  20 rr rr             JSR     next_token
000E93r 2  A9 0A                LDA     #TY_REAL
000E95r 2  60                   RTS
000E96r 2               @chk3b:
000E96r 2  20 rr rr             JSR     next_token
000E99r 2  A9 01                LDA     #TY_INT
000E9Br 2  60                   RTS
000E9Cr 2               @chk6:
000E9Cr 2  C9 06                CMP     #6
000E9Er 2  D0 06                BNE     @default_type
000EA0r 2               ; "STRING" (6)
000EA0r 2  20 rr rr             JSR     next_token
000EA3r 2  A9 04                LDA     #TY_STRING
000EA5r 2  60                   RTS
000EA6r 2               @default_type:
000EA6r 2  20 rr rr             JSR     next_token
000EA9r 2  A9 01                LDA     #TY_INT
000EABr 2  60                   RTS
000EACr 2               @not_ident:
000EACr 2  A5 rr                LDA     tok_type
000EAEr 2  C9 41                CMP     #TOK_ARRAY
000EB0r 2  D0 56                BNE     @not_array
000EB2r 2               ; --- ARRAY [lo..hi] OF basetype ---
000EB2r 2  20 rr rr             JSR     next_token      ; consume ARRAY → expect '['
000EB5r 2  A5 rr                LDA     tok_type
000EB7r 2  C9 1D                CMP     #TOK_LBRACK
000EB9r 2  D0 03                BNE     :+
000EBBr 2  20 rr rr             JSR     next_token      ; consume '['
000EBEr 2               :
000EBEr 2               ; parse lo bound (integer literal)
000EBEr 2  A5 rr                LDA     tok_ival_lo
000EC0r 2  8D rr rr             STA     array_lo
000EC3r 2  A5 rr                LDA     tok_ival_hi
000EC5r 2  8D rr rr             STA     array_lo+1
000EC8r 2  A5 rr                LDA     tok_type
000ECAr 2  C9 02                CMP     #TOK_INT
000ECCr 2  D0 03                BNE     :+
000ECEr 2  20 rr rr             JSR     next_token      ; consume lo
000ED1r 2               :
000ED1r 2               ; expect '..'
000ED1r 2  A5 rr                LDA     tok_type
000ED3r 2  C9 23                CMP     #TOK_DOTDOT
000ED5r 2  D0 03                BNE     :+
000ED7r 2  20 rr rr             JSR     next_token      ; consume '..'
000EDAr 2               :
000EDAr 2               ; parse hi bound
000EDAr 2  A5 rr                LDA     tok_ival_lo
000EDCr 2  8D rr rr             STA     array_hi
000EDFr 2  A5 rr                LDA     tok_ival_hi
000EE1r 2  8D rr rr             STA     array_hi+1
000EE4r 2  A5 rr                LDA     tok_type
000EE6r 2  C9 02                CMP     #TOK_INT
000EE8r 2  D0 03                BNE     :+
000EEAr 2  20 rr rr             JSR     next_token      ; consume hi
000EEDr 2               :
000EEDr 2               ; expect ']'
000EEDr 2  A5 rr                LDA     tok_type
000EEFr 2  C9 1E                CMP     #TOK_RBRACK
000EF1r 2  D0 03                BNE     :+
000EF3r 2  20 rr rr             JSR     next_token      ; consume ']'
000EF6r 2               :
000EF6r 2               ; expect 'OF'
000EF6r 2  A5 rr                LDA     tok_type
000EF8r 2  C9 51                CMP     #TOK_OF
000EFAr 2  D0 03                BNE     :+
000EFCr 2  20 rr rr             JSR     next_token      ; consume 'OF'
000EFFr 2               :
000EFFr 2               ; parse element type (recursive — handles named types, built-ins)
000EFFr 2  20 rr rr             JSR     parse_type_spec
000F02r 2  8D rr rr             STA     array_elem_ty
000F05r 2  A9 05                LDA     #TY_ARRAY
000F07r 2  60                   RTS
000F08r 2               @not_array:
000F08r 2  A5 rr                LDA     tok_type
000F0Ar 2  C9 57                CMP     #TOK_SET
000F0Cr 2  F0 03                BEQ     :+
000F0Er 2  4C rr rr             JMP     @not_set
000F11r 2               :
000F11r 2               ; --- SET OF lo..hi ---
000F11r 2               ; v1 stores sets as 16-bit masks over element values 0..15, so the
000F11r 2               ; declared bounds must fit within that range. The bounds are validated
000F11r 2               ; here but not otherwise retained for later type-checking.
000F11r 2  20 rr rr             JSR     next_token              ; consume SET
000F14r 2  A5 rr                LDA     tok_type
000F16r 2  C9 51                CMP     #TOK_OF
000F18r 2  D0 03                BNE     :+
000F1Ar 2  20 rr rr             JSR     next_token              ; consume OF
000F1Dr 2               :
000F1Dr 2  A5 rr                LDA     tok_type
000F1Fr 2  C9 02                CMP     #TOK_INT
000F21r 2  D0 37                BNE     @set_bad
000F23r 2  A5 rr                LDA     tok_ival_hi
000F25r 2  D0 33                BNE     @set_bad
000F27r 2  A5 rr                LDA     tok_ival_lo
000F29r 2  8D rr rr             STA     set_lit_lo
000F2Cr 2  C9 10                CMP     #16
000F2Er 2  B0 2A                BCS     @set_bad
000F30r 2  20 rr rr             JSR     next_token
000F33r 2  A5 rr                LDA     tok_type
000F35r 2  C9 23                CMP     #TOK_DOTDOT
000F37r 2  D0 21                BNE     @set_bad
000F39r 2  20 rr rr             JSR     next_token
000F3Cr 2  A5 rr                LDA     tok_type
000F3Er 2  C9 02                CMP     #TOK_INT
000F40r 2  D0 18                BNE     @set_bad
000F42r 2  A5 rr                LDA     tok_ival_hi
000F44r 2  D0 14                BNE     @set_bad
000F46r 2  A5 rr                LDA     tok_ival_lo
000F48r 2  8D rr rr             STA     set_lit_hi
000F4Br 2  C9 10                CMP     #16
000F4Dr 2  B0 0B                BCS     @set_bad
000F4Fr 2  CD rr rr             CMP     set_lit_lo
000F52r 2  90 06                BCC     @set_bad
000F54r 2  20 rr rr             JSR     next_token
000F57r 2  A9 09                LDA     #TY_SET
000F59r 2  60                   RTS
000F5Ar 2               @set_bad:
000F5Ar 2  A9 rr                LDA     #<err_type
000F5Cr 2  85 rr                STA     tmp0
000F5Er 2  A9 rr                LDA     #>err_type
000F60r 2  85 rr                STA     tmp0+1
000F62r 2  20 rr rr             JSR     compile_error
000F65r 2  A5 rr                LDA     tok_type
000F67r 2  C9 02                CMP     #TOK_INT
000F69r 2  D0 03                BNE     :+
000F6Br 2  20 rr rr             JSR     next_token
000F6Er 2  A9 09        :       LDA     #TY_SET
000F70r 2  60                   RTS
000F71r 2               @not_set:
000F71r 2  A5 rr                LDA     tok_type
000F73r 2  C9 55                CMP     #TOK_RECORD
000F75r 2  F0 03                BEQ     :+
000F77r 2  4C rr rr             JMP     @not_record
000F7Ar 2               :
000F7Ar 2               ; --- RECORD field { ; field } END ---
000F7Ar 2               ; Each field group: name { , name } : type
000F7Ar 2               ; All fields are stored as 2-byte slots; offsets are 0, 2, 4, ...
000F7Ar 2  20 rr rr             JSR     next_token              ; consume RECORD
000F7Dr 2  EE rr rr             INC     field_depth             ; mark new fields as belonging
000F80r 2                                                       ; to this nesting level
000F80r 2  A9 00                LDA     #0
000F82r 2  8D rr rr             STA     record_size
000F85r 2  8D rr rr             STA     record_size+1
000F88r 2  8D rr rr             STA     record_field_count
000F8Br 2  AD rr rr             LDA     field_table_count
000F8Er 2  8D rr rr             STA     record_first_field
000F91r 2               @rec_loop:
000F91r 2  A5 rr                LDA     tok_type
000F93r 2  C9 49                CMP     #TOK_END
000F95r 2  D0 03                BNE     :+
000F97r 2  4C rr rr             JMP     @rec_end
000F9Ar 2               :
000F9Ar 2  C9 01                CMP     #TOK_IDENT
000F9Cr 2  F0 03                BEQ     :+
000F9Er 2  4C rr rr             JMP     @rec_end                ; safety — bail on unexpected token
000FA1r 2               :
000FA1r 2               ; --- collect comma-separated field names into field_name_buf ---
000FA1r 2               ;     (separate from var_name_buf so an inline RECORD inside a VAR
000FA1r 2               ;      decl doesn't clobber the outer variable names being collected)
000FA1r 2  AE rr rr             LDX     field_depth
000FA4r 2  CA                   DEX
000FA5r 2  A9 00                LDA     #0
000FA7r 2  9D rr rr             STA     field_name_count,x
000FAAr 2               @rec_collect:
000FAAr 2  A5 rr                LDA     tok_type
000FACr 2  C9 01                CMP     #TOK_IDENT
000FAEr 2  D0 2D                BNE     @rec_endcol
000FB0r 2  AE rr rr             LDX     field_depth
000FB3r 2  CA                   DEX
000FB4r 2  BD rr rr             LDA     field_name_count,x
000FB7r 2  C9 08                CMP     #8
000FB9r 2  B0 14                BCS     @rec_skip_save
000FBBr 2  20 rr rr             JSR     field_name_slot_ptr
000FBEr 2  A0 0F                LDY     #15
000FC0r 2               @rec_cpin:
000FC0r 2  B9 rr rr             LDA     ident_buf,y
000FC3r 2  91 rr                STA     (tmp2),y
000FC5r 2  88                   DEY
000FC6r 2  10 F8                BPL     @rec_cpin
000FC8r 2  AE rr rr             LDX     field_depth
000FCBr 2  CA                   DEX
000FCCr 2  FE rr rr             INC     field_name_count,x
000FCFr 2               @rec_skip_save:
000FCFr 2  20 rr rr             JSR     next_token              ; consume name
000FD2r 2  A5 rr                LDA     tok_type
000FD4r 2  C9 1F                CMP     #TOK_COMMA
000FD6r 2  D0 05                BNE     @rec_endcol
000FD8r 2  20 rr rr             JSR     next_token              ; consume ','
000FDBr 2  80 CD                BRA     @rec_collect
000FDDr 2               @rec_endcol:
000FDDr 2               ; expect ':'
000FDDr 2  A5 rr                LDA     tok_type
000FDFr 2  C9 21                CMP     #TOK_COLON
000FE1r 2  D0 03                BNE     :+
000FE3r 2  20 rr rr             JSR     next_token
000FE6r 2               :       ; parse field type — recurse; result in A.  Save outer record
000FE6r 2               ; bookkeeping (size + first_field + field_count) so a nested RECORD
000FE6r 2               ; can use the same globals without losing our state.  After the inner
000FE6r 2               ; parse, capture the inner's metadata into nest_save_* and restore.
000FE6r 2  AD rr rr             LDA     record_size
000FE9r 2  48                   PHA
000FEAr 2  AD rr rr             LDA     record_size+1
000FEDr 2  48                   PHA
000FEEr 2  AD rr rr             LDA     record_first_field
000FF1r 2  48                   PHA
000FF2r 2  AD rr rr             LDA     record_field_count
000FF5r 2  48                   PHA
000FF6r 2  20 rr rr             JSR     parse_type_spec         ; may recurse into RECORD
000FF9r 2  85 rr                STA     scratch                 ; field type code
000FFBr 2               ; capture inner's metadata for @rec_addf (only meaningful for TY_RECORD)
000FFBr 2  AD rr rr             LDA     record_size
000FFEr 2  8D rr rr             STA     nest_save_size
001001r 2  AD rr rr             LDA     record_size+1
001004r 2  8D rr rr             STA     nest_save_size+1
001007r 2  AD rr rr             LDA     record_first_field
00100Ar 2  8D rr rr             STA     nest_save_first
00100Dr 2  AD rr rr             LDA     record_field_count
001010r 2  8D rr rr             STA     nest_save_count
001013r 2               ; restore outer record bookkeeping
001013r 2  68                   PLA
001014r 2  8D rr rr             STA     record_field_count
001017r 2  68                   PLA
001018r 2  8D rr rr             STA     record_first_field
00101Br 2  68                   PLA
00101Cr 2  8D rr rr             STA     record_size+1
00101Fr 2  68                   PLA
001020r 2  8D rr rr             STA     record_size
001023r 2               ; --- add each collected name to field_table at current record_size ---
001023r 2  A2 00                LDX     #0
001025r 2               @rec_addf:
001025r 2  8A                   TXA
001026r 2  AC rr rr             LDY     field_depth
001029r 2  88                   DEY
00102Ar 2  D9 rr rr             CMP     field_name_count,y
00102Dr 2  B0 68                BCS     @rec_endf
00102Fr 2  DA                   PHX
001030r 2  8A                   TXA
001031r 2  20 rr rr             JSR     field_name_slot_ptr
001034r 2  A0 0F                LDY     #15
001036r 2               @rec_cpout:
001036r 2  B1 rr                LDA     (tmp2),y
001038r 2  99 rr rr             STA     ident_buf,y
00103Br 2  88                   DEY
00103Cr 2  10 F8                BPL     @rec_cpout
00103Er 2               ; If the previous field group's type was an inline RECORD, its fields
00103Er 2               ; got appended to field_table BEFORE this outer field. Bump
00103Er 2               ; record_first_field past those leading slots so the lookup-scan starts
00103Er 2               ; at the first outer-depth field instead of an inner one. Only applies
00103Er 2               ; when no outer fields have been recorded yet.
00103Er 2  AD rr rr             LDA     record_field_count
001041r 2  D0 06                BNE     :+
001043r 2  AD rr rr             LDA     field_table_count
001046r 2  8D rr rr             STA     record_first_field
001049r 2               :
001049r 2               ; field_table_add: A=offset (record_size lo), X=type
001049r 2               ;   Returns: A = newly-assigned field index
001049r 2  AD rr rr             LDA     record_size
00104Cr 2  A6 rr                LDX     scratch
00104Er 2  20 rr rr             JSR     field_table_add
001051r 2               ; If this field's type is TY_RECORD, fold the inner record's
001051r 2               ; first_field/count (saved in nest_save_*) into the parallel
001051r 2               ; nested arrays so chained access can traverse it.
001051r 2  48                   PHA                             ; save field index
001052r 2  A6 rr                LDX     scratch                 ; field type
001054r 2  E0 06                CPX     #TY_RECORD
001056r 2  D0 0D                BNE     @rec_no_nest
001058r 2  AA                   TAX                             ; X = field index (A still holds it)
001059r 2  AD rr rr             LDA     nest_save_first
00105Cr 2  9D rr rr             STA     field_nested_first,x
00105Fr 2  AD rr rr             LDA     nest_save_count
001062r 2  9D rr rr             STA     field_nested_count,x
001065r 2               @rec_no_nest:
001065r 2  68                   PLA                             ; restore (no longer needed)
001066r 2  EE rr rr             INC     record_field_count
001069r 2               ; advance record_size by this field's size:
001069r 2               ;   record fields → nest_save_size (set by inner parse)
001069r 2               ;   anything else → 2 (all scalars are word-sized)
001069r 2  A6 rr                LDX     scratch
00106Br 2  E0 06                CPX     #TY_RECORD
00106Dr 2  F0 10                BEQ     @rec_adv_rec
00106Fr 2  18                   CLC
001070r 2  AD rr rr             LDA     record_size
001073r 2  69 02                ADC     #2
001075r 2  8D rr rr             STA     record_size
001078r 2  90 03                BCC     :+
00107Ar 2  EE rr rr             INC     record_size+1
00107Dr 2  80 13        :       BRA     @rec_advanced
00107Fr 2               @rec_adv_rec:
00107Fr 2  18                   CLC
001080r 2  AD rr rr             LDA     record_size
001083r 2  6D rr rr             ADC     nest_save_size
001086r 2  8D rr rr             STA     record_size
001089r 2  AD rr rr             LDA     record_size+1
00108Cr 2  6D rr rr             ADC     nest_save_size+1
00108Fr 2  8D rr rr             STA     record_size+1
001092r 2               @rec_advanced:
001092r 2  FA                   PLX
001093r 2  E8                   INX
001094r 2  4C rr rr             JMP     @rec_addf
001097r 2               @rec_endf:
001097r 2               ; expect ';' between groups, or END
001097r 2  A5 rr                LDA     tok_type
001099r 2  C9 20                CMP     #TOK_SEMICOLON
00109Br 2  D0 06                BNE     @rec_check_end
00109Dr 2  20 rr rr             JSR     next_token              ; consume ';'
0010A0r 2  4C rr rr             JMP     @rec_loop
0010A3r 2               @rec_check_end:
0010A3r 2  A5 rr                LDA     tok_type
0010A5r 2  C9 49                CMP     #TOK_END
0010A7r 2  F0 03                BEQ     :+
0010A9r 2  4C rr rr             JMP     @rec_loop               ; recover — try again
0010ACr 2               :
0010ACr 2               @rec_end:
0010ACr 2  20 rr rr             JSR     next_token              ; consume END
0010AFr 2  CE rr rr             DEC     field_depth             ; leaving this nesting level
0010B2r 2               ; record_field_count was per-named-field; recompute as the slot span so
0010B2r 2               ; field_lookup_in_record covers any inline-record sub-fields that got
0010B2r 2               ; physically interleaved between this record's named fields.
0010B2r 2  38                   SEC
0010B3r 2  AD rr rr             LDA     field_table_count
0010B6r 2  ED rr rr             SBC     record_first_field
0010B9r 2  8D rr rr             STA     record_field_count
0010BCr 2  A9 06                LDA     #TY_RECORD
0010BEr 2  60                   RTS
0010BFr 2               @not_record:
0010BFr 2  A5 rr                LDA     tok_type
0010C1r 2  C9 24                CMP     #TOK_CARET
0010C3r 2  D0 09                BNE     @not_caret
0010C5r 2               ; --- ^BASETYPE — pointer type. Element type recorded but not yet
0010C5r 2               ; type-checked; v1 only supports pointer-to-INTEGER (2-byte cell).
0010C5r 2  20 rr rr             JSR     next_token              ; consume '^'
0010C8r 2  20 rr rr             JSR     parse_type_spec         ; consume base type, result in A
0010CBr 2                       ; (base type code intentionally discarded — bump allocator
0010CBr 2                       ;  always grants 2 bytes per NEW; revisit when records land)
0010CBr 2  A9 07                LDA     #TY_PTR
0010CDr 2  60                   RTS
0010CEr 2               @not_caret:
0010CEr 2  20 rr rr             JSR     next_token
0010D1r 2  A9 01                LDA     #TY_INT
0010D3r 2  60                   RTS
0010D4r 2               
0010D4r 2               ; ---------------------------------------------------------------------------
0010D4r 2               ; parse_arg_lvalue — used for VAR-by-reference call arguments.  Expects the
0010D4r 2               ; current token to be an IDENT naming a variable; consumes the ident and
0010D4r 2               ; emits an opcode that pushes the variable's address.
0010D4r 2               ;
0010D4r 2               ;   SYM_VAR    global → OP_LDA_G <wordoff>
0010D4r 2               ;   SYM_VAR    local  → OP_LDA_L <byteoff>
0010D4r 2               ;   SYM_VARREF (passing a VAR param through) → OP_LDL <byteoff>   (the
0010D4r 2               ;              local slot itself already holds the upstream address)
0010D4r 2               ;
0010D4r 2               ; Anything else (literal, function call, undefined name) is silently ignored
0010D4r 2               ; — the argument slot will hold whatever was last on the stack.  Pascal
0010D4r 2               ; semantics say it's a compile error, but we emit no diagnostic for now.
0010D4r 2               ; ---------------------------------------------------------------------------
0010D4r 2               parse_arg_lvalue:
0010D4r 2  A5 rr                LDA     tok_type
0010D6r 2  C9 01                CMP     #TOK_IDENT
0010D8r 2  F0 01                BEQ     :+
0010DAr 2  60                   RTS
0010DBr 2               :
0010DBr 2  20 rr rr             JSR     symtab_find
0010DEr 2  B0 01                BCS     :+
0010E0r 2  60                   RTS                     ; undefined — emit nothing
0010E1r 2               :       ; Snapshot kind, scope, offset before next_token clobbers tmp3.
0010E1r 2  A0 10                LDY     #16
0010E3r 2  B1 rr                LDA     (tmp3),y
0010E5r 2  48                   PHA                     ; kind
0010E6r 2  A0 14                LDY     #20
0010E8r 2  B1 rr                LDA     (tmp3),y
0010EAr 2  48                   PHA                     ; scope
0010EBr 2  A0 13                LDY     #19
0010EDr 2  B1 rr                LDA     (tmp3),y
0010EFr 2  48                   PHA                     ; off hi
0010F0r 2  A0 12                LDY     #18
0010F2r 2  B1 rr                LDA     (tmp3),y
0010F4r 2  48                   PHA                     ; off lo (top)
0010F5r 2  20 rr rr             JSR     next_token      ; consume ident
0010F8r 2  68                   PLA                     ; off lo
0010F9r 2  AA                   TAX
0010FAr 2  68                   PLA                     ; off hi
0010FBr 2  85 rr                STA     scratch
0010FDr 2  68                   PLA                     ; scope
0010FEr 2  A8                   TAY
0010FFr 2  68                   PLA                     ; kind
001100r 2  C9 08                CMP     #SYM_VARREF
001102r 2  F0 0C                BEQ     @lv_passthrough
001104r 2  C0 00                CPY     #0
001106r 2  D0 04                BNE     @lv_local
001108r 2  8A                   TXA
001109r 2  4C rr rr             JMP     emit_LDA_G
00110Cr 2               @lv_local:
00110Cr 2  8A                   TXA
00110Dr 2  4C rr rr             JMP     emit_LDA_L
001110r 2               @lv_passthrough:
001110r 2  8A                   TXA
001111r 2  4C rr rr             JMP     emit_LDL        ; slot already holds caller's address
001114r 2               
001114r 2               ; ---------------------------------------------------------------------------
001114r 2               ; with_lookup_field — search active WITH contexts for ident_buf as an
001114r 2               ; unqualified field name. Innermost WITH wins.
001114r 2               ; Returns: carry set if found, A=field offset, X=field type
001114r 2               ;          carry clear if not found
001114r 2               ; Side effects on hit:
001114r 2               ;   with_lookup_off/type      = matched field offset/type
001114r 2               ;   with_lookup_base_lo/hi    = hidden global holding the WITH base address
001114r 2               ;   with_lookup_first/count   = nested-record metadata for this field
001114r 2               ; ---------------------------------------------------------------------------
001114r 2               with_lookup_field:
001114r 2  AD rr rr             LDA     with_depth
001117r 2  D0 02                BNE     :+
001119r 2  18                   CLC
00111Ar 2  60                   RTS
00111Br 2  AE rr rr     :       LDX     with_depth
00111Er 2  CA                   DEX
00111Fr 2               @wlf_ctx:
00111Fr 2  86 rr                STX     tmp1
001121r 2  BC rr rr             LDY     with_field_count,x
001124r 2  BD rr rr             LDA     with_first_field,x
001127r 2  84 rr                STY     scratch
001129r 2  A6 rr                LDX     scratch
00112Br 2  20 rr rr             JSR     field_lookup_in_record
00112Er 2  90 2B                BCC     @wlf_next
001130r 2  8D rr rr             STA     with_lookup_off
001133r 2  8A                   TXA
001134r 2  8D rr rr             STA     with_lookup_type
001137r 2  A6 rr                LDX     tmp3
001139r 2  BD rr rr             LDA     field_nested_first,x
00113Cr 2  8D rr rr             STA     with_lookup_first
00113Fr 2  BD rr rr             LDA     field_nested_count,x
001142r 2  8D rr rr             STA     with_lookup_count
001145r 2  A6 rr                LDX     tmp1
001147r 2  BD rr rr             LDA     with_base_lo,x
00114Ar 2  8D rr rr             STA     with_lookup_base_lo
00114Dr 2  BD rr rr             LDA     with_base_hi,x
001150r 2  8D rr rr             STA     with_lookup_base_hi
001153r 2  AD rr rr             LDA     with_lookup_off
001156r 2  AE rr rr             LDX     with_lookup_type
001159r 2  38                   SEC
00115Ar 2  60                   RTS
00115Br 2               @wlf_next:
00115Br 2  A6 rr                LDX     tmp1
00115Dr 2  E0 00                CPX     #0
00115Fr 2  F0 03                BEQ     @wlf_nf
001161r 2  CA                   DEX
001162r 2  80 BB                BRA     @wlf_ctx
001164r 2               @wlf_nf:
001164r 2  18                   CLC
001165r 2  60                   RTS
001166r 2               
001166r 2               ; emit_with_field_base — push the selected WITH record's base address, then
001166r 2               ; add the matched field offset (with_lookup_off) if nonzero.
001166r 2               emit_with_field_base:
001166r 2  AD rr rr             LDA     with_lookup_base_hi
001169r 2  85 rr                STA     scratch
00116Br 2  AD rr rr             LDA     with_lookup_base_lo
00116Er 2  20 rr rr             JSR     emit_LDG
001171r 2  AD rr rr             LDA     with_lookup_off
001174r 2  F0 06                BEQ     @ewfb_done
001176r 2  20 rr rr             JSR     emit_LDCI
001179r 2  20 rr rr             JSR     emit_ADI
00117Cr 2               @ewfb_done:
00117Cr 2  60                   RTS
00117Dr 2               
00117Dr 2               ; ---------------------------------------------------------------------------
00117Dr 2               ; parse_param_list — assumes '(' has already been consumed.  Parses zero or
00117Dr 2               ; more comma/semicolon-separated parameter groups, then ')'.  Each parameter
00117Dr 2               ; is added to symtab as SYM_VAR with offset = proc_param_count*2 and the
00117Dr 2               ; group's type code.  proc_param_count is incremented per param.
00117Dr 2               ;
00117Dr 2               ; Pascal supports two separator forms:
00117Dr 2               ;   ( A, B: INTEGER )            — names sharing one type, COMMA separated
00117Dr 2               ;   ( A: INTEGER; B: CHAR )      — different types, SEMICOLON between groups
00117Dr 2               ;   ( A, B: INTEGER; C: CHAR )   — both forms mixed
00117Dr 2               ;
00117Dr 2               ; Reuses var_name_buf (128 bytes / 8 names per group).  Safe because the
00117Dr 2               ; param list is fully parsed before parse_block runs (which is what calls
00117Dr 2               ; parse_var_decls).
00117Dr 2               ; ---------------------------------------------------------------------------
00117Dr 2               parse_param_list:
00117Dr 2  A9 00                LDA     #0
00117Fr 2  8D rr rr             STA     param_var_mask  ; reset bitmap (set by caller too — paranoia)
001182r 2               @group_loop:
001182r 2               ; A leading VAR keyword marks the entire group as by-reference.
001182r 2  A9 00                LDA     #0
001184r 2  8D rr rr             STA     group_is_var
001187r 2  A5 rr                LDA     tok_type
001189r 2  C9 5C                CMP     #TOK_VAR
00118Br 2  D0 08                BNE     @no_var_kw
00118Dr 2  A9 01                LDA     #1
00118Fr 2  8D rr rr             STA     group_is_var
001192r 2  20 rr rr             JSR     next_token      ; consume VAR
001195r 2               @no_var_kw:
001195r 2  A5 rr                LDA     tok_type
001197r 2  C9 01                CMP     #TOK_IDENT
001199r 2  F0 03                BEQ     @have_ident     ; jmp trampoline — body is too big for bra
00119Br 2  4C rr rr             JMP     @done_params
00119Er 2               @have_ident:
00119Er 2               ; --- collect comma-separated names of this group ---
00119Er 2  A9 00                LDA     #0
0011A0r 2  8D rr rr             STA     var_name_count
0011A3r 2               @gcollect:
0011A3r 2  A5 rr                LDA     tok_type
0011A5r 2  C9 01                CMP     #TOK_IDENT
0011A7r 2  D0 31                BNE     @gend
0011A9r 2  AD rr rr             LDA     var_name_count
0011ACr 2  C9 08                CMP     #8
0011AEr 2  B0 1C                BCS     @gskip          ; buffer full — silently drop name
0011B0r 2  0A                   ASL
0011B1r 2  0A                   ASL
0011B2r 2  0A                   ASL
0011B3r 2  0A                   ASL
0011B4r 2  18                   CLC
0011B5r 2  69 rr                ADC     #<var_name_buf
0011B7r 2  85 rr                STA     tmp2
0011B9r 2  A9 00                LDA     #0
0011BBr 2  69 rr                ADC     #>var_name_buf
0011BDr 2  85 rr                STA     tmp2+1
0011BFr 2  A0 0F                LDY     #15
0011C1r 2               @gcp:
0011C1r 2  B9 rr rr             LDA     ident_buf,y
0011C4r 2  91 rr                STA     (tmp2),y
0011C6r 2  88                   DEY
0011C7r 2  10 F8                BPL     @gcp
0011C9r 2  EE rr rr             INC     var_name_count
0011CCr 2               @gskip:
0011CCr 2  20 rr rr             JSR     next_token      ; consume name
0011CFr 2  A5 rr                LDA     tok_type
0011D1r 2  C9 1F                CMP     #TOK_COMMA
0011D3r 2  D0 05                BNE     @gend
0011D5r 2  20 rr rr             JSR     next_token      ; consume ','
0011D8r 2  80 C9                BRA     @gcollect
0011DAr 2               @gend:
0011DAr 2               ; expect ':'
0011DAr 2  A5 rr                LDA     tok_type
0011DCr 2  C9 21                CMP     #TOK_COLON
0011DEr 2  D0 03                BNE     :+
0011E0r 2  20 rr rr             JSR     next_token
0011E3r 2               :
0011E3r 2  20 rr rr             JSR     parse_type_spec
0011E6r 2  85 rr                STA     scratch         ; stash type for this group
0011E8r 2               ; --- add each collected name as SYM_VAR ---
0011E8r 2  A2 00                LDX     #0
0011EAr 2               @addloop:
0011EAr 2  EC rr rr             CPX     var_name_count
0011EDr 2  90 03                BCC     :+
0011EFr 2  4C rr rr             JMP     @groupdone
0011F2r 2               :
0011F2r 2  DA                   PHX
0011F3r 2  A5 rr                LDA     scratch
0011F5r 2  20 rr rr             JSR     store_proc_param_type
0011F8r 2               ; copy var_name_buf[X*16] → ident_buf
0011F8r 2  8A                   TXA
0011F9r 2  0A                   ASL
0011FAr 2  0A                   ASL
0011FBr 2  0A                   ASL
0011FCr 2  0A                   ASL
0011FDr 2  18                   CLC
0011FEr 2  69 rr                ADC     #<var_name_buf
001200r 2  85 rr                STA     tmp2
001202r 2  A9 00                LDA     #0
001204r 2  69 rr                ADC     #>var_name_buf
001206r 2  85 rr                STA     tmp2+1
001208r 2  A0 0F                LDY     #15
00120Ar 2               @cpout:
00120Ar 2  B1 rr                LDA     (tmp2),y
00120Cr 2  99 rr rr             STA     ident_buf,y
00120Fr 2  88                   DEY
001210r 2  10 F8                BPL     @cpout
001212r 2               ; offset for this param = proc_param_count * 2
001212r 2  AD rr rr             LDA     proc_param_count
001215r 2  0A                   ASL
001216r 2  85 rr                STA     tmp2
001218r 2  A9 00                LDA     #0
00121Ar 2  85 rr                STA     tmp2+1
00121Cr 2               ; If this is a VAR group, set the matching bit in param_var_mask
00121Cr 2               ; and use SYM_VARREF instead of SYM_VAR.
00121Cr 2  AD rr rr             LDA     group_is_var
00121Fr 2  F0 1E                BEQ     @use_var_kind
001221r 2               ; set bit (1 << proc_param_count) in param_var_mask (max 8 params)
001221r 2  AC rr rr             LDY     proc_param_count
001224r 2  C0 08                CPY     #8
001226r 2  B0 10                BCS     @skip_mask      ; >8 params: silently drop bit
001228r 2  A9 01                LDA     #1
00122Ar 2               @shl:
00122Ar 2  C0 00                CPY     #0
00122Cr 2  F0 04                BEQ     @done_shl
00122Er 2  0A                   ASL
00122Fr 2  88                   DEY
001230r 2  80 F8                BRA     @shl
001232r 2               @done_shl:
001232r 2  0D rr rr             ORA     param_var_mask
001235r 2  8D rr rr             STA     param_var_mask
001238r 2               @skip_mask:
001238r 2  A5 rr                LDA     scratch         ; type
00123Ar 2  AA                   TAX
00123Br 2  A9 08                LDA     #SYM_VARREF
00123Dr 2  80 05                BRA     @do_add
00123Fr 2               @use_var_kind:
00123Fr 2  A5 rr                LDA     scratch         ; type
001241r 2  AA                   TAX
001242r 2  A9 01                LDA     #SYM_VAR
001244r 2               @do_add:
001244r 2  20 rr rr             JSR     symtab_add
001247r 2  A5 rr                LDA     scratch
001249r 2  C9 05                CMP     #TY_ARRAY
00124Br 2  D0 0F                BNE     @pl_chk_rec
00124Dr 2  AD rr rr             LDA     array_elem_ty
001250r 2  A0 16                LDY     #22
001252r 2  91 rr                STA     (tmp3),y
001254r 2  A9 02                LDA     #2
001256r 2  A0 17                LDY     #23
001258r 2  91 rr                STA     (tmp3),y
00125Ar 2  80 12                BRA     @pl_meta_done
00125Cr 2               @pl_chk_rec:
00125Cr 2  C9 06                CMP     #TY_RECORD
00125Er 2  D0 0E                BNE     @pl_meta_done
001260r 2  AD rr rr             LDA     record_first_field
001263r 2  A0 16                LDY     #22
001265r 2  91 rr                STA     (tmp3),y
001267r 2  AD rr rr             LDA     record_field_count
00126Ar 2  A0 17                LDY     #23
00126Cr 2  91 rr                STA     (tmp3),y
00126Er 2               @pl_meta_done:
00126Er 2  EE rr rr             INC     proc_param_count
001271r 2  FA                   PLX
001272r 2  E8                   INX
001273r 2  4C rr rr             JMP     @addloop        ; bra would be out of range now
001276r 2               @groupdone:
001276r 2               ; SEMICOLON → another group; else fall through to ')'
001276r 2  A5 rr                LDA     tok_type
001278r 2  C9 20                CMP     #TOK_SEMICOLON
00127Ar 2  D0 06                BNE     @done_params
00127Cr 2  20 rr rr             JSR     next_token      ; consume ';'
00127Fr 2  4C rr rr             JMP     @group_loop
001282r 2               @done_params:
001282r 2  A5 rr                LDA     tok_type
001284r 2  C9 1C                CMP     #TOK_RPAREN
001286r 2  D0 03                BNE     :+
001288r 2  20 rr rr             JSR     next_token      ; consume ')'
00128Br 2               :
00128Br 2  60                   RTS
00128Cr 2               
00128Cr 2               ; ---------------------------------------------------------------------------
00128Cr 2               ; parse_param_sig_list — parse a PROCEDURE/FUNCTION signature parameter list
00128Cr 2               ; without creating SYM_VAR entries. Used by UNIT interface headings so the
00128Cr 2               ; exported routine can record only param-count / VAR-mask metadata.
00128Cr 2               ; ---------------------------------------------------------------------------
00128Cr 2               parse_param_sig_list:
00128Cr 2  A9 00                LDA     #0
00128Er 2  8D rr rr             STA     param_var_mask
001291r 2               @psig_group:
001291r 2  A9 00                LDA     #0
001293r 2  8D rr rr             STA     group_is_var
001296r 2  A5 rr                LDA     tok_type
001298r 2  C9 5C                CMP     #TOK_VAR
00129Ar 2  D0 08                BNE     @psig_no_var
00129Cr 2  A9 01                LDA     #1
00129Er 2  8D rr rr             STA     group_is_var
0012A1r 2  20 rr rr             JSR     next_token
0012A4r 2               @psig_no_var:
0012A4r 2  A5 rr                LDA     tok_type
0012A6r 2  C9 01                CMP     #TOK_IDENT
0012A8r 2  F0 03                BEQ     @psig_have_ident
0012AAr 2  4C rr rr             JMP     @psig_done
0012ADr 2               @psig_have_ident:
0012ADr 2  A9 00                LDA     #0
0012AFr 2  8D rr rr             STA     var_name_count
0012B2r 2               @psig_collect:
0012B2r 2  A5 rr                LDA     tok_type
0012B4r 2  C9 01                CMP     #TOK_IDENT
0012B6r 2  D0 11                BNE     @psig_end_names
0012B8r 2  EE rr rr             INC     var_name_count
0012BBr 2  20 rr rr             JSR     next_token
0012BEr 2  A5 rr                LDA     tok_type
0012C0r 2  C9 1F                CMP     #TOK_COMMA
0012C2r 2  D0 05                BNE     @psig_end_names
0012C4r 2  20 rr rr             JSR     next_token
0012C7r 2  80 E9                BRA     @psig_collect
0012C9r 2               @psig_end_names:
0012C9r 2  A5 rr                LDA     tok_type
0012CBr 2  C9 21                CMP     #TOK_COLON
0012CDr 2  D0 03                BNE     :+
0012CFr 2  20 rr rr             JSR     next_token
0012D2r 2  20 rr rr     :       JSR     parse_type_spec
0012D5r 2  85 rr                STA     scratch
0012D7r 2  A2 00                LDX     #0
0012D9r 2               @psig_add:
0012D9r 2  EC rr rr             CPX     var_name_count
0012DCr 2  B0 27                BCS     @psig_group_done
0012DEr 2  A5 rr                LDA     scratch
0012E0r 2  20 rr rr             JSR     store_proc_param_type
0012E3r 2  AD rr rr             LDA     group_is_var
0012E6r 2  F0 17                BEQ     @psig_inc
0012E8r 2  AC rr rr             LDY     proc_param_count
0012EBr 2  C0 08                CPY     #8
0012EDr 2  B0 10                BCS     @psig_inc
0012EFr 2  A9 01                LDA     #1
0012F1r 2               @psig_shl:
0012F1r 2  C0 00                CPY     #0
0012F3r 2  F0 04                BEQ     @psig_shl_done
0012F5r 2  0A                   ASL
0012F6r 2  88                   DEY
0012F7r 2  80 F8                BRA     @psig_shl
0012F9r 2               @psig_shl_done:
0012F9r 2  0D rr rr             ORA     param_var_mask
0012FCr 2  8D rr rr             STA     param_var_mask
0012FFr 2               @psig_inc:
0012FFr 2  EE rr rr             INC     proc_param_count
001302r 2  E8                   INX
001303r 2  80 D4                BRA     @psig_add
001305r 2               @psig_group_done:
001305r 2  A5 rr                LDA     tok_type
001307r 2  C9 20                CMP     #TOK_SEMICOLON
001309r 2  D0 06                BNE     @psig_done
00130Br 2  20 rr rr             JSR     next_token
00130Er 2  4C rr rr             JMP     @psig_group
001311r 2               @psig_done:
001311r 2  A5 rr                LDA     tok_type
001313r 2  C9 1C                CMP     #TOK_RPAREN
001315r 2  D0 03                BNE     :+
001317r 2  20 rr rr             JSR     next_token
00131Ar 2  60           :       RTS
00131Br 2               
00131Br 2               ; ---------------------------------------------------------------------------
00131Br 2               ; parse_proc_iface_decl — PROCEDURE heading in a UNIT INTERFACE section.
00131Br 2               ; Registers a global SYM_PROC with placeholder code offset 0 and fills
00131Br 2               ; param-count / VAR-mask metadata for later callers and implementation.
00131Br 2               ; ---------------------------------------------------------------------------
00131Br 2               parse_proc_iface_decl:
00131Br 2  A5 rr                LDA     tok_type
00131Dr 2  C9 01                CMP     #TOK_IDENT
00131Fr 2  F0 01                BEQ     :+
001321r 2  60                   RTS
001322r 2  A9 00        :       LDA     #0
001324r 2  8D rr rr             STA     proc_param_count
001327r 2  8D rr rr             STA     param_var_mask
00132Ar 2  85 rr                STA     tmp2
00132Cr 2  85 rr                STA     tmp2+1
00132Er 2  A9 03                LDA     #SYM_PROC
001330r 2  A2 00                LDX     #TY_NONE
001332r 2  20 rr rr             JSR     symtab_add
001335r 2  A5 rr                LDA     tmp3
001337r 2  8D rr rr             STA     proc_entry_idx
00133Ar 2  A5 rr                LDA     tmp3+1
00133Cr 2  8D rr rr             STA     proc_entry_idx+1
00133Fr 2  20 rr rr             JSR     next_token              ; consume name
001342r 2  A5 rr                LDA     tok_type
001344r 2  C9 1B                CMP     #TOK_LPAREN
001346r 2  D0 06                BNE     @ppid_patch
001348r 2  20 rr rr             JSR     next_token
00134Br 2  20 rr rr             JSR     parse_param_sig_list
00134Er 2               @ppid_patch:
00134Er 2  AD rr rr             LDA     proc_entry_idx
001351r 2  85 rr                STA     tmp3
001353r 2  AD rr rr             LDA     proc_entry_idx+1
001356r 2  85 rr                STA     tmp3+1
001358r 2  A0 15                LDY     #21
00135Ar 2  AD rr rr             LDA     proc_param_count
00135Dr 2  91 rr                STA     (tmp3),y
00135Fr 2  A0 16                LDY     #22
001361r 2  AD rr rr             LDA     param_var_mask
001364r 2  91 rr                STA     (tmp3),y
001366r 2  A5 rr                LDA     tok_type
001368r 2  C9 20                CMP     #TOK_SEMICOLON
00136Ar 2  D0 03                BNE     :+
00136Cr 2  20 rr rr             JSR     next_token
00136Fr 2  60           :       RTS
001370r 2               
001370r 2               ; ---------------------------------------------------------------------------
001370r 2               ; parse_func_iface_decl — FUNCTION heading in a UNIT INTERFACE section.
001370r 2               ; Registers a global SYM_FUNC with placeholder code offset 0 and patches
001370r 2               ; the return type plus param-count / VAR-mask metadata.
001370r 2               ; ---------------------------------------------------------------------------
001370r 2               parse_func_iface_decl:
001370r 2  A5 rr                LDA     tok_type
001372r 2  C9 01                CMP     #TOK_IDENT
001374r 2  F0 01                BEQ     :+
001376r 2  60                   RTS
001377r 2  A9 00        :       LDA     #0
001379r 2  8D rr rr             STA     proc_param_count
00137Cr 2  8D rr rr             STA     param_var_mask
00137Fr 2  85 rr                STA     tmp2
001381r 2  85 rr                STA     tmp2+1
001383r 2  A9 04                LDA     #SYM_FUNC
001385r 2  A2 00                LDX     #TY_NONE
001387r 2  20 rr rr             JSR     symtab_add
00138Ar 2  A5 rr                LDA     tmp3
00138Cr 2  8D rr rr             STA     proc_entry_idx
00138Fr 2  A5 rr                LDA     tmp3+1
001391r 2  8D rr rr             STA     proc_entry_idx+1
001394r 2  20 rr rr             JSR     next_token              ; consume name
001397r 2  A5 rr                LDA     tok_type
001399r 2  C9 1B                CMP     #TOK_LPAREN
00139Br 2  D0 06                BNE     @pfid_after_params
00139Dr 2  20 rr rr             JSR     next_token
0013A0r 2  20 rr rr             JSR     parse_param_sig_list
0013A3r 2               @pfid_after_params:
0013A3r 2  A5 rr                LDA     tok_type
0013A5r 2  C9 21                CMP     #TOK_COLON
0013A7r 2  D0 03                BNE     :+
0013A9r 2  20 rr rr             JSR     next_token
0013ACr 2  20 rr rr     :       JSR     parse_type_spec
0013AFr 2  85 rr                STA     scratch
0013B1r 2  AD rr rr             LDA     proc_entry_idx
0013B4r 2  85 rr                STA     tmp3
0013B6r 2  AD rr rr             LDA     proc_entry_idx+1
0013B9r 2  85 rr                STA     tmp3+1
0013BBr 2  A0 11                LDY     #17
0013BDr 2  A5 rr                LDA     scratch
0013BFr 2  91 rr                STA     (tmp3),y
0013C1r 2  A0 15                LDY     #21
0013C3r 2  AD rr rr             LDA     proc_param_count
0013C6r 2  91 rr                STA     (tmp3),y
0013C8r 2  A0 16                LDY     #22
0013CAr 2  AD rr rr             LDA     param_var_mask
0013CDr 2  91 rr                STA     (tmp3),y
0013CFr 2  A5 rr                LDA     tok_type
0013D1r 2  C9 20                CMP     #TOK_SEMICOLON
0013D3r 2  D0 03                BNE     :+
0013D5r 2  20 rr rr             JSR     next_token
0013D8r 2  60           :       RTS
0013D9r 2               
0013D9r 2               ; ---------------------------------------------------------------------------
0013D9r 2               ; parse_proc_decl — PROCEDURE name [ ( params ) ] ; <block> ;
0013D9r 2               ; The PROCEDURE keyword has already been consumed by parse_block @proc.
0013D9r 2               ;
0013D9r 2               ; Phase B: value parameters supported.  Each parameter occupies 2 bytes in
0013D9r 2               ; the AR at MP+AR_LOCALS+offset and is stored into the symbol table as
0013D9r 2               ; SYM_VAR in the inner scope.  Param-count is recorded on the proc's symbol
0013D9r 2               ; entry (offset 21) so callers know how many args to push.
0013D9r 2               ; ---------------------------------------------------------------------------
0013D9r 2               parse_proc_decl:
0013D9r 2               ; expect identifier (proc name)
0013D9r 2  A5 rr                LDA     tok_type
0013DBr 2  C9 01                CMP     #TOK_IDENT
0013DDr 2  F0 01                BEQ     @have_name
0013DFr 2  60                   RTS
0013E0r 2               @have_name:
0013E0r 2               ; Save outer local_alloc_off on 6502 stack — nested procs would
0013E0r 2               ; otherwise clobber the enclosing proc's allocator state.
0013E0r 2  AD rr rr             LDA     local_alloc_off
0013E3r 2  48                   PHA
0013E4r 2               
0013E4r 2               ; save proc name into save_name_buf (ident_buf gets clobbered later)
0013E4r 2  A0 0F                LDY     #15
0013E6r 2               @savename:
0013E6r 2  B9 rr rr             LDA     ident_buf,y
0013E9r 2  99 rr rr             STA     save_name_buf,y
0013ECr 2  88                   DEY
0013EDr 2  10 F7                BPL     @savename
0013EFr 2               
0013EFr 2               ; UNIT implementation bodies may be preceded by an INTERFACE heading.
0013EFr 2               ; Reuse that global SYM_PROC entry instead of creating a duplicate.
0013EFr 2  A5 rr                LDA     scope_depth
0013F1r 2  D0 2A                BNE     @new_entry
0013F3r 2  AD rr rr             LDA     unit_section
0013F6r 2  C9 02                CMP     #2
0013F8r 2  D0 23                BNE     @new_entry
0013FAr 2  20 rr rr             JSR     symtab_find
0013FDr 2  90 1E                BCC     @new_entry
0013FFr 2  A0 10                LDY     #16
001401r 2  B1 rr                LDA     (tmp3),y
001403r 2  C9 03                CMP     #SYM_PROC
001405r 2  D0 16                BNE     @new_entry
001407r 2  A0 14                LDY     #20
001409r 2  B1 rr                LDA     (tmp3),y
00140Br 2  D0 10                BNE     @new_entry
00140Dr 2  A5 rr                LDA     tmp3
00140Fr 2  8D rr rr             STA     proc_entry_idx
001412r 2  A5 rr                LDA     tmp3+1
001414r 2  8D rr rr             STA     proc_entry_idx+1
001417r 2  20 rr rr             JSR     next_token
00141Ar 2  4C rr rr             JMP     @enter_scope
00141Dr 2               @new_entry:
00141Dr 2               
00141Dr 2  20 rr rr             JSR     next_token      ; consume name
001420r 2               
001420r 2               ; Register proc in symbol table NOW so we have an entry to update
001420r 2               ; with the param count once the param list has been parsed.
001420r 2               ; Offset (proc entry point) = current cg_pc.
001420r 2  20 rr rr             JSR     swap_ident_save ; ident_buf <-> save_name_buf
001423r 2  A5 rr                LDA     cg_pc
001425r 2  85 rr                STA     tmp2
001427r 2  A5 rr                LDA     cg_pc+1
001429r 2  85 rr                STA     tmp2+1
00142Br 2  A9 03                LDA     #SYM_PROC
00142Dr 2  A2 00                LDX     #TY_NONE
00142Fr 2  20 rr rr             JSR     symtab_add
001432r 2  A5 rr                LDA     tmp3
001434r 2  8D rr rr             STA     proc_entry_idx
001437r 2  A5 rr                LDA     tmp3+1
001439r 2  8D rr rr             STA     proc_entry_idx+1
00143Cr 2  20 rr rr             JSR     swap_ident_save
00143Fr 2               
00143Fr 2               ; Enter scope: params and any locals belong to the proc's frame.
00143Fr 2               @enter_scope:
00143Fr 2  20 rr rr             JSR     symtab_enter_scope
001442r 2               
001442r 2               ; init param count and VAR-mask
001442r 2  A9 00                LDA     #0
001444r 2  8D rr rr             STA     proc_param_count
001447r 2  8D rr rr             STA     param_var_mask
00144Ar 2               
00144Ar 2               ; Optional parameter list
00144Ar 2  A5 rr                LDA     tok_type
00144Cr 2  C9 1B                CMP     #TOK_LPAREN
00144Er 2  D0 06                BNE     @backpatch_pcount
001450r 2  20 rr rr             JSR     next_token      ; consume '('
001453r 2  20 rr rr             JSR     parse_param_list
001456r 2               
001456r 2               @backpatch_pcount:
001456r 2               ; Write param count into proc's symbol entry (offset 21).
001456r 2  AD rr rr             LDA     proc_entry_idx
001459r 2  85 rr                STA     tmp3
00145Br 2  AD rr rr             LDA     proc_entry_idx+1
00145Er 2  85 rr                STA     tmp3+1
001460r 2  A0 12                LDY     #18
001462r 2  A5 rr                LDA     cg_pc
001464r 2  91 rr                STA     (tmp3),y
001466r 2  C8                   INY
001467r 2  A5 rr                LDA     cg_pc+1
001469r 2  91 rr                STA     (tmp3),y
00146Br 2  A0 15                LDY     #21
00146Dr 2  AD rr rr             LDA     proc_param_count
001470r 2  91 rr                STA     (tmp3),y
001472r 2  A0 16                LDY     #22
001474r 2  AD rr rr             LDA     param_var_mask
001477r 2  91 rr                STA     (tmp3),y
001479r 2               
001479r 2               ; Initialize local_alloc_off to start right after the params.
001479r 2               ; VAR declarations inside the body extend this; final value is
001479r 2               ; backpatched into entry offset 23 below as the MRKSTK size.
001479r 2  AD rr rr             LDA     proc_param_count
00147Cr 2  0A                   ASL
00147Dr 2  8D rr rr             STA     local_alloc_off
001480r 2               
001480r 2               ; expect ';'
001480r 2  A5 rr                LDA     tok_type
001482r 2  C9 20                CMP     #TOK_SEMICOLON
001484r 2  D0 03                BNE     :+
001486r 2  20 rr rr             JSR     next_token
001489r 2               :
001489r 2               ; No callee prologue: the caller emits MRKSTK + arg-stores + CALL,
001489r 2               ; so by the time we land at the proc entry the activation record
001489r 2               ; (and its param slots) already exists.
001489r 2               
001489r 2               ; Recurse: proc body may have its own const/type/var/proc/begin block.
001489r 2  20 rr rr             JSR     parse_block
00148Cr 2               
00148Cr 2               ; Epilogue
00148Cr 2  20 rr rr             JSR     emit_RET
00148Fr 2               
00148Fr 2               ; Backpatch total local-area size (params + declared locals) into
00148Fr 2               ; the proc's symbol entry at offset 23.  The caller reads this and
00148Fr 2               ; emits MRKSTK <lsize> so the AR is large enough to hold all locals
00148Fr 2               ; below pm_sp (otherwise value-stack pushes corrupt local slots).
00148Fr 2  AD rr rr             LDA     proc_entry_idx
001492r 2  85 rr                STA     tmp3
001494r 2  AD rr rr             LDA     proc_entry_idx+1
001497r 2  85 rr                STA     tmp3+1
001499r 2  A0 17                LDY     #23
00149Br 2  AD rr rr             LDA     local_alloc_off
00149Er 2  91 rr                STA     (tmp3),y
0014A0r 2               
0014A0r 2  20 rr rr             JSR     symtab_leave_scope
0014A3r 2               
0014A3r 2               ; Consume trailing ';' after END
0014A3r 2  A5 rr                LDA     tok_type
0014A5r 2  C9 20                CMP     #TOK_SEMICOLON
0014A7r 2  D0 03                BNE     :+
0014A9r 2  20 rr rr             JSR     next_token
0014ACr 2               :
0014ACr 2  68                   PLA
0014ADr 2  8D rr rr             STA     local_alloc_off ; restore outer allocator state
0014B0r 2  60                   RTS
0014B1r 2               
0014B1r 2               ; ---------------------------------------------------------------------------
0014B1r 2               ; parse_func_decl — FUNCTION name [ ( params ) ] : RETURN_TYPE ; <block> ;
0014B1r 2               ; The FUNCTION keyword has already been consumed by parse_block @func.
0014B1r 2               ; Mirrors parse_proc_decl but registers SYM_FUNC, parses the return type,
0014B1r 2               ; adds a SYM_RETVAL inner-scope binding (so `name := expr` in the body
0014B1r 2               ; emits OP_STR), and emits OP_RETF as the epilogue.
0014B1r 2               ; ---------------------------------------------------------------------------
0014B1r 2               parse_func_decl:
0014B1r 2               ; expect identifier (func name)
0014B1r 2  A5 rr                LDA     tok_type
0014B3r 2  C9 01                CMP     #TOK_IDENT
0014B5r 2  F0 01                BEQ     @have_name
0014B7r 2  60                   RTS
0014B8r 2               @have_name:
0014B8r 2               ; Save outer local_alloc_off on 6502 stack — nested func/proc would
0014B8r 2               ; otherwise clobber the enclosing frame's allocator state.
0014B8r 2  AD rr rr             LDA     local_alloc_off
0014BBr 2  48                   PHA
0014BCr 2               
0014BCr 2               ; save func name into save_name_buf
0014BCr 2  A0 0F                LDY     #15
0014BEr 2               @savename:
0014BEr 2  B9 rr rr             LDA     ident_buf,y
0014C1r 2  99 rr rr             STA     save_name_buf,y
0014C4r 2  88                   DEY
0014C5r 2  10 F7                BPL     @savename
0014C7r 2               
0014C7r 2               ; UNIT implementation bodies may bind to an INTERFACE-declared SYM_FUNC.
0014C7r 2  A5 rr                LDA     scope_depth
0014C9r 2  D0 2A                BNE     @new_entry
0014CBr 2  AD rr rr             LDA     unit_section
0014CEr 2  C9 02                CMP     #2
0014D0r 2  D0 23                BNE     @new_entry
0014D2r 2  20 rr rr             JSR     symtab_find
0014D5r 2  90 1E                BCC     @new_entry
0014D7r 2  A0 10                LDY     #16
0014D9r 2  B1 rr                LDA     (tmp3),y
0014DBr 2  C9 04                CMP     #SYM_FUNC
0014DDr 2  D0 16                BNE     @new_entry
0014DFr 2  A0 14                LDY     #20
0014E1r 2  B1 rr                LDA     (tmp3),y
0014E3r 2  D0 10                BNE     @new_entry
0014E5r 2  A5 rr                LDA     tmp3
0014E7r 2  8D rr rr             STA     proc_entry_idx
0014EAr 2  A5 rr                LDA     tmp3+1
0014ECr 2  8D rr rr             STA     proc_entry_idx+1
0014EFr 2  20 rr rr             JSR     next_token
0014F2r 2  4C rr rr             JMP     @enter_scope
0014F5r 2               @new_entry:
0014F5r 2               
0014F5r 2  20 rr rr             JSR     next_token      ; consume name
0014F8r 2               
0014F8r 2               ; Register SYM_FUNC NOW so we have an entry to backpatch.
0014F8r 2               ; Type backpatched after we parse `: RETURN_TYPE`.
0014F8r 2  20 rr rr             JSR     swap_ident_save ; ident_buf <-> save_name_buf
0014FBr 2  A5 rr                LDA     cg_pc
0014FDr 2  85 rr                STA     tmp2
0014FFr 2  A5 rr                LDA     cg_pc+1
001501r 2  85 rr                STA     tmp2+1
001503r 2  A9 04                LDA     #SYM_FUNC
001505r 2  A2 00                LDX     #TY_NONE        ; placeholder
001507r 2  20 rr rr             JSR     symtab_add
00150Ar 2  A5 rr                LDA     tmp3
00150Cr 2  8D rr rr             STA     proc_entry_idx
00150Fr 2  A5 rr                LDA     tmp3+1
001511r 2  8D rr rr             STA     proc_entry_idx+1
001514r 2  20 rr rr             JSR     swap_ident_save
001517r 2               
001517r 2               ; Enter scope: params, locals, and SYM_RETVAL belong to fn frame.
001517r 2               @enter_scope:
001517r 2  20 rr rr             JSR     symtab_enter_scope
00151Ar 2               
00151Ar 2               ; init param count and VAR-mask
00151Ar 2  A9 00                LDA     #0
00151Cr 2  8D rr rr             STA     proc_param_count
00151Fr 2  8D rr rr             STA     param_var_mask
001522r 2               
001522r 2               ; Optional parameter list
001522r 2  A5 rr                LDA     tok_type
001524r 2  C9 1B                CMP     #TOK_LPAREN
001526r 2  D0 06                BNE     @after_params
001528r 2  20 rr rr             JSR     next_token      ; consume '('
00152Br 2  20 rr rr             JSR     parse_param_list
00152Er 2               
00152Er 2               @after_params:
00152Er 2               ; Expect ':' then return type
00152Er 2  A5 rr                LDA     tok_type
001530r 2  C9 21                CMP     #TOK_COLON
001532r 2  D0 03                BNE     :+
001534r 2  20 rr rr             JSR     next_token
001537r 2               :
001537r 2  20 rr rr             JSR     parse_type_spec
00153Ar 2  85 rr                STA     scratch         ; save return type code
00153Cr 2               
00153Cr 2               ; Recompute SYM_FUNC entry pointer from proc_entry_idx and backpatch
00153Cr 2               ; offset 17 (return type) and offset 21 (param count).
00153Cr 2  AD rr rr             LDA     proc_entry_idx
00153Fr 2  85 rr                STA     tmp3
001541r 2  AD rr rr             LDA     proc_entry_idx+1
001544r 2  85 rr                STA     tmp3+1
001546r 2  A0 12                LDY     #18
001548r 2  A5 rr                LDA     cg_pc
00154Ar 2  91 rr                STA     (tmp3),y
00154Cr 2  C8                   INY
00154Dr 2  A5 rr                LDA     cg_pc+1
00154Fr 2  91 rr                STA     (tmp3),y
001551r 2  A0 11                LDY     #17
001553r 2  A5 rr                LDA     scratch
001555r 2  91 rr                STA     (tmp3),y
001557r 2  A0 15                LDY     #21
001559r 2  AD rr rr             LDA     proc_param_count
00155Cr 2  91 rr                STA     (tmp3),y
00155Er 2  A0 16                LDY     #22
001560r 2  AD rr rr             LDA     param_var_mask
001563r 2  91 rr                STA     (tmp3),y
001565r 2               
001565r 2               ; Initialize local_alloc_off to start right after the params.
001565r 2               ; VAR declarations in the body extend this; final value is
001565r 2               ; backpatched into entry offset 23 as the MRKSTK size.
001565r 2  AD rr rr             LDA     proc_param_count
001568r 2  0A                   ASL
001569r 2  8D rr rr             STA     local_alloc_off
00156Cr 2               
00156Cr 2               ; Add SYM_RETVAL binding: same name as function; assignments to
00156Cr 2               ; this name in the body emit OP_STR (writes MP+AR_RET_VAL).
00156Cr 2               ; save_name_buf still holds the function name (parse_param_list uses
00156Cr 2               ; var_name_buf, not save_name_buf).  Swap it into ident_buf.
00156Cr 2  20 rr rr             JSR     swap_ident_save
00156Fr 2  A9 00                LDA     #0
001571r 2  85 rr                STA     tmp2
001573r 2  85 rr                STA     tmp2+1
001575r 2  A9 07                LDA     #SYM_RETVAL
001577r 2  A6 rr                LDX     scratch
001579r 2  20 rr rr             JSR     symtab_add
00157Cr 2               
00157Cr 2               ; Expect ';' before body
00157Cr 2  A5 rr                LDA     tok_type
00157Er 2  C9 20                CMP     #TOK_SEMICOLON
001580r 2  D0 03                BNE     :+
001582r 2  20 rr rr             JSR     next_token
001585r 2               :
001585r 2  20 rr rr             JSR     parse_block
001588r 2               
001588r 2  20 rr rr             JSR     emit_RETF
00158Br 2               
00158Br 2               ; Backpatch total local-area size into the func's symbol entry at
00158Br 2               ; offset 23 (params + declared body locals).  Caller emits MRKSTK
00158Br 2               ; with this value so the AR holds all locals below pm_sp.
00158Br 2  AD rr rr             LDA     proc_entry_idx
00158Er 2  85 rr                STA     tmp3
001590r 2  AD rr rr             LDA     proc_entry_idx+1
001593r 2  85 rr                STA     tmp3+1
001595r 2  A0 17                LDY     #23
001597r 2  AD rr rr             LDA     local_alloc_off
00159Ar 2  91 rr                STA     (tmp3),y
00159Cr 2               
00159Cr 2  20 rr rr             JSR     symtab_leave_scope
00159Fr 2               
00159Fr 2               ; Consume trailing ';' after END
00159Fr 2  A5 rr                LDA     tok_type
0015A1r 2  C9 20                CMP     #TOK_SEMICOLON
0015A3r 2  D0 03                BNE     :+
0015A5r 2  20 rr rr             JSR     next_token
0015A8r 2               :
0015A8r 2  68                   PLA
0015A9r 2  8D rr rr             STA     local_alloc_off ; restore outer allocator state
0015ACr 2  60                   RTS
0015ADr 2               
0015ADr 2               ; ---------------------------------------------------------------------------
0015ADr 2               ; parse_compound_stmt — BEGIN { statement ; } END
0015ADr 2               ; ---------------------------------------------------------------------------
0015ADr 2               parse_compound_stmt:
0015ADr 2               ; consume BEGIN
0015ADr 2  A5 rr                LDA     tok_type
0015AFr 2  C9 42                CMP     #TOK_BEGIN
0015B1r 2  D0 36                BNE     @done
0015B3r 2  20 rr rr             JSR     next_token
0015B6r 2               @loop:
0015B6r 2  A5 rr                LDA     tok_type
0015B8r 2  C9 49                CMP     #TOK_END
0015BAr 2  F0 2A                BEQ     @end
0015BCr 2  C9 00                CMP     #TOK_EOF
0015BEr 2  F0 29                BEQ     @done
0015C0r 2               ; remember tok before parse_statement to detect no-progress
0015C0r 2  85 rr                STA     tmp3
0015C2r 2  20 rr rr             JSR     parse_statement
0015C5r 2  A5 rr                LDA     tok_type
0015C7r 2  C9 20                CMP     #TOK_SEMICOLON
0015C9r 2  F0 15                BEQ     @consume_semi
0015CBr 2  C9 49                CMP     #TOK_END
0015CDr 2  F0 17                BEQ     @end
0015CFr 2  C9 00                CMP     #TOK_EOF
0015D1r 2  F0 16                BEQ     @done
0015D3r 2               ; if parse_statement didn't consume anything, force-advance to avoid
0015D3r 2               ; an infinite loop on an unrecognised token
0015D3r 2  C5 rr                CMP     tmp3
0015D5r 2  F0 03                BEQ     @pcs_force_advance
0015D7r 2  4C rr rr             JMP     @loop
0015DAr 2               @pcs_force_advance:
0015DAr 2  20 rr rr             JSR     next_token
0015DDr 2  4C rr rr             JMP     @loop
0015E0r 2               @consume_semi:
0015E0r 2  20 rr rr             JSR     next_token
0015E3r 2  4C rr rr             JMP     @loop
0015E6r 2               @end:
0015E6r 2  20 rr rr             JSR     next_token      ; consume END
0015E9r 2               @done:
0015E9r 2  60                   RTS
0015EAr 2               
0015EAr 2               ; ---------------------------------------------------------------------------
0015EAr 2               ; parse_statement — dispatch based on current token
0015EAr 2               ; ---------------------------------------------------------------------------
0015EAr 2               parse_statement:
0015EAr 2  A5 rr                LDA     tok_type
0015ECr 2  C9 42                CMP     #TOK_BEGIN
0015EEr 2  F0 19                BEQ     @compound
0015F0r 2  C9 5E                CMP     #TOK_WITH
0015F2r 2  F0 18                BEQ     @with
0015F4r 2  C9 4C                CMP     #TOK_IF
0015F6r 2  F0 1C                BEQ     @if
0015F8r 2  C9 5D                CMP     #TOK_WHILE
0015FAr 2  F0 1C                BEQ     @while
0015FCr 2  C9 4A                CMP     #TOK_FOR
0015FEr 2  F0 1C                BEQ     @for
001600r 2  C9 56                CMP     #TOK_REPEAT
001602r 2  F0 1C                BEQ     @repeat
001604r 2  C9 01                CMP     #TOK_IDENT
001606r 2  F0 08                BEQ     @assign_or_call
001608r 2  60                   RTS                     ; empty statement
001609r 2               
001609r 2               @compound:
001609r 2  4C rr rr             JMP     parse_compound_stmt
00160Cr 2               
00160Cr 2               @with:
00160Cr 2  20 rr rr             JSR     parse_with_stmt
00160Fr 2  60                   RTS
001610r 2               
001610r 2               @assign_or_call:
001610r 2  20 rr rr             JSR     parse_assign_or_call
001613r 2  60                   RTS
001614r 2               
001614r 2               @if:
001614r 2  20 rr rr             JSR     parse_if
001617r 2  60                   RTS
001618r 2               
001618r 2               @while:
001618r 2  20 rr rr             JSR     parse_while
00161Br 2  60                   RTS
00161Cr 2               
