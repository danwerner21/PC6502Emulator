002274r 2  A5 rr                LDA     tok_ival_hi
002276r 2  D0 51                BNE     @psl_bad_item
002278r 2  A5 rr                LDA     tok_ival_lo
00227Ar 2  C9 10                CMP     #16
00227Cr 2  B0 4B                BCS     @psl_bad_item
00227Er 2  8D rr rr             STA     set_lit_lo
002281r 2  20 rr rr             JSR     next_token              ; consume item lo
002284r 2  A5 rr                LDA     tok_type
002286r 2  C9 23                CMP     #TOK_DOTDOT
002288r 2  D0 37                BNE     @psl_single
00228Ar 2  20 rr rr             JSR     next_token              ; consume ..
00228Dr 2  A5 rr                LDA     tok_type
00228Fr 2  C9 02                CMP     #TOK_INT
002291r 2  D0 3E                BNE     @psl_bad_range
002293r 2  A5 rr                LDA     tok_ival_hi
002295r 2  D0 3A                BNE     @psl_bad_range
002297r 2  A5 rr                LDA     tok_ival_lo
002299r 2  C9 10                CMP     #16
00229Br 2  B0 34                BCS     @psl_bad_range
00229Dr 2  8D rr rr             STA     set_lit_hi
