002E2Br 2  4C rr rr             JMP     emit_byte
002E2Er 2               
002E2Er 2               ; ---------------------------------------------------------------------------
002E2Er 2               ; codegen_alloc_global — reserve N bytes in global area; return offset in tmp2
002E2Er 2               ; N in A
002E2Er 2               ; ---------------------------------------------------------------------------
002E2Er 2               codegen_alloc_global:
002E2Er 2  A5 rr                LDA     cg_globals
002E30r 2  85 rr                STA     tmp2
002E32r 2  A5 rr                LDA     cg_globals+1
002E34r 2  85 rr                STA     tmp2+1
002E36r 2               ; advance by N (passed in A — caller puts size here)
002E36r 2               ; For now allocate 2 bytes (word) per variable
002E36r 2  A5 rr                LDA     cg_globals
002E38r 2  18                   CLC
002E39r 2  69 02                ADC     #2
002E3Br 2  85 rr                STA     cg_globals
002E3Dr 2  90 02                BCC     :+
002E3Fr 2  E6 rr                INC     cg_globals+1
002E41r 2               :
002E41r 2  60                   RTS
002E42r 2               
002E42r 1                       .include        "IOLIB.ASM"
002E42r 2               .pc02
002E42r 2               ; iolib.asm — console and file I/O wrappers for DOS/65
002E42r 2               ;
002E42r 2               ; Uses PEM function 2 (CONOUT) for character output.
002E42r 2               ; This routes through DFT_CONSOLE and works on all platforms
002E42r 2               ; (serial, ESP video, memory-mapped video) regardless of which
002E42r 2               ; console driver is active.
002E42r 2               
002E42r 2                       .segment        "CODE"
002E42r 2               
002E42r 2               ; ---------------------------------------------------------------------------
002E42r 2               ; console_putc — output character in A to console via PEM #2
002E42r 2               ; ---------------------------------------------------------------------------
002E42r 2               console_putc:
002E42r 2  48                   PHA
002E43r 2  A2 02                LDX     #PEM_CONOUT
002E45r 2  20 03 01             JSR     PEM_ENTRY
002E48r 2  68                   PLA
002E49r 2  60                   RTS
002E4Ar 2               
002E4Ar 2               ; ---------------------------------------------------------------------------
002E4Ar 2               ; console_newline — emit CR+LF
002E4Ar 2               ; ---------------------------------------------------------------------------
002E4Ar 2               console_newline:
002E4Ar 2  A9 0D                LDA     #$0D
002E4Cr 2  A2 02                LDX     #PEM_CONOUT
002E4Er 2  20 03 01             JSR     PEM_ENTRY
002E51r 2  A9 0A                LDA     #$0A
002E53r 2  A2 02                LDX     #PEM_CONOUT
002E55r 2  20 03 01             JSR     PEM_ENTRY
002E58r 2  60                   RTS
002E59r 2               
002E59r 2               ; ---------------------------------------------------------------------------
002E59r 2               ; console_print_sz — print null-terminated string at tmp0
002E59r 2               ; ---------------------------------------------------------------------------
002E59r 2               console_print_sz:
002E59r 2  A0 00                LDY     #0
002E5Br 2               @loop:
002E5Br 2  B1 rr                LDA     (tmp0),y
002E5Dr 2  F0 08                BEQ     @done
002E5Fr 2  A2 02                LDX     #PEM_CONOUT
002E61r 2  20 03 01             JSR     PEM_ENTRY
002E64r 2  C8                   INY
002E65r 2  D0 F4                BNE     @loop
002E67r 2               @done:
002E67r 2  60                   RTS
002E68r 2               
002E68r 2               ; ---------------------------------------------------------------------------
002E68r 2               ; console_print_pstr — print length-prefixed Pascal string at tmp0
002E68r 2               ; ---------------------------------------------------------------------------
002E68r 2               console_print_pstr:
002E68r 2  A0 00                LDY     #0
002E6Ar 2  B1 rr                LDA     (tmp0),y        ; length byte
002E6Cr 2  F0 10                BEQ     @done
002E6Er 2  AA                   TAX                     ; X = remaining chars — but X used by PEM!
002E6Fr 2               ; save length, use tmp1 as counter
002E6Fr 2  85 rr                STA     tmp1
002E71r 2  C8                   INY
002E72r 2               @loop:
002E72r 2  B1 rr                LDA     (tmp0),y
002E74r 2  A2 02                LDX     #PEM_CONOUT
002E76r 2  20 03 01             JSR     PEM_ENTRY
002E79r 2  C8                   INY
002E7Ar 2  C6 rr                DEC     tmp1
002E7Cr 2  D0 F4                BNE     @loop
002E7Er 2               @done:
002E7Er 2  60                   RTS
002E7Fr 2               
002E7Fr 2               ; ---------------------------------------------------------------------------
002E7Fr 2               ; console_print_dec — print signed 16-bit integer in tmp0:tmp0+1
002E7Fr 2               ; ---------------------------------------------------------------------------
002E7Fr 2               console_print_dec:
002E7Fr 2  A5 rr                LDA     tmp0+1
002E81r 2  10 14                BPL     @positive
002E83r 2  A9 2D                LDA     #'-'
002E85r 2  A2 02                LDX     #PEM_CONOUT
002E87r 2  20 03 01             JSR     PEM_ENTRY
002E8Ar 2  A9 00                LDA     #0
002E8Cr 2  38                   SEC
002E8Dr 2  E5 rr                SBC     tmp0
002E8Fr 2  85 rr                STA     tmp0
002E91r 2  A9 00                LDA     #0
002E93r 2  E5 rr                SBC     tmp0+1
002E95r 2  85 rr                STA     tmp0+1
002E97r 2               @positive:
002E97r 2  A9 00                LDA     #0
002E99r 2  48                   PHA                     ; sentinel
002E9Ar 2               @div_loop:
002E9Ar 2  20 rr rr             JSR     div16_by10      ; quotient→tmp0, remainder→scratch
002E9Dr 2  A5 rr                LDA     scratch
002E9Fr 2  18                   CLC
002EA0r 2  69 30                ADC     #'0'
002EA2r 2  48                   PHA
002EA3r 2  A5 rr                LDA     tmp0
002EA5r 2  05 rr                ORA     tmp0+1
002EA7r 2  D0 F1                BNE     @div_loop
002EA9r 2               @print_loop:
002EA9r 2  68                   PLA
002EAAr 2  F0 07                BEQ     @done2          ; sentinel
002EACr 2  A2 02                LDX     #PEM_CONOUT
002EAEr 2  20 03 01             JSR     PEM_ENTRY
002EB1r 2  80 F6                BRA     @print_loop
002EB3r 2               @done2:
002EB3r 2  60                   RTS
002EB4r 2               
002EB4r 2               ; ---------------------------------------------------------------------------
002EB4r 2               ; div16_by10 — divide tmp0:tmp0+1 by 10
002EB4r 2               ; Result: quotient in tmp0:tmp0+1, remainder in scratch
002EB4r 2               ; ---------------------------------------------------------------------------
002EB4r 2               div16_by10:
002EB4r 2  A9 00                LDA     #0
002EB6r 2  85 rr                STA     scratch
002EB8r 2  A2 10                LDX     #16
002EBAr 2               @bit:
002EBAr 2  06 rr                ASL     tmp0
002EBCr 2  26 rr                ROL     tmp0+1
002EBEr 2  26 rr                ROL     scratch
002EC0r 2  A5 rr                LDA     scratch
002EC2r 2  C9 0A                CMP     #10
002EC4r 2  90 06                BCC     @no_sub
002EC6r 2  E9 0A                SBC     #10
002EC8r 2  85 rr                STA     scratch
002ECAr 2  E6 rr                INC     tmp0
002ECCr 2               @no_sub:
002ECCr 2  CA                   DEX
002ECDr 2  D0 EB                BNE     @bit
002ECFr 2  60                   RTS
002ED0r 2               
002ED0r 2               ; ---------------------------------------------------------------------------
002ED0r 2               ; console_read_line — read a line into buffer at tmp0, max len in x_save
002ED0r 2               ; Returns: Y = length (not including CR)
002ED0r 2               ; ---------------------------------------------------------------------------
002ED0r 2               console_read_line:
002ED0r 2  8E rr rr             STX     x_save
002ED3r 2  A0 00                LDY     #0
002ED5r 2               @loop:
002ED5r 2  A2 01                LDX     #PEM_CONIN
002ED7r 2  20 03 01             JSR     PEM_ENTRY
002EDAr 2  C9 0D                CMP     #$0D
002EDCr 2  F0 28                BEQ     @done
002EDEr 2  C9 08                CMP     #$08            ; backspace
002EE0r 2  D0 1C                BNE     @store
002EE2r 2  C0 00                CPY     #0
002EE4r 2  F0 EF                BEQ     @loop
002EE6r 2  88                   DEY
002EE7r 2  A9 08                LDA     #$08
002EE9r 2  A2 02                LDX     #PEM_CONOUT
002EEBr 2  20 03 01             JSR     PEM_ENTRY
002EEEr 2  A9 20                LDA     #' '
002EF0r 2  A2 02                LDX     #PEM_CONOUT
002EF2r 2  20 03 01             JSR     PEM_ENTRY
002EF5r 2  A9 08                LDA     #$08
002EF7r 2  A2 02                LDX     #PEM_CONOUT
002EF9r 2  20 03 01             JSR     PEM_ENTRY
002EFCr 2  80 D7                BRA     @loop
002EFEr 2               @store:
002EFEr 2  91 rr                STA     (tmp0),y
002F00r 2  C8                   INY
002F01r 2  CC rr rr             CPY     x_save
002F04r 2  90 CF                BCC     @loop
002F06r 2               @done:
002F06r 2  60                   RTS
002F07r 2               x_save:
002F07r 2  00                   .BYTE   0
002F08r 2               
002F08r 2               ; ---------------------------------------------------------------------------
002F08r 2               ; file_open — open file via FCB at tmp1; returns A=0 success, $FF=not found
002F08r 2               ; PEM calling convention: X=function, A=FCB addr lo, Y=FCB addr hi
002F08r 2               ; ---------------------------------------------------------------------------
002F08r 2               file_open:
002F08r 2  A5 rr                LDA     tmp1
002F0Ar 2  A4 rr                LDY     tmp1+1
002F0Cr 2  A2 0F                LDX     #PEM_OPEN
002F0Er 2  20 03 01             JSR     PEM_ENTRY
002F11r 2  60                   RTS
002F12r 2               
002F12r 2               ; ---------------------------------------------------------------------------
002F12r 2               ; file_make — create/truncate file via FCB at tmp1
002F12r 2               ; ---------------------------------------------------------------------------
002F12r 2               file_make:
002F12r 2  A5 rr                LDA     tmp1
002F14r 2  A4 rr                LDY     tmp1+1
002F16r 2  A2 16                LDX     #PEM_MAKE
002F18r 2  20 03 01             JSR     PEM_ENTRY
002F1Br 2  60                   RTS
002F1Cr 2               
002F1Cr 2               ; ---------------------------------------------------------------------------
002F1Cr 2               ; file_read_sector — read 128 bytes into DMA_BUF; returns A=0 ok, A=1 EOF
002F1Cr 2               ; ---------------------------------------------------------------------------
002F1Cr 2               file_read_sector:
002F1Cr 2  A5 rr                LDA     tmp1
002F1Er 2  A4 rr                LDY     tmp1+1
002F20r 2  A2 14                LDX     #PEM_READ
002F22r 2  20 03 01             JSR     PEM_ENTRY
002F25r 2  60                   RTS
002F26r 2               
002F26r 2               ; ---------------------------------------------------------------------------
002F26r 2               ; file_write_sector — write 128 bytes from DMA_BUF
002F26r 2               ; ---------------------------------------------------------------------------
002F26r 2               file_write_sector:
002F26r 2  A5 rr                LDA     tmp1
002F28r 2  A4 rr                LDY     tmp1+1
002F2Ar 2  A2 15                LDX     #PEM_WRITE
002F2Cr 2  20 03 01             JSR     PEM_ENTRY
002F2Fr 2  60                   RTS
002F30r 2               
002F30r 2               ; ---------------------------------------------------------------------------
002F30r 2               ; file_close — close FCB at tmp1
002F30r 2               ; ---------------------------------------------------------------------------
002F30r 2               file_close:
002F30r 2  A5 rr                LDA     tmp1
002F32r 2  A4 rr                LDY     tmp1+1
002F34r 2  A2 10                LDX     #PEM_CLOSE
002F36r 2  20 03 01             JSR     PEM_ENTRY
002F39r 2  60                   RTS
002F3Ar 2               
002F3Ar 2               ; ---------------------------------------------------------------------------
002F3Ar 2               ; file_setdma — point PEM at the 128-byte buffer at (A:Y)
002F3Ar 2               ; A = lo, Y = hi.  Trashes X.
002F3Ar 2               ; ---------------------------------------------------------------------------
002F3Ar 2               file_setdma:
002F3Ar 2  A2 1A                LDX     #PEM_SETDMA
002F3Cr 2  4C 03 01             JMP     PEM_ENTRY
002F3Fr 2               
002F3Fr 2               ; ---------------------------------------------------------------------------
002F3Fr 2               ; file_setdma_default — restore PEM DMA pointer to system DMA_BUF
002F3Fr 2               ; ---------------------------------------------------------------------------
002F3Fr 2               file_setdma_default:
002F3Fr 2  A9 28                LDA     #<DMA_BUF
002F41r 2  A0 01                LDY     #>DMA_BUF
002F43r 2  A2 1A                LDX     #PEM_SETDMA
002F45r 2  4C 03 01             JMP     PEM_ENTRY
