0018C5  1               LAB_COLD:
0018C5  1  A0 04                LDY     #PG2_TABE-PG2_TABS-1
0018C7  1               ; byte count-1
0018C7  1               LAB_2D13:
0018C7  1  B9 33 08             LDA     PG2_TABS,Y      ; get byte
0018CA  1  99 00 06             STA     ccflag,Y        ; store in page 2
0018CD  1  88                   DEY                     ; decrement count
0018CE  1  10 F7                BPL     LAB_2D13        ; loop if not done
0018D0  1               
0018D0  1  A2 FF                LDX     #$FF            ; set byte
0018D2  1  86 88                STX     Clineh          ; set current line high byte (set immediate mode)
0018D4  1               
0018D4  1  A9 4C                LDA     #$4C            ; code for JMP
0018D6  1  85 A1                STA     Fnxjmp          ; save for jump vector for functions
0018D8  1               
0018D8  1               ; copy block from LAB_2CEE to $00BC - $00D3
0018D8  1               
0018D8  1  A0 1D                LDY     #StrTab-LAB_2CEE; set byte count
0018DA  1               LAB_2D4E:
0018DA  1  BE 02 08             LDX     LAB_2CEE-1,Y    ; get byte from table
0018DD  1  96 BB                STX     LAB_IGBY-1,Y    ; save byte in page zero
0018DF  1  88                   DEY                     ; decrement count
0018E0  1  D0 F8                BNE     LAB_2D4E        ; loop if not all done
0018E2  1               
0018E2  1               ; copy block from StrTab to $0000 - $0012
0018E2  1               
0018E2  1               LAB_GMEM:
0018E2  1  A0 12                LDY     #EndTab-StrTab-1; set byte count-1
0018E4  1               TabLoop:
0018E4  1  BE 20 08             LDX     StrTab,Y        ; get byte from table
0018E7  1  96 00                STX     PLUS_0,Y        ; save byte in page zero
0018E9  1  88                   DEY                     ; decrement count
0018EA  1  10 F8                BPL     TabLoop         ; loop if not all done
