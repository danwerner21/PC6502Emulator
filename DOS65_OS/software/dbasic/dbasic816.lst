0010DD  2               ; Basic Screen editor code
0010DD  2               ;
0010DD  2               ;__________________________________________________________
0010DD  2               ScreenEditor:
0010DD  2               ; allow prepopulate of screen
0010DD  2               ploop:
0010DD  2                       LDA     #58
0010DD  2                       STA     farfunct
0010DD  2                       JSR     DO_FARCALL      ; PAINT cursor
0010DD  2               ploop1:
0010DD  2                       LDA     #20
0010DD  2                       STA     farfunct
0010DD  2                       JSR     DO_FARCALL      ; GET KEYSTROKE
0010DD  2                       CMP     #$FF
0010DD  2                       BEQ     ploop1
0010DD  2                       PHA
0010DD  2                       LDA     #59
0010DD  2                       STA     farfunct
0010DD  2                       JSR     DO_FARCALL      ; UNPAINT cursor
0010DD  2                       PLA
0010DD  2                       CMP     #$F0
0010DD  2                       BEQ     insert
0010DD  2                       CMP     #$F1
0010DD  2                       BEQ     delete
0010DD  2                       CMP     #$F6
0010DD  2                       BEQ     crsrup
0010DD  2                       CMP     #$F7
0010DD  2                       BEQ     crsrdn
0010DD  2                       CMP     #$F8
0010DD  2                       BEQ     crsrlt
0010DD  2                       CMP     #$F9
0010DD  2                       BEQ     Lcrsrrt
0010DD  2                       CMP     #$0A
0010DD  2                       BEQ     ploop
0010DD  2                       CMP     #13
0010DD  2                       BEQ     Lpexit
0010DD  2               
0010DD  2                       PHA
0010DD  2                       LDA     #19
0010DD  2                       STA     farfunct
0010DD  2                       PLA
0010DD  2                       JSR     DO_FARCALL
0010DD  2                       JMP     ploop
0010DD  2               Lpexit:
0010DD  2                       JMP     pexit
0010DD  2               Lcrsrrt:
0010DD  2                       JMP     crsrrt
0010DD  2               insert:
0010DD  2                       JMP     DOINSERT
0010DD  2               delete:
0010DD  2                       JMP     DODELETE
0010DD  2               crsrup:
0010DD  2                       LDA     CURY
0010DD  2                       CMP     #00
0010DD  2                       BEQ     ploop
0010DD  2                       DEC     CURY
0010DD  2                       JMP     ploop
0010DD  2               crsrdn:
0010DD  2                       LDA     CURY
0010DD  2                       CMP     #23
0010DD  2                       BEQ     crsrdn_1
0010DD  2                       INC     CURY
0010DD  2                       JMP     ploop
