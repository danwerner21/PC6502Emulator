0017FE  3               ;___V_SCRCLR________________________________________________
0017FE  3               ;
0017FE  3               ; CLEAR SCREEN
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_SCRCLR:
0017FE  3               V_SCNCLR:
0017FE  3                       STA     DBGA
0017FE  3                       STY     DBGY
0017FE  3                       STX     DBGX
0017FE  3                       LDA     #38
0017FE  3                       STA     farfunct
0017FE  3                       JSR     DO_FARCALL
0017FE  3                       LDA     #59
0017FE  3                       STA     farfunct
0017FE  3                       JSR     DO_FARCALL
0017FE  3                       LDA     DBGA
0017FE  3                       LDY     DBGY
0017FE  3                       LDX     DBGX
0017FE  3                       RTS
0017FE  3               
0017FE  3               
0017FE  3               
0017FE  3               ;___V_LOCATE________________________________________________
0017FE  3               ;
0017FE  3               ; SET CURSOR LOCATION
0017FE  3               ;
0017FE  3               ;       LOCATE X,Y
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               V_LOCATE:
0017FE  3               LAB_LOCATE:
0017FE  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (MODE)
0017FE  3                       STX     DBGX
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3                       TXA
0017FE  3                       TAY
0017FE  3                       LDX     DBGX
0017FE  3                       LDA     #37
0017FE  3                       STA     farfunct
0017FE  3                       JSR     DO_FARCALL
0017FE  3                       RTS
0017FE  3               
0017FE  3               ;___V_COLOR_________________________________________________
0017FE  3               ;
0017FE  3               ; SET COLOR FG,BG,CFG,CBG
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_COLOR:
0017FE  3               V_COLOR:
0017FE  3                       LDA     #$00            ; CLEAR TEMP SPACE
0017FE  3                       STA     PTEMPW
0017FE  3                       STA     PTEMPW+1
0017FE  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (MODE)
0017FE  3                       TXA
0017FE  3                       AND     #$0F
0017FE  3                       STA     PTEMPW
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3                       TXA
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ORA     PTEMPW
0017FE  3                       STA     PTEMPW
0017FE  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE THIRD PARAMETER, RETURN IN X
0017FE  3                       TXA
0017FE  3                       AND     #$0F
0017FE  3                       STA     PTEMPW+1
0017FE  3                       JSR     LAB_1C01        ; GET THE FOURTH PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE FOURTH PARAMETER, RETURN IN X
0017FE  3                       TXA
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ORA     PTEMPW+1
0017FE  3                       STA     PTEMPW+1
0017FE  3                       LDX     PTEMPW
0017FE  3                       LDY     PTEMPW+1
0017FE  3                       LDA     #39
0017FE  3                       STA     farfunct
0017FE  3                       JSR     DO_FARCALL
0017FE  3                       RTS
0017FE  3               
0017FE  3               
0017FE  3               
0017FE  3               ;___V_SPEEK()______________________________________________
0017FE  3               ;
0017FE  3               ; GET VALUE FROM SCREEN MEMORY
0017FE  3               ;
0017FE  3               ;  TAKES ONE PARAMETER (ADDRESS), RETURNS VALUE
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_SPEEK:
0017FE  3               V_SPEEK:
0017FE  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
0017FE  3                       LDA     Itemph
0017FE  3                       TAY
0017FE  3                       AND     #$0F
0017FE  3                       ORA     #$A0
0017FE  3                       STA     Itemph
0017FE  3                       TYA
0017FE  3                       AND     #$F0
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       AND     #$07
0017FE  3                       CLC
0017FE  3                       ADC     #VIDEOBANK
0017FE  3                       TAY
0017FE  3                       LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
0017FE  3                       LDX     #$0A            ; MAP $AXXX
0017FE  3                       JSR     SETPAGE         ; CALL SETPAGE
0017FE  3                       LDA     #$01
0017FE  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
0017FE  3                       LDY     #0
0017FE  3                       LDA     (Itempl),Y
0017FE  3                       TAY
0017FE  3                       LDA     #$00
0017FE  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
0017FE  3                       JMP     LAB_1FD0        ; convert Y to byte in FAC1 and return
0017FE  3               
0017FE  3               
0017FE  3               
0017FE  3               ;___V_SPOKE_________________________________________________
0017FE  3               ;
0017FE  3               ; PUT VALUE IN SCREEN MEMORY
0017FE  3               ;
0017FE  3               ;  TAKES TWO PARAMETERS ADDRESS,VALUE
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_SPOKE:
0017FE  3               V_SPOKE:
0017FE  3                       JSR     LAB_GADB        ; get two parameters for POKE or WAIT
0017FE  3                       TXA                     ; BYTE ARGUMENT IS IN X
0017FE  3                       PHA                     ; PUSH BYTE ARGUMENT TO STACK
0017FE  3                       LDA     Itemph
0017FE  3                       TAY
0017FE  3                       AND     #$0F
0017FE  3                       ORA     #$A0
0017FE  3                       STA     Itemph
0017FE  3                       TYA
0017FE  3                       AND     #$F0
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       AND     #$07
0017FE  3                       CLC
0017FE  3                       ADC     #VIDEOBANK
0017FE  3                       TAY
0017FE  3                       LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
0017FE  3                       LDX     #$0A            ; MAP $AXXX
0017FE  3                       JSR     SETPAGE         ; CALL SETPAGE
0017FE  3                       LDA     #$01
0017FE  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
0017FE  3                       LDY     #0
0017FE  3                       PLA                     ; PULL BYTE ARGUMENT
0017FE  3                       STA     (Itempl),Y
0017FE  3                       LDA     #$00
0017FE  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
0017FE  3                       RTS
0017FE  3               
0017FE  3               ;___V_SCREEN_________________________________________________
0017FE  3               ;
0017FE  3               ;  SET SCREEN MODE
0017FE  3               ;
0017FE  3               ;  TAKES UP TO THREE PARAMETERS
0017FE  3               ;  FIRST PARAMETER SCREEN MODE
0017FE  3               ;  0=TEXT MODE
0017FE  3               ;  1=LORES MODE
0017FE  3               ;  2=HIRES MODE
0017FE  3               ;
0017FE  3               ;  TEXT MODE PARAMETERS
0017FE  3               ;  0=40 COLUMNS
0017FE  3               ;  1=80 COLUMNS
0017FE  3               ;  2=40 COLUMNS Multicolor
0017FE  3               ;  3=80 COLUMNS Multicolor
0017FE  3               ;
0017FE  3               ;  LORES MODE SECOND PARAMETER
0017FE  3               ;  0=SINGLE LORES
0017FE  3               ;  1=DOUBLE LORES
0017FE  3               ;  LORES MODE THIRD PARAMETER
0017FE  3               ;  0=MIXED MODE
0017FE  3               ;  1=FULL SCREEN MODE
0017FE  3               ;
0017FE  3               ;  HIRES MODE SECOND PARAMETER
0017FE  3               ;  0=SINGLE HIRES
0017FE  3               ;  1=DOUBLE HIRES
0017FE  3               ;  2=QUAD HIRES
0017FE  3               ;  3=MONO HIRES
0017FE  3               ;  HIRES MODE THIRD PARAMETER
0017FE  3               ;  1=MIXED MODE
0017FE  3               ;  0=FULL SCREEN MODE
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_SCREEN:
0017FE  3               V_SCREEN:
0017FE  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (MODE)
0017FE  3               V_SCREEN1:
0017FE  3                       STX     VIDEOMODE
0017FE  3                       CPX     #00
0017FE  3                       BNE     *+5
0017FE  3                       JMP     SETUPMODE0
0017FE  3                       CPX     #01
0017FE  3                       BNE     *+5
0017FE  3                       JMP     SETUPMODE1
0017FE  3                       CPX     #02
0017FE  3                       BNE     *+5
0017FE  3                       JMP     SETUPMODE2
0017FE  3               
0017FE  3                       LDX     #$02            ; SYNTAX ERROR
0017FE  3                       JSR     LAB_XERR
0017FE  3                       JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
0017FE  3                       RTS
0017FE  3               
0017FE  3               SETUPMODE0:                     ; TEXT MODE
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoTextMode
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoLoresMode
0017FE  3                       STA     VideoHiresMode
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoMulticolor
0017FE  3                       JSR     PAGE_EXIT
0017FE  3               
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3                       CPX     #$00
0017FE  3                       BNE     SETUPMODE0_80
0017FE  3               SETUPMODE0_40:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$02
0017FE  3                       STA     Video80col
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     #40
0017FE  3                       STA     VIDEOWIDTH
0017FE  3                       LDA     #0
0017FE  3                       STA     BVIDEOMODE
0017FE  3                       JMP     SETUPMODE0_CLEAR
0017FE  3               SETUPMODE0_80:
0017FE  3                       CPX     #$01
0017FE  3                       BNE     SETUPMODE0_40C
0017FE  3               SETUPMODE0_80a:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     Video80col
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     #80
0017FE  3                       STA     VIDEOWIDTH
0017FE  3                       LDA     #1
0017FE  3                       STA     BVIDEOMODE
0017FE  3               SETUPMODE0_CLEAR:
0017FE  3                       JMP     V_SCNCLR
0017FE  3                       RTS
0017FE  3               SETUPMODE0_40C:
0017FE  3                       CPX     #$02
0017FE  3                       BNE     SETUPMODE0_80C
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoMulticolor
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JMP     SETUPMODE0_40
0017FE  3               SETUPMODE0_80C:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoMulticolor
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JMP     SETUPMODE0_80a
0017FE  3               
0017FE  3               SETUPMODE1:                     ; LORES MODE
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoLoresMode
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoTextMode
0017FE  3                       STA     VideoHiresMode
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3               
0017FE  3                       CPX     #$00
0017FE  3                       BNE     SETUPMODE1_DOUBLE
0017FE  3               
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoDoubleLores
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JMP     SETUPMODE1_CLEAR
0017FE  3               SETUPMODE1_DOUBLE:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoDoubleLores
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     #$11
0017FE  3                       STA     VIDEOMODE
0017FE  3               SETUPMODE1_CLEAR:               ;    ($2000-$2800)
0017FE  3                       LDY     #$02+VIDEOBANK  ; AREA $2000-$2FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$00
0017FE  3                       STA     TEMPW
0017FE  3                       LDA     #$A0
0017FE  3                       STA     TEMPW+1
0017FE  3                       LDY     #$00
0017FE  3                       LDA     #$00
0017FE  3               :
0017FE  3                       STA     (TEMPW),Y
0017FE  3                       INC     TEMPW
0017FE  3                       BNE     :-
0017FE  3                       INC     TEMPW+1
0017FE  3               
0017FE  3                       LDX     TEMPW+1
0017FE  3                       CPX     #$A8
0017FE  3                       BNE     :-
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE THIRD PARAMETER, RETURN IN X
0017FE  3                       CPX     #$00
0017FE  3                       BNE     SETUPMODE1_MIXED
0017FE  3               
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoMixedMode
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               SETUPMODE1_MIXED:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoMixedMode
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       ORA     #$80
0017FE  3                       STA     VIDEOMODE
0017FE  3                       RTS
0017FE  3               
0017FE  3               
0017FE  3               SETUPMODE2:                     ; HIRES MODE
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoHiresMode
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoTextMode
0017FE  3                       STA     VideoLoresMode
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3               
0017FE  3                       CPX     #$00
0017FE  3                       BNE     SETUPMODE2_DOUBLE
0017FE  3               
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoDoubleHires
0017FE  3                       STA     VideoQuadHires
0017FE  3                       STA     VideoMonoHires
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JMP     SETUPMODE2_CLEAR
0017FE  3               SETUPMODE2_DOUBLE:
0017FE  3                       CPX     #$01
0017FE  3                       BNE     SETUPMODE2_QUAD
0017FE  3               
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoDoubleHires
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoQuadHires
0017FE  3                       STA     VideoMonoHires
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     #$12
0017FE  3                       STA     VIDEOMODE
0017FE  3                       JMP     SETUPMODE2_CLEAR
0017FE  3               SETUPMODE2_QUAD:
0017FE  3                       CPX     #$02
0017FE  3                       BNE     SETUPMODE2_MONO
0017FE  3               
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoQuadHires
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoDoubleHires
0017FE  3                       STA     VideoMonoHires
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     #$22
0017FE  3                       STA     VIDEOMODE
0017FE  3                       JMP     SETUPMODE2_CLEAR
0017FE  3               SETUPMODE2_MONO:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoMonoHires
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoDoubleHires
0017FE  3                       STA     VideoQuadHires
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     #$32
0017FE  3                       STA     VIDEOMODE
0017FE  3               
0017FE  3               SETUPMODE2_CLEAR:               ; ($2000-$7FFF)
0017FE  3                       LDY     #$02+VIDEOBANK
0017FE  3                       STY     CLRTMP
0017FE  3               
0017FE  3               :
0017FE  3                       LDY     CLRTMP
0017FE  3                       JSR     PAGE_ENTER
0017FE  3               
0017FE  3                       LDA     #$00
0017FE  3                       TAY
0017FE  3                       STA     TEMPW
0017FE  3                       LDA     #$A0
0017FE  3                       STA     TEMPW+1
0017FE  3                       LDA     #$00
0017FE  3               :
0017FE  3                       STA     (TEMPW),Y
0017FE  3                       INC     TEMPW
0017FE  3                       BNE     :-
0017FE  3                       INC     TEMPW+1
0017FE  3                       LDX     TEMPW+1
0017FE  3                       CPX     #$B0
0017FE  3                       BNE     :-
0017FE  3                       LDX     #$A0
0017FE  3                       INC     CLRTMP
0017FE  3                       LDX     CLRTMP
0017FE  3                       CPX     #$00
0017FE  3                       BNE     :--
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE THIRD PARAMETER, RETURN IN X
0017FE  3                       CPX     #$00
0017FE  3                       BNE     SETUPMODE2_MIXED
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$02
0017FE  3                       STA     VideoMixedMode
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               SETUPMODE2_MIXED:
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     #$01
0017FE  3                       STA     VideoMixedMode
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       ORA     #$80
0017FE  3                       STA     VIDEOMODE
0017FE  3                       RTS
0017FE  3               
0017FE  3               
0017FE  3               
0017FE  3               PAGE_EXIT:
0017FE  3                       LDA     #$00
0017FE  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
0017FE  3                       RTS
0017FE  3               
0017FE  3               PAGE_ENTER:
0017FE  3               ; Set "Y" register to video page ($YXXX)
0017FE  3                       LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
0017FE  3                       LDX     #$0A            ; MAP $AXXX
0017FE  3                       JSR     SETPAGE         ; CALL SETPAGE
0017FE  3                       LDA     #$01
0017FE  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
0017FE  3                       RTS
0017FE  3               
0017FE  3               ;___V_PLOT__________________________________________________
0017FE  3               ;
0017FE  3               ;  PLOT ON SCREEN
0017FE  3               ;         TAKES THREE PARAMETERS,  X,Y,COLOR
0017FE  3               ;
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_PLOT:
0017FE  3               V_PLOT:
0017FE  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
0017FE  3                                               ; else do type mismatch
0017FE  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
0017FE  3                       LDA     Itemph
0017FE  3                       STA     PLOTX+1
0017FE  3                       LDA     Itempl
0017FE  3                       STA     PLOTX
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3                       STX     PLOTY           ; STORE IN PLOTY
0017FE  3                       LDA     #$00
0017FE  3                       STA     PLOTY+1
0017FE  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; RETURN IN X
0017FE  3                       STX     PLOTCOLOR
0017FE  3               DOPLOTXY:
0017FE  3                                               ; PARAMETERS PARSED, GO TO PROPER MODE CODE
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       AND     #$0F
0017FE  3                       CMP     #$01
0017FE  3                       BEQ     V_PLOT_LORES
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       AND     #$2F
0017FE  3                       CMP     #$02
0017FE  3                       BNE     :+
0017FE  3                       JMP     V_PLOT_HIRES_COLOR
0017FE  3               :
0017FE  3                       CMP     #$22
0017FE  3                       BNE     :+
0017FE  3                       JMP     V_PLOT_HIRES_MONO
0017FE  3               :
0017FE  3                       RTS
0017FE  3               
0017FE  3               V_PLOT_LORES:
0017FE  3                       LDA     PLOTY
0017FE  3                       PHA
0017FE  3                       LSR     A               ; 2 LINES PER BYTE
0017FE  3                       STA     PLOTY
0017FE  3                                               ; MULTIPLY Y (PTEMPW) COORD BY 40 OR 80 (SINGLE OR DOUBLE LORES)
0017FE  3                       CLC
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*4)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*8)
0017FE  3                       LDA     PLOTY
0017FE  3                       STA     PTEMPW
0017FE  3                       LDA     PLOTY+1
0017FE  3                       STA     PTEMPW+1        ; STORE Y*8 INTO PTEMPW
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*16)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*32)
0017FE  3               ; NOW TAKE Y*8(PTEMPW) + Y*32(PLOTY) == Y*40 STORE IN PLOTY
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3               
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     PLOTY           ; Store the low byte of the result
0017FE  3               
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PTEMPW+1        ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     PLOTY+1         ; Store the high byte of the result
0017FE  3               
0017FE  3               ; if double lores columns double it.
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       AND     #$10
0017FE  3                       CMP     #00
0017FE  3                       BEQ     :+
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2
0017FE  3               :
0017FE  3               ; OK, Y OFFSET IS IN PTEMPW1, X IS IN PTEMPW
0017FE  3                       LDA     #$A0            ; ADD THE MEMORY OFFSET TO PTEMPW (BECAUSE IT IS EASY)
0017FE  3                       STA     PLOTX+1         ; THEN ADD PTEMPW1 TO PTEMPW THAT SHOULD BE THE MEMORY ADDRESS TO UPDATE
0017FE  3                                               ;
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTX           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PLOTY           ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     TEMPW           ; Store the low byte of the result
0017FE  3               
0017FE  3                       LDA     PLOTX+1         ; Load the high byte of the first number
0017FE  3                       ADC     PLOTY+1         ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     TEMPW+1         ; Store the high byte of the result
0017FE  3                                               ; PTEMPW IS THE MEMORY OFFSET TO UPDATE
0017FE  3                       PLA
0017FE  3                       LSR     A               ; TOP OR BOTTOM PIXEL?
0017FE  3                       BCC     :+
0017FE  3                                               ; TOP PIXEL
0017FE  3                       LDY     #$02+VIDEOBANK  ; AREA $2000-$2FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDY     #$00
0017FE  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
0017FE  3                       AND     #$0F
0017FE  3                       PHA
0017FE  3                       LDA     PLOTCOLOR
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       STA     PLOTCOLOR
0017FE  3                       PLA
0017FE  3                       ORA     PLOTCOLOR
0017FE  3                       STA     (TEMPW),Y       ; STORE  DOUBLE PIXEL
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               :
0017FE  3                                               ; BOTTOM PIXEL
0017FE  3                       LDY     #$02+VIDEOBANK  ; AREA $2000-$2FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDY     #$00
0017FE  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
0017FE  3                       AND     #$F0
0017FE  3                       ORA     PLOTCOLOR
0017FE  3                       STA     (TEMPW),Y       ; STORE  DOUBLE PIXEL
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               
0017FE  3               V_PLOT_HIRES_COLOR:
0017FE  3                       LDA     PLOTX
0017FE  3                       PHA                     ; PUSH LOW BYTE OF X (FOR EVEN/ODD LATER)
0017FE  3                       LSR     PLOTX+1
0017FE  3                       ROR     PLOTX           ; 2 PIXEL PER BYTE
0017FE  3                       LDA     PLOTX           ;
0017FE  3                                               ; FIGURE THE BUFFER OFFSET
0017FE  3                       CLC                     ; MULTIPLY Y COORD BY 70 OR 140 (SINGLE OR DOUBLE HIRES)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2
0017FE  3                       LDA     PLOTY
0017FE  3                       STA     PTEMPW
0017FE  3                       LDA     PLOTY+1
0017FE  3                       STA     PTEMPW+1        ; STORE Y*2 INTO PTEMPW
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*4)
0017FE  3                       LDA     PLOTY
0017FE  3                       STA     PTEMPW1
0017FE  3                       LDA     PLOTY+1
0017FE  3                       STA     PTEMPW1+1       ; STORE Y*4 INTO PTEMPW1
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*8)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*16)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*32)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*64)
0017FE  3                                               ; RESULT OFFSET PLOTY = PLOTY(Y*64)+PTEMPW(Y*2)+PTEMPW1(Y*4)
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     PLOTY           ; Store the low byte of the result
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PTEMPW+1        ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     PLOTY+1         ; Store the high byte of the result
0017FE  3               
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     PLOTY           ; Store the low byte of the result
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     PLOTY+1         ; Store the high byte of the result
0017FE  3               
0017FE  3               ; if double hires double it.
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       AND     #$10
0017FE  3                       CMP     #00
0017FE  3                       BEQ     :+
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2
0017FE  3               :
0017FE  3               ; PLOTY IS NOW Y OFFSET, ADD X OFFSET FOR MEMORY ADDRESS INTO TEMPW
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PLOTX           ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     TEMPW           ; Store the low byte of the result
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PLOTX+1         ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     TEMPW+1         ; Store the high byte of the result
0017FE  3               
0017FE  3                       LDA     TEMPW+1         ; OK, LET'S CALCULATE THE BANK
0017FE  3                       AND     #$F0
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       CLC
0017FE  3                       ADC     #$02+VIDEOBANK  ; AREA $2000-?
0017FE  3                       CMP     #$F8
0017FE  3                       BCC     V_PLOT_HIRES_COLOR_RANGE
0017FE  3                       TAY                     ; VIDEO BANK SHOULD BE IN Y
0017FE  3                       JSR     PAGE_ENTER
0017FE  3               
0017FE  3                       LDA     TEMPW+1
0017FE  3                       AND     #$0F
0017FE  3                       ORA     #$A0
0017FE  3                       STA     TEMPW+1         ; TEMPW NOW REFLECTS MAPPED ADDRESSS
0017FE  3                       PLA
0017FE  3                       LSR     A               ; LEFT OR RIGHT PIXEL?
0017FE  3                       BCC     :+
0017FE  3                                               ; LEFT PIXEL
0017FE  3                       LDY     #$00
0017FE  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
0017FE  3                       AND     #$0F
0017FE  3                       PHA
0017FE  3                       LDA     PLOTCOLOR
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       ASL     A
0017FE  3                       STA     PLOTCOLOR
0017FE  3                       PLA
0017FE  3                       ORA     PLOTCOLOR
0017FE  3                       STA     (TEMPW),Y       ; WRITE THE PIXEL BACK OUT
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               :
0017FE  3               ; RIGHT PIXEL
0017FE  3                       LDY     #$00
0017FE  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
0017FE  3                       AND     #$F0
0017FE  3                       ORA     PLOTCOLOR
0017FE  3                       STA     (TEMPW),Y       ; WRITE THE PIXEL BACK OUT
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               
0017FE  3               V_PLOT_HIRES_COLOR_RANGE:
0017FE  3                       JMP     LAB_2564
0017FE  3               
0017FE  3               V_PLOT_HIRES_MONO:
0017FE  3                       LDA     PLOTX
0017FE  3                       PHA
0017FE  3                       LSR     PLOTX+1
0017FE  3                       ROR     PLOTX
0017FE  3                       LSR     PLOTX+1
0017FE  3                       ROR     PLOTX
0017FE  3                       LSR     PLOTX+1
0017FE  3                       ROR     PLOTX           ; 8 PIXEL PER BYTE
0017FE  3                       LDA     #00
0017FE  3                       STA     PLOTX+1
0017FE  3                       STA     PTEMPW1+1
0017FE  3                       LDA     PLOTY
0017FE  3                       STA     PTEMPW1
0017FE  3                                               ; MULTIPLY Y COORD BY 35 OR 70 (MONO OR QUAD HIRES)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2
0017FE  3                       LDA     PLOTY
0017FE  3                       STA     PTEMPW
0017FE  3                       LDA     PLOTY+1
0017FE  3                       STA     PTEMPW+1        ; STORE *2 INTO PTEMPW
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*4)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*8)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*16)
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2 (*32)
0017FE  3               ;
0017FE  3               ; PLOTY(Y*35) = PLOTY(Y*32)+PTEMPW(Y*2)+PTEMPW1(Y)
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     PLOTY           ; Store the low byte of the result
0017FE  3               
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PTEMPW+1        ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     PLOTY+1         ; Store the high byte of the result
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     PLOTY           ; Store the low byte of the result
0017FE  3               
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     PLOTY+1         ; Store the high byte of the result
0017FE  3               ;
0017FE  3               ; PLOTY IS NOW THE Y OFFSET
0017FE  3               ; if quad hires double it.
0017FE  3                       LDA     VIDEOMODE
0017FE  3                       AND     #$10
0017FE  3                       CMP     #00
0017FE  3                       BNE     :+
0017FE  3                       ASL     PLOTY
0017FE  3                       ROL     PLOTY+1         ; *2
0017FE  3               :
0017FE  3               ; ADD THE X OFFSET
0017FE  3                       CLC                     ; Clear the Carry flag before the first addition
0017FE  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
0017FE  3                       ADC     PLOTX           ; Add the low byte of the second number (plus carry)
0017FE  3                       STA     TEMPW           ; Store the low byte of the result
0017FE  3               
0017FE  3                       LDA     PLOTY+1         ; Load the high byte of the first number
0017FE  3                       ADC     PLOTX+1         ; Add the high byte of the second number (plus carry from previous op)
0017FE  3                       STA     TEMPW+1         ; Store the high byte of the result
0017FE  3                                               ; TEMPW IS NOW THE MEMORY ADDRESS
0017FE  3               
0017FE  3                       LDA     TEMPW+1         ; OK, LET'S CALCULATE THE BANK
0017FE  3                       AND     #$F0
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       LSR     A
0017FE  3                       CLC
0017FE  3                       ADC     #$02+VIDEOBANK  ; AREA $2000-?
0017FE  3                       CMP     #$F8
0017FE  3                       BCC     V_PLOT_HIRES_COLOR_RANGE1
0017FE  3                       TAY                     ; VIDEO BANK SHOULD BE IN Y
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       LDA     TEMPW+1
0017FE  3                       AND     #$0F
0017FE  3                       ORA     #$A0
0017FE  3                       STA     TEMPW+1         ; TEMPW NOW REFLECTS MAPPED ADDRESSS
0017FE  3                       PLA
0017FE  3                       AND     #$07            ; WHICH BIT?
0017FE  3                       TAX
0017FE  3                       LDA     PLOTCOLOR
0017FE  3                       CMP     #$01
0017FE  3                       BNE     :+
0017FE  3                       LDA     HIRES_BIT_LOOKUP_SET,X
0017FE  3                       LDY     #$00
0017FE  3                       ORA     (TEMPW),Y
0017FE  3                       STA     (TEMPW),Y
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               :
0017FE  3                       LDA     HIRES_BIT_LOOKUP_RESET,X
0017FE  3                       PHA
0017FE  3                       LDY     #$00
0017FE  3                       AND     (TEMPW),Y
0017FE  3                       STA     (TEMPW),Y
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               V_PLOT_HIRES_COLOR_RANGE1:
0017FE  3                       JMP     LAB_2564
0017FE  3               HIRES_BIT_LOOKUP_SET:
0017FE  3                       .BYTE   %10000000,%01000000,%00100000,%00010000,%00001000,%00000100,%00000010,%00000001
0017FE  3               HIRES_BIT_LOOKUP_RESET:
0017FE  3                       .BYTE   %01111111,%10111111,%11011111,%11101111,%11110111,%11111011,%11111101,%11111110
0017FE  3               
0017FE  3               ;___V_PATTERN________________________________________________
0017FE  3               ;
0017FE  3               ;  DEFINE GRAPHICS PATTERN
0017FE  3               ;
0017FE  3               ;  TAKES 10 PARAMETERS
0017FE  3               ;       PATTERN NUM (0-255)
0017FE  3               ;       PATTERN DATA (8 BYTES)
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_PATTERN
0017FE  3               V_PATTERN:
0017FE  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X
0017FE  3                       TXA
0017FE  3                       PHA
0017FE  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
0017FE  3                       JSR     PAGE_ENTER
0017FE  3                       PLA
0017FE  3                       STA     VideoCharGenOffset
0017FE  3                       LDY     #8
0017FE  3               :
0017FE  3                       TYA
0017FE  3                       PHA
0017FE  3                       JSR     LAB_1C01        ; GET THE NEXT PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE NEXT PARAMETER, RETURN IN X
0017FE  3                       PLA
0017FE  3                       TAY
0017FE  3                       TXA
0017FE  3                       STA     VideoCharGenData
0017FE  3                       DEY
0017FE  3                       CPY     #$00
0017FE  3                       BNE     :-
0017FE  3                       JSR     PAGE_EXIT
0017FE  3                       RTS
0017FE  3               
0017FE  3               ;___LAB_LINE_______________________________________________
0017FE  3               ;
0017FE  3               ;  DRAW LINE USING THE BRESENHAM LINE DRAWING ALGORITHM
0017FE  3               ;
0017FE  3               ;  TAKES 5 PARAMETERS
0017FE  3               ;       START X,Y
0017FE  3               ;       DESTINATION X,Y
0017FE  3               ;       COLOR
0017FE  3               ;__________________________________________________________
0017FE  3               LAB_LINE:
0017FE  3               ; GET X1
0017FE  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
0017FE  3                                               ; else do type mismatch
0017FE  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
0017FE  3                       LDA     Itemph
0017FE  3                       STA     LINEX1+1
0017FE  3                       LDA     Itempl
0017FE  3                       STA     LINEX1
0017FE  3                                               ; GET Y1
0017FE  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
0017FE  3                       STX     LINEY1          ; STORE IN LINEY1
0017FE  3               
0017FE  3               ; GET X2
0017FE  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
0017FE  3                                               ; else do type mismatch
0017FE  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
0017FE  3                       LDA     Itemph
0017FE  3                       STA     LINEX2+1
0017FE  3                       LDA     Itempl
0017FE  3                       STA     LINEX2
0017FE  3                                               ; GET Y2
0017FE  3                       JSR     LAB_1C01        ; GET THE FOURTH PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; RETURN IN X
0017FE  3                       STX     LINEY2          ; STORE IN LINEY2
0017FE  3                                               ; GET COLOR
0017FE  3                       JSR     LAB_1C01        ; GET THE FIFTH PARAMETER (AFTER ',') OR SYN ERR
0017FE  3                       JSR     LAB_GTBY        ; RETURN IN X
0017FE  3                       STX     LINECOLOR       ; STORE IN COLOR
0017FE  3                       LDA     #$00
0017FE  3                       STA     LINEY1+1
0017FE  3                       STA     LINEY2+1
0017FE  3                                               ; LINE COORDS AND COLOR STORED IN PROPER PLACE
0017FE  3                                               ; CALCULATE DELTAX
0017FE  3                       SEC                     ; Set Carry flag (represents "no borrow" for 1st byte)
0017FE  3                       LDA     LINEX1          ; Load low byte of number 1
0017FE  3                       SBC     LINEX2          ; Subtract low byte of number 2 with carry
0017FE  3                       STA     DELTAX          ; Store result low byte
0017FE  3                       LDA     LINEX1+1        ; Load high byte of number 1
0017FE  3                       SBC     LINEX2+1        ; Subtract high byte of number 2 with borrow
0017FE  3                       STA     DELTAX+1        ; Store result high byte
0017FE  3                       BCS     :+              ; BRANCH IF X1>=X2
0017FE  3                                               ; X1 < X2
0017FE  3                       LDA     #0
0017FE  3                       STA     PTEMP           ; IF X2>X1 (PTEMP=x0)
0017FE  3                       LDA     #$FF            ; TAKE ABSOLUTE VALUE OF DELTAX
0017FE  3                       EOR     DELTAX+1        ; Invert high byte (one's complement)
0017FE  3                       STA     DELTAX+1
0017FE  3                       LDA     #$FF            ;
0017FE  3                       EOR     DELTAX          ; Invert low byte
0017FE  3                       STA     DELTAX          ;
0017FE  3                       INC     DELTAX          ; Add 1 to the low byte
0017FE  3                       BNE     :++             ; If no carry from low byte INC, we are done
0017FE  3                       INC     DELTAX+1        ; Increment high byte if carry occurred
0017FE  3                       JMP     :++
0017FE  3               :
0017FE  3                       LDA     #1
0017FE  3                       STA     PTEMP           ; IF X1>X2 (PTEMP=x1)
0017FE  3               :
0017FE  3                                               ; CALCULATE DELTAY
0017FE  3                       LDA     #0
0017FE  3                       STA     DELTAY+1
0017FE  3                       SEC                     ; Set Carry flag
0017FE  3                       LDA     LINEY1          ; Load low byte of number 1
0017FE  3                       SBC     LINEY2          ; Subtract low byte of number 2 with carry
0017FE  3                       STA     DELTAY          ; Store result low byte
0017FE  3                       BCS     :+              ; BRANCH IF Y1>=Y2
0017FE  3                                               ; Y1 < Y2
0017FE  3                       LDA     PTEMP
0017FE  3                       AND     #1
0017FE  3                       STA     PTEMP           ; IF Y2>Y1 (PTEMP=0x)
0017FE  3                                               ; TAKE ABSOLUTE VALUE OF DELTAY
0017FE  3                       LDA     #$FF
0017FE  3                       EOR     DELTAY          ; Flip all bits (one's complement)
0017FE  3                       STA     DELTAY
0017FE  3                       INC     DELTAY          ; Add 1 (two's complement)
0017FE  3                       JMP     :++
0017FE  3               :
0017FE  3                       LDA     PTEMP
0017FE  3                       ORA     #$10
0017FE  3                       STA     PTEMP           ; IF Y1>Y2 (PTEMP=1x)
0017FE  3               :
0017FE  3                                               ; SLOPE DETERMINED, AND DELTAS CALCULATED
0017FE  3                                               ; OK, LET'S FIND OUT IF THIS IS A HORIZONTAL-ISH
0017FE  3                                               ; OR VERTICAL-ISH LINE
0017FE  3                       SEC                     ; Set Carry Flag (for subtraction)
0017FE  3                       LDA     DELTAX          ; Load low byte of DELTAX
0017FE  3                       SBC     DELTAY          ; Subtract low byte of DELTAY
0017FE  3                       LDA     DELTAX+1        ; Load high byte of DELTAX
0017FE  3                       SBC     DELTAY+1        ; Subtract high byte of DELTAY (with borrow)
0017FE  3                                               ; Flags now reflect the 16-bit comparison
0017FE  3                       BCC     LINEVERT        ; If Carry clear, LINE IS VERTICAL-ISH
0017FE  3                       JMP     LINEHORZ
0017FE  3               LINEVERT:
0017FE  3                                               ; FOR A VERTICAL-ISH LINE WE STEP ALONG THE
0017FE  3                                               ; Y AXIS (STEEP GRADIENT)
0017FE  3                                               ; FIND LARGER Y . . .
0017FE  3                       LDA     LINEY1
0017FE  3                       CMP     LINEY2
0017FE  3                       BCS     :+
0017FE  3                       JSR     LINESWAPXY
0017FE  3               :
0017FE  3                                               ; Initialize error = DELTAY / 2
0017FE  3                       LDA     DELTAY
0017FE  3                       STA     LINEERR
0017FE  3                       LDA     DELTAY+1
0017FE  3                       STA     LINEERR+1
0017FE  3                       LSR     LINEERR+1
0017FE  3                       ROR     LINEERR
0017FE  3               LINEVERTLOOP:
0017FE  3                       LDA     LINEY1          ; OK LET'S PLOT A POINT
0017FE  3                       STA     PLOTY
0017FE  3                       LDA     LINEY1+1
0017FE  3                       STA     PLOTY+1
0017FE  3                       LDA     LINEX1
0017FE  3                       STA     PLOTX
0017FE  3                       LDA     LINEX1+1
0017FE  3                       STA     PLOTX+1
0017FE  3                       LDA     LINECOLOR
0017FE  3                       STA     PLOTCOLOR
0017FE  3                       JSR     DOPLOTXY
0017FE  3                                               ; NOW MOVE LINE1 CLOSER TO LINE2
0017FE  3                       DEC     LINEY1          ; BY STEPPING ALONG Y AXIS
0017FE  3               
0017FE  3               ; BRESENHAM: err -= DELTAX
0017FE  3                       SEC
0017FE  3                       LDA     LINEERR
0017FE  3                       SBC     DELTAX
0017FE  3                       STA     LINEERR
0017FE  3                       LDA     LINEERR+1
0017FE  3                       SBC     DELTAX+1
0017FE  3                       STA     LINEERR+1
0017FE  3                       BPL     LINEVERT_NOSTEP ; IF ERR >= 0, NO X STEP NEEDED
0017FE  3                                               ; ERR += DELTAY (RESTORE ERROR)
0017FE  3                       CLC
0017FE  3                       LDA     LINEERR
0017FE  3                       ADC     DELTAY
0017FE  3                       STA     LINEERR
0017FE  3                       LDA     LINEERR+1
0017FE  3                       ADC     DELTAY+1
0017FE  3                       STA     LINEERR+1
0017FE  3                                               ; STEP X TOWARD X2 (16-BIT)
0017FE  3                       LDA     LINEX2
0017FE  3                       CMP     LINEX1
0017FE  3                       LDA     LINEX2+1
0017FE  3                       SBC     LINEX1+1
0017FE  3                       BCC     LINEVERT_DECX   ; X2 < X1, DECREMENT X1
0017FE  3                       INC     LINEX1          ; X2 >= X1, INCREMENT X1
0017FE  3                       BNE     LINEVERT_NOSTEP
0017FE  3                       INC     LINEX1+1
0017FE  3                       JMP     LINEVERT_NOSTEP
0017FE  3               LINEVERT_DECX:
0017FE  3                       LDA     LINEX1
0017FE  3                       BNE     :+
0017FE  3                       DEC     LINEX1+1
0017FE  3               :
0017FE  3                       DEC     LINEX1
0017FE  3               LINEVERT_NOSTEP:
0017FE  3               
0017FE  3                       LDA     LINEY1
0017FE  3                       CMP     LINEY2
0017FE  3                       BNE     LINEVERTLOOP
0017FE  3                       RTS                     ; DONE
0017FE  3               
0017FE  3               LINEHORZ:
0017FE  3               ; FOR A HORIZONTAL-ISH LINE WE STEP ALONG THE
0017FE  3               ; X AXIS (SHALLOW GRADIENT)
0017FE  3               ; FIND LARGER X . . .
0017FE  3                       SEC                     ; Set carry flag for subtraction
0017FE  3                       LDA     LINEX2          ; Load low byte of first number
0017FE  3                       SBC     LINEX1          ; Subtract low byte of second number
0017FE  3                       LDA     LINEX2+1        ; Load high byte of first number
0017FE  3                       SBC     LINEX1+1        ; Subtract high byte of second number
0017FE  3                                               ; Result flags (N, Z, C) now reflect: Val1 - Val2
0017FE  3                       BCS     :+              ; If carry is set, LINEX2 >= LINEX1
0017FE  3                       JSR     LINESWAPXY
0017FE  3               :
0017FE  3                                               ; Initialize error = DELTAX / 2
0017FE  3                       LDA     DELTAX
0017FE  3                       STA     LINEERR
0017FE  3                       LDA     DELTAX+1
0017FE  3                       STA     LINEERR+1
0017FE  3                       LSR     LINEERR+1
0017FE  3                       ROR     LINEERR
0017FE  3               LINEHORZLOOP:
0017FE  3                       LDA     LINEY1          ; OK LET'S PLOT A POINT
0017FE  3                       STA     PLOTY
0017FE  3                       LDA     LINEY1+1
0017FE  3                       STA     PLOTY+1
0017FE  3                       LDA     LINEX1
0017FE  3                       STA     PLOTX
0017FE  3                       LDA     LINEX1+1
0017FE  3                       STA     PLOTX+1
0017FE  3                       LDA     LINECOLOR
0017FE  3                       STA     PLOTCOLOR
0017FE  3                       JSR     DOPLOTXY
0017FE  3                                               ; NOW MOVE LINE1 CLOSER TO LINE2
0017FE  3                       INC     LINEX1          ; BY STEPPING ALONG X AXIS
0017FE  3                       BNE     :+
0017FE  3                       INC     LINEX1+1
0017FE  3               :
0017FE  3                                               ; BRESENHAM: err -= DELTAY
0017FE  3                       SEC
0017FE  3                       LDA     LINEERR
0017FE  3                       SBC     DELTAY
0017FE  3                       STA     LINEERR
0017FE  3                       LDA     LINEERR+1
0017FE  3                       SBC     DELTAY+1
0017FE  3                       STA     LINEERR+1
0017FE  3                       BPL     LINEHORZ_NOSTEP ; IF ERR >= 0, NO Y STEP NEEDED
0017FE  3                                               ; ERR += DELTAX (RESTORE ERROR)
0017FE  3                       CLC
0017FE  3                       LDA     LINEERR
0017FE  3                       ADC     DELTAX
0017FE  3                       STA     LINEERR
0017FE  3                       LDA     LINEERR+1
0017FE  3                       ADC     DELTAX+1
0017FE  3                       STA     LINEERR+1
0017FE  3                                               ; STEP Y TOWARD Y2
0017FE  3                       LDA     LINEY2
0017FE  3                       CMP     LINEY1
0017FE  3                       BCC     LINEHORZ_DECY   ; Y2 < Y1, DECREMENT
0017FE  3                       INC     LINEY1          ; Y2 >= Y1, INCREMENT
0017FE  3                       JMP     LINEHORZ_NOSTEP
0017FE  3               LINEHORZ_DECY:
0017FE  3                       DEC     LINEY1
0017FE  3               LINEHORZ_NOSTEP:
0017FE  3               
0017FE  3                       LDA     LINEX1
0017FE  3                       CMP     LINEX2
0017FE  3                       BNE     LINEHORZLOOP
0017FE  3                       LDA     LINEX1+1
0017FE  3                       CMP     LINEX2+1
0017FE  3                       BNE     LINEHORZLOOP
0017FE  3                       RTS                     ; DONE
0017FE  3               
0017FE  3               LINESWAPXY:
0017FE  3                       LDA     LINEX1
0017FE  3                       LDY     LINEX2
0017FE  3                       STY     LINEX1
0017FE  3                       STA     LINEX2
0017FE  3                       LDA     LINEX1+1
0017FE  3                       LDY     LINEX2+1
0017FE  3                       STY     LINEX1+1
0017FE  3                       STA     LINEX2+1
0017FE  3               ;
0017FE  3                       LDA     LINEY1
0017FE  3                       LDY     LINEY2
0017FE  3                       STY     LINEY1
0017FE  3                       STA     LINEY2
0017FE  3                       LDA     LINEY1+1
0017FE  3                       LDY     LINEY2+1
0017FE  3                       STY     LINEY1+1
0017FE  3                       STA     LINEY2+1
0017FE  3                       RTS
0017FE  3                       .ELSE
