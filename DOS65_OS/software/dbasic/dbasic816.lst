0010DE  2  A9 01                LDA     #$01
0010E0  2  8D 84 10             STA     printflag
0010E3  2  28                   PLP
0010E4  2  20 A0 22             JSR     LAB_PRINT
0010E7  2  A9 00                LDA     #$00
0010E9  2  8D 84 10             STA     printflag
0010EC  2  60                   RTS
0010ED  2               V_LLIST:
0010ED  2  08                   PHP
0010EE  2  A9 01                LDA     #$01
0010F0  2  8D 84 10             STA     printflag
0010F3  2  28                   PLP
0010F4  2  20 0C 1D             JSR     LAB_LIST
0010F7  2  A9 00                LDA     #$00
0010F9  2  8D 84 10             STA     printflag
0010FC  2  60                   RTS
