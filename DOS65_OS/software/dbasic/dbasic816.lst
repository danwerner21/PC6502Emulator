0010DD  2                       LDA     Ibuffs,X
0010DD  2                       CMP     #32
0010DD  2                       BEQ     TERMLOOP_B
0010DD  2                       CMP     #00
0010DD  2                       BEQ     TERMLOOP_C
0010DD  2                       JMP     TERMLOOP_A
0010DD  2               TERMLOOP_B:
0010DD  2                       LDA     #00
0010DD  2                       STA     Ibuffs,X
