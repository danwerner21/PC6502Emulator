0010FD  2               UART1STATUS     = $EF85         ; SERIAL PORT 1 (I/O Card)
0010FD  2               UART1COMMAND    = $EF86         ; SERIAL PORT 1 (I/O Card)
0010FD  2               UART1CONTROL    = $EF87         ; SERIAL PORT 1 (I/O Card)
