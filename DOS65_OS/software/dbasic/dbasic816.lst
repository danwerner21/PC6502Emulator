000E15  1               ; DEFINITIONS
000E15  1                       .INCLUDE "definitions.asm"
000E15  2                       .IFDEF  DUODYNE
000E15  2               STACK_BOTTOM    = $4000         ; stack bottom, no offset
000E15  2               STACK           = $5FFF         ; stack top, no offset
000E15  2               Ram_top         = $D000         ; end of user RAM+1 (set as needed, should be page aligned)
000E15  2                       .ELSE
000E15  2               Ram_top         = $B800         ; end of user RAM+1 (set as needed, should be page aligned)
000E15  2                       .ENDIF
000E15  2               
000E15  2               SETPAGE         = $FFF6
000E15  2               DO_FARCALL      = $FFF0
000E15  2               farfunct        = $32           ; function to call in driver area
000E15  2               
000E15  2               ; offsets from a base of X or Y
000E15  2               PLUS_0          = $00           ; X or Y plus 0
000E15  2               PLUS_1          = $01           ; X or Y plus 1
000E15  2               PLUS_2          = $02           ; X or Y plus 2
000E15  2               PLUS_3          = $03           ; X or Y plus 3
000E15  2               
000E15  2               LAB_STAK        = $0100         ; stack bottom, no offset
000E15  2               
000E15  2               LAB_SKFE        = LAB_STAK+$FE
000E15  2               ; flushed stack address
000E15  2               LAB_SKFF        = LAB_STAK+$FF
000E15  2               ; flushed stack address
000E15  2               
000E15  2               ccflag          = $0600         ; BASIC CTRL-C flag, 00 = enabled, 01 = dis
000E15  2               ccbyte          = ccflag+1      ; BASIC CTRL-C byte
000E15  2               ccnull          = ccbyte+1      ; BASIC CTRL-C byte timeout
000E15  2               
000E15  2               VEC_CC          = ccnull+1      ; ctrl c check vector
000E15  2               
000E15  2               ; Ibuffs can now be anywhere in RAM AS LONG AS IT IS BEFORE RAM_BASE AND IS NOT PAGE ALIGNED!, ensure that the max length is < $80
000E15  2               Ibuffs          = (ENDOFBASIC&$FF00)+$181
000E15  2               Ibuffe          = Ibuffs+81     ; end of input buffer
000E15  2               Ram_base        = (Ibuffe&$FF00)+$100; start of user RAM (set as needed, should be page aligned)
000E15  2               
