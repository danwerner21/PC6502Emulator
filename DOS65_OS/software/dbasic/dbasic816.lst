0010FD  2               PRINT_CRLF:
0010FD  2  8E 6B 11             STX     TTX
001100  2  8C 6C 11             STY     TTY
001103  2  8D 6D 11             STA     TTA
001106  2  A9 0D                LDA     #13
001108  2  20 6E 11             JSR     WRSER1          ; output upper nybble
00110B  2  A9 0A                LDA     #10
00110D  2  20 6E 11             JSR     WRSER1          ; output upper nybble
001110  2  AE 6B 11             LDX     TTX
001113  2  AC 6C 11             LDY     TTY
001116  2  AD 6D 11             LDA     TTA
001119  2  60                   RTS
00111A  2               
00111A  2               PRINT_SPACE:
00111A  2  8E 6B 11             STX     TTX
00111D  2  8C 6C 11             STY     TTY
001120  2  8D 6D 11             STA     TTA
001123  2  A9 20                LDA     #32
001125  2  20 6E 11             JSR     WRSER1          ; output upper nybble
001128  2  AE 6B 11             LDX     TTX
00112B  2  AC 6C 11             LDY     TTY
00112E  2  AD 6D 11             LDA     TTA
001131  2  60                   RTS
001132  2               
001132  2               
001132  2               PRINT_BYTE:
001132  2  8E 6B 11             STX     TTX
001135  2  8C 6C 11             STY     TTY
001138  2  8D 6D 11             STA     TTA
00113B  2  8E 6A 11             STX     SAVX            ; save X
00113E  2  20 55 11             JSR     ASCTWO          ; get hex chars for byte in X (lower) and A (upper)
001141  2  20 6E 11             JSR     WRSER1          ; output upper nybble
001144  2  8A                   TXA                     ; transfer lower to A
001145  2  AE 6A 11             LDX     SAVX            ; restore X
001148  2  20 6E 11             JSR     WRSER1          ; output lower nybble
00114B  2  AE 6B 11             LDX     TTX
00114E  2  AC 6C 11             LDY     TTY
001151  2  AD 6D 11             LDA     TTA
001154  2  60                   RTS
001155  2               ASCTWO:
001155  2  48                   PHA                     ; save byte
001156  2  20 5F 11             JSR     ASCII           ; do low nybble
001159  2  AA                   TAX                     ; save in X
00115A  2  68                   PLA                     ; restore byte
00115B  2  4A                   LSR     A               ; shift upper nybble down
00115C  2  4A                   LSR     A
00115D  2  4A                   LSR     A
00115E  2  4A                   LSR     A
00115F  2               ; convert low nybble in A to hex digit
00115F  2               ASCII:
00115F  2  29 0F                AND     #$0F            ; clear upper nibble
001161  2  C9 0A                CMP     #$0A            ; if less than A, skip next step
001163  2  90 02                BCC     ASC1
001165  2  69 06                ADC     #6              ; skip ascii chars between 9 and A
001167  2               ASC1:
001167  2  69 30                ADC     #$30            ; add ascii char 0 to value
001169  2  60                   RTS
00116A  2               SAVX:
00116A  2  00                   .BYTE   00
00116B  2               TTX:
00116B  2  00                   .BYTE   00
00116C  2               TTY:
00116C  2  00                   .BYTE   00
00116D  2               TTA:
00116D  2  00                   .BYTE   00
00116E  2               ;__WRSER1________________________________________________________________________________________________________________________
00116E  2               ;
00116E  2               ;	WRITE CHARACTER(A) TO UART
00116E  2               ;________________________________________________________________________________________________________________________________
00116E  2               ;
00116E  2               WRSER1:
00116E  2  48                   PHA
00116F  2               WRSER1a:
00116F  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS
001172  2  29 10                AND     #%00010000      ; IS TX READY
001174  2  F0 F9                BEQ     WRSER1a         ; NO, WAIT FOR IT
001176  2  68                   PLA
001177  2  8D 84 EF             STA     UART1DATA       ; WRITE DATA
00117A  2  60                   RTS
