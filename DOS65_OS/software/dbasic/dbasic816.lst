001186  3               ;___SAVE____________________________________________________
001186  3               ;
001186  3               ; SAVE COMMAND
001186  3               ;
001186  3               ;  SAVE THE BASIC PROGRAM IN MEMORY TO DISK
001186  3               ;
001186  3               ;__________________________________________________________
001186  3               V_SAVE: ; save BASIC program
001186  3               DOS65SAVE:
001186  3  20 F9 12             JSR     DOS65FCBPREP    ; parse parameters into FCB
001189  3  B0 28                BCS     DOS65SAVE_ERR1  ; Error?, if so abort
00118B  3  A2 0D                LDX     #13             ;
00118D  3  20 80 11             JSR     PEM             ;
001190  3  A9 BC                LDA     #<FCB           ; CREATE File
001192  3  A0 17                LDY     #>FCB           ;
001194  3  A2 16                LDX     #22             ;
001196  3  20 80 11             JSR     PEM             ;
001199  3  A9 00                LDA     #0              ; clear
00119B  3  8D DC 17             STA     FCB+32          ; record number
00119E  3  A9 BC                LDA     #<FCB           ; Open File
0011A0  3  A0 17                LDY     #>FCB           ;
0011A2  3  A2 0F                LDX     #15             ;
0011A4  3  20 80 11             JSR     PEM             ;
0011A7  3  C9 FF                CMP     #$FF            ; error?, if NOT, continue
0011A9  3  D0 0B                BNE     DOS65SAVE_1     ;
0011AB  3               DOS65SAVE_ERR:
0011AB  3  A2 24                LDX     #$24            ; IO ERROR
0011AD  3  20 9C 1A             JSR     LAB_XERR
0011B0  3  4C 78 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
0011B3  3               DOS65SAVE_ERR1:
0011B3  3  4C AA 20             JMP     LAB_REM         ; comment out the remainder of the line (if any)
0011B6  3               DOS65SAVE_1:
0011B6  3  A9 32                LDA     #<FCBBUFFER     ; SETUP BUFFER
0011B8  3  85 20                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
0011BA  3  A0 41                LDY     #>FCBBUFFER     ;
0011BC  3  84 21                STY     FCBPTR+1        ;
0011BE  3  A2 1A                LDX     #26             ; Setup Buffer
0011C0  3  20 80 11             JSR     PEM             ;
0011C3  3               DOS65SAVE_2:
0011C3  3  A5 79                LDA     <Smeml          ; All is well, file opened and continue
0011C5  3  85 22                STA     FCBPTR+2        ; point to base of RAM
0011C7  3  A5 7A                LDA     <Smemh          ;
0011C9  3  85 23                STA     FCBPTR+3        ;
0011CB  3  A2 00                LDX     #$00            ; x=0 (null counter)
0011CD  3               DOS65SAVE_2A:
0011CD  3  A0 00                LDY     #$00            ; y=0 (Loop Index)
0011CF  3               DOS65SAVE_3:
0011CF  3  B1 22                LDA     (FCBPTR+2),Y    ; load from RAM
0011D1  3  91 20                STA     (FCBPTR),Y      ; save to Buffer
0011D3  3  C9 00                CMP     #$00            ; is Zero?
0011D5  3  D0 1E                BNE     DOS65SAVE_3A    ; No, continue
0011D7  3  E8                   INX                     ; yes, bump Null Counter
0011D8  3  E0 03                CPX     #$03            ; Three nulls in a row?
0011DA  3  D0 1B                BNE     DOS65SAVE_3B    ; No, continue
0011DC  3                                               ; FINISH FILLING BUFFER WITH NULLS
0011DC  3               :
0011DC  3  91 20                STA     (FCBPTR),Y      ; save to Buffer
0011DE  3  C8                   INY                     ; bump index
0011DF  3  C0 80                CPY     #$80            ; end of buffer?
0011E1  3  D0 F9                BNE     :-              ; no, loop
0011E3  3  A9 BC                LDA     #<FCB           ; Write record in buffer to disk file AND END
0011E5  3  A0 17                LDY     #>FCB           ;
0011E7  3  A2 15                LDX     #21             ;
0011E9  3  20 80 11             JSR     PEM             ;
0011EC  3  29 FE                AND     #$FE            ; strip out extension
0011EE  3  C9 00                CMP     #$00            ; is error
0011F0  3  D0 B9                BNE     DOS65SAVE_ERR   ; ERROR, do error handling
0011F2  3  4C 22 12             JMP     DOS65SAVE_4
0011F5  3               DOS65SAVE_3A:                   ;
0011F5  3  A2 00                LDX     #$00            ; prior char not null, reset null counter
0011F7  3               DOS65SAVE_3B:                   ;
0011F7  3  C8                   INY                     ; bump index
0011F8  3  C0 80                CPY     #$80            ; end of buffer?
0011FA  3  D0 D3                BNE     DOS65SAVE_3     ; no, loop
0011FC  3               DOS65SAVE_3C:
0011FC  3  A9 BC                LDA     #<FCB           ; Write record in buffer to disk file
0011FE  3  A0 17                LDY     #>FCB           ;
001200  3  A2 15                LDX     #21             ;
001202  3  20 80 11             JSR     PEM             ;
001205  3  29 FE                AND     #$FE            ; strip out extension
001207  3  C9 00                CMP     #$00            ; is error
001209  3  D0 A0                BNE     DOS65SAVE_ERR   ; ERROR, do error handling
00120B  3  18                   CLC                     ;
00120C  3  A5 22                LDA     FCBPTR+2        ; add $80 to base counter
00120E  3  69 80                ADC     #$80            ;
001210  3  85 22                STA     FCBPTR+2        ;
001212  3  90 B9                BCC     DOS65SAVE_2A    ; is carry?, no loop
001214  3  18                   CLC                     ; yes, carry, inc high byte
001215  3  A5 23                LDA     FCBPTR+3        ;
001217  3  69 01                ADC     #$01            ;
001219  3  85 23                STA     FCBPTR+3        ;
00121B  3  C9 D0                CMP     #>Ram_top       ; are we at the end of RAM?
00121D  3  F0 03                BEQ     DOS65SAVE_4
00121F  3  4C CD 11             JMP     DOS65SAVE_2A
001222  3               DOS65SAVE_4:
001222  3  A9 BC                LDA     #<FCB           ;
001224  3  A0 17                LDY     #>FCB           ;
001226  3  A2 10                LDX     #16             ;
001228  3  20 80 11             JSR     PEM             ;
00122B  3  C9 FF                CMP     #$FF            ;
00122D  3  D0 03                BNE     DOS65SAVE_5     ;
00122F  3  4C AB 11             JMP     DOS65SAVE_ERR   ; ERROR, DISPLAY IT
001232  3               DOS65SAVE_5:
001232  3  A9 AB                LDA     #<LAB_RMSG      ; point to "Ready" message low byte
001234  3  A0 0F                LDY     #>LAB_RMSG      ; point to "Ready" message high byte
001236  3  20 3B 23             JSR     LAB_18C3
001239  3  4C 78 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
00123C  3               
00123C  3               ;___LOAD____________________________________________________
00123C  3               ;
00123C  3               ; LOAD COMMAND
00123C  3               ;
00123C  3               ;  LOAD A BASIC PROGRAM FROM DISK TO MEMORY
00123C  3               ;
00123C  3               ;__________________________________________________________
00123C  3               V_LOAD: ; load BASIC program
00123C  3               DOS65LOAD:
00123C  3  A9 00                LDA     #$00
00123E  3  8D 68 13             STA     NullCounter
001241  3  20 F9 12             JSR     DOS65FCBPREP    ; parse parameters into FCB
001244  3  B0 1F                BCS     DOS65LOAD_ERR1  ; Error?, if so abort
001246  3  A2 0D                LDX     #13             ;
001248  3  20 80 11             JSR     PEM             ;
00124B  3  A9 00                LDA     #0              ; clear
00124D  3  8D DC 17             STA     FCB+32          ; record number
001250  3  A9 BC                LDA     #<FCB           ; Open File
001252  3  A0 17                LDY     #>FCB           ;
001254  3  A2 0F                LDX     #15             ;
001256  3  20 80 11             JSR     PEM             ;
001259  3  C9 FF                CMP     #$FF            ; error?, if NOT, continue
00125B  3  D0 0B                BNE     DOS65LOAD_1     ;
00125D  3               DOS65LOAD_ERR:
00125D  3  A2 24                LDX     #$24            ; IO ERROR
00125F  3  20 9C 1A             JSR     LAB_XERR
001262  3  4C 78 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
001265  3               DOS65LOAD_ERR1:
001265  3  4C AA 20             JMP     LAB_REM         ; comment out the remainder of the line (if any)
001268  3               DOS65LOAD_1:
001268  3  A5 79                LDA     <Smeml          ; All is well, file opened and continue
00126A  3  85 22                STA     FCBPTR+2        ; point to base of RAM
00126C  3  8D 66 13             STA     EndOfBas        ;
00126F  3  A5 7A                LDA     <Smemh          ;
001271  3  85 23                STA     FCBPTR+3        ;
001273  3  8D 67 13             STA     EndOfBas+1      ;
001276  3  A9 32                LDA     #<FCBBUFFER     ; SETUP BUFFER
001278  3  85 20                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
00127A  3  A0 41                LDY     #>FCBBUFFER     ;
00127C  3  84 21                STY     FCBPTR+1        ; STORE DEST BUFFER IN FCBPTR
00127E  3  A2 1A                LDX     #26             ; Setup Buffer
001280  3  20 80 11             JSR     PEM             ;
001283  3  4C C1 12             JMP     DOS65LOAD_3C
001286  3               DOS65LOAD_3:
001286  3  B1 20                LDA     (FCBPTR),Y      ; load from BUFFER
001288  3  91 22                STA     (FCBPTR+2),Y    ; save to RAM
00128A  3  EE 66 13             INC     EndOfBas
00128D  3  D0 03                BNE     :+
00128F  3  EE 67 13             INC     EndOfBas+1
001292  3               :
001292  3  C9 00                CMP     #$00
001294  3  D0 0D                BNE     :+
001296  3  EE 68 13             INC     NullCounter
001299  3  AD 68 13             LDA     NullCounter
00129C  3  C9 03                CMP     #3
00129E  3  D0 08                BNE     :++
0012A0  3  4C D4 12             JMP     DOS65LOAD_4
0012A3  3               :
0012A3  3  A9 00                LDA     #$00
0012A5  3  8D 68 13             STA     NullCounter
0012A8  3               :
0012A8  3  C8                   INY                     ; bump index
0012A9  3  C0 80                CPY     #$80            ; end of buffer?
0012AB  3  D0 D9                BNE     DOS65LOAD_3     ; no, loop
0012AD  3  18                   CLC                     ;
0012AE  3  A5 22                LDA     FCBPTR+2        ; add $80 to base counter
0012B0  3  69 80                ADC     #$80            ;
0012B2  3  85 22                STA     FCBPTR+2        ;
0012B4  3  90 0B                BCC     DOS65LOAD_3C    ; is carry?, no SKIP
0012B6  3  18                   CLC                     ; yes, carry, inc high byte
0012B7  3  A5 23                LDA     FCBPTR+3        ;
0012B9  3  69 01                ADC     #$01            ;
0012BB  3  85 23                STA     FCBPTR+3        ;
0012BD  3  C9 D0                CMP     #>Ram_top       ; are we at the end of RAM?
0012BF  3  F0 13                BEQ     DOS65LOAD_4
0012C1  3               
0012C1  3               DOS65LOAD_3C:
0012C1  3  A9 BC                LDA     #<FCB           ; READ record buffer from disk file
0012C3  3  A0 17                LDY     #>FCB           ;
0012C5  3  A2 14                LDX     #20             ;
0012C7  3  20 80 11             JSR     PEM             ;
0012CA  3  A0 00                LDY     #$00            ; RESET INDEX
0012CC  3  C9 00                CMP     #$00            ; is error or EOF
0012CE  3  F0 B6                BEQ     DOS65LOAD_3     ;
0012D0  3  C9 01                CMP     #$01            ; EOF?
0012D2  3  D0 89                BNE     DOS65LOAD_ERR   ; ERROR, do error handling
0012D4  3               DOS65LOAD_4:
0012D4  3  A9 BC                LDA     #<FCB           ;
0012D6  3  A0 17                LDY     #>FCB           ;
0012D8  3  A2 10                LDX     #16             ;
0012DA  3  20 80 11             JSR     PEM             ;
0012DD  3                                               ; setup pointers to return to basic
0012DD  3  AD 66 13             LDA     EndOfBas
0012E0  3  85 7B                STA     Svarl
0012E2  3  85 7D                STA     Sarryl
0012E4  3  85 7F                STA     Earryl
0012E6  3  AD 67 13             LDA     EndOfBas+1
0012E9  3  85 7C                STA     Svarh
0012EB  3  85 7E                STA     Sarryh
0012ED  3  85 80                STA     Earryh
0012EF  3  A9 AB                LDA     #<LAB_RMSG      ; point to "Ready" message low byte
0012F1  3  A0 0F                LDY     #>LAB_RMSG      ; point to "Ready" message high byte
0012F3  3  20 3B 23             JSR     LAB_18C3
0012F6  3  4C 78 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
0012F9  3               
0012F9  3               
0012F9  3               
0012F9  3               DOS65FCBPREP:
0012F9  3                       .IFDEF  DUODYNE
0012F9  3  22 C2 00 00          JSL     LAB_GBYT        ; scan memory
0012FD  3                       .ELSE
0012FD  3                       JSR     LAB_GBYT        ; scan memory
0012FD  3                       .ENDIF
0012FD  3               
0012FD  3  38                   SEC                     ;
0012FE  3  E9 40                SBC     #64             ; PARSE DRIVE NUMBER
001300  3  8D BC 17             STA     DOSDRIVE        ; STORE IT IN FCB
001303  3                       .IFDEF  DUODYNE
001303  3  22 BC 00 00          JSL     LAB_IGBY        ; increment and scan memory
001307  3                       .ELSE
001307  3                       JSR     LAB_IGBY        ; increment and scan memory
001307  3                       .ENDIF
001307  3               
001307  3  C9 3A                CMP     #':'            ;
001309  3  F0 08                BEQ     DOS65FCBPREP_1  ; YES, IT WAS A DRIVE, CONTINUE
00130B  3  A2 26                LDX     #$26            ; IO ERROR
00130D  3  20 9C 1A             JSR     LAB_XERR
001310  3  4C 78 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
001313  3               
001313  3               DOS65FCBPREP_1:
001313  3  A9 BC                LDA     #<FCB           ; SETUP FCBPTR
