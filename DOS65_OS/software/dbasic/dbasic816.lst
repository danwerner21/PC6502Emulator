000809  2               LAB_2CF4:
000809  2  AF FF FF FF          LDA     $FFFFFF         ; get byte to scan (addr set by call routine)
00080D  2  C9 BF                CMP     #TK_ELSE        ; compare with the token for ELSE
00080F  2  F0 0E                BEQ     LAB_2D05        ; exit if ELSE, not numeric, carry set
000811  2               
000811  2  C9 3A                CMP     #':'            ; compare with ":"
000813  2  B0 0A                BCS     LAB_2D05        ; exit if >= ":", not numeric, carry set
000815  2               
000815  2  C9 20                CMP     #' '            ; compare with " "
000817  2  F0 EA                BEQ     LAB_2CEE        ; if " " go do next
000819  2               
000819  2  38                   SEC                     ; set carry for SBC
00081A  2  E9 30                SBC     #'0'            ; subtract "0"
00081C  2  38                   SEC                     ; set carry for SBC
00081D  2  E9 D0                SBC     #$D0            ; subtract -"0"
00081F  2               ; clear carry if byte = "0"-"9"
00081F  2               LAB_2D05:
00081F  2  6B                   RTL
000820  2                       .ELSE
000820  2               LAB_2CF4:
000820  2                       LDA     $FFFF           ; get byte to scan (addr set by call routine)
000820  2                       CMP     #TK_ELSE        ; compare with the token for ELSE
000820  2                       BEQ     LAB_2D05        ; exit if ELSE, not numeric, carry set
000820  2               
000820  2                       CMP     #':'            ; compare with ":"
000820  2                       BCS     LAB_2D05        ; exit if >= ":", not numeric, carry set
000820  2               
000820  2                       CMP     #' '            ; compare with " "
000820  2                       BEQ     LAB_2CEE        ; if " " go do next
000820  2               
000820  2                       SEC                     ; set carry for SBC
000820  2                       SBC     #'0'            ; subtract "0"
000820  2                       SEC                     ; set carry for SBC
000820  2                       SBC     #$D0            ; subtract -"0"
000820  2               ; clear carry if byte = "0"-"9"
000820  2               LAB_2D05:
000820  2                       RTS
000820  2                       .ENDIF
