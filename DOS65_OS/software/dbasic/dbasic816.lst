00188A  3               ;__________________________________________________________
00188A  3               LAB_YEAR:
00188A  3  A2 06                LDX     #RTCYEAR
00188C  3  A9 33                LDA     #51
00188E  3  85 32                STA     farfunct
001890  3  20 F0 FF             JSR     DO_FARCALL
001893  3  98                   TYA
001894  3  20 A3 18             JSR     BCD_TO_HEX
001897  3  A9 00                LDA     #0              ; Get high byte
