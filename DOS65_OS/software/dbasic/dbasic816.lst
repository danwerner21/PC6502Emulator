001803  2                       .INCLUDE "ay38910.asm"
001803  3               
001803  3                       .IFNDEF  DUODYNE
001803  3               .pc02
001803  3               
001803  3               PPI_BASE        = $E230
001803  3               
001803  3               ppiPortA        = PPI_BASE+0         ; Register
001803  3               ppiPortB        = PPI_BASE+1         ; Register
001803  3               ppiPortC        = PPI_BASE+2         ; Register
001803  3               ppiControl      = PPI_BASE+3         ; Register
001803  3               
001803  3               ;___SOUND__________________________________________________
001803  3               ;
001803  3               ; PLAY SOUND
001803  3               ;
001803  3               ;  TAKES TWO PARAMETERS CHANNEL,FREQUENCY
001803  3               ;
001803  3               ;__________________________________________________________
001803  3               LAB_SOUND:
001803  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
001803  3                       PHX
001803  3                       JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
001803  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001803  3               ; else do type mismatch
001803  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001803  3               
001803  3                       PLA                     ; LIMIT THE CHANNELS TO <3
001803  3                       AND     #$03
001803  3                       CLC
001803  3                       ASL                     ; = *2
001803  3                       PHA
001803  3                       LDY     <Itempl
001803  3                       JSR     psgwr           ; SET LOW BYTE
001803  3                       PLA
001803  3                       INC     A
001803  3                       LDY     <Itemph
001803  3                       JSR     psgwr           ; SET HIGH BYTE
001803  3                       RTS
001803  3               
001803  3               ;___VOLUME__________________________________________________
001803  3               ;
001803  3               ; SET VOLUME
001803  3               ;
001803  3               ;  TAKES TWO PARAMETERS CHANNEL,VOLUME
001803  3               ;
001803  3               ;__________________________________________________________
001803  3               LAB_VOLUME:
001803  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
001803  3                       PHX
001803  3                       JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
001803  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X (VOLUME)
001803  3                       TXA
001803  3                       TAY
001803  3                       PLA                     ; LIMIT THE CHANNELS TO <3
001803  3                       AND     #$03
001803  3               
001803  3                       CLC
001803  3                       ADC     #08
001803  3                       JSR     psgwr
001803  3                       RTS
001803  3               
001803  3               
001803  3               ;___VOICE__________________________________________________
001803  3               ;
001803  3               ; SET VOICE
001803  3               ;
001803  3               ;  TAKES TWO PARAMETERS VOICE, ENVELOPE
001803  3               ;
001803  3               ;__________________________________________________________
001803  3               LAB_VOICE:
001803  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
001803  3                       PHX
001803  3                       JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
001803  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001803  3               ; else do type mismatch
001803  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001803  3                       PLY
001803  3                       LDA     #13
001803  3                       JSR     psgwr
001803  3               
001803  3                       LDA     #11
001803  3                       LDY     <Itempl
001803  3                       JSR     psgwr           ; SET LOW BYTE
001803  3                       LDA     #12
001803  3                       LDY     <Itemph         ; SET HIGH BYTE
001803  3                       JSR     psgwr
001803  3               
001803  3                       RTS
001803  3               
001803  3               
001803  3               
001803  3               
001803  3               
001803  3               ;___NOISE__________________________________________________
001803  3               ;
001803  3               ; SELECT NOISE CHANNEL
001803  3               ;
001803  3               ;  TAKES TWO PARAMETERS CHANNEL,FREQUENCY
001803  3               ;
001803  3               ;__________________________________________________________
001803  3               LAB_NOISE:
001803  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
001803  3                       PHX
001803  3                       JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
001803  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X (FREQ)
001803  3                       PLA                     ; LIMIT THE CHANNELS TO <3
001803  3                       PHX
001803  3                       TAX
001803  3               
001803  3                       AND     #%00011111
001803  3                       TAY
001803  3                       LDA     #$06
001803  3                       JSR     psgwr           ; SET NOISE FREQ
001803  3               
001803  3                       LDA     #$07
001803  3                       JSR     psgrd           ; GET CONFIG
001803  3                       PLA
001803  3                       PHY
001803  3                       AND     #$03
001803  3                       TAX                     ; A=CONFIG, X=CHANNEL
001803  3                       PLA
001803  3                       CPX     #$00
001803  3                       BNE     NOISE_1
001803  3                       AND     #%00110111
001803  3                       ORA     #%00000001
001803  3                       BRA     NOISE_3
001803  3               NOISE_1:
001803  3                       CPX     #$01
001803  3                       BNE     NOISE_2
001803  3                       AND     #%00101111
001803  3                       ORA     #%00000010
001803  3                       BRA     NOISE_3
001803  3               NOISE_2:
001803  3                       AND     #%00011111
001803  3                       ORA     #%00000100
001803  3               NOISE_3:
001803  3                       TAY
001803  3                       LDA     #$07
001803  3                       JSR     psgwr           ; SET LOW BYTE
001803  3                       RTS
001803  3               
001803  3               ;___TONE___________________________________________________
001803  3               ;
001803  3               ; SELECT TONE CHANNEL
001803  3               ;
001803  3               ;  TAKES ONE PARAMETER CHANNEL
001803  3               ;
001803  3               ;__________________________________________________________
001803  3               LAB_TONE:
001803  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
001803  3                       PHX
001803  3               
001803  3                       LDA     #$07
001803  3                       JSR     psgrd           ; GET CONFIG
001803  3                       PLA
001803  3                       PHY
001803  3                       AND     #$03
001803  3                       TAX                     ; A=CONFIG, X=CHANNEL
001803  3                       PLA
001803  3                       CPX     #$00
001803  3                       BNE     TONE_1
001803  3                       AND     #%00111110
001803  3                       ORA     #%00001000
001803  3                       BRA     TONE_3
001803  3               TONE_1:
001803  3                       CPX     #$01
001803  3                       BNE     TONE_2
001803  3                       AND     #%00111101
001803  3                       ORA     #%00010000
001803  3                       BRA     TONE_3
001803  3               TONE_2:
001803  3                       AND     #%00111011
001803  3                       ORA     #%00100000
001803  3               TONE_3:
001803  3                       TAY
001803  3                       LDA     #$07
001803  3                       JSR     psgwr           ; SET LOW BYTE
001803  3                       RTS
001803  3               
001803  3               
001803  3               ;___CONTROLLER_______________________________________________
001803  3               ;
001803  3               ; GET JOYTICK STATUS
001803  3               ;
001803  3               ;  TAKES ONE PARAMETERS JOYSTICK#, RETURNS STATUS
001803  3               ;
001803  3               ;__________________________________________________________
001803  3               LAB_CON:
001803  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001803  3                       LDA     <Itempl
001803  3                       AND     #$01
001803  3                       CLC
001803  3                       ADC     #14
001803  3                       JSR     psgrd           ; return value in y
001803  3                       JMP     LAB_1FD0        ; convert Y to byte in FAC1 and return
001803  3               
001803  3               
001803  3               
001803  3               
001803  3               ;___utility functions____________________________________________
001803  3               psginit:
001803  3                       LDA     #%10000000
001803  3                       STA     ppiControl
001803  3                       LDA     #%00010000
001803  3                       STA     ppiPortC
001803  3                       LDA     #$00
001803  3                       STA     ppiPortB
001803  3                       RTS
001803  3                       JSR     clrpsg
001803  3                       LDA     #7
001803  3                       LDY     #$3F
001803  3                       JSR     psgwr
001803  3                       RTS
001803  3               
001803  3               psgrd:
001803  3                       STA     ppiPortB      ; select register
001803  3                       LDA     #%00011100      ; latch address
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3               
001803  3                       LDA     #%00010000      ; inact
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3               
001803  3                       LDA     #%10000010
001803  3                       STA     ppiControl
001803  3                       LDA     #%00011000      ; latch data
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3               
001803  3                       LDA     ppiPortB      ; get data
001803  3                       TAY
001803  3                       LDA     #%10000000
001803  3                       STA     ppiControl
001803  3                       LDA     #%00010000      ; inact
001803  3                       STA     ppiPortC
001803  3                       RTS
001803  3               
001803  3               
001803  3               psgwr:
001803  3                       STA     ppiPortB      ; select register
001803  3                       LDA     #%00011100      ; latch address
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3               
001803  3                       LDA     #%00010000      ; inact
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3                       TYA
001803  3                       STA     ppiPortB      ; store data
001803  3                       STA     ppiPortB      ; store data
001803  3                       STA     ppiPortB      ; store data
001803  3               
001803  3                       LDA     #%00010100      ; latch data
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3                       STA     ppiPortC
001803  3               
001803  3                       LDA     #%00010000      ; inact
001803  3                       STA     ppiPortC
001803  3                       RTS
001803  3               
001803  3               ;
001803  3               ; Clear PSG registers to default
001803  3               ;
001803  3               clrpsg:
001803  3                       LDX     #00
001803  3                       LDY     #00
001803  3               clrpsg1:
001803  3                       TXA
001803  3                       JSR     psgwr           ; set register X to 0
001803  3                       INX
001803  3                       CPX     #16
001803  3                       BNE     clrpsg1
001803  3                       LDA     #07
001803  3                       LDY     #%00111000
001803  3                       JSR     psgwr
001803  3                       RTS
001803  3               
001803  3                       .ELSE
001803  3               
001803  3               
001803  3               ; ENSURE ALL OF THESE SPECIAL COMMANDS GIVE ERRORS IN NORMAL BASIC
