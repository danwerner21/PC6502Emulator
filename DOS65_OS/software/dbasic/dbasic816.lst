0010DD  2               DOINSERT:
0010DD  2                       JSR     GETVIDEOADDRESS
0010DD  2                       LDY     #$01+VIDEOBANK  ; SCREEN AREA $1000-$1FFF
0010DD  2                       JSR     PAGE_ENTER
0010DD  2                       LDY     VIDEOWIDTH
0010DD  2                       DEY
0010DD  2               :
0010DD  2                       DEY
0010DD  2                       LDA     (TEMPW),Y
0010DD  2                       INY
0010DD  2                       STA     (TEMPW),Y
0010DD  2                       DEY
0010DD  2                       CPY     CURX
0010DD  2                       BNE     :-
0010DD  2                       LDA     #32
0010DD  2                       STA     (TEMPW),Y
0010DD  2               
0010DD  2                       JSR     PAGE_EXIT
0010DD  2                       JMP     ploop
0010DD  2               DODELETE:
0010DD  2                       JSR     GETVIDEOADDRESS
0010DD  2                       LDY     #$01+VIDEOBANK  ; SCREEN AREA $1000-$1FFF
0010DD  2                       JSR     PAGE_ENTER
0010DD  2                       LDY     CURX
0010DD  2               :
0010DD  2                       INY
0010DD  2                       LDA     (TEMPW),Y
0010DD  2                       DEY
0010DD  2                       STA     (TEMPW),Y
0010DD  2                       INY
0010DD  2                       CPY     VIDEOWIDTH
0010DD  2                       BNE     :-
0010DD  2                       LDY     VIDEOWIDTH
0010DD  2                       DEY
0010DD  2                       LDA     #32
0010DD  2                       STA     (TEMPW),Y
0010DD  2               
0010DD  2                       JSR     PAGE_EXIT
0010DD  2                       JMP     ploop
0010DD  2               LdKbBuffer:
0010DD  2               ; clear input buffer
0010DD  2                       LDX     #81
0010DD  2               :
0010DD  2                       LDA     #00
0010DD  2                       STA     Ibuffs-1,X
0010DD  2                       DEX
0010DD  2                       BNE     :-
0010DD  2               
0010DD  2                       JSR     GETVIDEOADDRESS
0010DD  2                       LDY     #$01+VIDEOBANK  ; SCREEN AREA $1000-$1FFF
0010DD  2                       JSR     PAGE_ENTER
0010DD  2                       LDY     #0
0010DD  2               :
0010DD  2                       LDA     (TEMPW),Y
0010DD  2                       STA     Ibuffs,Y
0010DD  2                       INY
0010DD  2                       CPY     VIDEOWIDTH
0010DD  2                       BNE     :-
0010DD  2               
0010DD  2                       JSR     PAGE_EXIT
0010DD  2                       RTS
0010DD  2               
0010DD  2               GETVIDEOADDRESS:
0010DD  2                       LDY     CURY
0010DD  2               
0010DD  2                       STY     PTEMPW
0010DD  2                       LDA     #0
0010DD  2                       STA     PTEMPW+1
0010DD  2                       CLC
0010DD  2                       ASL     PTEMPW
0010DD  2                       ROL     PTEMPW+1        ; *2
0010DD  2                       ASL     PTEMPW
0010DD  2                       ROL     PTEMPW+1        ; *4
0010DD  2                       ASL     PTEMPW
0010DD  2                       ROL     PTEMPW+1        ; *8
0010DD  2                       LDA     PTEMPW
0010DD  2                       STA     PTEMPW1
0010DD  2                       LDA     PTEMPW+1
0010DD  2                       STA     PTEMPW1+1       ; PTEMPW1=Y*8
0010DD  2                       ASL     PTEMPW
0010DD  2                       ROL     PTEMPW+1        ; *16
0010DD  2                       ASL     PTEMPW
0010DD  2                       ROL     PTEMPW+1        ; *32
0010DD  2                                               ; TEMPW  = Y*8 + Y*32  (Y*40)
0010DD  2                       CLC                     ; Clear the Carry flag before the first addition
0010DD  2                       LDA     PTEMPW          ; Load the low byte of the first number into the accumulator
0010DD  2                       ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
0010DD  2                       STA     TEMPW           ; Store the low byte of the result
0010DD  2                       LDA     PTEMPW+1        ; Load the high byte of the first number
0010DD  2                       ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
0010DD  2                       STA     TEMPW+1         ; Store the high byte of the result
0010DD  2               
0010DD  2                       LDA     VIDEOWIDTH      ; If 80 col, double again
0010DD  2                       CMP     #80
0010DD  2                       BNE     :+
0010DD  2                       ASL     TEMPW
0010DD  2                       ROL     TEMPW+1         ; *2  (80)
0010DD  2               :
0010DD  2                       LDA     TEMPW+1
0010DD  2                       ORA     #$A0            ; add in the bank#
0010DD  2                       STA     TEMPW+1
0010DD  2                       RTS
0010DD  2               
0010DD  2               
0010DD  2                       .ENDIF
0010DD  2               
0010DD  2               V_LPRINT:
