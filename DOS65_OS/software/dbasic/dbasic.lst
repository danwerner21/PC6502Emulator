0015C3  3                                               ; space returns with A = length, X=$71=pointer low byte,
0015C3  3                                               ; Y=$72=pointer high byte
0015C3  3  85 AC                STA     str_ln          ; set string length
0015C5  3  86 AD                STX     str_pl          ; set string pointer low byte
0015C7  3  84 AE                STY     str_ph          ; set string pointer high byte
