001966  3               BCD_TO_HEX:
001966  3  85 12                STA     nums_2          ; Store in TEMP2
001968  3  29 F0                AND     #$F0
00196A  3  4A                   LSR     A               ; (shift 1 times to /2)
00196B  3  85 11                STA     nums_1          ; Store the /2 into TEMP
00196D  3  4A                   LSR     A               ;
00196E  3  4A                   LSR     A               ; Shift two more times to /8
00196F  3  18                   CLC
001970  3  65 11                ADC     nums_1          ; add /8 + /2 to get /10
001972  3  85 11                STA     nums_1          ; Store tens digit into TEMP
001974  3  A5 12                LDA     nums_2          ; Get Ones
001976  3  29 0F                AND     #$0F
001978  3  18                   CLC
001979  3  65 11                ADC     nums_1
00197B  3  60                   RTS                     ; Return from subroutine
