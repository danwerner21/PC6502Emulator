0010DC  2               ;
0010DC  2               ; Basic Screen editor code
0010DC  2               ;
0010DC  2               ;__________________________________________________________
0010DC  2               ScreenEditor:
0010DC  2               ; allow prepopulate of screen
0010DC  2               ploop:
0010DC  2                       LDA     #58
0010DC  2                       STA     farfunct
0010DC  2                       JSR     DO_FARCALL      ; PAINT cursor
0010DC  2               ploop1:
0010DC  2                       LDA     #20
0010DC  2                       STA     farfunct
0010DC  2                       JSR     DO_FARCALL      ; GET KEYSTROKE
0010DC  2                       CMP     #$FF
0010DC  2                       BEQ     ploop1
0010DC  2                       PHA
0010DC  2                       LDA     #59
0010DC  2                       STA     farfunct
0010DC  2                       JSR     DO_FARCALL      ; UNPAINT cursor
0010DC  2                       PLA
0010DC  2                       CMP     #$F0
0010DC  2                       BEQ     insert
0010DC  2                       CMP     #$F1
0010DC  2                       BEQ     delete
0010DC  2                       CMP     #$F6
0010DC  2                       BEQ     crsrup
0010DC  2                       CMP     #$F7
0010DC  2                       BEQ     crsrdn
0010DC  2                       CMP     #$F8
0010DC  2                       BEQ     crsrlt
0010DC  2                       CMP     #$F9
0010DC  2                       BEQ     Lcrsrrt
0010DC  2                       CMP     #$0A
0010DC  2                       BEQ     ploop
0010DC  2                       CMP     #13
0010DC  2                       BEQ     Lpexit
0010DC  2               
0010DC  2                       PHA
0010DC  2                       LDA     #19
0010DC  2                       STA     farfunct
0010DC  2                       PLA
0010DC  2                       JSR     DO_FARCALL
0010DC  2                       JMP     ploop
0010DC  2               Lpexit:
0010DC  2                       JMP     pexit
0010DC  2               Lcrsrrt:
0010DC  2                       JMP     crsrrt
0010DC  2               insert:
0010DC  2                       JMP     DOINSERT
0010DC  2               delete:
0010DC  2                       JMP     DODELETE
0010DC  2               crsrup:
0010DC  2                       LDA     CURY
0010DC  2                       CMP     #00
0010DC  2                       BEQ     ploop
0010DC  2                       DEC     CURY
0010DC  2                       JMP     ploop
0010DC  2               crsrdn:
0010DC  2                       LDA     CURY
0010DC  2                       CMP     #23
0010DC  2                       BEQ     crsrdn_1
0010DC  2                       INC     CURY
0010DC  2                       JMP     ploop
0010DC  2               crsrdn_1:
0010DC  2                       LDA     #56
0010DC  2                       STA     farfunct
0010DC  2                       JSR     DO_FARCALL
0010DC  2                       JMP     ploop
0010DC  2               crsrlt:
0010DC  2                       LDA     CURX
0010DC  2                       CMP     #00
0010DC  2                       BEQ     crsrlt_1
0010DC  2                       DEC     CURX
0010DC  2                       JMP     ploop
0010DC  2               crsrlt_1:
0010DC  2                       LDA     CURY
0010DC  2                       CMP     #00
0010DC  2                       BEQ     :+
0010DC  2                       LDX     VIDEOWIDTH
0010DC  2                       DEX
0010DC  2                       STX     CURX
0010DC  2                       LDY     CURY
0010DC  2                       DEY
0010DC  2                       STY     CURY
0010DC  2               :
0010DC  2                       JMP     ploop
0010DC  2               crsrrt:
0010DC  2                       LDX     VIDEOWIDTH
0010DC  2                       DEX
0010DC  2                       CPX     CURX
0010DC  2                       BEQ     crsrrt_1
0010DC  2                       INC     CURX
0010DC  2                       JMP     ploop
0010DC  2               crsrrt_1:
0010DC  2                       LDA     #00
0010DC  2                       STA     CURX
0010DC  2                       JMP     crsrdn
0010DC  2               pexit:
0010DC  2                       JSR     LdKbBuffer
0010DC  2                       LDX     #80
0010DC  2                       LDA     #$00
0010DC  2                       STA     Ibuffs,X
0010DC  2               TERMLOOP:
0010DC  2                       DEX
0010DC  2                       LDA     Ibuffs,X
0010DC  2                       CMP     #32
0010DC  2                       BEQ     TERMLOOP_B
0010DC  2                       CMP     #00
0010DC  2                       BEQ     TERMLOOP_C
0010DC  2                       JMP     TERMLOOP_A
0010DC  2               TERMLOOP_B:
0010DC  2                       LDA     #00
0010DC  2                       STA     Ibuffs,X
0010DC  2               TERMLOOP_C:
0010DC  2                       CPX     #00
0010DC  2                       BNE     TERMLOOP
0010DC  2               TERMLOOP_A:
0010DC  2                       LDA     #19
0010DC  2                       STA     farfunct
0010DC  2                       LDA     #13
0010DC  2                       JSR     DO_FARCALL
0010DC  2                       LDA     #19
0010DC  2                       STA     farfunct
0010DC  2                       LDA     #10
0010DC  2                       JSR     DO_FARCALL
0010DC  2                       RTS
0010DC  2               DOINSERT:
0010DC  2                       JSR     GETVIDEOADDRESS
0010DC  2                       LDY     #$01+VIDEOBANK  ; SCREEN AREA $1000-$1FFF
0010DC  2                       JSR     PAGE_ENTER
0010DC  2                       LDY     VIDEOWIDTH
0010DC  2                       DEY
0010DC  2               :
0010DC  2                       DEY
0010DC  2                       LDA     (TEMPW),Y
0010DC  2                       INY
0010DC  2                       STA     (TEMPW),Y
0010DC  2                       DEY
0010DC  2                       CPY     CURX
0010DC  2                       BNE     :-
0010DC  2                       LDA     #32
0010DC  2                       STA     (TEMPW),Y
0010DC  2               
0010DC  2                       JSR     PAGE_EXIT
0010DC  2                       JMP     ploop
0010DC  2               DODELETE:
0010DC  2                       JSR     GETVIDEOADDRESS
0010DC  2                       LDY     #$01+VIDEOBANK  ; SCREEN AREA $1000-$1FFF
0010DC  2                       JSR     PAGE_ENTER
0010DC  2                       LDY     CURX
0010DC  2               :
0010DC  2                       INY
0010DC  2                       LDA     (TEMPW),Y
0010DC  2                       DEY
0010DC  2                       STA     (TEMPW),Y
0010DC  2                       INY
0010DC  2                       CPY     VIDEOWIDTH
0010DC  2                       BNE     :-
0010DC  2                       LDY     VIDEOWIDTH
0010DC  2                       DEY
0010DC  2                       LDA     #32
0010DC  2                       STA     (TEMPW),Y
0010DC  2               
0010DC  2                       JSR     PAGE_EXIT
0010DC  2                       JMP     ploop
0010DC  2               LdKbBuffer:
0010DC  2               ; clear input buffer
0010DC  2                       LDX     #81
0010DC  2               :
0010DC  2                       LDA     #00
0010DC  2                       STA     Ibuffs-1,X
0010DC  2                       DEX
0010DC  2                       BNE     :-
0010DC  2               
0010DC  2                       JSR     GETVIDEOADDRESS
0010DC  2                       LDY     #$01+VIDEOBANK  ; SCREEN AREA $1000-$1FFF
0010DC  2                       JSR     PAGE_ENTER
0010DC  2                       LDY     #0
0010DC  2               :
0010DC  2                       LDA     (TEMPW),Y
0010DC  2                       STA     Ibuffs,Y
0010DC  2                       INY
0010DC  2                       CPY     VIDEOWIDTH
0010DC  2                       BNE     :-
0010DC  2               
0010DC  2                       JSR     PAGE_EXIT
0010DC  2                       RTS
0010DC  2               
0010DC  2               GETVIDEOADDRESS:
0010DC  2                       LDY     CURY
0010DC  2               
0010DC  2                       STY     PTEMPW
0010DC  2                       LDA     #0
0010DC  2                       STA     PTEMPW+1
0010DC  2                       CLC
0010DC  2                       ASL     PTEMPW
0010DC  2                       ROL     PTEMPW+1        ; *2
0010DC  2                       ASL     PTEMPW
0010DC  2                       ROL     PTEMPW+1        ; *4
0010DC  2                       ASL     PTEMPW
0010DC  2                       ROL     PTEMPW+1        ; *8
0010DC  2                       LDA     PTEMPW
0010DC  2                       STA     PTEMPW1
0010DC  2                       LDA     PTEMPW+1
0010DC  2                       STA     PTEMPW1+1       ; PTEMPW1=Y*8
0010DC  2                       ASL     PTEMPW
0010DC  2                       ROL     PTEMPW+1        ; *16
0010DC  2                       ASL     PTEMPW
0010DC  2                       ROL     PTEMPW+1        ; *32
0010DC  2                                               ; TEMPW  = Y*8 + Y*32  (Y*40)
0010DC  2                       CLC                     ; Clear the Carry flag before the first addition
0010DC  2                       LDA     PTEMPW          ; Load the low byte of the first number into the accumulator
0010DC  2                       ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
0010DC  2                       STA     TEMPW           ; Store the low byte of the result
0010DC  2                       LDA     PTEMPW+1        ; Load the high byte of the first number
0010DC  2                       ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
0010DC  2                       STA     TEMPW+1         ; Store the high byte of the result
0010DC  2               
0010DC  2                       LDA     VIDEOWIDTH      ; If 80 col, double again
0010DC  2                       CMP     #80
0010DC  2                       BNE     :+
0010DC  2                       ASL     TEMPW
0010DC  2                       ROL     TEMPW+1         ; *2  (80)
0010DC  2               :
0010DC  2                       LDA     TEMPW+1
0010DC  2                       ORA     #$A0            ; add in the bank#
0010DC  2                       STA     TEMPW+1
0010DC  2                       RTS
0010DC  2               
0010DC  2               
0010DC  2                       .ENDIF
0010DC  2               
