0010FC  2  8E 6A 11             STX     TTX
0010FF  2  8C 6B 11             STY     TTY
001102  2  8D 6C 11             STA     TTA
001105  2  A9 0D                LDA     #13
001107  2  20 6D 11             JSR     WRSER1          ; output upper nybble
00110A  2  A9 0A                LDA     #10
00110C  2  20 6D 11             JSR     WRSER1          ; output upper nybble
00110F  2  AE 6A 11             LDX     TTX
001112  2  AC 6B 11             LDY     TTY
001115  2  AD 6C 11             LDA     TTA
001118  2  60                   RTS
001119  2               
001119  2               PRINT_SPACE:
001119  2  8E 6A 11             STX     TTX
00111C  2  8C 6B 11             STY     TTY
00111F  2  8D 6C 11             STA     TTA
001122  2  A9 20                LDA     #32
001124  2  20 6D 11             JSR     WRSER1          ; output upper nybble
001127  2  AE 6A 11             LDX     TTX
00112A  2  AC 6B 11             LDY     TTY
00112D  2  AD 6C 11             LDA     TTA
001130  2  60                   RTS
001131  2               
001131  2               
001131  2               PRINT_BYTE:
001131  2  8E 6A 11             STX     TTX
001134  2  8C 6B 11             STY     TTY
001137  2  8D 6C 11             STA     TTA
00113A  2  8E 69 11             STX     SAVX            ; save X
00113D  2  20 54 11             JSR     ASCTWO          ; get hex chars for byte in X (lower) and A (upper)
001140  2  20 6D 11             JSR     WRSER1          ; output upper nybble
001143  2  8A                   TXA                     ; transfer lower to A
001144  2  AE 69 11             LDX     SAVX            ; restore X
001147  2  20 6D 11             JSR     WRSER1          ; output lower nybble
00114A  2  AE 6A 11             LDX     TTX
00114D  2  AC 6B 11             LDY     TTY
001150  2  AD 6C 11             LDA     TTA
001153  2  60                   RTS
001154  2               ASCTWO:
001154  2  48                   PHA                     ; save byte
001155  2  20 5E 11             JSR     ASCII           ; do low nybble
001158  2  AA                   TAX                     ; save in X
001159  2  68                   PLA                     ; restore byte
00115A  2  4A                   LSR     A               ; shift upper nybble down
00115B  2  4A                   LSR     A
00115C  2  4A                   LSR     A
00115D  2  4A                   LSR     A
00115E  2               ; convert low nybble in A to hex digit
00115E  2               ASCII:
00115E  2  29 0F                AND     #$0F            ; clear upper nibble
001160  2  C9 0A                CMP     #$0A            ; if less than A, skip next step
001162  2  90 02                BCC     ASC1
001164  2  69 06                ADC     #6              ; skip ascii chars between 9 and A
001166  2               ASC1:
001166  2  69 30                ADC     #$30            ; add ascii char 0 to value
001168  2  60                   RTS
001169  2               SAVX:
001169  2  00                   .BYTE   00
00116A  2               TTX:
00116A  2  00                   .BYTE   00
00116B  2               TTY:
00116B  2  00                   .BYTE   00
00116C  2               TTA:
00116C  2  00                   .BYTE   00
00116D  2               ;__WRSER1________________________________________________________________________________________________________________________
00116D  2               ;
00116D  2               ;	WRITE CHARACTER(A) TO UART
00116D  2               ;________________________________________________________________________________________________________________________________
00116D  2               ;
00116D  2               WRSER1:
00116D  2  48                   PHA
00116E  2               WRSER1a:
00116E  2  AD 85 EF             LDA     UART1STATUS     ; GET STATUS
001171  2  29 10                AND     #%00010000      ; IS TX READY
001173  2  F0 F9                BEQ     WRSER1a         ; NO, WAIT FOR IT
001175  2  68                   PLA
001176  2  8D 84 EF             STA     UART1DATA       ; WRITE DATA
001179  2  60                   RTS
