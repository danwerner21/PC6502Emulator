001758  3               ;___V_SCRCLR________________________________________________
001758  3               ;
001758  3               ; CLEAR SCREEN
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               LAB_SCRCLR:
001758  3               V_SCNCLR:
001758  3                       STA     DBGA
001758  3                       STY     DBGY
001758  3                       STX     DBGX
001758  3                       LDA     #38
001758  3                       STA     farfunct
001758  3                       JSR     DO_FARCALL
001758  3                       LDA     #59
001758  3                       STA     farfunct
001758  3                       JSR     DO_FARCALL
001758  3                       LDA     DBGA
001758  3                       LDY     DBGY
001758  3                       LDX     DBGX
001758  3                       RTS
001758  3               
001758  3               
001758  3               
001758  3               ;___V_LOCATE________________________________________________
001758  3               ;
001758  3               ; SET CURSOR LOCATION
001758  3               ;
001758  3               ;       LOCATE X,Y
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               V_LOCATE:
001758  3               LAB_LOCATE:
001758  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (MODE)
001758  3                       STX     DBGX
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3                       TXA
001758  3                       TAY
001758  3                       LDX     DBGX
001758  3                       LDA     #37
001758  3                       STA     farfunct
001758  3                       JSR     DO_FARCALL
001758  3                       RTS
001758  3               
001758  3               ;___V_COLOR_________________________________________________
001758  3               ;
001758  3               ; SET COLOR FG,BG,CFG,CBG
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               LAB_COLOR:
001758  3               V_COLOR:
001758  3                       LDA     #$00            ; CLEAR TEMP SPACE
001758  3                       STA     PTEMPW
001758  3                       STA     PTEMPW+1
001758  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (MODE)
001758  3                       TXA
001758  3                       AND     #$0F
001758  3                       STA     PTEMPW
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3                       TXA
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ORA     PTEMPW
001758  3                       STA     PTEMPW
001758  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE THIRD PARAMETER, RETURN IN X
001758  3                       TXA
001758  3                       AND     #$0F
001758  3                       STA     PTEMPW+1
001758  3                       JSR     LAB_1C01        ; GET THE FOURTH PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE FOURTH PARAMETER, RETURN IN X
001758  3                       TXA
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ORA     PTEMPW+1
001758  3                       STA     PTEMPW+1
001758  3                       LDX     PTEMPW
001758  3                       LDY     PTEMPW+1
001758  3                       LDA     #39
001758  3                       STA     farfunct
001758  3                       JSR     DO_FARCALL
001758  3                       RTS
001758  3               
001758  3               
001758  3               
001758  3               ;___V_SPEEK()______________________________________________
001758  3               ;
001758  3               ; GET VALUE FROM SCREEN MEMORY
001758  3               ;
001758  3               ;  TAKES ONE PARAMETER (ADDRESS), RETURNS VALUE
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               LAB_SPEEK:
001758  3               V_SPEEK:
001758  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001758  3                       LDA     Itemph
001758  3                       TAY
001758  3                       AND     #$0F
001758  3                       ORA     #$A0
001758  3                       STA     Itemph
001758  3                       TYA
001758  3                       AND     #$F0
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       AND     #$07
001758  3                       CLC
001758  3                       ADC     #VIDEOBANK
001758  3                       TAY
001758  3                       LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
001758  3                       LDX     #$0A            ; MAP $AXXX
001758  3                       JSR     SETPAGE         ; CALL SETPAGE
001758  3                       LDA     #$01
001758  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
001758  3                       LDY     #0
001758  3                       LDA     (Itempl),Y
001758  3                       TAY
001758  3                       LDA     #$00
001758  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
001758  3                       JMP     LAB_1FD0        ; convert Y to byte in FAC1 and return
001758  3               
001758  3               
001758  3               
001758  3               ;___V_SPOKE_________________________________________________
001758  3               ;
001758  3               ; PUT VALUE IN SCREEN MEMORY
001758  3               ;
001758  3               ;  TAKES TWO PARAMETERS ADDRESS,VALUE
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               LAB_SPOKE:
001758  3               V_SPOKE:
001758  3                       JSR     LAB_GADB        ; get two parameters for POKE or WAIT
001758  3                       TXA                     ; BYTE ARGUMENT IS IN X
001758  3                       PHA                     ; PUSH BYTE ARGUMENT TO STACK
001758  3                       LDA     Itemph
001758  3                       TAY
001758  3                       AND     #$0F
001758  3                       ORA     #$A0
001758  3                       STA     Itemph
001758  3                       TYA
001758  3                       AND     #$F0
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       AND     #$07
001758  3                       CLC
001758  3                       ADC     #VIDEOBANK
001758  3                       TAY
001758  3                       LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
001758  3                       LDX     #$0A            ; MAP $AXXX
001758  3                       JSR     SETPAGE         ; CALL SETPAGE
001758  3                       LDA     #$01
001758  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
001758  3                       LDY     #0
001758  3                       PLA                     ; PULL BYTE ARGUMENT
001758  3                       STA     (Itempl),Y
001758  3                       LDA     #$00
001758  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
001758  3                       RTS
001758  3               
001758  3               ;___V_SCREEN_________________________________________________
001758  3               ;
001758  3               ;  SET SCREEN MODE
001758  3               ;
001758  3               ;  TAKES UP TO THREE PARAMETERS
001758  3               ;  FIRST PARAMETER SCREEN MODE
001758  3               ;  0=TEXT MODE
001758  3               ;  1=LORES MODE
001758  3               ;  2=HIRES MODE
001758  3               ;
001758  3               ;  TEXT MODE PARAMETERS
001758  3               ;  0=40 COLUMNS
001758  3               ;  1=80 COLUMNS
001758  3               ;  2=40 COLUMNS Multicolor
001758  3               ;  3=80 COLUMNS Multicolor
001758  3               ;
001758  3               ;  LORES MODE SECOND PARAMETER
001758  3               ;  0=SINGLE LORES
001758  3               ;  1=DOUBLE LORES
001758  3               ;  LORES MODE THIRD PARAMETER
001758  3               ;  0=MIXED MODE
001758  3               ;  1=FULL SCREEN MODE
001758  3               ;
001758  3               ;  HIRES MODE SECOND PARAMETER
001758  3               ;  0=SINGLE HIRES
001758  3               ;  1=DOUBLE HIRES
001758  3               ;  2=QUAD HIRES
001758  3               ;  3=MONO HIRES
001758  3               ;  HIRES MODE THIRD PARAMETER
001758  3               ;  1=MIXED MODE
001758  3               ;  0=FULL SCREEN MODE
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               LAB_SCREEN:
001758  3               V_SCREEN:
001758  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (MODE)
001758  3               V_SCREEN1:
001758  3                       STX     VIDEOMODE
001758  3                       CPX     #00
001758  3                       BNE     *+5
001758  3                       JMP     SETUPMODE0
001758  3                       CPX     #01
001758  3                       BNE     *+5
001758  3                       JMP     SETUPMODE1
001758  3                       CPX     #02
001758  3                       BNE     *+5
001758  3                       JMP     SETUPMODE2
001758  3               
001758  3                       LDX     #$02            ; SYNTAX ERROR
001758  3                       JSR     LAB_XERR
001758  3                       JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
001758  3                       RTS
001758  3               
001758  3               SETUPMODE0:                     ; TEXT MODE
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoTextMode
001758  3                       LDA     #$02
001758  3                       STA     VideoLoresMode
001758  3                       STA     VideoHiresMode
001758  3                       LDA     #$02
001758  3                       STA     VideoMulticolor
001758  3                       JSR     PAGE_EXIT
001758  3               
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3                       CPX     #$00
001758  3                       BNE     SETUPMODE0_80
001758  3               SETUPMODE0_40:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$02
001758  3                       STA     Video80col
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     #40
001758  3                       STA     VIDEOWIDTH
001758  3                       LDA     #0
001758  3                       STA     BVIDEOMODE
001758  3                       JMP     SETUPMODE0_CLEAR
001758  3               SETUPMODE0_80:
001758  3                       CPX     #$01
001758  3                       BNE     SETUPMODE0_40C
001758  3               SETUPMODE0_80a:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     Video80col
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     #80
001758  3                       STA     VIDEOWIDTH
001758  3                       LDA     #1
001758  3                       STA     BVIDEOMODE
001758  3               SETUPMODE0_CLEAR:
001758  3                       JMP     V_SCNCLR
001758  3                       RTS
001758  3               SETUPMODE0_40C:
001758  3                       CPX     #$02
001758  3                       BNE     SETUPMODE0_80C
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoMulticolor
001758  3                       JSR     PAGE_EXIT
001758  3                       JMP     SETUPMODE0_40
001758  3               SETUPMODE0_80C:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoMulticolor
001758  3                       JSR     PAGE_EXIT
001758  3                       JMP     SETUPMODE0_80a
001758  3               
001758  3               SETUPMODE1:                     ; LORES MODE
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoLoresMode
001758  3                       LDA     #$02
001758  3                       STA     VideoTextMode
001758  3                       STA     VideoHiresMode
001758  3                       JSR     PAGE_EXIT
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3               
001758  3                       CPX     #$00
001758  3                       BNE     SETUPMODE1_DOUBLE
001758  3               
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$02
001758  3                       STA     VideoDoubleLores
001758  3                       JSR     PAGE_EXIT
001758  3                       JMP     SETUPMODE1_CLEAR
001758  3               SETUPMODE1_DOUBLE:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoDoubleLores
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     #$11
001758  3                       STA     VIDEOMODE
001758  3               SETUPMODE1_CLEAR:               ;    ($2000-$2800)
001758  3                       LDY     #$02+VIDEOBANK  ; AREA $2000-$2FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$00
001758  3                       STA     TEMPW
001758  3                       LDA     #$A0
001758  3                       STA     TEMPW+1
001758  3                       LDY     #$00
001758  3                       LDA     #$00
001758  3               :
001758  3                       STA     (TEMPW),Y
001758  3                       INC     TEMPW
001758  3                       BNE     :-
001758  3                       INC     TEMPW+1
001758  3               
001758  3                       LDX     TEMPW+1
001758  3                       CPX     #$A8
001758  3                       BNE     :-
001758  3                       JSR     PAGE_EXIT
001758  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE THIRD PARAMETER, RETURN IN X
001758  3                       CPX     #$00
001758  3                       BNE     SETUPMODE1_MIXED
001758  3               
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$02
001758  3                       STA     VideoMixedMode
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               SETUPMODE1_MIXED:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoMixedMode
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     VIDEOMODE
001758  3                       ORA     #$80
001758  3                       STA     VIDEOMODE
001758  3                       RTS
001758  3               
001758  3               
001758  3               SETUPMODE2:                     ; HIRES MODE
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoHiresMode
001758  3                       LDA     #$02
001758  3                       STA     VideoTextMode
001758  3                       STA     VideoLoresMode
001758  3                       JSR     PAGE_EXIT
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3               
001758  3                       CPX     #$00
001758  3                       BNE     SETUPMODE2_DOUBLE
001758  3               
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$02
001758  3                       STA     VideoDoubleHires
001758  3                       STA     VideoQuadHires
001758  3                       STA     VideoMonoHires
001758  3                       JSR     PAGE_EXIT
001758  3                       JMP     SETUPMODE2_CLEAR
001758  3               SETUPMODE2_DOUBLE:
001758  3                       CPX     #$01
001758  3                       BNE     SETUPMODE2_QUAD
001758  3               
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoDoubleHires
001758  3                       LDA     #$02
001758  3                       STA     VideoQuadHires
001758  3                       STA     VideoMonoHires
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     #$12
001758  3                       STA     VIDEOMODE
001758  3                       JMP     SETUPMODE2_CLEAR
001758  3               SETUPMODE2_QUAD:
001758  3                       CPX     #$02
001758  3                       BNE     SETUPMODE2_MONO
001758  3               
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoQuadHires
001758  3                       LDA     #$02
001758  3                       STA     VideoDoubleHires
001758  3                       STA     VideoMonoHires
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     #$22
001758  3                       STA     VIDEOMODE
001758  3                       JMP     SETUPMODE2_CLEAR
001758  3               SETUPMODE2_MONO:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoMonoHires
001758  3                       LDA     #$02
001758  3                       STA     VideoDoubleHires
001758  3                       STA     VideoQuadHires
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     #$32
001758  3                       STA     VIDEOMODE
001758  3               
001758  3               SETUPMODE2_CLEAR:               ; ($2000-$7FFF)
001758  3                       LDY     #$02+VIDEOBANK
001758  3                       STY     CLRTMP
001758  3               
001758  3               :
001758  3                       LDY     CLRTMP
001758  3                       JSR     PAGE_ENTER
001758  3               
001758  3                       LDA     #$00
001758  3                       TAY
001758  3                       STA     TEMPW
001758  3                       LDA     #$A0
001758  3                       STA     TEMPW+1
001758  3                       LDA     #$00
001758  3               :
001758  3                       STA     (TEMPW),Y
001758  3                       INC     TEMPW
001758  3                       BNE     :-
001758  3                       INC     TEMPW+1
001758  3                       LDX     TEMPW+1
001758  3                       CPX     #$B0
001758  3                       BNE     :-
001758  3                       LDX     #$A0
001758  3                       INC     CLRTMP
001758  3                       LDX     CLRTMP
001758  3                       CPX     #$00
001758  3                       BNE     :--
001758  3                       JSR     PAGE_EXIT
001758  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE THIRD PARAMETER, RETURN IN X
001758  3                       CPX     #$00
001758  3                       BNE     SETUPMODE2_MIXED
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$02
001758  3                       STA     VideoMixedMode
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               SETUPMODE2_MIXED:
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     #$01
001758  3                       STA     VideoMixedMode
001758  3                       JSR     PAGE_EXIT
001758  3                       LDA     VIDEOMODE
001758  3                       ORA     #$80
001758  3                       STA     VIDEOMODE
001758  3                       RTS
001758  3               
001758  3               
001758  3               
001758  3               PAGE_EXIT:
001758  3                       LDA     #$00
001758  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 00
001758  3                       RTS
001758  3               
001758  3               PAGE_ENTER:
001758  3               ; Set "Y" register to video page ($YXXX)
001758  3                       LDA     #$01            ; MODIFY TASK 01 (DRIVER TASK)
001758  3                       LDX     #$0A            ; MAP $AXXX
001758  3                       JSR     SETPAGE         ; CALL SETPAGE
001758  3                       LDA     #$01
001758  3                       STA     PC6502_ACT_TASK ; SET ACTIVE TASK TO 01
001758  3                       RTS
001758  3               
001758  3               ;___V_PLOT__________________________________________________
001758  3               ;
001758  3               ;  PLOT ON SCREEN
001758  3               ;         TAKES THREE PARAMETERS,  X,Y,COLOR
001758  3               ;
001758  3               ;__________________________________________________________
001758  3               LAB_PLOT:
001758  3               V_PLOT:
001758  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001758  3                                               ; else do type mismatch
001758  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001758  3                       LDA     Itemph
001758  3                       STA     PLOTX+1
001758  3                       LDA     Itempl
001758  3                       STA     PLOTX
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3                       STX     PLOTY           ; STORE IN PLOTY
001758  3                       LDA     #$00
001758  3                       STA     PLOTY+1
001758  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; RETURN IN X
001758  3                       STX     PLOTCOLOR
001758  3               DOPLOTXY:
001758  3                                               ; PARAMETERS PARSED, GO TO PROPER MODE CODE
001758  3                       LDA     VIDEOMODE
001758  3                       AND     #$0F
001758  3                       CMP     #$01
001758  3                       BEQ     V_PLOT_LORES
001758  3                       LDA     VIDEOMODE
001758  3                       AND     #$2F
001758  3                       CMP     #$02
001758  3                       BNE     :+
001758  3                       JMP     V_PLOT_HIRES_COLOR
001758  3               :
001758  3                       CMP     #$22
001758  3                       BNE     :+
001758  3                       JMP     V_PLOT_HIRES_MONO
001758  3               :
001758  3                       RTS
001758  3               
001758  3               V_PLOT_LORES:
001758  3                       LDA     PLOTY
001758  3                       PHA
001758  3                       LSR     A               ; 2 LINES PER BYTE
001758  3                       STA     PLOTY
001758  3                                               ; MULTIPLY Y (PTEMPW) COORD BY 40 OR 80 (SINGLE OR DOUBLE LORES)
001758  3                       CLC
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*4)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*8)
001758  3                       LDA     PLOTY
001758  3                       STA     PTEMPW
001758  3                       LDA     PLOTY+1
001758  3                       STA     PTEMPW+1        ; STORE Y*8 INTO PTEMPW
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*16)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*32)
001758  3               ; NOW TAKE Y*8(PTEMPW) + Y*32(PLOTY) == Y*40 STORE IN PLOTY
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3               
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
001758  3                       STA     PLOTY           ; Store the low byte of the result
001758  3               
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PTEMPW+1        ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     PLOTY+1         ; Store the high byte of the result
001758  3               
001758  3               ; if double lores columns double it.
001758  3                       LDA     VIDEOMODE
001758  3                       AND     #$10
001758  3                       CMP     #00
001758  3                       BEQ     :+
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2
001758  3               :
001758  3               ; OK, Y OFFSET IS IN PTEMPW1, X IS IN PTEMPW
001758  3                       LDA     #$A0            ; ADD THE MEMORY OFFSET TO PTEMPW (BECAUSE IT IS EASY)
001758  3                       STA     PLOTX+1         ; THEN ADD PTEMPW1 TO PTEMPW THAT SHOULD BE THE MEMORY ADDRESS TO UPDATE
001758  3                                               ;
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTX           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PLOTY           ; Add the low byte of the second number (plus carry)
001758  3                       STA     TEMPW           ; Store the low byte of the result
001758  3               
001758  3                       LDA     PLOTX+1         ; Load the high byte of the first number
001758  3                       ADC     PLOTY+1         ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     TEMPW+1         ; Store the high byte of the result
001758  3                                               ; PTEMPW IS THE MEMORY OFFSET TO UPDATE
001758  3                       PLA
001758  3                       LSR     A               ; TOP OR BOTTOM PIXEL?
001758  3                       BCC     :+
001758  3                                               ; TOP PIXEL
001758  3                       LDY     #$02+VIDEOBANK  ; AREA $2000-$2FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDY     #$00
001758  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
001758  3                       AND     #$0F
001758  3                       PHA
001758  3                       LDA     PLOTCOLOR
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       STA     PLOTCOLOR
001758  3                       PLA
001758  3                       ORA     PLOTCOLOR
001758  3                       STA     (TEMPW),Y       ; STORE  DOUBLE PIXEL
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               :
001758  3                                               ; BOTTOM PIXEL
001758  3                       LDY     #$02+VIDEOBANK  ; AREA $2000-$2FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       LDY     #$00
001758  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
001758  3                       AND     #$F0
001758  3                       ORA     PLOTCOLOR
001758  3                       STA     (TEMPW),Y       ; STORE  DOUBLE PIXEL
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               
001758  3               V_PLOT_HIRES_COLOR:
001758  3                       LDA     PLOTX
001758  3                       PHA                     ; PUSH LOW BYTE OF X (FOR EVEN/ODD LATER)
001758  3                       LSR     PLOTX+1
001758  3                       ROR     PLOTX           ; 2 PIXEL PER BYTE
001758  3                       LDA     PLOTX           ;
001758  3                                               ; FIGURE THE BUFFER OFFSET
001758  3                       CLC                     ; MULTIPLY Y COORD BY 70 OR 140 (SINGLE OR DOUBLE HIRES)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2
001758  3                       LDA     PLOTY
001758  3                       STA     PTEMPW
001758  3                       LDA     PLOTY+1
001758  3                       STA     PTEMPW+1        ; STORE Y*2 INTO PTEMPW
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*4)
001758  3                       LDA     PLOTY
001758  3                       STA     PTEMPW1
001758  3                       LDA     PLOTY+1
001758  3                       STA     PTEMPW1+1       ; STORE Y*4 INTO PTEMPW1
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*8)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*16)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*32)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*64)
001758  3                                               ; RESULT OFFSET PLOTY = PLOTY(Y*64)+PTEMPW(Y*2)+PTEMPW1(Y*4)
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
001758  3                       STA     PLOTY           ; Store the low byte of the result
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PTEMPW+1        ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     PLOTY+1         ; Store the high byte of the result
001758  3               
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
001758  3                       STA     PLOTY           ; Store the low byte of the result
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     PLOTY+1         ; Store the high byte of the result
001758  3               
001758  3               ; if double hires double it.
001758  3                       LDA     VIDEOMODE
001758  3                       AND     #$10
001758  3                       CMP     #00
001758  3                       BEQ     :+
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2
001758  3               :
001758  3               ; PLOTY IS NOW Y OFFSET, ADD X OFFSET FOR MEMORY ADDRESS INTO TEMPW
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PLOTX           ; Add the low byte of the second number (plus carry)
001758  3                       STA     TEMPW           ; Store the low byte of the result
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PLOTX+1         ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     TEMPW+1         ; Store the high byte of the result
001758  3               
001758  3                       LDA     TEMPW+1         ; OK, LET'S CALCULATE THE BANK
001758  3                       AND     #$F0
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       CLC
001758  3                       ADC     #$02+VIDEOBANK  ; AREA $2000-?
001758  3                       CMP     #$F8
001758  3                       BCC     V_PLOT_HIRES_COLOR_RANGE
001758  3                       TAY                     ; VIDEO BANK SHOULD BE IN Y
001758  3                       JSR     PAGE_ENTER
001758  3               
001758  3                       LDA     TEMPW+1
001758  3                       AND     #$0F
001758  3                       ORA     #$A0
001758  3                       STA     TEMPW+1         ; TEMPW NOW REFLECTS MAPPED ADDRESSS
001758  3                       PLA
001758  3                       LSR     A               ; LEFT OR RIGHT PIXEL?
001758  3                       BCC     :+
001758  3                                               ; LEFT PIXEL
001758  3                       LDY     #$00
001758  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
001758  3                       AND     #$0F
001758  3                       PHA
001758  3                       LDA     PLOTCOLOR
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       ASL     A
001758  3                       STA     PLOTCOLOR
001758  3                       PLA
001758  3                       ORA     PLOTCOLOR
001758  3                       STA     (TEMPW),Y       ; WRITE THE PIXEL BACK OUT
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               :
001758  3               ; RIGHT PIXEL
001758  3                       LDY     #$00
001758  3                       LDA     (TEMPW),Y       ; GET EXISTING DOUBLE PIXEL
001758  3                       AND     #$F0
001758  3                       ORA     PLOTCOLOR
001758  3                       STA     (TEMPW),Y       ; WRITE THE PIXEL BACK OUT
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               
001758  3               V_PLOT_HIRES_COLOR_RANGE:
001758  3                       JMP     LAB_2564
001758  3               
001758  3               V_PLOT_HIRES_MONO:
001758  3                       LDA     PLOTX
001758  3                       PHA
001758  3                       LSR     PLOTX+1
001758  3                       ROR     PLOTX
001758  3                       LSR     PLOTX+1
001758  3                       ROR     PLOTX
001758  3                       LSR     PLOTX+1
001758  3                       ROR     PLOTX           ; 8 PIXEL PER BYTE
001758  3                       LDA     #00
001758  3                       STA     PLOTX+1
001758  3                       STA     PTEMPW1+1
001758  3                       LDA     PLOTY
001758  3                       STA     PTEMPW1
001758  3                                               ; MULTIPLY Y COORD BY 35 OR 70 (MONO OR QUAD HIRES)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2
001758  3                       LDA     PLOTY
001758  3                       STA     PTEMPW
001758  3                       LDA     PLOTY+1
001758  3                       STA     PTEMPW+1        ; STORE *2 INTO PTEMPW
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*4)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*8)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*16)
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2 (*32)
001758  3               ;
001758  3               ; PLOTY(Y*35) = PLOTY(Y*32)+PTEMPW(Y*2)+PTEMPW1(Y)
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
001758  3                       STA     PLOTY           ; Store the low byte of the result
001758  3               
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PTEMPW+1        ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     PLOTY+1         ; Store the high byte of the result
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
001758  3                       STA     PLOTY           ; Store the low byte of the result
001758  3               
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     PLOTY+1         ; Store the high byte of the result
001758  3               ;
001758  3               ; PLOTY IS NOW THE Y OFFSET
001758  3               ; if quad hires double it.
001758  3                       LDA     VIDEOMODE
001758  3                       AND     #$10
001758  3                       CMP     #00
001758  3                       BNE     :+
001758  3                       ASL     PLOTY
001758  3                       ROL     PLOTY+1         ; *2
001758  3               :
001758  3               ; ADD THE X OFFSET
001758  3                       CLC                     ; Clear the Carry flag before the first addition
001758  3                       LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001758  3                       ADC     PLOTX           ; Add the low byte of the second number (plus carry)
001758  3                       STA     TEMPW           ; Store the low byte of the result
001758  3               
001758  3                       LDA     PLOTY+1         ; Load the high byte of the first number
001758  3                       ADC     PLOTX+1         ; Add the high byte of the second number (plus carry from previous op)
001758  3                       STA     TEMPW+1         ; Store the high byte of the result
001758  3                                               ; TEMPW IS NOW THE MEMORY ADDRESS
001758  3               
001758  3                       LDA     TEMPW+1         ; OK, LET'S CALCULATE THE BANK
001758  3                       AND     #$F0
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       LSR     A
001758  3                       CLC
001758  3                       ADC     #$02+VIDEOBANK  ; AREA $2000-?
001758  3                       CMP     #$F8
001758  3                       BCC     V_PLOT_HIRES_COLOR_RANGE1
001758  3                       TAY                     ; VIDEO BANK SHOULD BE IN Y
001758  3                       JSR     PAGE_ENTER
001758  3                       LDA     TEMPW+1
001758  3                       AND     #$0F
001758  3                       ORA     #$A0
001758  3                       STA     TEMPW+1         ; TEMPW NOW REFLECTS MAPPED ADDRESSS
001758  3                       PLA
001758  3                       AND     #$07            ; WHICH BIT?
001758  3                       TAX
001758  3                       LDA     PLOTCOLOR
001758  3                       CMP     #$01
001758  3                       BNE     :+
001758  3                       LDA     HIRES_BIT_LOOKUP_SET,X
001758  3                       LDY     #$00
001758  3                       ORA     (TEMPW),Y
001758  3                       STA     (TEMPW),Y
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               :
001758  3                       LDA     HIRES_BIT_LOOKUP_RESET,X
001758  3                       PHA
001758  3                       LDY     #$00
001758  3                       AND     (TEMPW),Y
001758  3                       STA     (TEMPW),Y
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               V_PLOT_HIRES_COLOR_RANGE1:
001758  3                       JMP     LAB_2564
001758  3               HIRES_BIT_LOOKUP_SET:
001758  3                       .BYTE   %10000000,%01000000,%00100000,%00010000,%00001000,%00000100,%00000010,%00000001
001758  3               HIRES_BIT_LOOKUP_RESET:
001758  3                       .BYTE   %01111111,%10111111,%11011111,%11101111,%11110111,%11111011,%11111101,%11111110
001758  3               
001758  3               ;___V_PATTERN________________________________________________
001758  3               ;
001758  3               ;  DEFINE GRAPHICS PATTERN
001758  3               ;
001758  3               ;  TAKES 10 PARAMETERS
001758  3               ;       PATTERN NUM (0-255)
001758  3               ;       PATTERN DATA (8 BYTES)
001758  3               ;__________________________________________________________
001758  3               LAB_PATTERN
001758  3               V_PATTERN:
001758  3                       JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X
001758  3                       TXA
001758  3                       PHA
001758  3                       LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001758  3                       JSR     PAGE_ENTER
001758  3                       PLA
001758  3                       STA     VideoCharGenOffset
001758  3                       LDY     #8
001758  3               :
001758  3                       TYA
001758  3                       PHA
001758  3                       JSR     LAB_1C01        ; GET THE NEXT PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE NEXT PARAMETER, RETURN IN X
001758  3                       PLA
001758  3                       TAY
001758  3                       TXA
001758  3                       STA     VideoCharGenData
001758  3                       DEY
001758  3                       CPY     #$00
001758  3                       BNE     :-
001758  3                       JSR     PAGE_EXIT
001758  3                       RTS
001758  3               
001758  3               ;___LAB_LINE_______________________________________________
001758  3               ;
001758  3               ;  DRAW LINE USING THE BRESENHAM LINE DRAWING ALGORITHM
001758  3               ;
001758  3               ;  TAKES 5 PARAMETERS
001758  3               ;       START X,Y
001758  3               ;       DESTINATION X,Y
001758  3               ;       COLOR
001758  3               ;__________________________________________________________
001758  3               LAB_LINE:
001758  3               ; GET X1
001758  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001758  3                                               ; else do type mismatch
001758  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001758  3                       LDA     Itemph
001758  3                       STA     LINEX1+1
001758  3                       LDA     Itempl
001758  3                       STA     LINEX1
001758  3                                               ; GET Y1
001758  3                       JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001758  3                       STX     LINEY1          ; STORE IN LINEY1
001758  3               
001758  3               ; GET X2
001758  3                       JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001758  3                                               ; else do type mismatch
001758  3                       JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001758  3                       LDA     Itemph
001758  3                       STA     LINEX2+1
001758  3                       LDA     Itempl
001758  3                       STA     LINEX2
001758  3                                               ; GET Y2
001758  3                       JSR     LAB_1C01        ; GET THE FOURTH PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; RETURN IN X
001758  3                       STX     LINEY2          ; STORE IN LINEY2
001758  3                                               ; GET COLOR
001758  3                       JSR     LAB_1C01        ; GET THE FIFTH PARAMETER (AFTER ',') OR SYN ERR
001758  3                       JSR     LAB_GTBY        ; RETURN IN X
001758  3                       STX     LINECOLOR       ; STORE IN COLOR
001758  3                       LDA     #$00
001758  3                       STA     LINEY1+1
001758  3                       STA     LINEY2+1
001758  3                                               ; LINE COORDS AND COLOR STORED IN PROPER PLACE
001758  3                                               ; CALCULATE DELTAX
001758  3                       SEC                     ; Set Carry flag (represents "no borrow" for 1st byte)
001758  3                       LDA     LINEX1          ; Load low byte of number 1
001758  3                       SBC     LINEX2          ; Subtract low byte of number 2 with carry
001758  3                       STA     DELTAX          ; Store result low byte
001758  3                       LDA     LINEX1+1        ; Load high byte of number 1
001758  3                       SBC     LINEX2+1        ; Subtract high byte of number 2 with borrow
001758  3                       STA     DELTAX+1        ; Store result high byte
001758  3                       BCS     :+              ; BRANCH IF X1>=X2
001758  3                                               ; X1 < X2
001758  3                       LDA     #0
001758  3                       STA     PTEMP           ; IF X2>X1 (PTEMP=x0)
001758  3                       LDA     #$FF            ; TAKE ABSOLUTE VALUE OF DELTAX
001758  3                       EOR     DELTAX+1        ; Invert high byte (one's complement)
001758  3                       STA     DELTAX+1
001758  3                       LDA     #$FF            ;
001758  3                       EOR     DELTAX          ; Invert low byte
001758  3                       STA     DELTAX          ;
001758  3                       INC     DELTAX          ; Add 1 to the low byte
001758  3                       BNE     :++             ; If no carry from low byte INC, we are done
001758  3                       INC     DELTAX+1        ; Increment high byte if carry occurred
001758  3                       JMP     :++
001758  3               :
001758  3                       LDA     #1
001758  3                       STA     PTEMP           ; IF X1>X2 (PTEMP=x1)
001758  3               :
001758  3                                               ; CALCULATE DELTAY
001758  3                       LDA     #0
001758  3                       STA     DELTAY+1
001758  3                       SEC                     ; Set Carry flag
001758  3                       LDA     LINEY1          ; Load low byte of number 1
001758  3                       SBC     LINEY2          ; Subtract low byte of number 2 with carry
001758  3                       STA     DELTAY          ; Store result low byte
001758  3                       BCS     :+              ; BRANCH IF Y1>=Y2
001758  3                                               ; Y1 < Y2
001758  3                       LDA     PTEMP
001758  3                       AND     #1
001758  3                       STA     PTEMP           ; IF Y2>Y1 (PTEMP=0x)
001758  3                                               ; TAKE ABSOLUTE VALUE OF DELTAY
001758  3                       LDA     #$FF
001758  3                       EOR     DELTAY          ; Flip all bits (one's complement)
001758  3                       STA     DELTAY
001758  3                       INC     DELTAY          ; Add 1 (two's complement)
001758  3                       JMP     :++
001758  3               :
001758  3                       LDA     PTEMP
001758  3                       ORA     #$10
001758  3                       STA     PTEMP           ; IF Y1>Y2 (PTEMP=1x)
001758  3               :
001758  3                                               ; SLOPE DETERMINED, AND DELTAS CALCULATED
001758  3                                               ; OK, LET'S FIND OUT IF THIS IS A HORIZONTAL-ISH
001758  3                                               ; OR VERTICAL-ISH LINE
001758  3                       SEC                     ; Set Carry Flag (for subtraction)
001758  3                       LDA     DELTAX          ; Load low byte of DELTAX
001758  3                       SBC     DELTAY          ; Subtract low byte of DELTAY
001758  3                       LDA     DELTAX+1        ; Load high byte of DELTAX
001758  3                       SBC     DELTAY+1        ; Subtract high byte of DELTAY (with borrow)
001758  3                                               ; Flags now reflect the 16-bit comparison
001758  3                       BCC     LINEVERT        ; If Carry clear, LINE IS VERTICAL-ISH
001758  3                       JMP     LINEHORZ
001758  3               LINEVERT:
001758  3                                               ; FOR A VERTICAL-ISH LINE WE STEP ALONG THE
001758  3                                               ; Y AXIS (STEEP GRADIENT)
001758  3                                               ; FIND LARGER Y . . .
001758  3                       LDA     LINEY1
001758  3                       CMP     LINEY2
001758  3                       BCS     :+
001758  3                       JSR     LINESWAPXY
001758  3               :
001758  3                                               ; Initialize error = DELTAY / 2
001758  3                       LDA     DELTAY
001758  3                       STA     LINEERR
001758  3                       LDA     DELTAY+1
001758  3                       STA     LINEERR+1
001758  3                       LSR     LINEERR+1
001758  3                       ROR     LINEERR
001758  3               LINEVERTLOOP:
001758  3                       LDA     LINEY1          ; OK LET'S PLOT A POINT
001758  3                       STA     PLOTY
001758  3                       LDA     LINEY1+1
001758  3                       STA     PLOTY+1
001758  3                       LDA     LINEX1
001758  3                       STA     PLOTX
001758  3                       LDA     LINEX1+1
001758  3                       STA     PLOTX+1
001758  3                       LDA     LINECOLOR
001758  3                       STA     PLOTCOLOR
001758  3                       JSR     DOPLOTXY
001758  3                                               ; NOW MOVE LINE1 CLOSER TO LINE2
001758  3                       DEC     LINEY1          ; BY STEPPING ALONG Y AXIS
001758  3               
001758  3               ; BRESENHAM: err -= DELTAX
001758  3                       SEC
001758  3                       LDA     LINEERR
001758  3                       SBC     DELTAX
001758  3                       STA     LINEERR
001758  3                       LDA     LINEERR+1
001758  3                       SBC     DELTAX+1
001758  3                       STA     LINEERR+1
001758  3                       BPL     LINEVERT_NOSTEP ; IF ERR >= 0, NO X STEP NEEDED
001758  3                                               ; ERR += DELTAY (RESTORE ERROR)
001758  3                       CLC
001758  3                       LDA     LINEERR
001758  3                       ADC     DELTAY
001758  3                       STA     LINEERR
001758  3                       LDA     LINEERR+1
001758  3                       ADC     DELTAY+1
001758  3                       STA     LINEERR+1
001758  3                                               ; STEP X TOWARD X2 (16-BIT)
001758  3                       LDA     LINEX2
001758  3                       CMP     LINEX1
001758  3                       LDA     LINEX2+1
001758  3                       SBC     LINEX1+1
001758  3                       BCC     LINEVERT_DECX   ; X2 < X1, DECREMENT X1
001758  3                       INC     LINEX1          ; X2 >= X1, INCREMENT X1
001758  3                       BNE     LINEVERT_NOSTEP
001758  3                       INC     LINEX1+1
001758  3                       JMP     LINEVERT_NOSTEP
001758  3               LINEVERT_DECX:
001758  3                       LDA     LINEX1
001758  3                       BNE     :+
001758  3                       DEC     LINEX1+1
001758  3               :
001758  3                       DEC     LINEX1
001758  3               LINEVERT_NOSTEP:
001758  3               
001758  3                       LDA     LINEY1
001758  3                       CMP     LINEY2
001758  3                       BNE     LINEVERTLOOP
001758  3                       RTS                     ; DONE
001758  3               
001758  3               LINEHORZ:
001758  3               ; FOR A HORIZONTAL-ISH LINE WE STEP ALONG THE
001758  3               ; X AXIS (SHALLOW GRADIENT)
001758  3               ; FIND LARGER X . . .
001758  3                       SEC                     ; Set carry flag for subtraction
001758  3                       LDA     LINEX2          ; Load low byte of first number
001758  3                       SBC     LINEX1          ; Subtract low byte of second number
001758  3                       LDA     LINEX2+1        ; Load high byte of first number
001758  3                       SBC     LINEX1+1        ; Subtract high byte of second number
001758  3                                               ; Result flags (N, Z, C) now reflect: Val1 - Val2
001758  3                       BCS     :+              ; If carry is set, LINEX2 >= LINEX1
001758  3                       JSR     LINESWAPXY
001758  3               :
001758  3                                               ; Initialize error = DELTAX / 2
001758  3                       LDA     DELTAX
001758  3                       STA     LINEERR
001758  3                       LDA     DELTAX+1
001758  3                       STA     LINEERR+1
001758  3                       LSR     LINEERR+1
001758  3                       ROR     LINEERR
001758  3               LINEHORZLOOP:
001758  3                       LDA     LINEY1          ; OK LET'S PLOT A POINT
001758  3                       STA     PLOTY
001758  3                       LDA     LINEY1+1
001758  3                       STA     PLOTY+1
001758  3                       LDA     LINEX1
001758  3                       STA     PLOTX
001758  3                       LDA     LINEX1+1
001758  3                       STA     PLOTX+1
001758  3                       LDA     LINECOLOR
001758  3                       STA     PLOTCOLOR
001758  3                       JSR     DOPLOTXY
001758  3                                               ; NOW MOVE LINE1 CLOSER TO LINE2
001758  3                       INC     LINEX1          ; BY STEPPING ALONG X AXIS
001758  3                       BNE     :+
001758  3                       INC     LINEX1+1
001758  3               :
001758  3                                               ; BRESENHAM: err -= DELTAY
001758  3                       SEC
001758  3                       LDA     LINEERR
001758  3                       SBC     DELTAY
001758  3                       STA     LINEERR
001758  3                       LDA     LINEERR+1
001758  3                       SBC     DELTAY+1
001758  3                       STA     LINEERR+1
001758  3                       BPL     LINEHORZ_NOSTEP ; IF ERR >= 0, NO Y STEP NEEDED
001758  3                                               ; ERR += DELTAX (RESTORE ERROR)
001758  3                       CLC
001758  3                       LDA     LINEERR
001758  3                       ADC     DELTAX
001758  3                       STA     LINEERR
001758  3                       LDA     LINEERR+1
001758  3                       ADC     DELTAX+1
001758  3                       STA     LINEERR+1
001758  3                                               ; STEP Y TOWARD Y2
001758  3                       LDA     LINEY2
001758  3                       CMP     LINEY1
001758  3                       BCC     LINEHORZ_DECY   ; Y2 < Y1, DECREMENT
001758  3                       INC     LINEY1          ; Y2 >= Y1, INCREMENT
001758  3                       JMP     LINEHORZ_NOSTEP
001758  3               LINEHORZ_DECY:
001758  3                       DEC     LINEY1
001758  3               LINEHORZ_NOSTEP:
001758  3               
001758  3                       LDA     LINEX1
001758  3                       CMP     LINEX2
001758  3                       BNE     LINEHORZLOOP
001758  3                       LDA     LINEX1+1
001758  3                       CMP     LINEX2+1
001758  3                       BNE     LINEHORZLOOP
001758  3                       RTS                     ; DONE
001758  3               
001758  3               LINESWAPXY:
001758  3                       LDA     LINEX1
001758  3                       LDY     LINEX2
001758  3                       STY     LINEX1
001758  3                       STA     LINEX2
001758  3                       LDA     LINEX1+1
001758  3                       LDY     LINEX2+1
001758  3                       STY     LINEX1+1
001758  3                       STA     LINEX2+1
001758  3               ;
