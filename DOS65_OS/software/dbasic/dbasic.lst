001185  3               ;___SAVE____________________________________________________
001185  3               ;
001185  3               ; SAVE COMMAND
001185  3               ;
001185  3               ;  SAVE THE BASIC PROGRAM IN MEMORY TO DISK
001185  3               ;
001185  3               ;__________________________________________________________
001185  3               V_SAVE: ; save BASIC program
001185  3               DOS65SAVE:
001185  3  20 F8 12             JSR     DOS65FCBPREP    ; parse parameters into FCB
001188  3  B0 28                BCS     DOS65SAVE_ERR1  ; Error?, if so abort
00118A  3  A2 0D                LDX     #13             ;
00118C  3  20 7F 11             JSR     PEM             ;
00118F  3  A9 16                LDA     #<FCB           ; CREATE File
001191  3  A0 17                LDY     #>FCB           ;
001193  3  A2 16                LDX     #22             ;
001195  3  20 7F 11             JSR     PEM             ;
001198  3  A9 00                LDA     #0              ; clear
00119A  3  8D 36 17             STA     FCB+32          ; record number
00119D  3  A9 16                LDA     #<FCB           ; Open File
00119F  3  A0 17                LDY     #>FCB           ;
0011A1  3  A2 0F                LDX     #15             ;
0011A3  3  20 7F 11             JSR     PEM             ;
0011A6  3  C9 FF                CMP     #$FF            ; error?, if NOT, continue
0011A8  3  D0 0B                BNE     DOS65SAVE_1     ;
0011AA  3               DOS65SAVE_ERR:
0011AA  3  A2 24                LDX     #$24            ; IO ERROR
0011AC  3  20 A9 1A             JSR     LAB_XERR
0011AF  3  4C 81 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
0011B2  3               DOS65SAVE_ERR1:
0011B2  3  4C 82 20             JMP     LAB_REM         ; comment out the remainder of the line (if any)
0011B5  3               DOS65SAVE_1:
0011B5  3  A9 0A                LDA     #<FCBBUFFER     ; SETUP BUFFER
0011B7  3  85 20                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
0011B9  3  A0 3A                LDY     #>FCBBUFFER     ;
0011BB  3  84 21                STY     FCBPTR+1        ;
0011BD  3  A2 1A                LDX     #26             ; Setup Buffer
0011BF  3  20 7F 11             JSR     PEM             ;
0011C2  3               DOS65SAVE_2:
0011C2  3  A5 79                LDA     <Smeml          ; All is well, file opened and continue
0011C4  3  85 22                STA     FCBPTR+2        ; point to base of RAM
0011C6  3  A5 7A                LDA     <Smemh          ;
0011C8  3  85 23                STA     FCBPTR+3        ;
0011CA  3  A2 00                LDX     #$00            ; x=0 (null counter)
0011CC  3               DOS65SAVE_2A:
0011CC  3  A0 00                LDY     #$00            ; y=0 (Loop Index)
0011CE  3               DOS65SAVE_3:
0011CE  3  B1 22                LDA     (FCBPTR+2),Y    ; load from RAM
0011D0  3  91 20                STA     (FCBPTR),Y      ; save to Buffer
0011D2  3  C9 00                CMP     #$00            ; is Zero?
0011D4  3  D0 1E                BNE     DOS65SAVE_3A    ; No, continue
0011D6  3  E8                   INX                     ; yes, bump Null Counter
0011D7  3  E0 03                CPX     #$03            ; Three nulls in a row?
0011D9  3  D0 1B                BNE     DOS65SAVE_3B    ; No, continue
0011DB  3                                               ; FINISH FILLING BUFFER WITH NULLS
0011DB  3               :
0011DB  3  91 20                STA     (FCBPTR),Y      ; save to Buffer
0011DD  3  C8                   INY                     ; bump index
0011DE  3  C0 80                CPY     #$80            ; end of buffer?
0011E0  3  D0 F9                BNE     :-              ; no, loop
0011E2  3  A9 16                LDA     #<FCB           ; Write record in buffer to disk file AND END
0011E4  3  A0 17                LDY     #>FCB           ;
0011E6  3  A2 15                LDX     #21             ;
0011E8  3  20 7F 11             JSR     PEM             ;
0011EB  3  29 FE                AND     #$FE            ; strip out extension
0011ED  3  C9 00                CMP     #$00            ; is error
0011EF  3  D0 B9                BNE     DOS65SAVE_ERR   ; ERROR, do error handling
0011F1  3  4C 21 12             JMP     DOS65SAVE_4
0011F4  3               DOS65SAVE_3A:                   ;
0011F4  3  A2 00                LDX     #$00            ; prior char not null, reset null counter
0011F6  3               DOS65SAVE_3B:                   ;
0011F6  3  C8                   INY                     ; bump index
0011F7  3  C0 80                CPY     #$80            ; end of buffer?
0011F9  3  D0 D3                BNE     DOS65SAVE_3     ; no, loop
0011FB  3               DOS65SAVE_3C:
0011FB  3  A9 16                LDA     #<FCB           ; Write record in buffer to disk file
0011FD  3  A0 17                LDY     #>FCB           ;
0011FF  3  A2 15                LDX     #21             ;
001201  3  20 7F 11             JSR     PEM             ;
001204  3  29 FE                AND     #$FE            ; strip out extension
001206  3  C9 00                CMP     #$00            ; is error
001208  3  D0 A0                BNE     DOS65SAVE_ERR   ; ERROR, do error handling
00120A  3  18                   CLC                     ;
00120B  3  A5 22                LDA     FCBPTR+2        ; add $80 to base counter
00120D  3  69 80                ADC     #$80            ;
00120F  3  85 22                STA     FCBPTR+2        ;
001211  3  90 B9                BCC     DOS65SAVE_2A    ; is carry?, no loop
001213  3  18                   CLC                     ; yes, carry, inc high byte
001214  3  A5 23                LDA     FCBPTR+3        ;
001216  3  69 01                ADC     #$01            ;
001218  3  85 23                STA     FCBPTR+3        ;
00121A  3  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
00121C  3  F0 03                BEQ     DOS65SAVE_4
00121E  3  4C CC 11             JMP     DOS65SAVE_2A
001221  3               DOS65SAVE_4:
001221  3  A9 16                LDA     #<FCB           ;
001223  3  A0 17                LDY     #>FCB           ;
001225  3  A2 10                LDX     #16             ;
001227  3  20 7F 11             JSR     PEM             ;
00122A  3  C9 FF                CMP     #$FF            ;
00122C  3  D0 03                BNE     DOS65SAVE_5     ;
00122E  3  4C AA 11             JMP     DOS65SAVE_ERR   ; ERROR, DISPLAY IT
001231  3               DOS65SAVE_5:
001231  3  A9 AA                LDA     #<LAB_RMSG      ; point to "Ready" message low byte
001233  3  A0 0F                LDY     #>LAB_RMSG      ; point to "Ready" message high byte
001235  3  20 29 22             JSR     LAB_18C3
001238  3  4C 81 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
00123B  3               
00123B  3               ;___LOAD____________________________________________________
00123B  3               ;
00123B  3               ; LOAD COMMAND
00123B  3               ;
00123B  3               ;  LOAD A BASIC PROGRAM FROM DISK TO MEMORY
00123B  3               ;
00123B  3               ;__________________________________________________________
00123B  3               V_LOAD: ; load BASIC program
00123B  3               DOS65LOAD:
00123B  3  A9 00                LDA     #$00
00123D  3  8D 3C 13             STA     NullCounter
001240  3  20 F8 12             JSR     DOS65FCBPREP    ; parse parameters into FCB
001243  3  B0 1F                BCS     DOS65LOAD_ERR1  ; Error?, if so abort
001245  3  A2 0D                LDX     #13             ;
001247  3  20 7F 11             JSR     PEM             ;
00124A  3  A9 00                LDA     #0              ; clear
00124C  3  8D 36 17             STA     FCB+32          ; record number
00124F  3  A9 16                LDA     #<FCB           ; Open File
001251  3  A0 17                LDY     #>FCB           ;
001253  3  A2 0F                LDX     #15             ;
001255  3  20 7F 11             JSR     PEM             ;
001258  3  C9 FF                CMP     #$FF            ; error?, if NOT, continue
00125A  3  D0 0B                BNE     DOS65LOAD_1     ;
00125C  3               DOS65LOAD_ERR:
00125C  3  A2 24                LDX     #$24            ; IO ERROR
00125E  3  20 A9 1A             JSR     LAB_XERR
001261  3  4C 81 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
001264  3               DOS65LOAD_ERR1:
001264  3  4C 82 20             JMP     LAB_REM         ; comment out the remainder of the line (if any)
001267  3               DOS65LOAD_1:
001267  3  A5 79                LDA     <Smeml          ; All is well, file opened and continue
001269  3  85 22                STA     FCBPTR+2        ; point to base of RAM
00126B  3  8D 3A 13             STA     EndOfBas        ;
00126E  3  A5 7A                LDA     <Smemh          ;
001270  3  85 23                STA     FCBPTR+3        ;
001272  3  8D 3B 13             STA     EndOfBas+1      ;
001275  3  A9 0A                LDA     #<FCBBUFFER     ; SETUP BUFFER
001277  3  85 20                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
001279  3  A0 3A                LDY     #>FCBBUFFER     ;
00127B  3  84 21                STY     FCBPTR+1        ; STORE DEST BUFFER IN FCBPTR
00127D  3  A2 1A                LDX     #26             ; Setup Buffer
00127F  3  20 7F 11             JSR     PEM             ;
001282  3  4C C0 12             JMP     DOS65LOAD_3C
001285  3               DOS65LOAD_3:
001285  3  B1 20                LDA     (FCBPTR),Y      ; load from BUFFER
001287  3  91 22                STA     (FCBPTR+2),Y    ; save to RAM
001289  3  EE 3A 13             INC     EndOfBas
00128C  3  D0 03                BNE     :+
00128E  3  EE 3B 13             INC     EndOfBas+1
001291  3               :
001291  3  C9 00                CMP     #$00
001293  3  D0 0D                BNE     :+
001295  3  EE 3C 13             INC     NullCounter
001298  3  AD 3C 13             LDA     NullCounter
00129B  3  C9 03                CMP     #3
00129D  3  D0 08                BNE     :++
00129F  3  4C D3 12             JMP     DOS65LOAD_4
0012A2  3               :
0012A2  3  A9 00                LDA     #$00
0012A4  3  8D 3C 13             STA     NullCounter
0012A7  3               :
0012A7  3  C8                   INY                     ; bump index
0012A8  3  C0 80                CPY     #$80            ; end of buffer?
0012AA  3  D0 D9                BNE     DOS65LOAD_3     ; no, loop
0012AC  3  18                   CLC                     ;
0012AD  3  A5 22                LDA     FCBPTR+2        ; add $80 to base counter
0012AF  3  69 80                ADC     #$80            ;
0012B1  3  85 22                STA     FCBPTR+2        ;
0012B3  3  90 0B                BCC     DOS65LOAD_3C    ; is carry?, no SKIP
0012B5  3  18                   CLC                     ; yes, carry, inc high byte
0012B6  3  A5 23                LDA     FCBPTR+3        ;
0012B8  3  69 01                ADC     #$01            ;
0012BA  3  85 23                STA     FCBPTR+3        ;
0012BC  3  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
0012BE  3  F0 13                BEQ     DOS65LOAD_4
0012C0  3               
0012C0  3               DOS65LOAD_3C:
0012C0  3  A9 16                LDA     #<FCB           ; READ record buffer from disk file
0012C2  3  A0 17                LDY     #>FCB           ;
0012C4  3  A2 14                LDX     #20             ;
0012C6  3  20 7F 11             JSR     PEM             ;
0012C9  3  A0 00                LDY     #$00            ; RESET INDEX
0012CB  3  C9 00                CMP     #$00            ; is error or EOF
0012CD  3  F0 B6                BEQ     DOS65LOAD_3     ;
0012CF  3  C9 01                CMP     #$01            ; EOF?
0012D1  3  D0 89                BNE     DOS65LOAD_ERR   ; ERROR, do error handling
0012D3  3               DOS65LOAD_4:
0012D3  3  A9 16                LDA     #<FCB           ;
0012D5  3  A0 17                LDY     #>FCB           ;
0012D7  3  A2 10                LDX     #16             ;
0012D9  3  20 7F 11             JSR     PEM             ;
0012DC  3                                               ; setup pointers to return to basic
0012DC  3  AD 3A 13             LDA     EndOfBas
0012DF  3  85 7B                STA     Svarl
0012E1  3  85 7D                STA     Sarryl
0012E3  3  85 7F                STA     Earryl
0012E5  3  AD 3B 13             LDA     EndOfBas+1
0012E8  3  85 7C                STA     Svarh
0012EA  3  85 7E                STA     Sarryh
0012EC  3  85 80                STA     Earryh
0012EE  3  A9 AA                LDA     #<LAB_RMSG      ; point to "Ready" message low byte
0012F0  3  A0 0F                LDY     #>LAB_RMSG      ; point to "Ready" message high byte
0012F2  3  20 29 22             JSR     LAB_18C3
0012F5  3  4C 81 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
0012F8  3               
0012F8  3               
0012F8  3               
0012F8  3               DOS65FCBPREP:
0012F8  3                       .IFDEF  DUODYNE
0012F8  3                       JSL     LAB_GBYT        ; scan memory
0012F8  3                       .ELSE
0012F8  3  20 C2 00             JSR     LAB_GBYT        ; scan memory
0012FB  3                       .ENDIF
0012FB  3               
0012FB  3  38                   SEC                     ;
0012FC  3  E9 40                SBC     #64             ; PARSE DRIVE NUMBER
0012FE  3  8D 16 17             STA     DOSDRIVE        ; STORE IT IN FCB
001301  3                       .IFDEF  DUODYNE
001301  3                       JSL     LAB_IGBY        ; increment and scan memory
001301  3                       .ELSE
001301  3  20 BC 00             JSR     LAB_IGBY        ; increment and scan memory
001304  3                       .ENDIF
001304  3               
001304  3  C9 3A                CMP     #':'            ;
001306  3  F0 08                BEQ     DOS65FCBPREP_1  ; YES, IT WAS A DRIVE, CONTINUE
001308  3  A2 26                LDX     #$26            ; IO ERROR
00130A  3  20 A9 1A             JSR     LAB_XERR
00130D  3  4C 81 1B             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
001310  3               
001310  3               DOS65FCBPREP_1:
