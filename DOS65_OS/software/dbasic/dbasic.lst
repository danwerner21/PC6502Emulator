00175D  3               ;__________________________________________________________
00175D  3               LAB_SOUND:
00175D  3  20 E4 2D             JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
001760  3  DA                   PHX
001761  3  20 53 25             JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
001764  3  20 21 24             JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001767  3               ; else do type mismatch
001767  3  20 4A 2E             JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
00176A  3               
00176A  3  68                   PLA                     ; LIMIT THE CHANNELS TO <3
00176B  3  29 03                AND     #$03
00176D  3  18                   CLC
00176E  3  0A                   ASL                     ; = *2
00176F  3  48                   PHA
001770  3  A4 11                LDY     <Itempl
001772  3  20 82 18             JSR     psgwr           ; SET LOW BYTE
001775  3  68                   PLA
001776  3  1A                   INC     A
001777  3  A4 12                LDY     <Itemph
001779  3  20 82 18             JSR     psgwr           ; SET HIGH BYTE
00177C  3  60                   RTS
