0013BB  3               ; DRIVE,MODE, FILENAME$,FILE$
0013BB  3               ;
0013BB  3               ; FILE$ = STRING TO HOLD 33 BYTE FCB
0013BB  3               ; DRIVE = NUMERIC DRIVE -- 0=CURRENT, 1=A, 2=B . . .
0013BB  3               ; MODE = 0=EXISTING, 1=CREATE
0013BB  3               ; FILENAME$ = FILENAME STRING
0013BB  3               ;__________________________________________________________
0013BB  3               V_OPEN:
