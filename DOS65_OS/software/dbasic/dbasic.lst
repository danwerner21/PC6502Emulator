000803  2               Rbyte1          = Rbyte4+1      ; most significant PRNG byte
000803  2               Rbyte2          = Rbyte4+2      ; middle PRNG byte
000803  2               Rbyte3          = <Rbyte4+3     ; least significant PRNG byte
000803  2               NmiBase         = $E5           ; NMI handler enabled/setup/triggered flags
000803  2               ; bit	function
000803  2               ; ===	========
000803  2               ; 7	interrupt enabled
000803  2               ; 6	interrupt setup
000803  2               ; 5	interrupt happened
000803  2               ;			= $E6		; NMI handler addr low byte
000803  2               ;			= $E7		; NMI handler addr high byte
000803  2               IrqBase         = $E8           ; IRQ handler enabled/setup/triggered flags
000803  2               ;			= $E9		; IRQ handler addr low byte
000803  2               ;			= $EA		; IRQ handler addr high byte
000803  2               FCBPTR          = $20           ; POINTER TO FCB FOR FILE OPS
000803  2               Decss           = $EF           ; number to decimal string start
000803  2               Decssp1         = Decss+1       ; number to decimal string start
000803  2               TEMPW           = $FD
000803  2               ;			= $FF		; decimal string end
000803  2               
000803  2               ; character get subroutine for zero page
000803  2               
000803  2               ; For a 1.8432MHz 6502 including the JSR and RTS
000803  2               ; fastest (>=":")	=  29 cycles =  15.7uS
000803  2               ; slowest (<":")	=  40 cycles =  21.7uS
000803  2               ; space skip	= +21 cycles = +11.4uS
000803  2               ; inc across page	=  +4 cycles =  +2.2uS
000803  2               
000803  2               ; the target address for the LDA at LAB_2CF4 becomes the BASIC execute pointer once the
000803  2               ; block is copied to it's destination, any non zero page address will do at assembly
000803  2               ; time, to assemble a three byte instruction.
000803  2               
000803  2               ; page 0 initialisation table from $BC
000803  2               ; increment and scan memory
000803  2               
000803  2               LAB_2CEE:
000803  2  E6 C3                INC     Bpntrl          ; increment BASIC execute pointer low byte
000805  2  D0 02                BNE     LAB_2CF4        ; branch if no carry
000807  2               ; else
000807  2  E6 C4                INC     Bpntrh          ; increment BASIC execute pointer high byte
000809  2               
000809  2               ; page 0 initialisation table from $C2
000809  2               ; scan memory
000809  2                       .IFDEF  DUODYNE
000809  2               LAB_2CF4:
000809  2                       LDA     $FFFFFF         ; get byte to scan (addr set by call routine)
000809  2                       CMP     #TK_ELSE        ; compare with the token for ELSE
000809  2                       BEQ     LAB_2D05        ; exit if ELSE, not numeric, carry set
000809  2               
000809  2                       CMP     #':'            ; compare with ":"
000809  2                       BCS     LAB_2D05        ; exit if >= ":", not numeric, carry set
000809  2               
000809  2                       CMP     #' '            ; compare with " "
000809  2                       BEQ     LAB_2CEE        ; if " " go do next
000809  2               
000809  2                       SEC                     ; set carry for SBC
000809  2                       SBC     #'0'            ; subtract "0"
000809  2                       SEC                     ; set carry for SBC
000809  2                       SBC     #$D0            ; subtract -"0"
000809  2               ; clear carry if byte = "0"-"9"
000809  2               LAB_2D05:
000809  2                       RTL
000809  2                       .ELSE
000809  2               LAB_2CF4:
000809  2  AD FF FF             LDA     $FFFF           ; get byte to scan (addr set by call routine)
00080C  2  C9 BF                CMP     #TK_ELSE        ; compare with the token for ELSE
00080E  2  F0 0E                BEQ     LAB_2D05        ; exit if ELSE, not numeric, carry set
000810  2               
000810  2  C9 3A                CMP     #':'            ; compare with ":"
000812  2  B0 0A                BCS     LAB_2D05        ; exit if >= ":", not numeric, carry set
000814  2               
000814  2  C9 20                CMP     #' '            ; compare with " "
000816  2  F0 EB                BEQ     LAB_2CEE        ; if " " go do next
000818  2               
000818  2  38                   SEC                     ; set carry for SBC
000819  2  E9 30                SBC     #'0'            ; subtract "0"
00081B  2  38                   SEC                     ; set carry for SBC
00081C  2  E9 D0                SBC     #$D0            ; subtract -"0"
00081E  2               ; clear carry if byte = "0"-"9"
00081E  2               LAB_2D05:
00081E  2  60                   RTS
00081F  2                       .ENDIF
