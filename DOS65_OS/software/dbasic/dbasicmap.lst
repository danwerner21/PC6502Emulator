00122F  2               GETVIDEOADDRESS:
00122F  2  AC 48 06             LDY     CURY
001232  2               
001232  2  8C 19 19             STY     PTEMPW
001235  2  A9 00                LDA     #0
001237  2  8D 1A 19             STA     PTEMPW+1
00123A  2  18                   CLC
00123B  2  0E 19 19             ASL     PTEMPW
00123E  2  2E 1A 19             ROL     PTEMPW+1        ; *2
001241  2  0E 19 19             ASL     PTEMPW
001244  2  2E 1A 19             ROL     PTEMPW+1        ; *4
001247  2  0E 19 19             ASL     PTEMPW
00124A  2  2E 1A 19             ROL     PTEMPW+1        ; *8
00124D  2  AD 19 19             LDA     PTEMPW
001250  2  8D 1B 19             STA     PTEMPW1
001253  2  AD 1A 19             LDA     PTEMPW+1
001256  2  8D 1C 19             STA     PTEMPW1+1       ; PTEMPW1=Y*8
001259  2  0E 19 19             ASL     PTEMPW
00125C  2  2E 1A 19             ROL     PTEMPW+1        ; *16
00125F  2  0E 19 19             ASL     PTEMPW
001262  2  2E 1A 19             ROL     PTEMPW+1        ; *32
001265  2                                               ; TEMPW  = Y*8 + Y*32  (Y*40)
001265  2  18                   CLC                     ; Clear the Carry flag before the first addition
001266  2  AD 19 19             LDA     PTEMPW          ; Load the low byte of the first number into the accumulator
001269  2  6D 1B 19             ADC     PTEMPW1         ; Add the low byte of the second number (plus carry)
00126C  2  85 FD                STA     TEMPW           ; Store the low byte of the result
00126E  2  AD 1A 19             LDA     PTEMPW+1        ; Load the high byte of the first number
001271  2  6D 1C 19             ADC     PTEMPW1+1       ; Add the high byte of the second number (plus carry from previous op)
001274  2  85 FE                STA     TEMPW+1         ; Store the high byte of the result
001276  2               
001276  2  AD 06 19             LDA     VIDEOWIDTH      ; If 80 col, double again
001279  2  C9 50                CMP     #80
00127B  2  D0 04                BNE     :+
00127D  2  06 FD                ASL     TEMPW
00127F  2  26 FE                ROL     TEMPW+1         ; *2  (80)
001281  2               :
001281  2  A5 FE                LDA     TEMPW+1
001283  2  09 A0                ORA     #$A0            ; add in the bank#
001285  2  85 FE                STA     TEMPW+1
001287  2  60                   RTS
001288  2               
001288  2               
001288  2                       .ENDIF
