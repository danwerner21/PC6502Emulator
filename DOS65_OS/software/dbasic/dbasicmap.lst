00234C  3  85 11                STA     nums_1          ; Store tens digit into TEMP
00234E  3  A5 12                LDA     nums_2          ; Get Ones
002350  3  29 0F                AND     #$0F
002352  3  18                   CLC
002353  3  65 11                ADC     nums_1
002355  3  60                   RTS                     ; Return from subroutine
