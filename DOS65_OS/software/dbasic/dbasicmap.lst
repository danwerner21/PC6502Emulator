001EDD  3  60                   RTS
001EDE  3               V_PLOT_HIRES_COLOR_RANGE1:
001EDE  3  4C 2A 3A             JMP     LAB_2564
001EE1  3               HIRES_BIT_LOOKUP_SET:
001EE1  3  80 40 20 10          .BYTE   %10000000,%01000000,%00100000,%00010000,%00001000,%00000100,%00000010,%00000001
001EE5  3  08 04 02 01  
001EE9  3               HIRES_BIT_LOOKUP_RESET:
001EE9  3  7F BF DF EF          .BYTE   %01111111,%10111111,%11011111,%11101111,%11110111,%11111011,%11111101,%11111110
001EED  3  F7 FB FD FE  
001EF1  3               
001EF1  3               ;___V_PATTERN________________________________________________
001EF1  3               ;
001EF1  3               ;  DEFINE GRAPHICS PATTERN
001EF1  3               ;
001EF1  3               ;  TAKES 10 PARAMETERS
001EF1  3               ;       PATTERN NUM (0-255)
001EF1  3               ;       PATTERN DATA (8 BYTES)
001EF1  3               ;__________________________________________________________
001EF1  3               LAB_PATTERN
001EF1  3               V_PATTERN:
001EF1  3  20 EB 37             JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X
001EF4  3  8A                   TXA
001EF5  3  48                   PHA
001EF6  3  A0 F8                LDY     #$00+VIDEOBANK  ; AREA $0000-$0FFF
001EF8  3  20 39 1C             JSR     PAGE_ENTER
001EFB  3  68                   PLA
001EFC  3  8D 02 A0             STA     VideoCharGenOffset
001EFF  3  A0 08                LDY     #8
001F01  3               :
001F01  3  98                   TYA
001F02  3  48                   PHA
001F03  3  20 5A 2F             JSR     LAB_1C01        ; GET THE NEXT PARAMETER (AFTER ',') OR SYN ERR
001F06  3  20 EB 37             JSR     LAB_GTBY        ; GET THE NEXT PARAMETER, RETURN IN X
001F09  3  68                   PLA
001F0A  3  A8                   TAY
001F0B  3  8A                   TXA
001F0C  3  8D 03 A0             STA     VideoCharGenData
001F0F  3  88                   DEY
001F10  3  C0 00                CPY     #$00
001F12  3  D0 ED                BNE     :-
001F14  3  20 33 1C             JSR     PAGE_EXIT
001F17  3  60                   RTS
001F18  3               
001F18  3               ;___LAB_LINE_______________________________________________
001F18  3               ;
001F18  3               ;  DRAW LINE USING THE BRESENHAM LINE DRAWING ALGORITHM
001F18  3               ;
001F18  3               ;  TAKES 5 PARAMETERS
001F18  3               ;       START X,Y
001F18  3               ;       DESTINATION X,Y
001F18  3               ;       COLOR
001F18  3               ;__________________________________________________________
001F18  3               LAB_LINE:
001F18  3               ; GET X1
001F18  3  20 28 2E             JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001F1B  3                                               ; else do type mismatch
001F1B  3  20 51 38             JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001F1E  3  A5 12                LDA     Itemph
001F20  3  8D 0E 19             STA     LINEX1+1
001F23  3  A5 11                LDA     Itempl
001F25  3  8D 0D 19             STA     LINEX1
001F28  3                                               ; GET Y1
001F28  3  20 5A 2F             JSR     LAB_1C01        ; GET THE SECOND PARAMETER (AFTER ',') OR SYN ERR
001F2B  3  20 EB 37             JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X
001F2E  3  8E 0F 19             STX     LINEY1          ; STORE IN LINEY1
001F31  3               
001F31  3               ; GET X2
001F31  3  20 5A 2F             JSR     LAB_1C01        ; GET THE THIRD PARAMETER (AFTER ',') OR SYN ERR
001F34  3  20 28 2E             JSR     LAB_EVNM        ; evaluate expression and check is numeric,
001F37  3                                               ; else do type mismatch
001F37  3  20 51 38             JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
001F3A  3  A5 12                LDA     Itemph
001F3C  3  8D 12 19             STA     LINEX2+1
001F3F  3  A5 11                LDA     Itempl
001F41  3  8D 11 19             STA     LINEX2
001F44  3                                               ; GET Y2
001F44  3  20 5A 2F             JSR     LAB_1C01        ; GET THE FOURTH PARAMETER (AFTER ',') OR SYN ERR
001F47  3  20 EB 37             JSR     LAB_GTBY        ; RETURN IN X
001F4A  3  8E 13 19             STX     LINEY2          ; STORE IN LINEY2
001F4D  3                                               ; GET COLOR
001F4D  3  20 5A 2F             JSR     LAB_1C01        ; GET THE FIFTH PARAMETER (AFTER ',') OR SYN ERR
001F50  3  20 EB 37             JSR     LAB_GTBY        ; RETURN IN X
001F53  3  8E 0C 19             STX     LINECOLOR       ; STORE IN COLOR
001F56  3  A9 00                LDA     #$00
001F58  3  8D 10 19             STA     LINEY1+1
001F5B  3  8D 14 19             STA     LINEY2+1
001F5E  3                                               ; LINE COORDS AND COLOR STORED IN PROPER PLACE
001F5E  3                                               ; CALCULATE DELTAX
001F5E  3  38                   SEC                     ; Set Carry flag (represents "no borrow" for 1st byte)
001F5F  3  AD 0D 19             LDA     LINEX1          ; Load low byte of number 1
001F62  3  ED 11 19             SBC     LINEX2          ; Subtract low byte of number 2 with carry
001F65  3  8D 15 19             STA     DELTAX          ; Store result low byte
001F68  3  AD 0E 19             LDA     LINEX1+1        ; Load high byte of number 1
001F6B  3  ED 12 19             SBC     LINEX2+1        ; Subtract high byte of number 2 with borrow
001F6E  3  8D 16 19             STA     DELTAX+1        ; Store result high byte
001F71  3  B0 20                BCS     :+              ; BRANCH IF X1>=X2
001F73  3                                               ; X1 < X2
001F73  3  A9 00                LDA     #0
001F75  3  8D 1D 19             STA     PTEMP           ; IF X2>X1 (PTEMP=x0)
001F78  3  A9 FF                LDA     #$FF            ; TAKE ABSOLUTE VALUE OF DELTAX
001F7A  3  4D 16 19             EOR     DELTAX+1        ; Invert high byte (one's complement)
001F7D  3  8D 16 19             STA     DELTAX+1
001F80  3  A9 FF                LDA     #$FF            ;
001F82  3  4D 15 19             EOR     DELTAX          ; Invert low byte
001F85  3  8D 15 19             STA     DELTAX          ;
001F88  3  EE 15 19             INC     DELTAX          ; Add 1 to the low byte
001F8B  3  D0 0B                BNE     :++             ; If no carry from low byte INC, we are done
001F8D  3  EE 16 19             INC     DELTAX+1        ; Increment high byte if carry occurred
001F90  3  4C 98 1F             JMP     :++
001F93  3               :
001F93  3  A9 01                LDA     #1
001F95  3  8D 1D 19             STA     PTEMP           ; IF X1>X2 (PTEMP=x1)
001F98  3               :
001F98  3                                               ; CALCULATE DELTAY
001F98  3  A9 00                LDA     #0
001F9A  3  8D 18 19             STA     DELTAY+1
001F9D  3  38                   SEC                     ; Set Carry flag
001F9E  3  AD 0F 19             LDA     LINEY1          ; Load low byte of number 1
001FA1  3  ED 13 19             SBC     LINEY2          ; Subtract low byte of number 2 with carry
001FA4  3  8D 17 19             STA     DELTAY          ; Store result low byte
001FA7  3  B0 16                BCS     :+              ; BRANCH IF Y1>=Y2
001FA9  3                                               ; Y1 < Y2
001FA9  3  AD 1D 19             LDA     PTEMP
001FAC  3  29 01                AND     #1
001FAE  3  8D 1D 19             STA     PTEMP           ; IF Y2>Y1 (PTEMP=0x)
001FB1  3                                               ; TAKE ABSOLUTE VALUE OF DELTAY
001FB1  3  A9 FF                LDA     #$FF
001FB3  3  4D 17 19             EOR     DELTAY          ; Flip all bits (one's complement)
001FB6  3  8D 17 19             STA     DELTAY
001FB9  3  EE 17 19             INC     DELTAY          ; Add 1 (two's complement)
001FBC  3  4C C7 1F             JMP     :++
001FBF  3               :
001FBF  3  AD 1D 19             LDA     PTEMP
001FC2  3  09 10                ORA     #$10
001FC4  3  8D 1D 19             STA     PTEMP           ; IF Y1>Y2 (PTEMP=1x)
001FC7  3               :
001FC7  3                                               ; SLOPE DETERMINED, AND DELTAS CALCULATED
001FC7  3                                               ; OK, LET'S FIND OUT IF THIS IS A HORIZONTAL-ISH
001FC7  3                                               ; OR VERTICAL-ISH LINE
001FC7  3  38                   SEC                     ; Set Carry Flag (for subtraction)
001FC8  3  AD 15 19             LDA     DELTAX          ; Load low byte of DELTAX
001FCB  3  ED 17 19             SBC     DELTAY          ; Subtract low byte of DELTAY
001FCE  3  AD 16 19             LDA     DELTAX+1        ; Load high byte of DELTAX
001FD1  3  ED 18 19             SBC     DELTAY+1        ; Subtract high byte of DELTAY (with borrow)
001FD4  3                                               ; Flags now reflect the 16-bit comparison
001FD4  3  90 03                BCC     LINEVERT        ; If Carry clear, LINE IS VERTICAL-ISH
001FD6  3  4C 6F 20             JMP     LINEHORZ
001FD9  3               LINEVERT:
001FD9  3                                               ; FOR A VERTICAL-ISH LINE WE STEP ALONG THE
001FD9  3                                               ; Y AXIS (STEEP GRADIENT)
001FD9  3                                               ; FIND LARGER Y . . .
001FD9  3  AD 0F 19             LDA     LINEY1
001FDC  3  CD 13 19             CMP     LINEY2
001FDF  3  B0 03                BCS     :+
001FE1  3  20 06 21             JSR     LINESWAPXY
001FE4  3               :
001FE4  3                                               ; Initialize error = DELTAY / 2
001FE4  3  AD 17 19             LDA     DELTAY
001FE7  3  8D 1E 19             STA     LINEERR
001FEA  3  AD 18 19             LDA     DELTAY+1
001FED  3  8D 1F 19             STA     LINEERR+1
001FF0  3  4E 1F 19             LSR     LINEERR+1
001FF3  3  6E 1E 19             ROR     LINEERR
001FF6  3               LINEVERTLOOP:
001FF6  3  AD 0F 19             LDA     LINEY1          ; OK LET'S PLOT A POINT
001FF9  3  8D 09 19             STA     PLOTY
001FFC  3  AD 10 19             LDA     LINEY1+1
001FFF  3  8D 0A 19             STA     PLOTY+1
002002  3  AD 0D 19             LDA     LINEX1
002005  3  8D 07 19             STA     PLOTX
002008  3  AD 0E 19             LDA     LINEX1+1
00200B  3  8D 08 19             STA     PLOTX+1
00200E  3  AD 0C 19             LDA     LINECOLOR
002011  3  8D 0B 19             STA     PLOTCOLOR
002014  3  20 6D 1C             JSR     DOPLOTXY
002017  3                                               ; NOW MOVE LINE1 CLOSER TO LINE2
002017  3  CE 0F 19             DEC     LINEY1          ; BY STEPPING ALONG Y AXIS
00201A  3               
00201A  3               ; BRESENHAM: err -= DELTAX
00201A  3  38                   SEC
00201B  3  AD 1E 19             LDA     LINEERR
00201E  3  ED 15 19             SBC     DELTAX
002021  3  8D 1E 19             STA     LINEERR
002024  3  AD 1F 19             LDA     LINEERR+1
002027  3  ED 16 19             SBC     DELTAX+1
00202A  3  8D 1F 19             STA     LINEERR+1
00202D  3  10 37                BPL     LINEVERT_NOSTEP ; IF ERR >= 0, NO X STEP NEEDED
00202F  3                                               ; ERR += DELTAY (RESTORE ERROR)
00202F  3  18                   CLC
002030  3  AD 1E 19             LDA     LINEERR
002033  3  6D 17 19             ADC     DELTAY
002036  3  8D 1E 19             STA     LINEERR
002039  3  AD 1F 19             LDA     LINEERR+1
00203C  3  6D 18 19             ADC     DELTAY+1
00203F  3  8D 1F 19             STA     LINEERR+1
002042  3                                               ; STEP X TOWARD X2 (16-BIT)
002042  3  AD 11 19             LDA     LINEX2
002045  3  CD 0D 19             CMP     LINEX1
002048  3  AD 12 19             LDA     LINEX2+1
00204B  3  ED 0E 19             SBC     LINEX1+1
00204E  3  90 0B                BCC     LINEVERT_DECX   ; X2 < X1, DECREMENT X1
002050  3  EE 0D 19             INC     LINEX1          ; X2 >= X1, INCREMENT X1
002053  3  D0 11                BNE     LINEVERT_NOSTEP
002055  3  EE 0E 19             INC     LINEX1+1
002058  3  4C 66 20             JMP     LINEVERT_NOSTEP
00205B  3               LINEVERT_DECX:
00205B  3  AD 0D 19             LDA     LINEX1
00205E  3  D0 03                BNE     :+
002060  3  CE 0E 19             DEC     LINEX1+1
002063  3               :
002063  3  CE 0D 19             DEC     LINEX1
002066  3               LINEVERT_NOSTEP:
002066  3               
002066  3  AD 0F 19             LDA     LINEY1
002069  3  CD 13 19             CMP     LINEY2
00206C  3  D0 88                BNE     LINEVERTLOOP
00206E  3  60                   RTS                     ; DONE
00206F  3               
00206F  3               LINEHORZ:
00206F  3               ; FOR A HORIZONTAL-ISH LINE WE STEP ALONG THE
00206F  3               ; X AXIS (SHALLOW GRADIENT)
00206F  3               ; FIND LARGER X . . .
00206F  3  38                   SEC                     ; Set carry flag for subtraction
002070  3  AD 11 19             LDA     LINEX2          ; Load low byte of first number
002073  3  ED 0D 19             SBC     LINEX1          ; Subtract low byte of second number
002076  3  AD 12 19             LDA     LINEX2+1        ; Load high byte of first number
002079  3  ED 0E 19             SBC     LINEX1+1        ; Subtract high byte of second number
00207C  3                                               ; Result flags (N, Z, C) now reflect: Val1 - Val2
00207C  3  B0 03                BCS     :+              ; If carry is set, LINEX2 >= LINEX1
00207E  3  20 06 21             JSR     LINESWAPXY
002081  3               :
002081  3                                               ; Initialize error = DELTAX / 2
002081  3  AD 15 19             LDA     DELTAX
002084  3  8D 1E 19             STA     LINEERR
002087  3  AD 16 19             LDA     DELTAX+1
00208A  3  8D 1F 19             STA     LINEERR+1
00208D  3  4E 1F 19             LSR     LINEERR+1
002090  3  6E 1E 19             ROR     LINEERR
002093  3               LINEHORZLOOP:
002093  3  AD 0F 19             LDA     LINEY1          ; OK LET'S PLOT A POINT
002096  3  8D 09 19             STA     PLOTY
002099  3  AD 10 19             LDA     LINEY1+1
00209C  3  8D 0A 19             STA     PLOTY+1
00209F  3  AD 0D 19             LDA     LINEX1
0020A2  3  8D 07 19             STA     PLOTX
0020A5  3  AD 0E 19             LDA     LINEX1+1
0020A8  3  8D 08 19             STA     PLOTX+1
0020AB  3  AD 0C 19             LDA     LINECOLOR
0020AE  3  8D 0B 19             STA     PLOTCOLOR
0020B1  3  20 6D 1C             JSR     DOPLOTXY
0020B4  3                                               ; NOW MOVE LINE1 CLOSER TO LINE2
0020B4  3  EE 0D 19             INC     LINEX1          ; BY STEPPING ALONG X AXIS
0020B7  3  D0 03                BNE     :+
0020B9  3  EE 0E 19             INC     LINEX1+1
0020BC  3               :
0020BC  3                                               ; BRESENHAM: err -= DELTAY
0020BC  3  38                   SEC
0020BD  3  AD 1E 19             LDA     LINEERR
0020C0  3  ED 17 19             SBC     DELTAY
0020C3  3  8D 1E 19             STA     LINEERR
0020C6  3  AD 1F 19             LDA     LINEERR+1
0020C9  3  ED 18 19             SBC     DELTAY+1
0020CC  3  8D 1F 19             STA     LINEERR+1
0020CF  3  10 24                BPL     LINEHORZ_NOSTEP ; IF ERR >= 0, NO Y STEP NEEDED
0020D1  3                                               ; ERR += DELTAX (RESTORE ERROR)
0020D1  3  18                   CLC
0020D2  3  AD 1E 19             LDA     LINEERR
0020D5  3  6D 15 19             ADC     DELTAX
0020D8  3  8D 1E 19             STA     LINEERR
0020DB  3  AD 1F 19             LDA     LINEERR+1
0020DE  3  6D 16 19             ADC     DELTAX+1
0020E1  3  8D 1F 19             STA     LINEERR+1
0020E4  3                                               ; STEP Y TOWARD Y2
0020E4  3  AD 13 19             LDA     LINEY2
0020E7  3  CD 0F 19             CMP     LINEY1
0020EA  3  90 06                BCC     LINEHORZ_DECY   ; Y2 < Y1, DECREMENT
0020EC  3  EE 0F 19             INC     LINEY1          ; Y2 >= Y1, INCREMENT
0020EF  3  4C F5 20             JMP     LINEHORZ_NOSTEP
0020F2  3               LINEHORZ_DECY:
0020F2  3  CE 0F 19             DEC     LINEY1
0020F5  3               LINEHORZ_NOSTEP:
0020F5  3               
0020F5  3  AD 0D 19             LDA     LINEX1
0020F8  3  CD 11 19             CMP     LINEX2
0020FB  3  D0 96                BNE     LINEHORZLOOP
0020FD  3  AD 0E 19             LDA     LINEX1+1
002100  3  CD 12 19             CMP     LINEX2+1
002103  3  D0 8E                BNE     LINEHORZLOOP
002105  3  60                   RTS                     ; DONE
002106  3               
002106  3               LINESWAPXY:
002106  3  AD 0D 19             LDA     LINEX1
002109  3  AC 11 19             LDY     LINEX2
00210C  3  8C 0D 19             STY     LINEX1
00210F  3  8D 11 19             STA     LINEX2
002112  3  AD 0E 19             LDA     LINEX1+1
002115  3  AC 12 19             LDY     LINEX2+1
002118  3  8C 0E 19             STY     LINEX1+1
00211B  3  8D 12 19             STA     LINEX2+1
00211E  3               ;
00211E  3  AD 0F 19             LDA     LINEY1
002121  3  AC 13 19             LDY     LINEY2
002124  3  8C 0F 19             STY     LINEY1
002127  3  8D 13 19             STA     LINEY2
00212A  3  AD 10 19             LDA     LINEY1+1
00212D  3  AC 14 19             LDY     LINEY2+1
002130  3  8C 10 19             STY     LINEY1+1
002133  3  8D 14 19             STA     LINEY2+1
002136  3  60                   RTS
002137  3                       .ELSE
002137  3               
002137  3               
002137  3               ; ENSURE ALL OF THESE SPECIAL COMMANDS GIVE ERRORS IN NORMAL BASIC
002137  3               LAB_SPEEK:
002137  3               LAB_SPOKE:
002137  3               LAB_SCRCLR:
002137  3               LAB_SCREEN:
002137  3               LAB_PATTERN:
002137  3               LAB_PLOT:
002137  3               LAB_LOCATE:
002137  3               LAB_COLOR:
002137  3               LAB_LINE:
002137  3                       LDX     #$02            ; error code $02 ("SYNTAX" error)
002137  3                       JMP     LAB_XERR        ; do error #X, then warm start
002137  3               
002137  3                       .ENDIF
