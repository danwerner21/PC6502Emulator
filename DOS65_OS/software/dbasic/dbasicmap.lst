002137  3               ;___SOUND__________________________________________________
002137  3               ;
002137  3               ; PLAY SOUND
002137  3               ;
002137  3               ;  TAKES TWO PARAMETERS CHANNEL,FREQUENCY
002137  3               ;
002137  3               ;__________________________________________________________
002137  3               LAB_SOUND:
002137  3  20 EB 37             JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
00213A  3  DA                   PHX
00213B  3  20 5A 2F             JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
00213E  3  20 28 2E             JSR     LAB_EVNM        ; evaluate expression and check is numeric,
002141  3               ; else do type mismatch
002141  3  20 51 38             JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
002144  3               
002144  3  68                   PLA                     ; LIMIT THE CHANNELS TO <3
002145  3  29 03                AND     #$03
002147  3  18                   CLC
002148  3  0A                   ASL                     ; = *2
002149  3  48                   PHA
00214A  3  A4 11                LDY     <Itempl
00214C  3  20 5C 22             JSR     psgwr           ; SET LOW BYTE
00214F  3  68                   PLA
002150  3  1A                   INC     A
002151  3  A4 12                LDY     <Itemph
002153  3  20 5C 22             JSR     psgwr           ; SET HIGH BYTE
002156  3  60                   RTS
002157  3               
002157  3               ;___VOLUME__________________________________________________
002157  3               ;
002157  3               ; SET VOLUME
002157  3               ;
002157  3               ;  TAKES TWO PARAMETERS CHANNEL,VOLUME
002157  3               ;
002157  3               ;__________________________________________________________
002157  3               LAB_VOLUME:
002157  3  20 EB 37             JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
00215A  3  DA                   PHX
00215B  3  20 5A 2F             JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
00215E  3  20 EB 37             JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X (VOLUME)
002161  3  8A                   TXA
002162  3  A8                   TAY
002163  3  68                   PLA                     ; LIMIT THE CHANNELS TO <3
002164  3  29 03                AND     #$03
002166  3               
002166  3  18                   CLC
002167  3  69 08                ADC     #08
002169  3  20 5C 22             JSR     psgwr
00216C  3  60                   RTS
00216D  3               
00216D  3               
00216D  3               ;___VOICE__________________________________________________
00216D  3               ;
00216D  3               ; SET VOICE
00216D  3               ;
00216D  3               ;  TAKES TWO PARAMETERS VOICE, ENVELOPE
00216D  3               ;
00216D  3               ;__________________________________________________________
00216D  3               LAB_VOICE:
00216D  3  20 EB 37             JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
002170  3  DA                   PHX
002171  3  20 5A 2F             JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
002174  3  20 28 2E             JSR     LAB_EVNM        ; evaluate expression and check is numeric,
002177  3               ; else do type mismatch
002177  3  20 51 38             JSR     LAB_F2FX        ; save integer part of FAC1 in temporary integer
00217A  3  7A                   PLY
00217B  3  A9 0D                LDA     #13
00217D  3  20 5C 22             JSR     psgwr
002180  3               
002180  3  A9 0B                LDA     #11
002182  3  A4 11                LDY     <Itempl
002184  3  20 5C 22             JSR     psgwr           ; SET LOW BYTE
002187  3  A9 0C                LDA     #12
002189  3  A4 12                LDY     <Itemph         ; SET HIGH BYTE
00218B  3  20 5C 22             JSR     psgwr
00218E  3               
00218E  3  60                   RTS
00218F  3               
00218F  3               
00218F  3               
00218F  3               
00218F  3               
00218F  3               ;___NOISE__________________________________________________
00218F  3               ;
00218F  3               ; SELECT NOISE CHANNEL
00218F  3               ;
00218F  3               ;  TAKES TWO PARAMETERS CHANNEL,FREQUENCY
00218F  3               ;
00218F  3               ;__________________________________________________________
00218F  3               LAB_NOISE:
00218F  3  20 EB 37             JSR     LAB_GTBY        ; GET THE FIRST PARAMETER, RETURN IN X (CHANNEL)
002192  3  DA                   PHX
002193  3  20 5A 2F             JSR     LAB_1C01        ; (AFTER ',') OR SYN ERR
002196  3  20 EB 37             JSR     LAB_GTBY        ; GET THE SECOND PARAMETER, RETURN IN X (FREQ)
002199  3  68                   PLA                     ; LIMIT THE CHANNELS TO <3
00219A  3  DA                   PHX
00219B  3  AA                   TAX
00219C  3               
