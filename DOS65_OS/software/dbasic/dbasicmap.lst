001CBD  3  18                   CLC                     ; Clear the Carry flag before the first addition
001CBE  3               
001CBE  3  AD 09 19             LDA     PLOTY           ; Load the low byte of the first number into the accumulator
001CC1  3  6D 19 19             ADC     PTEMPW          ; Add the low byte of the second number (plus carry)
