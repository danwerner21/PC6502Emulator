001904  3                       .IFDEF  MEMORYMAPPEDSCREEN
001904  3               
001904  3               ;* MEMORY MAP
001904  3               ;  VIDEO CARD IS A 32K AREA (MAPPED IN BANKS TO $AXXX)
001904  3               ;  $0x00 0x01=soft_scanline_emulation, 0x02 NO soft_scanline_emulation
001904  3               ;  $0x01 0x01=page1, 0x02 page2
001904  3               ;  $0x02  character generator write offset (data << 3)
001904  3               ;  $0x03 character generator write DATA
001904  3               ;  $0x04 EXECUTE device command
001904  3               ;        0x00- reset to the default configuration
001904  3               ;        0x01- reset to the saved configuration
001904  3               ;	0x02- save the current configuration
001904  3               ;
001904  3               ;  $0x05  0x01=soft_text=true, 0x02=soft_text=false
001904  3               ;  $0x06 Lores Mode=0X01,NO lores Mode=0x02
001904  3               ;  $0x07 Double Lores Mode=0X01,NO Double lores Mode=0x02
001904  3               ;  $0x08 Hires Mode=0X01,NO Hires Mode=0x02
001904  3               ;  $0x09 Double Hires Mode=0X01,NO Double Hires lores Mode=0x02
001904  3               ;  $0x0A 80COL Mode=0X01,NO 80COL Mode=0x02
001904  3               ;  $0x0B MIXED Mode=0X01,NO MIXED Mode=0x02
001904  3               ;  $0x0C QUAD Hires Mode=0X01,NO QUAD Hires lores Mode=0x02
001904  3               ;  $0x0D MONO Hires Mode=0X01,NO MONO Hires lores Mode=0x02
001904  3               ;
001904  3               ; 	VRAM Memory Map
001904  3               ;	$1000-$177F	40/80 Text Page 1
001904  3               ;	$1800-$1F7F	40/80 Color Page 1
001904  3               ;	$2000-$277F	40/80 Text Page 2
001904  3               ;	$2800-$2F7F	40/80 Color Page 2
001904  3               ;	$3000-$377F	40/80 Color Multicolor Page 1
001904  3               ;	$3800-$3F7F	40/80 Color Multicolor Page 2
001904  3               ;	$2000-$5FFF	HIRES PAGE 1
001904  3               ;	$6000-$8FFF	HIRES PAGE 2
001904  3               ;	$2000-$BFFF	DOUBLE HIRES
001904  3               
001904  3               VIDEOBANK       = $F8
001904  3               PC6502_IOSPACE  = $EF00
001904  3               ; PAGER
001904  3               PC6502_ACT_TASK = PC6502_IOSPACE+$E0
001904  3               PC6502_MAP_SETUP = PC6502_IOSPACE+$E1
001904  3               PC6502_MMU_ENA  = PC6502_IOSPACE+$E2
001904  3               PC6502_MAP_SPACE = PC6502_IOSPACE+$D0
001904  3               
001904  3               VideoDisplayPage = $A001
001904  3               VideoCharGenOffset = $A002
001904  3               VideoCharGenData = $A003
001904  3               VideoTextMode   = $A005
001904  3               VideoLoresMode  = $A006
001904  3               VideoDoubleLores = $A007
001904  3               VideoHiresMode  = $A008
001904  3               VideoDoubleHires = $A009
001904  3               Video80col      = $A00A
001904  3               VideoMixedMode  = $A00b
001904  3               VideoQuadHires  = $A00c
001904  3               VideoMonoHires  = $A00d
001904  3               VideoMulticolor = $A00e
001904  3               
001904  3               CURX            = $0647         ; CURRENT CURSOR POSITION (MEMORY MAPPED)
001904  3               CURY            = $0648
001904  3               SHOWCRSR        = $0649         ; SHOW CURSOR (1-YES, 0-NO) (MEMORY MAPPED)
001904  3               CURCOLOR        = $064A         ; CURRENT PRINT COLOR (MEMORY MAPPED)
001904  3               CSRCOLOR        = $064B         ; CURRENT CURSOR COLOR (MEMORY MAPPED)
001904  3               BVIDEOMODE      = $064C         ; CURRENT VIDEO MODE (MEMORY MAPPED) 00=40 COL, 01=80 COL
