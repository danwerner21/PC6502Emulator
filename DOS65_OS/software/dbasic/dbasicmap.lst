00131D  2  29 10                AND     #%00010000      ; IS TX READY
00131F  2  F0 F9                BEQ     WRSER1a         ; NO, WAIT FOR IT
001321  2  68                   PLA
001322  2  8D 84 EF             STA     UART1DATA       ; WRITE DATA
001325  2  60                   RTS
