0012A8  2  8E 16 13             STX     TTX
0012AB  2  8C 17 13             STY     TTY
0012AE  2  8D 18 13             STA     TTA
0012B1  2  A9 0D                LDA     #13
0012B3  2  20 19 13             JSR     WRSER1          ; output upper nybble
0012B6  2  A9 0A                LDA     #10
0012B8  2  20 19 13             JSR     WRSER1          ; output upper nybble
0012BB  2  AE 16 13             LDX     TTX
0012BE  2  AC 17 13             LDY     TTY
0012C1  2  AD 18 13             LDA     TTA
0012C4  2  60                   RTS
0012C5  2               
0012C5  2               PRINT_SPACE:
0012C5  2  8E 16 13             STX     TTX
0012C8  2  8C 17 13             STY     TTY
0012CB  2  8D 18 13             STA     TTA
0012CE  2  A9 20                LDA     #32
0012D0  2  20 19 13             JSR     WRSER1          ; output upper nybble
0012D3  2  AE 16 13             LDX     TTX
0012D6  2  AC 17 13             LDY     TTY
0012D9  2  AD 18 13             LDA     TTA
0012DC  2  60                   RTS
0012DD  2               
0012DD  2               
0012DD  2               PRINT_BYTE:
0012DD  2  8E 16 13             STX     TTX
0012E0  2  8C 17 13             STY     TTY
0012E3  2  8D 18 13             STA     TTA
0012E6  2  8E 15 13             STX     SAVX            ; save X
0012E9  2  20 00 13             JSR     ASCTWO          ; get hex chars for byte in X (lower) and A (upper)
0012EC  2  20 19 13             JSR     WRSER1          ; output upper nybble
0012EF  2  8A                   TXA                     ; transfer lower to A
0012F0  2  AE 15 13             LDX     SAVX            ; restore X
0012F3  2  20 19 13             JSR     WRSER1          ; output lower nybble
0012F6  2  AE 16 13             LDX     TTX
0012F9  2  AC 17 13             LDY     TTY
0012FC  2  AD 18 13             LDA     TTA
0012FF  2  60                   RTS
001300  2               ASCTWO:
001300  2  48                   PHA                     ; save byte
001301  2  20 0A 13             JSR     ASCII           ; do low nybble
001304  2  AA                   TAX                     ; save in X
001305  2  68                   PLA                     ; restore byte
001306  2  4A                   LSR     A               ; shift upper nybble down
001307  2  4A                   LSR     A
001308  2  4A                   LSR     A
001309  2  4A                   LSR     A
00130A  2               ; convert low nybble in A to hex digit
00130A  2               ASCII:
00130A  2  29 0F                AND     #$0F            ; clear upper nibble
00130C  2  C9 0A                CMP     #$0A            ; if less than A, skip next step
00130E  2  90 02                BCC     ASC1
001310  2  69 06                ADC     #6              ; skip ascii chars between 9 and A
001312  2               ASC1:
001312  2  69 30                ADC     #$30            ; add ascii char 0 to value
001314  2  60                   RTS
001315  2               SAVX:
001315  2  00                   .BYTE   00
001316  2               TTX:
001316  2  00                   .BYTE   00
001317  2               TTY:
001317  2  00                   .BYTE   00
001318  2               TTA:
001318  2  00                   .BYTE   00
