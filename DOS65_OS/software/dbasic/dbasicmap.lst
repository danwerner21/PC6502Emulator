001331  3               ;___SAVE____________________________________________________
001331  3               ;
001331  3               ; SAVE COMMAND
001331  3               ;
001331  3               ;  SAVE THE BASIC PROGRAM IN MEMORY TO DISK
001331  3               ;
001331  3               ;__________________________________________________________
001331  3               V_SAVE: ; save BASIC program
001331  3               DOS65SAVE:
001331  3  20 A4 14             JSR     DOS65FCBPREP    ; parse parameters into FCB
001334  3  B0 28                BCS     DOS65SAVE_ERR1  ; Error?, if so abort
001336  3  A2 0D                LDX     #13             ;
001338  3  20 2B 13             JSR     PEM             ;
00133B  3  A9 C2                LDA     #<FCB           ; CREATE File
00133D  3  A0 18                LDY     #>FCB           ;
00133F  3  A2 16                LDX     #22             ;
001341  3  20 2B 13             JSR     PEM             ;
001344  3  A9 00                LDA     #0              ; clear
001346  3  8D E2 18             STA     FCB+32          ; record number
001349  3  A9 C2                LDA     #<FCB           ; Open File
00134B  3  A0 18                LDY     #>FCB           ;
00134D  3  A2 0F                LDX     #15             ;
00134F  3  20 2B 13             JSR     PEM             ;
001352  3  C9 FF                CMP     #$FF            ; error?, if NOT, continue
001354  3  D0 0B                BNE     DOS65SAVE_1     ;
001356  3               DOS65SAVE_ERR:
001356  3  A2 24                LDX     #$24            ; IO ERROR
001358  3  20 96 24             JSR     LAB_XERR
00135B  3  4C 6E 25             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
00135E  3               DOS65SAVE_ERR1:
00135E  3  4C 89 2A             JMP     LAB_REM         ; comment out the remainder of the line (if any)
001361  3               DOS65SAVE_1:
001361  3  A9 11                LDA     #<FCBBUFFER     ; SETUP BUFFER
001363  3  85 20                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
001365  3  A0 44                LDY     #>FCBBUFFER     ;
001367  3  84 21                STY     FCBPTR+1        ;
001369  3  A2 1A                LDX     #26             ; Setup Buffer
00136B  3  20 2B 13             JSR     PEM             ;
00136E  3               DOS65SAVE_2:
00136E  3  A5 79                LDA     <Smeml          ; All is well, file opened and continue
001370  3  85 22                STA     FCBPTR+2        ; point to base of RAM
001372  3  A5 7A                LDA     <Smemh          ;
001374  3  85 23                STA     FCBPTR+3        ;
001376  3  A2 00                LDX     #$00            ; x=0 (null counter)
001378  3               DOS65SAVE_2A:
001378  3  A0 00                LDY     #$00            ; y=0 (Loop Index)
00137A  3               DOS65SAVE_3:
00137A  3  B1 22                LDA     (FCBPTR+2),Y    ; load from RAM
00137C  3  91 20                STA     (FCBPTR),Y      ; save to Buffer
00137E  3  C9 00                CMP     #$00            ; is Zero?
001380  3  D0 1E                BNE     DOS65SAVE_3A    ; No, continue
001382  3  E8                   INX                     ; yes, bump Null Counter
001383  3  E0 03                CPX     #$03            ; Three nulls in a row?
001385  3  D0 1B                BNE     DOS65SAVE_3B    ; No, continue
001387  3                                               ; FINISH FILLING BUFFER WITH NULLS
001387  3               :
001387  3  91 20                STA     (FCBPTR),Y      ; save to Buffer
001389  3  C8                   INY                     ; bump index
00138A  3  C0 80                CPY     #$80            ; end of buffer?
00138C  3  D0 F9                BNE     :-              ; no, loop
00138E  3  A9 C2                LDA     #<FCB           ; Write record in buffer to disk file AND END
001390  3  A0 18                LDY     #>FCB           ;
001392  3  A2 15                LDX     #21             ;
001394  3  20 2B 13             JSR     PEM             ;
001397  3  29 FE                AND     #$FE            ; strip out extension
001399  3  C9 00                CMP     #$00            ; is error
00139B  3  D0 B9                BNE     DOS65SAVE_ERR   ; ERROR, do error handling
00139D  3  4C CD 13             JMP     DOS65SAVE_4
0013A0  3               DOS65SAVE_3A:                   ;
0013A0  3  A2 00                LDX     #$00            ; prior char not null, reset null counter
0013A2  3               DOS65SAVE_3B:                   ;
0013A2  3  C8                   INY                     ; bump index
0013A3  3  C0 80                CPY     #$80            ; end of buffer?
0013A5  3  D0 D3                BNE     DOS65SAVE_3     ; no, loop
0013A7  3               DOS65SAVE_3C:
0013A7  3  A9 C2                LDA     #<FCB           ; Write record in buffer to disk file
0013A9  3  A0 18                LDY     #>FCB           ;
0013AB  3  A2 15                LDX     #21             ;
0013AD  3  20 2B 13             JSR     PEM             ;
0013B0  3  29 FE                AND     #$FE            ; strip out extension
0013B2  3  C9 00                CMP     #$00            ; is error
0013B4  3  D0 A0                BNE     DOS65SAVE_ERR   ; ERROR, do error handling
0013B6  3  18                   CLC                     ;
0013B7  3  A5 22                LDA     FCBPTR+2        ; add $80 to base counter
0013B9  3  69 80                ADC     #$80            ;
0013BB  3  85 22                STA     FCBPTR+2        ;
0013BD  3  90 B9                BCC     DOS65SAVE_2A    ; is carry?, no loop
0013BF  3  18                   CLC                     ; yes, carry, inc high byte
0013C0  3  A5 23                LDA     FCBPTR+3        ;
0013C2  3  69 01                ADC     #$01            ;
0013C4  3  85 23                STA     FCBPTR+3        ;
0013C6  3  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
0013C8  3  F0 03                BEQ     DOS65SAVE_4
0013CA  3  4C 78 13             JMP     DOS65SAVE_2A
0013CD  3               DOS65SAVE_4:
0013CD  3  A9 C2                LDA     #<FCB           ;
0013CF  3  A0 18                LDY     #>FCB           ;
0013D1  3  A2 10                LDX     #16             ;
0013D3  3  20 2B 13             JSR     PEM             ;
0013D6  3  C9 FF                CMP     #$FF            ;
0013D8  3  D0 03                BNE     DOS65SAVE_5     ;
0013DA  3  4C 56 13             JMP     DOS65SAVE_ERR   ; ERROR, DISPLAY IT
0013DD  3               DOS65SAVE_5:
0013DD  3  A9 AA                LDA     #<LAB_RMSG      ; point to "Ready" message low byte
0013DF  3  A0 0F                LDY     #>LAB_RMSG      ; point to "Ready" message high byte
0013E1  3  20 30 2C             JSR     LAB_18C3
0013E4  3  4C 6E 25             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
0013E7  3               
0013E7  3               ;___LOAD____________________________________________________
0013E7  3               ;
0013E7  3               ; LOAD COMMAND
0013E7  3               ;
0013E7  3               ;  LOAD A BASIC PROGRAM FROM DISK TO MEMORY
0013E7  3               ;
0013E7  3               ;__________________________________________________________
0013E7  3               V_LOAD: ; load BASIC program
0013E7  3               DOS65LOAD:
0013E7  3  A9 00                LDA     #$00
0013E9  3  8D E8 14             STA     NullCounter
0013EC  3  20 A4 14             JSR     DOS65FCBPREP    ; parse parameters into FCB
0013EF  3  B0 1F                BCS     DOS65LOAD_ERR1  ; Error?, if so abort
0013F1  3  A2 0D                LDX     #13             ;
0013F3  3  20 2B 13             JSR     PEM             ;
0013F6  3  A9 00                LDA     #0              ; clear
0013F8  3  8D E2 18             STA     FCB+32          ; record number
0013FB  3  A9 C2                LDA     #<FCB           ; Open File
0013FD  3  A0 18                LDY     #>FCB           ;
0013FF  3  A2 0F                LDX     #15             ;
001401  3  20 2B 13             JSR     PEM             ;
001404  3  C9 FF                CMP     #$FF            ; error?, if NOT, continue
001406  3  D0 0B                BNE     DOS65LOAD_1     ;
001408  3               DOS65LOAD_ERR:
001408  3  A2 24                LDX     #$24            ; IO ERROR
00140A  3  20 96 24             JSR     LAB_XERR
00140D  3  4C 6E 25             JMP     LAB_1319        ; RESET VARS, STACK AND RETURN CONTROL TO BASIC
001410  3               DOS65LOAD_ERR1:
001410  3  4C 89 2A             JMP     LAB_REM         ; comment out the remainder of the line (if any)
001413  3               DOS65LOAD_1:
001413  3  A5 79                LDA     <Smeml          ; All is well, file opened and continue
001415  3  85 22                STA     FCBPTR+2        ; point to base of RAM
001417  3  8D E6 14             STA     EndOfBas        ;
00141A  3  A5 7A                LDA     <Smemh          ;
00141C  3  85 23                STA     FCBPTR+3        ;
00141E  3  8D E7 14             STA     EndOfBas+1      ;
001421  3  A9 11                LDA     #<FCBBUFFER     ; SETUP BUFFER
001423  3  85 20                STA     FCBPTR          ; STORE DEST BUFFER IN FCBPTR
001425  3  A0 44                LDY     #>FCBBUFFER     ;
001427  3  84 21                STY     FCBPTR+1        ; STORE DEST BUFFER IN FCBPTR
001429  3  A2 1A                LDX     #26             ; Setup Buffer
00142B  3  20 2B 13             JSR     PEM             ;
00142E  3  4C 6C 14             JMP     DOS65LOAD_3C
001431  3               DOS65LOAD_3:
001431  3  B1 20                LDA     (FCBPTR),Y      ; load from BUFFER
001433  3  91 22                STA     (FCBPTR+2),Y    ; save to RAM
001435  3  EE E6 14             INC     EndOfBas
001438  3  D0 03                BNE     :+
00143A  3  EE E7 14             INC     EndOfBas+1
00143D  3               :
00143D  3  C9 00                CMP     #$00
00143F  3  D0 0D                BNE     :+
001441  3  EE E8 14             INC     NullCounter
001444  3  AD E8 14             LDA     NullCounter
001447  3  C9 03                CMP     #3
001449  3  D0 08                BNE     :++
00144B  3  4C 7F 14             JMP     DOS65LOAD_4
00144E  3               :
00144E  3  A9 00                LDA     #$00
001450  3  8D E8 14             STA     NullCounter
001453  3               :
001453  3  C8                   INY                     ; bump index
001454  3  C0 80                CPY     #$80            ; end of buffer?
001456  3  D0 D9                BNE     DOS65LOAD_3     ; no, loop
001458  3  18                   CLC                     ;
001459  3  A5 22                LDA     FCBPTR+2        ; add $80 to base counter
00145B  3  69 80                ADC     #$80            ;
00145D  3  85 22                STA     FCBPTR+2        ;
00145F  3  90 0B                BCC     DOS65LOAD_3C    ; is carry?, no SKIP
001461  3  18                   CLC                     ; yes, carry, inc high byte
001462  3  A5 23                LDA     FCBPTR+3        ;
001464  3  69 01                ADC     #$01            ;
001466  3  85 23                STA     FCBPTR+3        ;
001468  3  C9 B8                CMP     #>Ram_top       ; are we at the end of RAM?
00146A  3  F0 13                BEQ     DOS65LOAD_4
00146C  3               
00146C  3               DOS65LOAD_3C:
00146C  3  A9 C2                LDA     #<FCB           ; READ record buffer from disk file
00146E  3  A0 18                LDY     #>FCB           ;
001470  3  A2 14                LDX     #20             ;
001472  3  20 2B 13             JSR     PEM             ;
001475  3  A0 00                LDY     #$00            ; RESET INDEX
001477  3  C9 00                CMP     #$00            ; is error or EOF
001479  3  F0 B6                BEQ     DOS65LOAD_3     ;
