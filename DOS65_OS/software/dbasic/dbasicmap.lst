001C92  3                                               ; MULTIPLY Y (PTEMPW) COORD BY 40 OR 80 (SINGLE OR DOUBLE LORES)
001C92  3  18                   CLC
001C93  3  0E 09 19             ASL     PLOTY
001C96  3  2E 0A 19             ROL     PLOTY+1         ; *2
001C99  3  0E 09 19             ASL     PLOTY
001C9C  3  2E 0A 19             ROL     PLOTY+1         ; *2 (*4)
001C9F  3  0E 09 19             ASL     PLOTY
