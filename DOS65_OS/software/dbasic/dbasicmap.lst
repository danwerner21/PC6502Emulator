0023D0  1  D0 07                BNE     LAB_2DB6        ; branch if fail
0023D2  1               
0023D2  1  0A                   ASL     A               ; shift test byte left (now $AA)
0023D3  1  91 11                STAINDIRECTY Itempl     ; save via temporary integer
0023D5  1  D1 11                CMPINDIRECTY Itempl     ; compare via temporary integer
0023D7  1  F0 E5                BEQ     LAB_2D93        ; if ok go do next byte
0023D9  1               
