00182D  2  20 28 09     
001830  2               
001830  2               ; initialize display position
001830  2  A9 01                LDA     #1
001832  2  85 5B                STA     scrrow          ; current display row (1-22)
001834  2  64 5C                STZ     csrcol          ; column offset (0,16,32,48,64)
001836  2  A9 50                LDA     #$50            ; video pointer = $A050 (row 1)
001838  2  85 FD                STA     indir
00183A  2  A9 A0                LDA     #$A0
00183C  2  85 FE                STA     indir+1
00183E  2               
00183E  2               ; find first file
00183E  2  A9 70                LDA     #<fcb
001840  2  A0 20                LDY     #>fcb
001842  2  A2 11                LDX     #17             ; PEM: find first match
001844  2  20 03 01             JSR     PEM
001847  2  C9 FF                CMP     #$FF
001849  2  D0 03                BNE     @catshow
00184B  2  4C EB 18             JMP     @nofiles
00184E  2               
