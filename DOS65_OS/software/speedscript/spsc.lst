0013A5  2  9C AD 1C             STZ     huntlen
0013A8  2  9C CC 1C             STZ     replen
0013AB  2  9C 49 06             STZ     SHOWCRSR        ; TURN OFF CURSOR
0013AE  2               
0013AE  2  A9 20                LDA     #>END           ;
0013B0  2  1A                   INC
