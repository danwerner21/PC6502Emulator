001771  2               
001771  2               @savecrlf:
001771  2               ; convert retchar to CR + LF
001771  2  A9 0D                LDA     #13             ; CR
001773  2  99 EB 1C             STA     codebuffer,Y
001776  2  C8                   INY
001777  2  C0 80                CPY     #128
001779  2  D0 07                BNE     :+
00177B  2  20 E0 17             JSR     @flush
00177E  2  D0 47                BNE     @writerr
001780  2  A0 00                LDY     #0
001782  2               :
001782  2  A9 0A                LDA     #10             ; LF
001784  2  99 EB 1C             STA     codebuffer,Y
001787  2  C8                   INY
001788  2  C0 80                CPY     #128
00178A  2  D0 07                BNE     @nexttex
00178C  2  20 E0 17             JSR     @flush
00178F  2  D0 36                BNE     @writerr
001791  2  A0 00                LDY     #0
001793  2               
