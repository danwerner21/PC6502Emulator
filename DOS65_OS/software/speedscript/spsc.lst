001720  2  8D 90 20             STA     fcb+32
001723  2               
001723  2               ; open file
001723  2  A9 70                LDA     #<fcb
001725  2  A0 20                LDY     #>fcb
001727  2  A2 0F                LDX     #15             ; PEM: open file
001729  2  20 03 01             JSR     PEM
00172C  2  C9 FF                CMP     #$FF
00172E  2  D0 03                BNE     :+
001730  2  4C C7 17             JMP     @diskerr
001733  2               :
001733  2               
001733  2               ; set DMA buffer to codebuffer
001733  2  A9 EB                LDA     #<codebuffer
001735  2  A0 1C                LDY     #>codebuffer
001737  2  A2 1A                LDX     #26             ; PEM: set DMA address
001739  2  20 03 01             JSR     PEM
00173C  2               
00173C  2               ; source pointer: start of text
00173C  2  AD DD 1B 85          COPY16  texstart,tex
001740  2  FB AD DE 1B  
001744  2  85 FC        
001746  2  A0 00                LDY     #0              ; Y = codebuffer index
001748  2               
001748  2               ; --- main save loop ---
001748  2               @saveloop:
001748  2               ; check if tex >= lastline
001748  2  A5 FC                LDA     tex+1
00174A  2  CD ED 1B             CMP     lastline+1
00174D  2  90 09                BCC     @getbyte        ; high byte less = more to go
00174F  2  D0 4A                BNE     @padeof         ; high byte greater = past end
001751  2  A5 FB                LDA     tex
001753  2  CD EC 1B             CMP     lastline
001756  2  B0 43                BCS     @padeof         ; low byte >= = at or past end
001758  2               
001758  2               @getbyte:
001758  2  B2 FB                LDA     (tex)           ; 65C02 indirect (no index)
00175A  2  C9 1F                CMP     #retchar
00175C  2  F0 13                BEQ     @savecrlf
00175E  2               
00175E  2               ; normal character - strip high bit and store
00175E  2  29 7F                AND     #$7F
001760  2  99 EB 1C             STA     codebuffer,Y
001763  2  C8                   INY
001764  2  C0 80                CPY     #128
001766  2  D0 2B                BNE     @nexttex
