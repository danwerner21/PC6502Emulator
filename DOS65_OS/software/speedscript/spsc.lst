000000r 1               ;__SpeedScript_________________________________________________________________
000000r 1               ;
000000r 1               ; SpeedScript 3.1 by Charles Brannon
000000r 1               ; published in Compute Magazine for various 8-bit computers.
000000r 1               ; This project is a port of the Commodore 64 version of SpeedScript
000000r 1               ; to the 6502PC running DOS/65 with the memory mapped video card.
000000r 1               ;
000000r 1               ;______________________________________________________________________________
000000r 1                       .PSC02
000000r 1               
000000r 1                       .SEGMENT "TEA"
000000r 1                       .ORG    $0800
000800  1               
000800  1                       .INCLUDE "macro.asm"
000800  2               ; some macros
000800  2                       .macro COPY16  src, dst
000800  2                       LDA     src
000800  2                       STA     dst
000800  2                       LDA     src+1
000800  2                       STA     dst+1
000800  2                       .endmacro
000800  2               
000800  2                       .macro COPY162  src, dst, dst2
000800  2                       LDA     src
000800  2                       STA     dst
000800  2                       STA     dst2
000800  2                       LDA     src+1
000800  2                       STA     dst+1
000800  2                       STA     dst2+1
000800  2                       .endmacro
000800  2               
000800  2               
000800  2                       .macro ADD16   left,right
000800  2                       CLC
000800  2                       LDA     left
000800  2                       ADC     right
000800  2                       STA     left
000800  2                       LDA     left+1
000800  2                       ADC     right+1
000800  2                       STA     left+1
000800  2                       .endmacro
000800  2               
000800  2               ;Compares two 16-bit values, and sets the C and Z flags the
000800  2               ;same as a LDA and CMP;instruction would for 8-bit addresses.
000800  2                       .macro COMP16  left,right
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     temp
000800  2                       LDA     left+1
000800  2                       SBC     right+1
000800  2                       ORA     temp
000800  2                       .endmacro
000800  2               
000800  2               ; Compares two 16-bit values but only affects the C flag.
000800  2                       .macro COMPC16 left,right
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       LDA     left+1
000800  2                       SBC     right+1
000800  2                       .endmacro
000800  2               
000800  2               ;  sub16 left,right       :  left - right -> left
000800  2               ;  sub16 left,right,dst   : left - right -> dst
000800  2                       .macro SUB16   left,right
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     left
000800  2                       LDA     left+1
000800  2                       SBC     right+1
000800  2                       STA     left+1
000800  2                       .endmacro
000800  2               
000800  2                       .macro SUB162   left,right,dst
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     dst
000800  2                       LDA     left+1
000800  2                       SBC     right+1
000800  2                       STA     dst+1
000800  2                       .endmacro
000800  2               
000800  2               ; Subtract an 8-bit value from a 16-bit one
000800  2                       .macro  SUB8    left,right
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     left
000800  2                       LDA     left+1
000800  2                       SBC     #0
000800  2                       STA     left+1
000800  2                       .endmacro
000800  2               
000800  2               
000800  2                       .macro  SUB82    left,right,dst
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     dst
000800  2                       LDA     left+1
000800  2                       SBC     #0
000800  2                       STA     dst+1
000800  2                       .endmacro
000800  2               
000800  2                       .macro  SUB83    left,right,dst,dst2
000800  2                       SEC
000800  2                       LDA     left
000800  2                       SBC     right
000800  2                       STA     dst
000800  2                       STA     dst2
000800  2                       LDA     left+1
000800  2                       SBC     #0
000800  2                       STA     dst+1
000800  2                       STA     dst2+1
000800  2                       .endmacro
000800  2               
000800  2                       .macro PRINTMESSAGE message
000800  2                       LDA     #<message
000800  2                       LDY     #>message
000800  2                       JSR     PRMSG
000800  2                       .endmacro
000800  2               
000800  2                       .macro  TOPPRINTMESSAGE message
000800  2                       JSR     topclr
000800  2                       PRINTMESSAGE message
000800  2                       .endmacro
000800  2               
000800  2               ;Display a 16-bit integer from the A and X registers
000800  2               ;in decimal using CHROUT.
000800  2                       .macro         DISPLAY_NUMBER
000800  2                       JSR     displaynum
000800  2                       .endmacro
000800  2               
000800  2               ;TODO: DOS/65 has no modifier key state register.
000800  2               ; For now, always branch (shift/ctrl combos disabled).
000800  2                       .macro   B_UNLESS_SHIFT_CTRL addr
000800  2                       JMP     addr
000800  2                       .endmacro
000800  2               
000800  2                       .macro        B_UNLESS_SHIFT addr
000800  2                       JMP     addr
000800  2                       .endmacro
000800  2               
000800  2                       .MACRO  B_IF_PUNCT dst
000800  2                       CMP     #'.'
000800  2                       BEQ     dst
000800  2                       CMP     #'!'
000800  2                       BEQ     dst
000800  2                       CMP     #'?'
000800  2                       BEQ     dst
000800  2                       .ENDMACRO
000800  2               
000800  2                       .macro        PRCODE  dst
000800  2                       JSR     aschex
000800  2                       STA     dst
000800  2                       .endmacro
000800  2                       .macro  PRCODE16 dst
000800  2                       PRCODE  dst
000800  2                       LDA     hex+1
000800  2                       STA     dst+1
000800  2                       .endmacro
000800  2               
000800  2                       .macro  RVS_TEXT text
000800  2                       .BYTE   $12
000800  2                       .BYTE   text
000800  2                       .BYTE   $92
000800  2                       .endmacro
000800  2               
000800  1                       .INCLUDE "defines.asm"
000800  2               
000800  2               ; DOS/65 system entry points
000800  2               DFLFCB          = $107          ;DEFAULT FCB
000800  2               PEM             = $103          ;PEM ENTRY
000800  2               BOOT            = $100          ;WARM BOOT
000800  2               
000800  2               CURX            = $0647         ; CURRENT CURSOR POSITION (MEMORY MAPPED)
000800  2               CURY            = $0648
000800  2               SHOWCRSR        = $0649         ; SHOW CURSOR (1-YES, 0-NO) (MEMORY MAPPED)
000800  2               CURCOLOR        = $064A         ; CURRENT PRINT COLOR (MEMORY MAPPED)
000800  2               CSRCOLOR        = $064B         ; CURRENT CURSOR COLOR (MEMORY MAPPED)
000800  2               BVIDEOMODE      = $064C         ; CURRENT VIDEO MODE (MEMORY MAPPED) 00=40 COL, 01=80 COL
000800  2               
000800  2               
000800  2               ; DO_FARCALL dispatch vector
000800  2               DO_FARCALL      = $FFF0
000800  2               farfunct        = $32           ;zero-page: FARCALL function number
000800  2               
000800  2               ; MMU / video paging (6502PC hardware)
000800  2               SETPAGE         = $FFF6         ;configure MMU mapping (A=task, X=bank, Y=page)
000800  2               VIDEOBANK       = $F8           ;base physical page for video RAM
000800  2               PC6502_ACT_TASK = $EFE0        ;MMU active task register (write-only)
000800  2               VIDTEXT_PAGE    = $01+VIDEOBANK ;physical page for text page 1 chars ($F9)
000800  2               
000800  2               ; FARCALL function numbers
000800  2               FC_CHROUT       = 19            ;output character (A=char)
000800  2               FC_CHRIN        = 20            ;read keyboard (returns A=key or $FF)
000800  2               FC_LOCATE       = 37            ;set cursor position (X=col, Y=row)
000800  2               FC_SCNCLR       = 38            ;clear screen
000800  2               FC_SETMODE      = 57            ;set screen mode
000800  2               FC_COLOR        = 39            ;set color (X=fg|bg, Y=cursor_fg|bg)
000800  2               FC_SCROLLDN     = 56            ;scroll screen down
000800  2               FC_PAINTCSR     = 58            ;paint cursor at current position
000800  2               FC_UNPAINTCSR   = 59            ;unpaint/hide cursor
000800  2               
000800  2               ; memory map
000800  2               TEXEND_INIT     = $9000
000800  2               TEXBUF_INIT     = $A000
000800  2               BUFEND_INIT     = $B800
000800  2               
000800  2               INSCOLOR        = $7C
000800  2               TOPCOLOR        = $7B
000800  2               CRCOLOR         = $E1
000800  2               SCNCOLOR        = $1E
000800  2               
000800  2               DEFAULT_DEVICE  = 1
000800  2               
000800  2               ; constants
000800  2               space           = 32
000800  2               BLINK_DELAY     = $60           ;cursor blink speed (higher=slower)
000800  2               
000800  2               ; Screen state variables - relocated from C64 KERNAL addresses
000800  2               ; to safe zero-page locations
000800  2               COLUMNS         = $50
000800  2               ROWS            = $51
000800  2               CURRENT_COLUMN  = $52
000800  2               QUOTE_MODE      = $53
000800  2               INSERT_MODE     = $54
000800  2               
000800  2               ;Locations used by high-speed memory
000800  2               ;move routines:
000800  2               
000800  2               froml           = $55
000800  2               fromh           = $56
000800  2               destl           = $57
000800  2               desth           = $58
000800  2               llen            = $59
000800  2               hlen            = $5A
000800  2               
000800  2               ;curr: Position of cursor within text
000800  2               ;memory. scr: used by the refresh
000800  2               ;routine.
000800  2               
000800  2               curr            = $61
000800  2               
000800  2               ;tex: An alternate location used in tan-
000800  2               ;dem with curr. COLR is used by RE-
000800  2               ;FRESH. temp is used throughout as a
000800  2               ;reusable scratchpad pointer. INDIR is
000800  2               ;also a reusable indirect pointer.
000800  2               ;UNDERCURS stores the value of the
000800  2               ;character highlighted by the cursor.
000800  2               
000800  2               tex             = $FB
000800  2               temp            = $5E
000800  2               indir           = $FD
000800  2               UNDERCURS       = $FA
000800  2               
000800  2               ;RETCHAR is the screen-
000800  2               ;code value of the return mark (a left-
000800  2               ;pointing arrow).
000800  2               
000800  2               retchar         = 31
000800  2               
000800  2               ; refresh routine state
000800  2               scrrow          = $5B           ; current screen row during refresh
000800  2               csrcol          = $5C           ; cursor column found during refresh
000800  2               csrrow          = $5D           ; cursor row found during refresh
000800  2               
000800  1               
000800  1               BEGIN:
000800  1  20 6D 13             JSR     INIT
000803  1  20 EE 08             JSR     erase
000806  1  20 C7 13             JSR     INIT2
000809  1  4C 3F 09             JMP     main
00080C  1               
00080C  1               ;UMOVE is a high-speed memory move
00080C  1               ;routine. It gets its speed from self-
00080C  1               ;modifying code (the $0000's at
00080C  1               ;MOVLOOP are replaced by actual ad-
00080C  1               ;dresses when UMOVE is called). Some
00080C  1               ;assemblers may assemble this as a
00080C  1               ;zero-page mode, so you may want to
00080C  1               ;change the $0000's to $FFFF's. UMOVE
00080C  1               ;is used to move an overlapping range
00080C  1               ;of memory upward, so it is used to de-
00080C  1               ;lete. Set froml/fromh to point to
00080C  1               ;the source area of memory,
00080C  1               ;destl/desth to point to the destina-
00080C  1               ;tion, and llen/hlen to hold the
00080C  1               ;length of the area being moved.
00080C  1               
00080C  1               umove:
00080C  1  A5 55                LDA     froml
00080E  1  8D 2C 08             STA     MOVLOOP+1
000811  1  A5 56                LDA     fromh
000813  1  8D 2D 08             STA     MOVLOOP+2
000816  1  A5 57                LDA     destl
000818  1  8D 2F 08             STA     MOVLOOP+4
00081B  1  A5 58                LDA     desth
00081D  1  8D 30 08             STA     MOVLOOP+5
000820  1  A6 5A                LDX     hlen
000822  1  F0 20                BEQ     SKIPMOV
000824  1               MOV1:
000824  1  A9 00                LDA     #0
000826  1               MOV2:
000826  1  8D EA 1B             STA     endpos
000829  1  A0 00                LDY     #0
00082B  1               MOVLOOP:
00082B  1  B9 00 00             LDA     $0000,Y
00082E  1  99 00 00             STA     $0000,Y
000831  1  C8                   INY
000832  1  CC EA 1B             CPY     endpos
000835  1  D0 F4                BNE     MOVLOOP
000837  1  EE 2D 08             INC     MOVLOOP+2
00083A  1  EE 30 08             INC     MOVLOOP+5
00083D  1  E0 00                CPX     #0
00083F  1  F0 07                BEQ     OUT
000841  1  CA                   DEX
000842  1  D0 E0                BNE     MOV1
000844  1               SKIPMOV:
000844  1  A5 59                LDA     llen
000846  1  D0 DE                BNE     MOV2
000848  1               OUT:
000848  1  60                   RTS
000849  1               ;DMOVE uses the same variables as UMOVE, but is used to move an
000849  1               ;overlapping block of memory down ward, so it is used to insert. If the block
000849  1               ;of memory to be moved does not overlap the destination area, then either
000849  1               ;routine can be used.
000849  1               dmove:
000849  1  A5 5A                LDA     hlen
00084B  1  AA                   TAX
00084C  1  05 59                ORA     llen
00084E  1  D0 01                BNE     NOTNULL
000850  1  60                   RTS
000851  1               NOTNULL:
000851  1  18                   CLC
000852  1  8A                   TXA
000853  1  65 56                ADC     fromh
000855  1  8D 74 08             STA     DMOVLOOP+2
000858  1  A5 55                LDA     froml
00085A  1  8D 73 08             STA     DMOVLOOP+1
00085D  1  18                   CLC
00085E  1  8A                   TXA
00085F  1  65 58                ADC     desth
000861  1  8D 77 08             STA     DMOVLOOP+5
000864  1  A5 57                LDA     destl
000866  1  8D 76 08             STA     DMOVLOOP+4
000869  1  E8                   INX
00086A  1  A4 59                LDY     llen
00086C  1  D0 04                BNE     DMOVLOOP
00086E  1  F0 0D                BEQ     SKIPDMOV
000870  1               DMOV1:
000870  1  A0 FF                LDY     #255
000872  1               DMOVLOOP:
000872  1  B9 00 00             LDA     $0000,Y
000875  1  99 00 00             STA     $0000,Y
000878  1  88                   DEY
000879  1  C0 FF                CPY     #255
00087B  1  D0 F5                BNE     DMOVLOOP
00087D  1               SKIPDMOV:
00087D  1  CE 74 08             DEC     DMOVLOOP+2
000880  1  CE 77 08             DEC     DMOVLOOP+5
000883  1  CA                   DEX
000884  1  D0 EA                BNE     DMOV1
000886  1  60                   RTS
000887  1               
000887  1               ; displaynum replaces the call to BASIC $BCDC
000887  1               ; from the original one.
000887  1               nums:
000887  1  01 00 0A 00          .WORD   1,10,100,1000,10000
00088B  1  64 00 E8 03  
00088F  1  10 27        
000891  1               numarg:
000891  1  00 00                .WORD   0
000893  1               numspace:
000893  1  20                   .BYTE   $20
000894  1               displaynum:
000894  1  8E 91 08             STX     numarg
000897  1  8D 92 08             STA     numarg+1
00089A  1               ;lda #space
00089A  1               ;jsr chrout ; leading space just like real one
00089A  1               basicdisplaynum:
00089A  1  A0 08                LDY     #8
00089C  1               dnzz:
00089C  1  AD 92 08             LDA     numarg+1
00089F  1  D9 88 08             CMP     nums+1,y
0008A2  1  90 0A                BCC     dn2
0008A4  1  D0 0C                BNE     startout
0008A6  1  AD 91 08             LDA     numarg
0008A9  1  D9 87 08             CMP     nums,y
0008AC  1  B0 04                BCS     startout
0008AE  1               dn2:
0008AE  1  88                   DEY
0008AF  1  88                   DEY
0008B0  1  D0 EA                BNE     dnzz
0008B2  1               startout:
0008B2  1  A9 30                LDA     #$30
0008B4  1  8D 93 08             STA     numspace
0008B7  1               diglp:
0008B7  1  AD 92 08             LDA     numarg+1
0008BA  1  D9 88 08             CMP     nums+1,y
0008BD  1  90 24                BCC     digitout
0008BF  1  D0 0A                BNE     dontcmp
0008C1  1  AD 91 08             LDA     numarg
0008C4  1  F9 87 08             SBC     nums,y          ;carry already set
0008C7  1  90 1A                BCC     digitout
0008C9  1  B0 06                BCS     digsub
0008CB  1               dontcmp:
0008CB  1  AD 91 08             LDA     numarg
0008CE  1  F9 87 08             SBC     nums,y          ;carry already set
0008D1  1               digsub: ; subtract value of digit
0008D1  1  EE 93 08             INC     numspace
0008D4  1  8D 91 08             STA     numarg          ;already subtracted
0008D7  1  AD 92 08             LDA     numarg+1
0008DA  1  F9 88 08             SBC     nums+1,y
0008DD  1  8D 92 08             STA     numarg+1
0008E0  1  4C B7 08             JMP     diglp
0008E3  1               digitout:
0008E3  1  AD 93 08             LDA     numspace
0008E6  1  20 4A 14             JSR     chrout
0008E9  1  88                   DEY
0008EA  1  88                   DEY
0008EB  1  10 C5                BPL     startout
0008ED  1  60                   RTS
0008EE  1               
0008EE  1               
0008EE  1               ; comment from left column of page 99
0008EE  1               
0008EE  1               erase:
0008EE  1  AD DD 1B             LDA     texstart
0008F1  1  85 FB                STA     tex
0008F3  1  8D E6 1B             STA     toplin
0008F6  1  8D EC 1B             STA     lastline
0008F9  1  85 61                STA     curr
0008FB  1  AD DE 1B             LDA     texstart+1
0008FE  1  85 FC                STA     tex+1
000900  1  8D E7 1B             STA     toplin+1
000903  1  8D ED 1B             STA     lastline+1
000906  1  85 62                STA     curr+1
000908  1  38                   SEC
000909  1  AD E0 1B             LDA     texend+1
00090C  1  ED DE 1B             SBC     texstart+1
00090F  1  AA                   TAX
000910  1  A9 20                LDA     #space
000912  1               CLRLOOP:
000912  1  A0 FF                LDY     #255
000914  1  C6 FC                DEC     tex+1
000916  1  91 FB                STA     (tex),Y
000918  1  C8                   INY
000919  1  E6 FC                INC     tex+1
00091B  1               CLR2:
00091B  1  91 FB                STA     (tex),Y
00091D  1  C8                   INY
00091E  1  D0 FB                BNE     CLR2
000920  1  E6 FC                INC     tex+1
000922  1  CA                   DEX
000923  1  D0 F6                BNE     CLR2
000925  1  91 FB                STA     (tex),Y
000927  1  60                   RTS
000928  1               
000928  1               ; PRMSG is used anytime we need to
000928  1               ; print something at the top of the screen
000928  1               ; (the command line). Pass it the address
000928  1               ; of the message to be printed by storing
000928  1               ; the low .byte of the address in the accu
000928  1               ; mulator, and the high .byte in the
000928  1               ; register. The message in memory must
000928  1               ; end with a zero .byte. The routine does
000928  1               ; not add a carriage return.
000928  1               
000928  1               PRMSG:
000928  1  85 5E                STA     temp
00092A  1  84 5F                STY     temp+1
00092C  1  A0 00                LDY     #0
00092E  1               PRLOOP:
00092E  1  B1 5E                LDA     (temp),Y
000930  1  F0 06                BEQ     PREXIT
000932  1  20 4A 14             JSR     chrout
000935  1  C8                   INY
000936  1  D0 F6                BNE     PRLOOP
000938  1               PREXIT:
000938  1  60                   RTS
000939  1               getakey:
000939  1  20 38 14             JSR     chrin
00093C  1  F0 FB                BEQ     getakey
00093E  1  60                   RTS
00093F  1               
00093F  1               
00093F  1               
00093F  1               ;The MAIN loop blinks the cursor,
00093F  1               ;checks for keystrokes, converts
00093F  1               ;them from ASCII to screen codes,
00093F  1               ;puts them in text at the CURRent position, and increments
00093F  1               ;the CURRent position and lastline. It also checks for special
00093F  1               ;cases like the back-arrow and the return key and passes control
00093F  1               ;characters to the CONTROL routine. SHIFTed spaces are turned into
00093F  1               ;unSHIFTed ones. The INSMODE flag is checked to see if we should
00093F  1               ;insert a space before a character.
00093F  1               main:
00093F  1  20 53 15             JSR     hidecursor
000942  1  20 6A 14             JSR     refresh
000945  1  20 40 15             JSR     showcursor
000948  1               WAIT:
000948  1  20 38 14             JSR     chrin
00094B  1  F0 FB                BEQ     WAIT
00094D  1               KEYPRESS:
00094D  1  48                   PHA                     ; save key code (hidecursor trashes A)
00094E  1  20 53 15             JSR     hidecursor
000951  1  68                   PLA                     ; restore key code
000952  1  AA                   TAX
000953  1  E0 08                CPX     #8              ; ASCII backspace
000955  1  F0 04                BEQ     @dobackspace
000957  1  E0 7F                CPX     #127            ; ASCII DEL
000959  1  D0 0A                BNE     NOTBKS
00095B  1               @dobackspace:
00095B  1  20 05 0B             JSR     left
00095E  1  A9 20                LDA     #space
000960  1  92 61                STA     (curr)
000962  1  4C 3F 09             JMP     main
000965  1               NOTBKS:
000965  1  AD E8 1B             LDA     msgflg
000968  1  F0 05                BEQ     nomsg
00096A  1  DA                   PHX
00096B  1  20 E2 13             JSR     sysmsg
00096E  1  FA                   PLX
00096F  1               nomsg:
00096F  1  8A                   TXA
000970  1  C9 0D                CMP     #13             ; ASCII carriage return?
000972  1  D0 04                BNE     notcr
000974  1  A2 1F                LDX     #retchar        ; store paragraph marker directly
000976  1  80 0C                BRA     NESHIFT         ; skip control-char check (retchar < 32)
000978  1               notcr:
000978  1  8A                   TXA
000979  1  29 7F                AND     #127
00097B  1  C9 20                CMP     #32
00097D  1  90 4A                BCC     CONTROL
00097F  1  8A                   TXA
000980  1  C9 E0                CMP     #$E0
000982  1  B0 45                BCS     CONTROL
000984  1               NESHIFT:
000984  1  8A                   TXA
000985  1  48                   PHA
000986  1  A0 00                LDY     #0
000988  1  B1 61                LDA     (curr),Y
00098A  1  C9 1F                CMP     #retchar
00098C  1  F0 07                BEQ     DOINS
00098E  1  AD E9 1B             LDA     INSMODE
000991  1  C9 00                CMP     #$00
000993  1  F0 03                BEQ     NOTINST
000995  1               DOINS:
000995  1  20 94 0E             JSR     inschar
000998  1               NOTINST:
000998  1  68                   PLA
000999  1               PUTCHR:
000999  1  92 61                STA     (curr)
00099B  1  20 6A 14             JSR     refresh
00099E  1  38                   SEC
00099F  1  A5 61                LDA     curr
0009A1  1  ED EC 1B             SBC     lastline
0009A4  1  85 5E                STA     temp
0009A6  1  A5 62                LDA     curr+1
0009A8  1  ED ED 1B             SBC     lastline+1
