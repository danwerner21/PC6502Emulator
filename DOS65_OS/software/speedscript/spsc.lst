0017FF  2  A2 20                LDX     #32
001801  2  A9 00                LDA     #0
001803  2               @clrfcb:
001803  2  9D 70 20             STA     fcb,X
001806  2  CA                   DEX
001807  2  10 FA                BPL     @clrfcb
001809  2  A2 01                LDX     #1
