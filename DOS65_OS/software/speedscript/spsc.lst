0009C6  1  4C 3F 09             JMP     main
0009C9  1               ;CONTROl looks up a keyboard command in the list
0009C9  1               ;of control codes at CTBL. The first .byte of
0009C9  1               ;CTBL is the actual number of commands. Once the
0009C9  1               ;position is found, this position is doubled as
0009C9  1               ;an index to the two-byte address table at VECT.
0009C9  1               ;The address of MAIN-1 is put on the stack,
0009C9  1               ;simulating the return address; then the address
0009C9  1               ;of the command routine taken from VECT is pushed.
0009C9  1               ;We then perform an RTS. RTS pulls the .bytes off
0009C9  1               ;the stack as if they were put there by a JSR.
0009C9  1               ;This powerful technique is used to simulate
0009C9  1               ;ON+GOTO in machine language.
0009C9  1               CONTROL:
0009C9  1  8A                   TXA
0009CA  1  AE EB 09             LDX     CTBL
0009CD  1               SRCH:
0009CD  1  DD EB 09             CMP     CTBL,X
0009D0  1  F0 06                BEQ     FOUND
0009D2  1  CA                   DEX
0009D3  1  D0 F8                BNE     SRCH
0009D5  1  4C 3F 09             JMP     main
0009D8  1               FOUND:
0009D8  1  CA                   DEX
0009D9  1  8A                   TXA
0009DA  1  0A                   ASL
0009DB  1  AA                   TAX
0009DC  1  A9 09                LDA     #>(main-1)
0009DE  1  48                   PHA
0009DF  1  A9 3E                LDA     #<(main-1)
0009E1  1  48                   PHA
0009E2  1  BD 0B 0A             LDA     VECT+1,X
0009E5  1  48                   PHA
0009E6  1  BD 0A 0A             LDA     VECT,X
0009E9  1  48                   PHA
0009EA  1  60                   RTS
0009EB  1               ; Command key table - remapped for ASCII (Ctrl+letter combos)
0009EB  1               ; CTBL[1..N] are key codes, VECT[0..N-1] are matching function addresses
0009EB  1               CTBL:
0009EB  1  1E                   .BYTE   30              ; 30 commands
0009EC  1  F9                   .BYTE   $F9             ; <RIGHT>:cursor right
0009ED  1  F8                   .BYTE   $F8             ; <LEFT>: cursor left
0009EE  1  F1                   .BYTE   $F1             ; <DEL>:  delete character at cursor
0009EF  1  04                   .BYTE   4               ; Ctrl+D: delete (S,W,P)
0009F0  1  13                   .BYTE   19              ; Ctrl+S: home (top of text)
0009F1  1  F0                   .BYTE   $F0             ; <INS>:  insert mode toggle
0009F2  1  11                   .BYTE   17              ; Ctrl+Q: erase all text (with confirm)
0009F3  1  05                   .BYTE   5               ; Ctrl+E: erase (S,W,P)
0009F4  1  0C                   .BYTE   12              ; Ctrl+L: load file
0009F5  1  16                   .BYTE   22              ; Ctrl+V: save file
0009F6  1  12                   .BYTE   18              ; Ctrl+R: insert buffer
0009F7  1  18                   .BYTE   24              ; Ctrl+X: switch (cut to buffer)
0009F8  1  1A                   .BYTE   26              ; Ctrl+Z: go to end of text
0009F9  1  10                   .BYTE   16              ; Ctrl+P: print
0009FA  1  1C                   .BYTE   28              ; Ctrl+\: format code
0009FB  1  19                   .BYTE   25              ; Ctrl+Y: delete line
0009FC  1  01                   .BYTE   1               ; Ctrl+A: alpha (go to top of screen)
0009FD  1  0B                   .BYTE   11              ; Ctrl+K: kill buffer
0009FE  1  08                   .BYTE   8               ; Ctrl+H: hunt/search (backspace handled before here)
0009FF  1  1F                   .BYTE   31              ; Ctrl+_: show free memory
000A00  1  03                   .BYTE   3               ; Ctrl+C: tab
000A01  1  0A                   .BYTE   10              ; Ctrl+J: replace start
000A02  1  07                   .BYTE   7               ; Ctrl+G: search and replace
000A03  1  F7                   .BYTE   $F7             ; <DOWN>: paragraph right
000A04  1  F6                   .BYTE   $F6             ; <UP>:   paragraph left
000A05  1  17                   .BYTE   23              ; Ctrl+W: word left
000A06  1  15                   .BYTE   21              ; Ctrl+U: word right
000A07  1  E2                   .BYTE   $E2             ; <F3>:   return to os
000A08  1  E0                   .BYTE   $E0             ; <F1>:   disk catalog
000A09  1  E8                   .BYTE   $E8             ; <F9>:   print
000A0A  1               VECT:
000A0A  1  FB 0A                .WORD   right-1         ; <RIGHT>
000A0C  1  04 0B                .WORD   left-1          ; <LEFT>
000A0E  1  3D 0D                .WORD   DELCHAR-1       ; <DEL>
000A10  1  6D 0D                .WORD   DELETE-1        ; Ctrl+D
000A12  1  AC 0D                .WORD   HOME-1          ; Ctrl+S
000A14  1  F5 0E                .WORD   instgl-1        ; <INSERT>
000A16  1  11 0F                .WORD   CLEAR-1         ; Ctrl+Q
000A18  1  AB 0F                .WORD   ERAS-1          ; Ctrl+E
000A1A  1  5C 15                .WORD   TLOAD-1         ; Ctrl+L
000A1C  1  BA 16                .WORD   TSAVE-1         ; Ctrl+V
000A1E  1  0A 11                .WORD   insbuffer-1     ; Ctrl+R
000A20  1  98 11                .WORD   switch-1        ; Ctrl+X
000A22  1  89 0B                .WORD   endtex-1        ; Ctrl+Z
000A24  1  85 19                .WORD   print-1         ; Ctrl+P
000A26  1  82 10                .WORD   FORMAT-1        ; Ctrl+\
000A28  1  58 0D                .WORD   DELIN-1         ; Ctrl+Y
000A2A  1  A5 11                .WORD   alpha-1         ; Ctrl+A
000A2C  1  58 0C                .WORD   killbuff-1      ; Ctrl+K
000A2E  1  EC 11                .WORD   HUNT-1          ; Ctrl+H
000A30  1  26 13                .WORD   FREEMEM-1       ; Ctrl+_
000A32  1  50 0E                .WORD   tab-1           ; Ctrl+C
000A34  1  88 12                .WORD   repstart-1      ; Ctrl+J
000A36  1  CB 11                .WORD   SANDR-1         ; Ctrl+G
000A38  1  2F 0F                .WORD   paright-1       ; <DOWN>
000A3A  1  50 0F                .WORD   parleft-1       ; <UP>
000A3C  1  0F 0B                .WORD   wleft-1         ; Ctrl+W
000A3E  1  45 0B                .WORD   wright-1        ; Ctrl+U
000A40  1  40 13                .WORD   quit-1          ; <F3>
000A42  1  FE 17                .WORD   catalog-1       ; <F1>
000A44  1  85 19                .WORD   print-1         ; <F9>
