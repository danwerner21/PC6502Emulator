001A1B  2  A9 0C                LDA     #12             ; FF (form feed)
001A1D  2  A2 05                LDX     #5              ; PEM fn 5: list output
001A1F  2  20 03 01             JSR     PEM
001A22  2  20 10 14 A9          TOPPRINTMESSAGE okmsg
001A26  2  1B A0 1B 20  
001A2A  2  28 09        
001A2C  2  A9 01                LDA     #1
