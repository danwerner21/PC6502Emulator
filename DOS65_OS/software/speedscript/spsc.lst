001986  2               ;--------------------------------------------------------------
001986  2               ; print: Print formatted document to list device (printer).
001986  2               ; Word-wraps at 80 columns (same as screen display).
001986  2               ; Converts retchar to CR/LF. Press any key to abort.
001986  2               ;--------------------------------------------------------------
001986  2               print:
001986  2  20 10 14 A9          TOPPRINTMESSAGE @prtmsg
00198A  2  32 A0 1A 20  
00198E  2  28 09        
001990  2               ; source pointer: start of text
001990  2  AD DD 1B 85          COPY16  texstart,tex
001994  2  FB AD DE 1B  
001998  2  85 FC        
00199A  2               
00199A  2               @prtpage:
00199A  2               ; check if done: tex >= lastline
00199A  2  A5 FC                LDA     tex+1
00199C  2  CD ED 1B             CMP     lastline+1
00199F  2  90 09                BCC     @prtscan        ; high byte less = more to go
0019A1  2  D0 78                BNE     @prtdone        ; high byte greater = past end
0019A3  2  A5 FB                LDA     tex
0019A5  2  CD EC 1B             CMP     lastline
0019A8  2  B0 71                BCS     @prtdone        ; low byte >= = done
0019AA  2               
0019AA  2               @prtscan:
0019AA  2               ; scan for line break (same word-wrap algorithm as refresh)
0019AA  2  A0 00                LDY     #0
0019AC  2               @scanloop:
0019AC  2  B1 FB                LDA     (tex),Y
0019AE  2  C8                   INY
0019AF  2  29 7F                AND     #$7F
0019B1  2  C9 1F                CMP     #retchar
0019B3  2  F0 13                BEQ     @gotbreak
0019B5  2  C0 50                CPY     #80
0019B7  2  D0 F3                BNE     @scanloop
0019B9  2               ; hit 80 chars without paragraph break - word wrap
0019B9  2               ; scan backward for a space to break at
0019B9  2  88                   DEY
0019BA  2               @wrapback:
0019BA  2  B1 FB                LDA     (tex),Y
0019BC  2  29 7F                AND     #$7F
0019BE  2  C9 20                CMP     #space
0019C0  2  F0 05                BEQ     @wrapfound
0019C2  2  88                   DEY
0019C3  2  D0 F5                BNE     @wrapback
0019C5  2               ; no space in entire line - force break at column width
0019C5  2  A0 4F                LDY     #79
0019C7  2               @wrapfound:
0019C7  2  C8                   INY                     ; wrap point (char after space)
0019C8  2               @gotbreak:
0019C8  2  84 5E                STY     temp            ; temp = chars to consume this line
0019CA  2               
0019CA  2               ; output the line characters to list device
0019CA  2  A0 00                LDY     #0
0019CC  2               @prtchar:
0019CC  2  C4 5E                CPY     temp
0019CE  2  F0 18                BEQ     @endline
0019D0  2  B1 FB                LDA     (tex),Y
0019D2  2  29 7F                AND     #$7F
0019D4  2  C9 1F                CMP     #retchar
0019D6  2  F0 0D                BEQ     @skipchar       ; don't print paragraph marker
0019D8  2  C9 20                CMP     #space
0019DA  2  B0 02                BCS     @printable
0019DC  2  A9 20                LDA     #space          ; replace control chars with space
0019DE  2               @printable:
0019DE  2  5A                   PHY                     ; save index (PEM trashes regs)
0019DF  2  A2 05                LDX     #5              ; PEM fn 5: list output
0019E1  2  20 03 01             JSR     PEM
0019E4  2  7A                   PLY                     ; restore index
0019E5  2               @skipchar:
0019E5  2  C8                   INY
0019E6  2  80 E4                BRA     @prtchar
0019E8  2               
0019E8  2               @endline:
0019E8  2               ; send CR + LF to list device
0019E8  2  A9 0D                LDA     #13             ; CR
0019EA  2  A2 05                LDX     #5
0019EC  2  20 03 01             JSR     PEM
0019EF  2  A9 0A                LDA     #10             ; LF
0019F1  2  A2 05                LDX     #5
0019F3  2  20 03 01             JSR     PEM
0019F6  2               
0019F6  2               ; advance tex past consumed characters
0019F6  2  18                   CLC
0019F7  2  A5 5E                LDA     temp
0019F9  2  65 FB                ADC     tex
0019FB  2  85 FB                STA     tex
0019FD  2  A5 FC                LDA     tex+1
0019FF  2  69 00                ADC     #0
001A01  2  85 FC                STA     tex+1
001A03  2               
001A03  2               ; check for abort (any key pressed?)
001A03  2  20 38 14             JSR     chrin           ; non-blocking keyboard check
001A06  2  D0 03                BNE     @prtabort       ; non-zero = key pressed, abort
001A08  2  4C 9A 19             JMP     @prtpage
001A0B  2               
001A0B  2               @prtabort:
001A0B  2  20 10 14 A9          TOPPRINTMESSAGE @abrtmsg
001A0F  2  3E A0 1A 20  
001A13  2  28 09        
001A15  2  A9 01                LDA     #1
001A17  2  8D E8 1B             STA     msgflg
001A1A  2  60                   RTS
001A1B  2               
001A1B  2               @prtdone:
