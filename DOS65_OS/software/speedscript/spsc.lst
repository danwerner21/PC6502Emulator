0017DC  2  8D E8 1B             STA     msgflg
0017DF  2  60                   RTS
0017E0  2               
0017E0  2               ; --- write codebuffer to disk ---
0017E0  2               ; Returns Z=1 (BEQ) on success, Z=0 (BNE) on error.
0017E0  2               @flush:
0017E0  2  A9 70                LDA     #<fcb
