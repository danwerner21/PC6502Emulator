00136D  2               ;The initialization routine sets up the
00136D  2               ;memory map, clears out certain flags,
00136D  2               ;and enables the raster interrupt
00136D  2               
00136D  2               INIT:
00136D  2               ; set 80 col text mode here
00136D  2  A2 50                LDX     #80
00136F  2  86 50                STX     COLUMNS
001371  2               ; Use 23 rows so refresh paints rows 1-22 only.
001371  2               ; Row 0 = banner, row 23 = unused. Screen has 24 rows (0-23).
001371  2               ; Painting row 23 wraps cursor to row 24 which auto-scrolls.
001371  2  A0 17                LDY     #23
001373  2  84 51                STY     ROWS
001375  2               ; ensure 80 col
001375  2  A9 39                LDA     #FC_SETMODE
001377  2  85 32                STA     farfunct
001379  2  A9 01                LDA     #1
00137B  2  20 F0 FF             JSR     DO_FARCALL
