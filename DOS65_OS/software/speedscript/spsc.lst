001458  2               ; drain all pending keystrokes from the keyboard buffer
001458  2               drainkeys:
001458  2  A2 0B                LDX     #11             ; keyboard status
00145A  2  20 03 01             JSR     PEM
00145D  2  C9 00                CMP     #0
00145F  2  F0 08                BEQ     @drained
001461  2  A2 06                LDX     #6              ; consume the key
001463  2  20 03 01             JSR     PEM
001466  2  4C 58 14             JMP     drainkeys
001469  2               @drained:
001469  2  60                   RTS
00146A  2               
00146A  2               ;refresh copies a screenful of text
00146A  2               ;from the area of memory pointed to by
00146A  2               ;toplin. It works like a printer routine,
00146A  2               ;fitting a line of text between the screen
00146A  2               ;margins, wrapping words, and restarts
00146A  2               ;at the left margin after printing a car-
00146A  2               ;riage return.
00146A  2               ;
00146A  2               ;It also tracks the screen position of
00146A  2               ;the cursor (curr) so the hardware cursor
00146A  2               ;can be painted there afterward.
00146A  2               ;
00146A  2               ;Uses direct video memory writes via MMU
00146A  2               ;paging for performance (~18x faster than
00146A  2               ;per-character FARCALL calls).
00146A  2               
00146A  2               refresh:
00146A  2               ; force screen dimensions (protect against corruption)
00146A  2  A9 17                LDA     #23
00146C  2  85 51                STA     ROWS
00146E  2  A9 50                LDA     #80
001470  2  85 50                STA     COLUMNS
001472  2               ; set pointer tex to top of visible text
001472  2  AD E6 1B 85          COPY16  toplin,tex
001476  2  FB AD E7 1B  
00147A  2  85 FC        
00147C  2  A9 01                LDA     #1
00147E  2  85 5B                STA     scrrow          ; start at screen row 1 (row 0 = command line)
001480  2               ; default cursor position (in case curr is off-screen)
001480  2  A9 01                LDA     #1
001482  2  85 5D                STA     csrrow
001484  2  64 5C                STZ     csrcol
001486  2               
001486  2               ; map video text page into $A000-$AFFF
001486  2  A0 F9                LDY     #VIDTEXT_PAGE
001488  2  20 2D 15             JSR     vid_enter
00148B  2               ; initialize video pointer to row 1 ($A000 + 1*80 = $A050)
00148B  2  A9 50                LDA     #$50
00148D  2  85 FD                STA     indir
00148F  2  A9 A0                LDA     #$A0
001491  2  85 FE                STA     indir+1
001493  2               
001493  2               ; main page loop: process one screen row per iteration
001493  2               RPPAGE:
001493  2  A0 00                LDY     #0
001495  2               ; scan text for line break point
001495  2               RPLINE:
001495  2  B1 FB                LDA     (tex),Y
001497  2  C8                   INY
001498  2  29 7F                AND     #$7F            ; strip high bit for comparison
00149A  2  C9 1F                CMP     #retchar        ; end of paragraph?
00149C  2  F0 14                BEQ     RBREAK
00149E  2  C4 50                CPY     COLUMNS
0014A0  2  D0 F3                BNE     RPLINE
0014A2  2               
0014A2  2               ; hit screen width without a paragraph break - word wrap
0014A2  2               ; scan backward for a space to break at
0014A2  2  88                   DEY
0014A3  2               RSLOOP:
0014A3  2  B1 FB                LDA     (tex),Y
0014A5  2  29 7F                AND     #$7F
0014A7  2  C9 20                CMP     #space
0014A9  2  F0 06                BEQ     RSBRK           ; found a space - wrap here
0014AB  2  88                   DEY
0014AC  2  D0 F5                BNE     RSLOOP
0014AE  2               ; no space found in entire line - force break at column width
0014AE  2  A4 50                LDY     COLUMNS
0014B0  2  88                   DEY
0014B1  2               RSBRK:
0014B1  2  C8                   INY                     ; wrap point (char after the space)
0014B2  2               RBREAK:
0014B2  2  84 5E                STY     temp            ; temp = number of chars in this line
0014B4  2               
0014B4  2               ; copy line to video memory, tracking cursor position
0014B4  2  A0 00                LDY     #0
0014B6  2               RCOPY:
0014B6  2               ; check if this text position is the cursor (tex + Y == curr?)
0014B6  2  98                   TYA
0014B7  2  18                   CLC
0014B8  2  65 FB                ADC     tex             ; A = low byte of tex+Y
0014BA  2  48                   PHA                     ; save (preserves carry for high byte calc)
0014BB  2  A5 FC                LDA     tex+1
0014BD  2  69 00                ADC     #0              ; A = high byte of tex+Y
0014BF  2  C5 62                CMP     curr+1          ; compare high bytes
0014C1  2  D0 0D                BNE     @nocsr
0014C3  2  68                   PLA                     ; A = low byte of tex+Y
0014C4  2  C5 61                CMP     curr            ; compare low bytes
0014C6  2  D0 09                BNE     @nocsr2
0014C8  2               ; found the cursor position on screen
0014C8  2  84 5C                STY     csrcol
0014CA  2  A5 5B                LDA     scrrow
0014CC  2  85 5D                STA     csrrow
0014CE  2  80 01                BRA     @dochr
0014D0  2               @nocsr:
0014D0  2  68                   PLA                     ; clean up stack
0014D1  2               @nocsr2:
0014D1  2               @dochr:
0014D1  2               ; read character from text memory and write to video RAM
0014D1  2  B1 FB                LDA     (tex),Y         ; read from text buffer (below $A000)
0014D3  2  29 7F                AND     #$7F            ; strip high bit
0014D5  2  C9 20                CMP     #space
0014D7  2  B0 02                BCS     @rok            ; >= 32 is printable
0014D9  2  A9 20                LDA     #space          ; replace control chars with space
0014DB  2               @rok:
0014DB  2  91 FD                STA     (indir),Y       ; write directly to video RAM
0014DD  2  C8                   INY
0014DE  2  C4 5E                CPY     temp
0014E0  2  D0 D4                BNE     RCOPY
0014E2  2               
0014E2  2               ; store length of first screen line in LENTABLE
0014E2  2  A5 5B                LDA     scrrow
0014E4  2  C9 01                CMP     #1
0014E6  2  D0 05                BNE     RCLRLN
0014E8  2  A5 5E                LDA     temp
0014EA  2  8D E5 1B             STA     LENTABLE
0014ED  2               
0014ED  2               ; pad remainder of line with spaces
0014ED  2               RCLRLN:
0014ED  2  A4 5E                LDY     temp
0014EF  2  A9 20                LDA     #space
0014F1  2               @rpad:
0014F1  2  C4 50                CPY     COLUMNS
0014F3  2  F0 05                BEQ     RCLEARED
0014F5  2  91 FD                STA     (indir),Y       ; write space to video RAM
0014F7  2  C8                   INY
0014F8  2  80 F7                BRA     @rpad
0014FA  2               
0014FA  2               RCLEARED:
0014FA  2               ; advance tex past the characters consumed
0014FA  2  18                   CLC
0014FB  2  A5 5E                LDA     temp
0014FD  2  65 FB                ADC     tex
0014FF  2  85 FB                STA     tex
001501  2  A5 FC                LDA     tex+1
001503  2  69 00                ADC     #0
001505  2  85 FC                STA     tex+1
001507  2               
001507  2               ; advance video pointer to next row (+80 bytes)
001507  2  18                   CLC
001508  2  A5 FD                LDA     indir
00150A  2  69 50                ADC     #80
00150C  2  85 FD                STA     indir
00150E  2  A5 FE                LDA     indir+1
001510  2  69 00                ADC     #0
001512  2  85 FE                STA     indir+1
001514  2               
001514  2               ; next screen row
001514  2  E6 5B                INC     scrrow
001516  2  A5 5B                LDA     scrrow
001518  2  C5 51                CMP     ROWS
00151A  2  F0 03                BEQ     @refdone
00151C  2  4C 93 14             JMP     RPPAGE
00151F  2               @refdone:
00151F  2               
00151F  2               ; unmap video memory
00151F  2  20 3A 15             JSR     vid_exit
001522  2               ; record bottom-of-screen text address
001522  2  A5 FB 8D F0          COPY16  tex,BOTSCR
001526  2  1B A5 FC 8D  
00152A  2  F1 1B        
00152C  2  60                   RTS
00152D  2               
00152D  2               ; --- video memory paging helpers ---
00152D  2               ; Following the pattern from dbasic/screencmds.asm
00152D  2               
00152D  2               ; Map a video sub-page into $A000-$AFFF via Task 01.
00152D  2               ; Y = video sub-page (e.g. VIDTEXT_PAGE for text chars).
00152D  2               ; Trashes A, X. Preserves Y.
00152D  2               vid_enter:
00152D  2  A9 01                LDA     #$01            ; configure Task 01
00152F  2  A2 0A                LDX     #$0A            ; bank $A ($A000-$AFFF)
001531  2  20 F6 FF             JSR     SETPAGE         ; Y = video sub-page (set by caller)
001534  2  A9 01                LDA     #$01
001536  2  8D E0 EF             STA     PC6502_ACT_TASK ; switch to Task 01
001539  2  60                   RTS
00153A  2               
00153A  2               ; Switch back to Task 00 (normal memory at $A000-$AFFF).
00153A  2               vid_exit:
00153A  2  A9 00                LDA     #$00
00153C  2  8D E0 EF             STA     PC6502_ACT_TASK ; switch to Task 00
00153F  2  60                   RTS
001540  2               
001540  2               ; --- cursor helpers using FARCALL #58/#59 ---
001540  2               
001540  2               ; Paint the hardware cursor at the position found during refresh.
001540  2               ; Call this AFTER refresh returns.
001540  2               showcursor:
001540  2  A6 5C                LDX     csrcol
001542  2  A4 5D                LDY     csrrow
001544  2  A9 25                LDA     #FC_LOCATE
001546  2  85 32                STA     farfunct
001548  2  20 F0 FF             JSR     DO_FARCALL
00154B  2  A9 3A                LDA     #FC_PAINTCSR
00154D  2  85 32                STA     farfunct
00154F  2  20 F0 FF             JSR     DO_FARCALL
001552  2  60                   RTS
001553  2               
001553  2               ; Remove the hardware cursor from the screen.
001553  2               ; Call this BEFORE refresh or when processing a keypress.
001553  2               hidecursor:
001553  2  A9 3B                LDA     #FC_UNPAINTCSR
001555  2  85 32                STA     farfunct
001557  2  20 F0 FF             JSR     DO_FARCALL
00155A  2  60                   RTS
00155B  2               
00155B  2               BORDER:
00155B  2  60                   RTS
00155C  2               
00155C  2               scrcol:
00155C  2               LETTERS:
00155C  2  60                   RTS
00155D  2               
00155D  1                       .INCLUDE "io.asm"
00155D  2               ;
00155D  2               ;
00155D  2               ;
00155D  2               ; i/o
00155D  2               ;--------------------------------------------------------------
00155D  2               ; TLOAD: Load a text file from disk into the editor.
00155D  2               ; Prompts for filename, opens via DOS/65 PEM, reads sequential
00155D  2               ; 128-byte records into text memory, stops at CP/M EOF ($1A).
00155D  2               ;--------------------------------------------------------------
00155D  2               TLOAD:
00155D  2  20 10 14 A9          TOPPRINTMESSAGE loadmsg ; "Load:" on command line
001561  2  25 A0 1B 20  
001565  2  28 09        
001567  2  A9 01                LDA     #1
001569  2  8D 49 06             STA     SHOWCRSR        ; TURN ON CURSOR
00156C  2  20 34 10             JSR     input           ; get filename in inbuff, length in A
00156F  2  F0 4C                BEQ     @tabort         ; empty = abort
001571  2  8D EF 1B             STA     inlen
001574  2  20 4B 16             JSR     fcb_prep        ; parse inbuff → fcb
001577  2               
001577  2               ; initialize DOS/65 file system
001577  2  A2 0D                LDX     #13
001579  2  20 03 01             JSR     PEM
00157C  2               
00157C  2  9C 49 06             STZ     SHOWCRSR        ; TURN OFF CURSOR
00157F  2               ; open the file (before erasing text!)
00157F  2  A9 00                LDA     #0
001581  2  8D 90 20             STA     fcb+32          ; next record = 0
001584  2  A9 70                LDA     #<fcb
001586  2  A0 20                LDY     #>fcb
001588  2  A2 0F                LDX     #15             ; PEM: open file
00158A  2  20 03 01             JSR     PEM
00158D  2  C9 FF                CMP     #$FF
00158F  2  D0 03                BNE     :+
001591  2  4C 22 16             JMP     @notfound       ; file not found
001594  2               :
001594  2               ; file opened successfully - now erase existing text
001594  2  20 EE 08             JSR     erase           ; resets curr/toplin/lastline to texstart
001597  2               
001597  2               ; set DMA buffer to codebuffer (128 bytes)
001597  2  A9 EB                LDA     #<codebuffer
001599  2  A0 1C                LDY     #>codebuffer
00159B  2  A2 1A                LDX     #26             ; PEM: set DMA address
00159D  2  20 03 01             JSR     PEM
0015A0  2               
0015A0  2               ; destination pointer: load at curr (= texstart after erase)
0015A0  2  A5 61 85 FB          COPY16  curr,tex
0015A4  2  A5 62 85 FC  
0015A8  2               
0015A8  2               @readloop:
0015A8  2  A9 70                LDA     #<fcb
0015AA  2  A0 20                LDY     #>fcb
0015AC  2  A2 14                LDX     #20             ; PEM: read sequential
0015AE  2  20 03 01             JSR     PEM
0015B1  2  A0 00                LDY     #0              ; default: no bytes to copy
0015B3  2  C9 00                CMP     #$00
0015B5  2  F0 0A                BEQ     @gotdata        ; success - 128 bytes in codebuffer
0015B7  2  C9 01                CMP     #$01
0015B9  2  F0 3D                BEQ     @closefile      ; EOF - done reading
0015BB  2  80 75                BRA     @ioerror        ; any other value = error
0015BD  2               
0015BD  2               @tabort:
0015BD  2  20 E2 13             JSR     sysmsg          ; restore banner
0015C0  2  60                   RTS
0015C1  2               
0015C1  2               @gotdata:
0015C1  2               @copybyte:
0015C1  2  B9 EB 1C             LDA     codebuffer,Y
0015C4  2  C9 1A                CMP     #$1A            ; CP/M EOF marker?
0015C6  2  F0 30                BEQ     @closefile
0015C8  2  C9 0A                CMP     #10
0015CA  2  D0 0B                BNE     :++
0015CC  2  A5 FB                LDA     tex
0015CE  2  D0 02                BNE     :+
0015D0  2  C6 FC                DEC     tex+1
0015D2  2               :
0015D2  2  C6 FB                DEC     tex
0015D4  2  4C DF 15             JMP     @skipbyte
0015D7  2               :
0015D7  2  C9 0D                CMP     #13
0015D9  2  D0 02                bne     :+
0015DB  2  A9 1F                LDA     #retchar
0015DD  2               :
0015DD  2  91 FB                STA     (tex),Y         ; store in text memory
0015DF  2               @skipbyte:
0015DF  2  C8                   INY
0015E0  2  C0 80                CPY     #128
0015E2  2  D0 DD                BNE     @copybyte
0015E4  2               
0015E4  2               ; advance destination by 128 bytes
0015E4  2  18                   CLC
0015E5  2  A5 FB                LDA     tex
0015E7  2  69 80                ADC     #128
0015E9  2  85 FB                STA     tex
0015EB  2  A5 FC                LDA     tex+1
0015ED  2  69 00                ADC     #0
0015EF  2  85 FC                STA     tex+1
0015F1  2               
0015F1  2               ; check for text area overflow
0015F1  2  A5 FC                LDA     tex+1
0015F3  2  CD E0 1B             CMP     texend+1
0015F6  2  90 B0                BCC     @readloop       ; still room
0015F8  2               ; fall through to close (text area full)
0015F8  2               
0015F8  2               @closefile:
0015F8  2               ; lastline = tex + Y (end of loaded data)
0015F8  2  98                   TYA
0015F9  2  18                   CLC
0015FA  2  65 FB                ADC     tex
0015FC  2  8D EC 1B             STA     lastline
0015FF  2  A5 FC                LDA     tex+1
001601  2  69 00                ADC     #0
001603  2  8D ED 1B             STA     lastline+1
001606  2               
001606  2               ; close the file
001606  2  A9 70                LDA     #<fcb
001608  2  A0 20                LDY     #>fcb
00160A  2  A2 10                LDX     #16             ; PEM: close file
00160C  2  20 03 01             JSR     PEM
00160F  2               
00160F  2               ; save filename for reuse by TSAVE
00160F  2  20 EC 17             JSR     savefn
001612  2               
001612  2  20 10 14 A9          TOPPRINTMESSAGE okmsg
001616  2  1B A0 1B 20  
00161A  2  28 09        
00161C  2  A9 01                LDA     #1
00161E  2  8D E8 1B             STA     msgflg
001621  2  60                   RTS                     ; returns to main (via stacked return addr)
001622  2               
001622  2               @notfound:
001622  2  20 10 14 A9          TOPPRINTMESSAGE fnfmsg
001626  2  02 A0 1B 20  
00162A  2  28 09        
00162C  2  A9 01                LDA     #1
00162E  2  8D E8 1B             STA     msgflg
001631  2  60                   RTS
001632  2               
001632  2               @ioerror:
001632  2               ; close file on error
001632  2  A9 70                LDA     #<fcb
001634  2  A0 20                LDY     #>fcb
001636  2  A2 10                LDX     #16
001638  2  20 03 01             JSR     PEM
00163B  2  20 10 14 A9          TOPPRINTMESSAGE ioerrmsg
00163F  2  11 A0 1B 20  
001643  2  28 09        
001645  2  A9 01                LDA     #1
001647  2  8D E8 1B             STA     msgflg
00164A  2  60                   RTS
00164B  2               
00164B  2               
00164B  2               
00164B  2               ;--------------------------------------------------------------
00164B  2               ; fcb_prep: Parse filename from inbuff into fcb (33-byte FCB).
00164B  2               ; Handles optional "X:" drive prefix, 8.3 format, uppercase.
00164B  2               ; Input: inbuff (null-terminated filename)
00164B  2               ; Output: fcb filled with drive, name, extension, zeros
00164B  2               ;--------------------------------------------------------------
00164B  2               fcb_prep:
00164B  2               ; clear entire fcb to zeros
00164B  2  A2 20                LDX     #32
00164D  2  A9 00                LDA     #0
00164F  2               @clr:
00164F  2  9D 70 20             STA     fcb,X
001652  2  CA                   DEX
001653  2  10 FA                BPL     @clr
001655  2               
001655  2               ; fill name (bytes 1-8) and extension (bytes 9-11) with spaces
001655  2  A2 01                LDX     #1
001657  2  A9 20                LDA     #space
001659  2               @spc:
001659  2  9D 70 20             STA     fcb,X
00165C  2  E8                   INX
00165D  2  E0 0C                CPX     #12
00165F  2  D0 F8                BNE     @spc
001661  2               
001661  2               ; check for drive prefix (e.g., "A:")
001661  2  A0 00                LDY     #0              ; Y = index into inbuff
001663  2  AD 43 1C             LDA     inbuff+1
001666  2  C9 3A                CMP     #':'
001668  2  D0 0E                BNE     @nodrive
00166A  2               ; extract drive letter
00166A  2  AD 42 1C             LDA     inbuff
00166D  2  20 B0 16             JSR     @toupper
001670  2  38                   SEC
001671  2  E9 40                SBC     #'A'-1          ; A=1, B=2, etc.
001673  2  8D 70 20             STA     fcb             ; fcb+0 = drive number
001676  2  A0 02                LDY     #2              ; skip past "X:"
001678  2               @nodrive:
001678  2               ; copy filename (up to 8 chars, until '.' or null)
001678  2  A2 01                LDX     #1              ; X = FCB position (1-8)
00167A  2               @fname:
00167A  2  B9 42 1C             LDA     inbuff,Y
00167D  2  F0 30                BEQ     @done           ; null terminator = end
00167F  2  C9 2E                CMP     #'.'
001681  2  F0 18                BEQ     @doext          ; dot = start extension
001683  2  20 B0 16             JSR     @toupper
001686  2  9D 70 20             STA     fcb,X
001689  2  C8                   INY
00168A  2  E8                   INX
00168B  2  E0 09                CPX     #9              ; max 8 chars for name
00168D  2  D0 EB                BNE     @fname
00168F  2               ; if name > 8 chars, skip to dot or end
00168F  2               @skip:
00168F  2  B9 42 1C             LDA     inbuff,Y
001692  2  F0 1B                BEQ     @done
001694  2  C9 2E                CMP     #'.'
001696  2  F0 03                BEQ     @doext
001698  2  C8                   INY
001699  2  80 F4                BRA     @skip
00169B  2               
00169B  2               @doext:
00169B  2  C8                   INY                     ; skip the '.'
00169C  2  A2 09                LDX     #9              ; X = FCB position (9-11)
00169E  2               @ext:
00169E  2  B9 42 1C             LDA     inbuff,Y
0016A1  2  F0 0C                BEQ     @done           ; null terminator
0016A3  2  20 B0 16             JSR     @toupper
0016A6  2  9D 70 20             STA     fcb,X
0016A9  2  C8                   INY
0016AA  2  E8                   INX
0016AB  2  E0 0C                CPX     #12             ; max 3 chars for extension
0016AD  2  D0 EF                BNE     @ext
0016AF  2               @done:
0016AF  2  60                   RTS
0016B0  2               
0016B0  2               @toupper:
0016B0  2  C9 61                CMP     #'a'
0016B2  2  90 06                BCC     @noup
0016B4  2  C9 7B                CMP     #'z'+1
0016B6  2  B0 02                BCS     @noup
0016B8  2  29 DF                AND     #$DF            ; clear bit 5 → uppercase
0016BA  2               @noup:
0016BA  2  60                   RTS
0016BB  2               
0016BB  2               ;--------------------------------------------------------------
0016BB  2               ; TSAVE: Save text to disk as a text file.
0016BB  2               ; Prompts for filename (shows previous name if available).
0016BB  2               ; Converts retchar to CR/LF. Pads final record with $1A.
0016BB  2               ; Overwrites existing files (delete + create).
0016BB  2               ;--------------------------------------------------------------
0016BB  2               TSAVE:
0016BB  2  20 10 14 A9          TOPPRINTMESSAGE savmsg  ; "Save:" on command line
0016BF  2  FC A0 1A 20  
0016C3  2  28 09        
0016C5  2  A9 01                LDA     #1
0016C7  2  8D 49 06             STA     SHOWCRSR        ; TURN ON CURSOR
0016CA  2               ; pre-fill inbuff with stored filename (if any) so user can edit it
0016CA  2  AE 82 1C             LDX     fnlen
0016CD  2  F0 19                BEQ     @noprev
0016CF  2  A0 00                LDY     #0
0016D1  2               @prefill:
0016D1  2  B9 6A 1C             LDA     filename,Y
0016D4  2  99 42 1C             STA     inbuff,Y        ; copy to inbuff
0016D7  2  20 4A 14             JSR     chrout          ; echo to screen
0016DA  2  C8                   INY
0016DB  2  CA                   DEX
0016DC  2  D0 F3                BNE     @prefill
0016DE  2               ; enter input loop with Y = fnlen (backspace works on pre-filled text)
0016DE  2  A9 27                LDA     #39
0016E0  2  8D EE 1B             STA     limit
0016E3  2  20 3B 10             JSR     cursin          ; returns length in A
0016E6  2  80 03                BRA     @chkname
0016E8  2               @noprev:
0016E8  2  20 34 10             JSR     input           ; no previous filename, start fresh
0016EB  2               @chkname:
0016EB  2  9C 49 06             STZ     SHOWCRSR        ; TURN OFF CURSOR
0016EE  2  D0 04                BNE     @gotname
0016F0  2               ; empty = abort (user backspaced everything or pressed Enter with nothing)
0016F0  2  20 E2 13             JSR     sysmsg          ; restore banner
0016F3  2  60                   RTS
0016F4  2               
0016F4  2               @gotname:
0016F4  2  8D EF 1B             STA     inlen
0016F7  2               ; save this as the working filename
0016F7  2  20 EC 17             JSR     savefn
0016FA  2               
0016FA  2               @doprep:
0016FA  2  20 4B 16             JSR     fcb_prep        ; parse inbuff -> fcb
0016FD  2               
0016FD  2               ; initialize DOS/65
0016FD  2  A2 0D                LDX     #13
0016FF  2  20 03 01             JSR     PEM
001702  2               
001702  2               ; delete existing file (ignore error - file may not exist)
001702  2  A9 70                LDA     #<fcb
001704  2  A0 20                LDY     #>fcb
001706  2  A2 13                LDX     #19             ; PEM: delete file
001708  2  20 03 01             JSR     PEM
00170B  2               
00170B  2               ; re-prep FCB (delete modifies it)
00170B  2  20 4B 16             JSR     fcb_prep
00170E  2               
00170E  2               ; create new file
00170E  2  A9 70                LDA     #<fcb
001710  2  A0 20                LDY     #>fcb
