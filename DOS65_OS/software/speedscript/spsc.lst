00184E  2               ; A = dirmod (0-3), compute offset = dirmod * 32
00184E  2  0A                   ASL
00184F  2  0A                   ASL
001850  2  0A                   ASL
001851  2  0A                   ASL
001852  2  0A                   ASL
001853  2  AA                   TAX                     ; X = base offset in codebuffer
001854  2  E8                   INX                     ; +1 to skip user number byte
001855  2               
001855  2               ; map video and write filename at current position
001855  2  DA                   PHX                     ; save codebuffer offset
001856  2  A0 F9                LDY     #VIDTEXT_PAGE
001858  2  20 2D 15             JSR     vid_enter
00185B  2  FA                   PLX                     ; restore offset
00185C  2               
00185C  2               ; Y = starting column in current video row
00185C  2  A4 5C                LDY     csrcol
00185E  2               
00185E  2               ; write 8 filename chars
00185E  2  A9 08                LDA     #8
001860  2  85 5E                STA     temp
